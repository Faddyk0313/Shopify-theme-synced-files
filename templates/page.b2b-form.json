=\"custom-form\">\n    <p class=\"success_msg\">\n        <svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewBox=\"0 0 30 30\" width=\"30px\" height=\"30px\">\n            <path\n                d=\"M 26.980469 5.9902344 A 1.0001 1.0001 0 0 0 26.292969 6.2929688 L 11 21.585938 L 4.7070312 15.292969 A 1.0001 1.0001 0 1 0 3.2929688 16.707031 L 10.292969 23.707031 A 1.0001 1.0001 0 0 0 11.707031 23.707031 L 27.707031 7.7070312 A 1.0001 1.0001 0 0 0 26.980469 5.9902344 z\" \/>\n        <\/svg>\n        <span><\/span>\n    <\/p>\n    <h3>Customer Information<\/h3>\n    <div class=\"form-grid\">\n        <div class=\"field\">\n            <input class=\"input is-floating\" name=\"contact[first_name]\" id=\"customFirstName\" type=\"text\"\n                placeholder=\"First Name\" required>\n            <label class=\"label is-floating\" for=\"customFirstName\">First Name<\/label>\n        <\/div>\n        <div class=\"field\">\n            <input class=\"input is-floating\" name=\"contact[last_name]\" id=\"customLastName\" type=\"text\"\n                placeholder=\"Last Name\" required>\n            <label class=\"label is-floating\" for=\"customLastName\">Last Name<\/label>\n        <\/div>\n        <div class=\"field\">\n            <input class=\"input is-floating\" name=\"contact[email]\" id=\"customEmail\" type=\"email\" placeholder=\"Email\"\n                required>\n            <label class=\"label is-floating\" for=\"customEmail\">Email<\/label>\n        <\/div>\n        <div class=\"field\">\n            <input class=\"input is-floating\" name=\"contact[phone]\" id=\"customPhone\" type=\"tel\"\n                placeholder=\"Phone Number\" required>\n            <label class=\"label is-floating\" for=\"customPhone\">Phone Number<\/label>\n        <\/div>\n    <\/div>\n\n    <h3>Shipping Address<\/h3>\n    <div class=\"form-grid\">\n        <div class=\"field\" style=\"grid-column: span 2;\">\n            <input class=\"input is-floating\" name=\"contact[addres