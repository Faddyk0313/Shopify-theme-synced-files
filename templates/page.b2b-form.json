     <option>Suriname<\/option>\n                    <option>Sweden<\/option>\n                    <option>Switzerland<\/option>\n                    <option>Syria<\/option>\n                    <option>Taiwan<\/option>\n                    <option>Tajikistan<\/option>\n                    <option>Tanzania<\/option>\n                    <option>Thailand<\/option>\n                    <option>Togo<\/option>\n                    <option>Tonga<\/option>\n                    <option>Trinidad and Tobago<\/option>\n                    <option>Tunisia<\/option>\n                    <option>Turkey<\/option>\n                    <option>Turkmenistan<\/option>\n                    <option>Tuvalu<\/option>\n                    <option>Uganda<\/option>\n                    <option>Ukraine<\/option>\n                    <option>United Arab Emirates<\/option>\n                    <option>United Kingdom<\/option> -->\n                <option selected>United States<\/option>\n                <!-- <option>Uruguay<\/option>\n                    <option>Uzbekistan<\/option>\n                    <option>Vanuatu<\/option>\n                    <option>Vatican City<\/option>\n                    <option>Venezuela<\/option>\n                    <option>Vietnam<\/option>\n                    <option>Yemen<\/option>\n                    <option>Zambia<\/option>\n                    <option>Zimbabwe<\/option> -->\n            <\/select>\n            {%- render 'icon', icon: 'chevron-up', size: 'sm', class: 'absolute' -%}\n            <label class=\"label is-floating\" for=\"customCountry\">Country<\/label>\n        <\/div>\n\n        \n        <div class=\"field\" style=\"grid-column: span 2;\">\n            <input class=\"input is-floating\" name=\"contact[metafields][custom][website]\" id=\"customWebite\" type=\"text\"\n                placeholder=\"Website\" required>\n            <label class=\"label is-floating\" for=\"customWebite\">Website<\/label>\n        <\/div>\n\n        <div class=\"field\">\n            <input class=\"input is-floating\" name=\"contact[metafields][custom][tax_id]\" id=\"customTax\" type=\"text\"\n                placeholder=\"Tax ID\/ABN\/VAT Number\" required>\n            <label class=\"label is-floating\" for=\"customTax\">Tax ID\/ABN\/VAT Number<\/label>\n        <\/div>\n\n        <div class=\"field input is-floating file_upload\" style=\"grid-column: span 2;\">\n            <div class=\"customLabel\">\n  <!-- placeholder text + SVG icon -->\n  <span class=\"placeholder\">\n    Upload Annual Resale Certificate for Sales Tax Exemption\n  <\/span>\n  <svg class=\"upload-icon\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewBox=\"0 0 24 24\">\n    <path d=\"M5 20h14v-2H5v2zm7-18L5.33 9h3.34v4h6.66V9h3.34L12 2z\"\/>\n  <\/svg>\n  <!-- will be replaced by filename after upload -->\n  <span class=\"fileName\"><\/span>\n<\/div>\n            <input id=\"customFile\" onchange=\"storeFile(event)\" name=\"contact[metafields][custom][tax_id]\" required\n                type=\"file\" accept=\".pdf, .jpg, .jpeg, .png\">\n        <\/div>\n\n        <div class=\"field field--full\" style=\"grid-column: span 2;\">\n            <textarea id=\"business_description\" class=\"textarea is-floating\" rows=\"5\"\n                name=\"contact[metafields][custom][business_description]\"\n                placeholder=\"Tell us a little about yourself so that we can verify your business identity \"><\/textarea>\n\n        <\/div>\n\n    <\/div>\n\n    <div class=\"field field--full\">\n        <label for=\"customFormSubmit\" class=\"sr-only\">Apply<\/label>\n        <button type=\"submit\" id=\"customFormSubmit\" class=\"button button--primary button--fixed\" is=\"hover-button\">\n            <span class=\"btn-fill\" data-fill><\/span>\n            <span class=\"btn-text\">Apply<\/span>\n        <\/button>\n    <\/div>\n<\/form>\n\n<script>\n    document.addEventListener(\"DOMContentLoaded\", function () {\n        const fileInput = document.querySelector('input[type=\"file\"]');\n        const fileNameSpan = document.querySelector('.fileName');\n\n        fileInput.addEventListener('change', function () {\n  const placeholder = document.querySelector('.file_upload .placeholder');\n  if (fileInput.files.length > 0) {\n    fileNameSpan.textContent = fileInput.files[0].name;\n    placeholder.style.display = 'none';\n  } else {\n    fileNameSpan.textContent = '';\n    placeholder.style.display = 'inline';\n  }\n});\n\n    });\n<\/script>\n<script>\n\n    let file;\n    function storeFile(e) {\n        file = e.target.files[0];\n    }\n\n    async function submitForm(e) {\n\n        e.preventDefault();\n\n        const formData = new FormData();\n\n        \/\/ const rawPartnerType = document.getElementById(\"customPartnerType\").value;\n        \/\/ const cleanedPartnerType = rawPartnerType.replace(\/\\s*\\(.*?\\)\/g, '').trim();\n\n        formData.append(\"first_name\", document.getElementById(\"customFirstName\").value.trim());\n        formData.append(\"last_name\", document.getElementById(\"customLastName\").value.trim());\n        formData.append(\"email\", document.getElementById(\"customEmail\").value.trim());\n        formData.append(\"phone\", document.getElementById(\"customPhone\").value.trim());\n        formData.append(\"address1\", document.getElementById(\"customAddress\").value.trim());\n\n        const additionalAddress = document.getElementById(\"customAdditionalAddress\").value.trim();\n        formData.append(\"address2\", additionalAddress || \"\");\n\n        formData.append(\"city\", document.getElementById(\"customCity\").value.trim());\n        formData.append(\"province\", document.getElementById(\"customState\").value.trim());\n        formData.append(\"country\", document.getElementById(\"customCountry\").value.trim());\n        formData.append(\"zip\", document.getElementById(\"customPostalCode\").value.trim());\n\n        \/\/ formData.append(\"partner_type\", cleanedPartnerType); \/\/ already trimmed\n\n        formData.append(\"website\", document.getElementById(\"customWebite\").value.trim());\n        formData.append(\"tax_id\", document.getElementById(\"customTax\").value.trim());\n        formData.append(\"business_description\", document.getElementById(\"business_description\").value.trim());\n\n        formData.append(\"tax_file\", file);\n\n\n        const submitBtn = document.getElementById(\"customFormSubmit\");\n        const success_msg = document.querySelector(\".success_msg\");\n        submitBtn.disabled = true;\n        \/\/ submitBtn.classList.add(\"is-loading\");\n\n        const response = await fetch(\"https:\/\/hocky-name-generator-seven.vercel.app\/api\/createPartner\", {\n            method: \"POST\",\n            headers: {\n            },\n            body: formData\n        });\n        const data = await response.json();\n        console.log(data);\n\n        success_msg.querySelector(\"svg\").style.fill = data.success ? \"#1B7F4A\" : \"#C62828 \";\n        success_msg.querySelector(\"svg\").style.borderColor = data.success ? \"#1B7F4A\" : \"#C62828 \";\n        success_msg.querySelector(\"span\").style.color = data.success ? \"#1B7F4A\" : \"#C62828 \";\n        success_msg.style.backgroundColor = data.success ? \"#E6F4EA\" : \"#FDEAEA\";\n        \/\/ success_msg.querySelector(\"span\").textContent = data.message;\n\n        let messageToShow;\n\n        if (data.success) {\n            messageToShow = data.message;\n        } else {\n            \/\/ data.message is an object with 'errors' key\n            const errors = data.message.errors;\n            messageToShow = Object.entries(errors)\n                .map(([field, messages]) => field === 'email' ? `Email ${messages[0]}` : field === 'phone' ? messages[0] : 'Something Went Wrong')\n                .join(' <br> ');\n        }\n\n        success_msg.querySelector(\"span\").innerHTML = messageToShow;\n\n\n        success_msg.style.display = \"flex\";\n        submitBtn.disabled = false;\n        submitBtn.querySelector('.btn-loader').style.opacity = \"0\";\n        submitBtn.querySelector('.btn-text').style.opacity = \"1\";\n\n        \/\/ submitBtn.classList.remove(\"is-loading\");\n\n    };\n<\/script>","color_text":"","color_background":"","gradient_background":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":72,"divider":false,"narrow":false,"rounded":false}},"custom_liquid_dUMDEz":{"type":"custom-liquid","disabled":true,"settings":{"liquid":"<iframe src=\"https:\/\/app.vectary.com\/p\/7Ye8aV5kPYipVskVhIFI5w\" frameborder=\"0\" width=\"100%\" height=\"480\" allow=\"xr-spatial-tracking; fullscreen;\"><\/iframe>","color_text":"","color_background":"","gradient_background":"linear-gradient(117deg, rgba(226, 251, 49, 1) 16%, rgba(165, 222, 115, 1) 49%, rgba(218, 239, 120, 1) 75%, rgba(237, 255, 179, 1) 91%)","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":0,"padding_bottom":0,"divider":false,"narrow":false,"rounded":false}}},"order":["main-page","174115863752771b7e","rich_text_epammP","custom_liquid_VybfXg","custom_liquid_dUMDEz"]}