ty: 0;\n  transition: opacity 0.3s ease;\n}\n\/* End TBG Custom Code *\/\n<\/style>\n\n<div id=\"3d-prod-configurator-section\">\n\n  <!-- TBG Custom Code -->\n  <div class=\"tbg-iframe-loader\" id=\"tbgLoader\">\n    <div class=\"tbg-spinner\"><\/div>\n  <\/div>\n  <!-- End TBG Custom Code -->\n\n  <iframe \n    id=\"productConfigurator\" \n    src=\"https:\/\/titan-3d-product-configurator.vercel.app\/\" \n    width=\"100%\" \n    scrolling=\"no\"\n    style=\"border: none; overflow: clip;\"\n  ><\/iframe>\n\n<\/div>\n\n<script>\n\/\/ TBG Custom Code\nconst iframe = document.getElementById(\"productConfigurator\");\nconst loader = document.getElementById(\"tbgLoader\");\n\niframe.addEventListener(\"load\", function () {\n  loader.style.display = \"none\";\n  iframe.style.opacity = \"1\";\n});\n\nwindow.addEventListener(\"message\", function (event) {\n  if (event.data.frameHeight) {\n    iframe.style.height = event.data.frameHeight + \"px\";\n  }\n});\n\/\/ End TBG Custom Code\n<\/script>","color_text":"","color_background":"","gradient_background":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":8,"padding_bottom":0,"divider":false,"narrow":false,"rounded":false}},"image_with_text_W9AHFF":{"type":"image-with-text","blocks":{"heading_7ND6A4":{"type":"heading","settings":{"heading":"Semi-Custom","heading_size":"title-md","heading_tag":"h2","highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false}},"text_cARCAL":{"type":"text","settings":{"text":"<ul><li>Choose from 8 designs, 21 sublimation colors, and 17 thread colors<\/li><li>Select your design and assign your colors to portions of the shirt<\/li><li>Upload your logo<\/li><li>Offered in Adult and Youth Long Sleeve Stretch ProCurve<\/li><li>Requires a minimum order of 12 units (black or white thread) to begin production<\/li><li>Two ordering options: Individual ordering (our team sets up a custom store for your club on <a href=\"http:\/\/tit