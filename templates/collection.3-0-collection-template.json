rem;\n  }\n  .rating-star:before {\n    content: \"\\2605\\2605\\2605\\2605\\2605\";\n    background: black;\n    -webkit-text-fill-color: transparent;\n    -webkit-background-clip: text;\n    background-clip: text;\n  }\n  .cus_sub_header {\n    font-weight: 700;\n    padding-bottom: 0.5rem;\n    margin: 0 !important;\n    padding: 0 !important;\n    color: #5b5b5b;\n    font-size: var(--text-sm);\n    text-transform: uppercase;\n  }\n  .h1.heading {\n     font-size: 1.5rem;\n  }\n  @media (min-width: 1024px) {\n    .cus_sub_header {\n      padding-top: 1rem;\n      padding-bottom: 0.3rem;\n    }\n  }\n  @media (max-width: 500px) {\n    .h1.heading,\n    .customStyle {\n      font-size: 1.3rem !important;\n    }\n  }\n  .customStyle {\n    font-family: Armourxbd !important;\n    font-size: 1.5rem;\n  }\n  .customStyle.diagonal-strike {\n    font-size: 1rem;\n  }\n\n  .h1.heading {\n    font-size: 1.5rem;\n  }\n\n  \/* TBG Custom Code *\/\n  .tbg-payment-terms-source {\n    position: relative;\n    min-height: 0;\n  }\n\n  .tbg-payment-terms-source shopify-payment-terms,\n  .tbg-payment-terms-source .shopify-payment-terms,\n  .tbg-payment-terms-source iframe {\n    position: absolute !important;\n    width: 1px !important;\n    height: 1px !important;\n    margin: -1px !important;\n    padding: 0 !important;\n    overflow: hidden !important;\n    clip: rect(0 0 0 0) !important;\n    clip-path: inset(50%) !important;\n    white-space: nowrap !important;\n    border: 0 !important;\n    opacity: 0 !important;\n    pointer-events: none !important;\n  }\n\n  .tbg-installment-row {\n    display: flex;\n    justify-content: flex-end;\n  }\n\n  .tbg-installment-row .installment {\n    text-align: left;\n  }\n\n  .tbg-installment-row .installment strong {\n    font-weight: 700;\n  }\n\n  .tbg-installment-trigger {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 16px;\n    height: 16px;\n    margin-left: 6px;\n    padding: 0;\n    border: 0;\n    background: transparent;\n    color: currentColor;\n    cursor: pointer;\n    vertical-align: middle;\n  }\n\n  .tbg-installment-trigger svg {\n    width: 14px;\n    height: 14px;\n    display: block;\n  }\n\n  .tbg-installment-trigger:focus-visible {\n    outline: 2px solid currentColor;\n    outline-offset: 2px;\n    border-radius: 999px;\n  }\n\n  .tbg-installment-row {\n    margin-top: 6px;\n  }\n<\/style>\n\n{%- assign product = all_products[section.settings.product] -%}\n\n{%- if product -%}\n  {%- assign product_form_installment_id = 'ProductFormInstallment-' | append: section.id | append: '-' | append: product.id -%}\n  {%- assign tbg_custom_installment_id = 'TBG-CustomInstallment-' | append: section.id | append: '-' | append: product.id -%}\n  {%- assign tbg_variant_data_id = 'TBG-InstallmentVariantData-' | append: section.id | append: '-' | append: product.id -%}\n\n  <p class=\"cus_sub_header\">\n    {{ product.metafields.custom.collection_name | default: \"HECC Certified\" }}\n  <\/p>\n\n  <div class=\"product__title flex gap-3\">\n    <h1 class=\"h1 heading leading-none product-title-sm mobile:product-title-sm\" style=\"margin: 0 !important; font-family: Armourxbd !important;\">\n      <split-words class=\"split-words block\" data-animate=\"fade-up\">\n        {{ product.title }}\n      <\/split-words>\n    <\/h1>\n\n    <div style=\"margin-left: auto;\" class=\"product__price grid gap-3\">\n      <div class=\"no-js-hidden\" id=\"Price-{{ section.id }}-{{ product.id }}\">\n        {%- render 'product-price', product: product, use_variant: true, class: 'flex flex-wrap items-baseline gap-2 lg:gap-1d5', style: \"ml-2 flex-col-reverse\", boldPrice: true -%}\n      <\/div>\n\n      {%- form 'product',\n        product,\n        id: product_form_installment_id,\n        class: 'installment text-sm leading-tight tbg-payment-terms-source'\n      -%}\n        <input type=\"hidden\" name=\"id\" value=\"{{ product.selected_or_first_available_variant.id }}\">\n        {{ form | payment_terms }}\n      {%- endform -%}\n\n      <script type=\"application\/json\" id=\"{{ tbg_variant_data_id }}\">\n        [\n          {%- for variant in product.variants -%}\n            { \"id\": {{ variant.id | json }}, \"price\": {{ variant.price | json }} }{%- unless forloop.last -%},{%- endunless -%}\n          {%- endfor -%}\n        ]\n      <\/script>\n\n      <script>\n        (function () {\n          var sourceFormId = {{ product_form_installment_id | json }};\n          var customInstallmentId = {{ tbg_custom_installment_id | json }};\n          var variantDataId = {{ tbg_variant_data_id | json }};\n          var minPriceCents = 3500;\n          var monthlyThresholdCents = 5000;\n          var currencyCode = {{ cart.currency.iso_code | default: shop.currency | json }};\n\n          window.TBGCustomInstallments = window.TBGCustomInstallments || {};\n          if (window.TBGCustomInstallments[customInstallmentId]) return;\n          window.TBGCustomInstallments[customInstallmentId] = true;\n\n          var retryTimer = null;\n          var nativeObserver = null;\n          var shadowObserver = null;\n          var variantPriceMap = {};\n\n          try {\n            var variantDataEl = document.getElementById(variantDataId);\n            var variantData = variantDataEl ? JSON.parse(variantDataEl.textContent) : [];\n            variantData.forEach(function (variant) {\n              variantPriceMap[String(variant.id)] = Number(variant.price || 0);\n            });\n          } catch (e) {}\n\n          function getSourceForm() {\n            return document.getElementById(sourceFormId);\n          }\n\n          function getCustomLine() {\n            return document.getElementById(customInstallmentId);\n          }\n\n          function getScopeRoot() {\n            var sourceForm = getSourceForm();\n            if (!sourceForm) return document;\n            return (\n              sourceForm.closest('[data-section-id]') ||\n              sourceForm.closest('product-info') ||\n              sourceForm.closest('section') ||\n              document\n            );\n          }\n\n          function formatMoney(cents) {\n            var amount = Number(cents || 0) \/ 100;\n\n            try {\n              return new Intl.NumberFormat(undefined, {\n                style: 'currency',\n                currency: currencyCode,\n                minimumFractionDigits: 2,\n                maximumFractionDigits: 2\n              }).format(amount);\n            } catch (e) {\n              return '$' + amount.toFixed(2);\n            }\n          }\n\n          function getSelectedVariantId() {\n            var sourceForm = getSourceForm();\n            if (!sourceForm) return '';\n\n            var scopeRoot = getScopeRoot();\n            var primaryInputs = scopeRoot.querySelectorAll(\n              'form[action*=\"\/cart\/add\"] input[name=\"id\"], product-form input[name=\"id\"], .product-form input[name=\"id\"]'\n            );\n\n            for (var i = 0; i < primaryInputs.length; i++) {\n              var input = primaryInputs[i];\n              var parentForm = input.closest('form');\n\n              if (parentForm && parentForm.id !== sourceFormId && input.value) {\n                return String(input.value);\n              }\n            }\n\n            var sourceInput = sourceForm.querySelector('input[name=\"id\"]');\n            if (sourceInput && sourceInput.value) {\n              return String(sourceInput.value);\n            }\n\n            var urlVariant = new URLSearchParams(window.location.search).get('variant');\n            return urlVariant ? String(urlVariant) : '';\n          }\n\n          function syncSourceFormVariant(variantId) {\n            var sourceForm = getSourceForm();\n            if (!sourceForm || !variantId) return;\n\n            var input = sourceForm.querySelector('input[name=\"id\"]');\n            if (!input || input.value === variantId) return;\n\n            input.value = variantId;\n            input.dispatchEvent(new Event('change', { bubbles: true }));\n          }\n\n          function getVariantPriceCents(variantId) {\n            if (!variantId) return null;\n            var price = variantPriceMap[String(variantId)];\n            return typeof price === 'number' && !isNaN(price) ? price : null;\n          }\n\n          function getNativePaymentTermsElement() {\n            var sourceForm = getSourceForm();\n            return sourceForm ? sourceForm.querySelector('shopify-payment-terms') : null;\n          }\n\n          function getNativePaymentText() {\n            var paymentTermsEl = getNativePaymentTermsElement();\n            if (!paymentTermsEl) return '';\n\n            var textParts = [];\n\n            if (paymentTermsEl.textContent) {\n              textParts.push(paymentTermsEl.textContent);\n            }\n\n            if (paymentTermsEl.innerText) {\n              textParts.push(paymentTermsEl.innerText);\n            }\n\n            if (paymentTermsEl.shadowRoot) {\n              if (paymentTermsEl.shadowRoot.textContent) {\n                textParts.push(paymentTermsEl.shadowRoot.textContent);\n              }\n              if (paymentTermsEl.shadowRoot.innerText) {\n                textParts.push(paymentTermsEl.shadowRoot.innerText);\n              }\n            }\n\n            return textParts.join(' ').replace(\/\\s+\/g, ' ').trim();\n          }\n\n          function extractInstallmentValue(text) {\n            if (!text) return null;\n\n            var normalizedText = text.replace(\/\\s+\/g, ' ').trim();\n\n            var monthlyMatch = normalizedText.match(\/([€£$]\\s?\\d[\\d,]*(?:\\.\\d{2})?)\\\/mo\\b\/i);\n            if (monthlyMatch) {\n              return {\n                amount: monthlyMatch[1].replace(\/\\s+\/g, ' ').trim(),\n                suffix: '\/mo'\n              };\n            }\n\n            var installmentMatch = normalizedText.match(\/(?:pay in|or pay in)?\\s*(\\d+)\\s+interest-free installments? of\\s+([€£$]\\s?\\d[\\d,]*(?:\\.\\d{2})?)\/i);\n            if (installmentMatch) {\n              return {\n                amount: installmentMatch[2].replace(\/\\s+\/g, ' ').trim(),\n                suffix: ''\n              };\n            }\n\n            return null;\n          }\n\n          function getNativePopupTrigger() {\n            var paymentTermsEl = getNativePaymentTermsElement();\n            if (!paymentTermsEl) return null;\n\n            var candidates = [];\n\n            function collectClickableElements(root) {\n              if (!root || !root.querySelectorAll) return [];\n              return Array.prototype.slice.call(\n                root.querySelectorAll('a, button, [role=\"button\"], [tabindex]')\n              );\n            }\n\n            candidates = candidates.concat(collectClickableElements(paymentTermsEl));\n\n            if (paymentTermsEl.shadowRoot) {\n              candidates = candidates.concat(collectClickableElements(paymentTermsEl.shadowRoot));\n            }\n\n            var preferredTexts = [\n              'check your purchasing power',\n              'learn more'\n            ];\n\n            for (var i = 0; i < preferredTexts.length; i++) {\n              var preferredText = preferredTexts[i];\n\n              for (var j = 0; j < candidates.length; j++) {\n                var el = candidates[j];\n                var text = (el.textContent || el.innerText || '').replace(\/\\s+\/g, ' ').trim().toLowerCase();\n\n                if (text.indexOf(preferredText) !== -1) {\n                  return el;\n                }\n              }\n            }\n\n            return candidates.length ? candidates[0] : null;\n          }\n\n          function openNativeInstallmentPopup() {\n            var trigger = getNativePopupTrigger();\n            if (!trigger) return;\n            trigger.click();\n          }\n\n          function renderCustomInstallment() {\n            var customLine = getCustomLine();\n            if (!customLine) return;\n\n            var variantId = getSelectedVariantId();\n            syncSourceFormVariant(variantId);\n\n            var variantPriceCents = getVariantPriceCents(variantId);\n\n            if (variantPriceCents !== null && variantPriceCents < minPriceCents) {\n              customLine.innerHTML = '';\n              customLine.hidden = true;\n              return;\n            }\n\n            var installmentData = extractInstallmentValue(getNativePaymentText());\n\n            if (!installmentData && variantPriceCents !== null) {\n              var divisor = variantPriceCents >= monthlyThresholdCents ? 4 : 2;\n              installmentData = {\n                amount: formatMoney(Math.round(variantPriceCents \/ divisor)),\n                suffix: divisor === 4 ? '\/mo' : ''\n              };\n            }\n\n            if (!installmentData || !installmentData.amount) {\n              customLine.innerHTML = '';\n              customLine.hidden = true;\n              return;\n            }\n\n            customLine.innerHTML =\n              'or from <strong>' +\n              installmentData.amount +\n              '<\/strong>' +\n              installmentData.suffix +\n              '<button type=\"button\" class=\"tbg-installment-trigger\" aria-label=\"Learn more about payment options\">' +\n                '<svg viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\">' +\n                  '<circle cx=\"10\" cy=\"10\" r=\"8.25\" stroke=\"currentColor\" stroke-width=\"1.5\"><\/circle>' +\n                  '<path d=\"M10 8.2V13\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"><\/path>' +\n                  '<circle cx=\"10\" cy=\"5.8\" r=\"0.9\" fill=\"currentColor\"><\/circle>' +\n                '<\/svg>' +\n              '<\/button>';\n\n            customLine.hidden = false;\n          }\n\n          function attachNativeObserver() {\n            var paymentTermsEl = getNativePaymentTermsElement();\n            if (!paymentTermsEl) return;\n\n            if (!nativeObserver) {\n              nativeObserver = new MutationObserver(function () {\n                renderCustomInstallment();\n              });\n            }\n\n            nativeObserver.disconnect();\n            nativeObserver.observe(paymentTermsEl, {\n              attributes: true,\n              childList: true,\n              subtree: true,\n              characterData: true\n            });\n\n            if (paymentTermsEl.shadowRoot) {\n              if (!shadowObserver) {\n                shadowObserver = new MutationObserver(function () {\n                  renderCustomInstallment();\n                });\n              }\n\n              shadowObserver.disconnect();\n              shadowObserver.observe(paymentTermsEl.shadowRoot, {\n                childList: true,\n                subtree: true,\n                characterData: true\n              });\n            }\n          }\n\n          function startRefreshWindow() {\n            renderCustomInstallment();\n            attachNativeObserver();\n\n            if (retryTimer) {\n              clearInterval(retryTimer);\n            }\n\n            var attempts = 0;\n            retryTimer = setInterval(function () {\n              attempts += 1;\n              attachNativeObserver();\n              renderCustomInstallment();\n\n              if (attempts >= 10) {\n                clearInterval(retryTimer);\n              }\n            }, 300);\n          }\n\n          function bindVariantListeners() {\n            var scopeRoot = getScopeRoot();\n\n            function handleVariantInteraction(event) {\n              var target = event.target;\n              if (!target || !scopeRoot.contains(target)) return;\n\n              if (\n                target.name === 'id' ||\n                target.matches('select[name^=\"options[\"]') ||\n                target.matches('input[name^=\"options[\"]') ||\n                target.closest('variant-selects') ||\n                target.closest('variant-radios')\n              ) {\n                requestAnimationFrame(startRefreshWindow);\n              }\n            }\n\n            scopeRoot.addEventListener('change', handleVariantInteraction);\n            scopeRoot.addEventListener('input', handleVariantInteraction);\n\n            scopeRoot.addEventListener('click', function (event) {\n              var trigger = event.target.closest('.tbg-installment-trigger');\n              if (!trigger) return;\n\n              event.preventDefault();\n              openNativeInstallmentPopup();\n            });\n\n            document.addEventListener('variant:change', startRefreshWindow);\n            document.addEventListener('product:variant-change', startRefreshWindow);\n            document.addEventListener('product-info:variant-change', startRefreshWindow);\n          }\n\n          function init() {\n            startRefreshWindow();\n            bindVariantListeners();\n          }\n\n          if (document.readyState === 'loading') {\n            document.addEventListener('DOMContentLoaded', init, { once: true });\n          } else {\n            init();\n          }\n        })();\n      <\/script>\n    <\/div>\n  <\/div>\n\n  <div class=\"tbg-installment-row\">\n    <div id=\"{{ tbg_custom_installment_id }}\" class=\"installment text-sm leading-tight\" aria-live=\"polite\" hidden><\/div>\n  <\/div>\n{%- endif -%}"}},"title_fYXeYp":{"type":"title","disabled":true,"settings":{"title_size":"product-title-md","title_size_mobile":"product-title-md","title_tag":"h2","show_price":true,"show_rating":true}},"text_Yt6nYn":{"type":"text","settings":{"icon":"time","iwidth":"custom","icon_width":22,"text":"<strong>NEW IN STOCK - LIMITED UNITS AVAILABLE<\/strong>","text_size":"text-base"}},"read_more_XfamLV":{"type":"read_more","settings":{}},"spinning_text_Fz7zCb":{"type":"spinning_text","settings":{"text":"NEW IN STOCK