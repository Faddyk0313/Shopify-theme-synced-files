      "settings": {
        "liquid": "<style>\n#compareTable {\n  position: relative;\n  left: 50%; \n  right: 50%;\n  margin-left: -50vw;\n  margin-right: -50vw;\n  width: 100vw;\n  max-width: 100vw;\n}\n #titanLogoImg {\n      padding-block: 0 !important;\n    }\n\n  .cs-page-width {\n    margin: 0 auto;\n    padding-inline: var(--page-padding);\n    padding-right: 0;\n  }\n\n  #compareTable .header {\n    font-size: 20px !important;\n    color: white;\n    font-weight: 600;\n    letter-spacing: 1px;\n  }\n  @media (min-width: 500px) {\n    #compareTable .header {\n      font-size: 26px !important;\n    }\n  }\n\n  #compareTable .row {\n    font-weight: 600;\n    height: 60px;\n    display: flex;\n    align-items: center;\n  }\n  @media (min-width: 500px) {\n    #compareTable .row {\n      height: 70px;\n    }\n  }\n\n  #compareTable #features .row {\n    font-size: 12px;\n    text-align: start !important;\n  }\n  @media (min-width: 500px) {\n    #compareTable #features .row {\n      font-size: 18px;\n    }\n  }\n\n  #compareTable .column {\n    justify-content: center;\n    width: 100%;\n    min-width: 115px;\n  }\n  #compareTable .cs-bg-black {\n    background-color: black;\n  }\n  #compareTable .cs-bg-dark-green,#compareTable .cs-bg-gray {\n    background-color: #fff;\n  }\n  #compareTable .cs-bg-light-green,#compareTable .cs-bg-white {\n    background-color: #f2f2f2;\n  }\n  #compareTable .small-text {\n    font-size: 10px;\n    font-weight: 400;\n  }\n  #compareTable .flex-direction-column {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  #compareTable .row.column img {\n    width: 20px;\n    height: 20px;\n  }\n  #compareTable .row.column {\n    padding: 0;\n  }\n  @media (min-width: 786px) {\n    #compareTable .row.column {\n      font-size: 20px;\n    }\n  }\n  #compareTable .row.column.header img {\n    width: 100%;\n    height: 100%;\n    padding: 5px;\n    object-fit: contain;\n  }\n  @media (min-width: 1000px) {\n    #compareTable .row.column.header img {\n      padding: 5px;\n      padding-block: 0;\n    }\n  }\n\n  #compareTable {\n    position: relative;\n  }\n\n  /* #compareTable #features {\n    padding: 1rem 0;\n  } */\n\n  #compareTable #columns {\n    position: absolute;\n    top: -15px;\n    /* left: 130px; */\n    right: 0;\n    display: flex;\n    align-items: center;\n    \n    transform: translateY(-2rem);\n  }\n  @media (min-width: 500px) {\n    #compareTable #columns {\n      left: 180px;\n      right: 0;\n      width: calc(100vw - 180px);\n    }\n  }\n  @media (min-width: 1000px) {\n    #compareTable #columns {\n      left: 220px;\n      right: 0;\n      width: calc(100vw - 220px);\n    }\n  }\n  @media (min-width: 1400px) {\n    #compareTable #columns {\n      left: 250px;\n      right: 0;\n      width: calc(100vw - 250px);\n    }\n  }\n\n  #compareTable .card-wrapper {\n    flex: 0 0 100%;\n    border-radius: 15px;\n    scroll-snap-align: start;\n    overflow: visible;\nmax-width: 120px;\n  }\n\n  @media (min-width: 500px) {\n    #compareTable .card-wrapper {\n      max-width: calc(25% - 10px) !important;\n      min-width: 130px;\n      width: 25%;\n    }\n  }\n\n  @media (max-width: 500px) {\n    #compareTable .card-wrapper:last-child {\n      margin-right: 30px;\n    }\n  }\n\n  #compareTable .card-wrapper-titan {\n    z-index: 10;\n    overflow: visible;\n    border-radius: 15px;\n    min-width: 115px;\n    width: fit-content;\n  }\n\n  @media (min-width: 500px) {\n    #compareTable .card-wrapper-titan {\n      min-width: 130px;\n    }\n  }\n\n  @media (min-width: 786px) {\n    #compareTable .card-wrapper-titan {\n      min-width: 20%;\n    }\n  }\n\n\n  #compareTable #titan {\n    box-shadow: 0px 5px 20px rgba(107, 107, 107, 0.4);\n  }\n  #compareTable #titan,\n  #compareTable .competitor {\n    padding: 1rem 0;\n    background-color: #f2f2f2;\n    border-radius: 15px;\n    box-shadow: 0px 5px 20px rgba(107, 107, 107, 0.4);\n    width: fit-content;\n  }\n  @media (min-width: 