{\n          var sourceForm = getSourceForm();\n          return sourceForm ? sourceForm.querySelector('shopify-payment-terms') : null;\n        }\n\n        function getNativePaymentText() {\n          var paymentTermsEl = getNativePaymentTermsElement();\n          if (!paymentTermsEl) return '';\n\n          var textParts = [];\n\n          if (paymentTermsEl.textContent) {\n            textParts.push(paymentTermsEl.textContent);\n          }\n\n          if (paymentTermsEl.innerText) {\n            textParts.push(paymentTermsEl.innerText);\n          }\n\n          if (paymentTermsEl.shadowRoot) {\n            if (paymentTermsEl.shadowRoot.textContent) {\n              textParts.push(paymentTermsEl.shadowRoot.textContent);\n            }\n            if (paymentTermsEl.shadowRoot.innerText) {\n              textParts.push(paymentTermsEl.shadowRoot.innerText);\n            }\n          }\n\n          return textParts.join(' ').replace(/\\s+/g, ' ').trim();\n        }\n\n        function extractInstallmentValue(text) {\n          if (!text) return null;\n\n          var normalizedText = text.replace(/\\s+/g, ' ').trim();\n\n          var monthlyMatch = normalizedText.match(/([€£$]\\s?\\d[\\d,]*(?:\\.\\d{2})?)\\/mo\\b/i);\n          if (monthlyMatch) {\n            return {\n              amount: monthlyMatch[1].replace(/\\s+/g, ' ').trim(),\n              suffix: '/mo'\n            };\n          }\n\n          var installmentMatch = normalizedText.match(/(?:pay in|or pay in)?\\s*(\\d+)\\s+interest-free installments? of\\s+([€£$]\\s?\\d[\\d,]*(?:\\.\\d{2})?)/i);\n          if (installmentMatch) {\n            return {\n              amount: installmentMatch[2].replace(/\\s+/g, ' ').trim(),\n              suffix: ''\n            };\n          }\n\n          return null;\n        }\n\n        function getNativePopupTrigger() {\n          var paymentTermsEl = getNativePaymentTermsElement();\n          if (!paymentTermsEl) return null;\n\n          var candidates = [];\n\n          function collectClickableElements(root) {\n            if (!root || !root.querySelectorAll) return [];\n            return Array.prototype.slice.call(\n              root.querySelectorAll('a, button, [role=\"button\"], [tabindex]')\n            );\n          }\n\n          candidates = candidates.concat(collectClickableElements(paymentTermsEl));\n\n          if (paymentTermsEl.shadowRoot) {\n            candidates = candidates.concat(collectClickableElements(paymentTermsEl.shadowRoot));\n          }\n\n          var preferredTexts = [\n            'check your purchasing power',\n            'learn more'\n          ];\n\n          for (var i = 0; i < preferredTexts.length; i++) {\n            var preferredText = preferredTexts[i];\n\n            for (var j = 0; j < candidates.length; j++) {\n              var el = candidates[j];\n              var text = (el.textContent || el.innerText || '').replace(/\\s+/g, ' ').trim().toLowerCase();\n\n              if (text.indexOf(preferredText) !== -1) {\n                return el;\n              }\n            }\n          }\n\n          return candidates.length ? candidates[0] : null;\n        }\n\n        function openNativeInstallmentPopup() {\n          var trigger = getNativePopupTrigger();\n          if (!trigger) return;\n          trigger.click();\n        }\n\n        function renderCustomInstallment() {\n          var customLine = getCustomLine();\n          if (!customLine) return;\n\n          var variantId = getSelectedVariantId();\n          syncSourceFormVariant(variantId);\n\n          var variantPriceCents = getVariantPriceCents(variantId);\n\n          if (variantPriceCents !== null && variantPriceCents < minPriceCents) {\n            customLine.innerHTML = '';\n            customLine.hidden = true;\n            return;\n          }\n\n          var installmentData = extractInstallmentValue(getNativePaymentText());\n\n          if (!installmentData && variantPriceCents !== null) {\n            var divisor = variantPriceCents >= monthlyThresholdCents ? 4 : 2;\n            installmentData = {\n              amount: formatMoney(Math.round(variantPriceCents / divisor)),\n              suffix: divisor === 4 ? '/mo' : ''\n            };\n          }\n\n          if (!installmentData || !installmentData.amount) {\n            customLine.innerHTML = '';\n            customLine.hidden = true;\n            return;\n          }\n\n          customLine.innerHTML =\n            'or from <strong>' +\n            installmentData.amount +\n            '</strong>' +\n            installmentData.suffix +\n            '<button type=\"button\" class=\"tbg-installment-trigger\" aria-label=\"Learn more about payment options\">' +\n              '<svg viewBox=\"0 0 20 20\" fill=\"none\" aria-hidden=\"true\">' +\n                '<circle cx=\"10\" cy=\"10\" r=\"8.25\" stroke=\"currentColor\" stroke-width=\"1.5\"></circle>' +\n                '<path d=\"M10 8.2V13\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"></path>' +\n                '<circle cx=\"10\" cy=\"5.8\" r=\"0.9\" fill=\"currentColor\"></circle>' +\n              '</svg>' +\n            '</button>';\n\n          customLine.hidden = false;\n        }\n\n        function attachNativeObserver() {\n          var paymentTermsEl = getNativePaymentTermsElement();\n          if (!paymentTermsEl) return;\n\n          if (!nativeObserver) {\n            nativeObserver = new MutationObserver(function () {\n              renderCustomInstallment();\n            });\n          }\n\n          nativeObserver.disconnect();\n          nativeObserver.observe(paymentTermsEl, {\n            attributes: true,\n            childList: true,\n            subtree: true,\n            characterData: true\n          });\n\n          if (paymentTermsEl.shadowRoot) {\n            if (!shadowObserver) {\n              shadowObserver = new MutationObserver(function () {\n                renderCustomInstallment();\n              });\n            }\n\n            shadowObserver.disconnect();\n            shadowObserver.observe(paymentTermsEl.shadowRoot, {\n              childList: true,\n              subtree: true,\n              characterData: true\n            });\n          }\n        }\n\n        function startRefreshWindow() {\n          renderCustomInstallment();\n          attachNativeObserver();\n\n          if (retryTimer) {\n            clearInterval(retryTimer);\n          }\n\n          var attempts = 0;\n          retryTimer = setInterval(function () {\n            attempts += 1;\n            attachNativeObserver();\n            renderCustomInstallment();\n\n            if (attempts >= 10) {\n              clearInterval(retryTimer);\n            }\n          }, 300);\n        }\n\n        function bindVariantListeners() {\n          var scopeRoot = getScopeRoot();\n\n          function handleVariantInteraction(event) {\n            var target = event.target;\n            if (!target || !scopeRoot.contains(target)) return;\n\n            if (\n              target.name === 'id' ||\n              target.matches('select[name^=\"options[\"]') ||\n              target.matches('input[name^=\"options[\"]') ||\n              target.closest('variant-selects') ||\n              target.closest('variant-radios')\n            ) {\n              requestAnimationFrame(startRefreshWindow);\n            }\n          }\n\n          scopeRoot.addEventListener('change', handleVariantInteraction);\n          scopeRoot.addEventListener('input', handleVariantInteraction);\n\n          scopeRoot.addEventListener('click', function (event) {\n            var trigger = event.target.closest('.tbg-installment-trigger');\n            if (!trigger) return;\n\n            event.preventDefault();\n            openNativeInstallmentPopup();\n          });\n\n          document.addEventListener('variant:change', startRefreshWindow);\n          document.addEventListener('product:variant-change', startRefreshWindow);\n          document.addEventListener('product-info:variant-change', startRefreshWindow);\n        }\n\n        function init() {\n          startRefreshWindow();\n          bindVariantListeners();\n        }\n\n        if (document.readyState === 'loading') {\n          document.addEventListener('DOMContentLoaded', init, { once: true });\n        } else {\n          init();\n        }\n      })();\n      // End TBG Custom Code\n    </script>\n    <!-- End TBG Custom Code -->\n\n    {%- if block.settings.show_taxes_notice -%}\n      {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}\n        <div class=\"product__tax rte text-sm\">\n          {%- liquid\n            if cart.taxes_included\n              echo 'products.product.include_taxes' | t\n            endif\n            if shop.shipping_policy.body != blank\n              echo 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url\n            endif\n          -%}\n        </div>\n      {%- endif -%}\n    {%- endif -%}\n  </div>\n</div>\n\n<!-- TBG Custom Code -->\n<div class=\"tbg-installment-row\">\n  <div\n    id=\"{{ tbg_custom_installment_id }}\"\n    class=\"installment text-sm leading-tight\"\n    aria-live=\"polite\"\n    hidden\n  ></div>\n</div>\n<!-- End TBG Custom Code -->"
