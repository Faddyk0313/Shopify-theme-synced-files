        "liquid_WXXG7g": {
          "type": "liquid",
          "name": "BUY 2 -3 discount msg",
          "disabled": true,
          "settings": {
            "liquid": "<!-- TBG Custom Code -->\n{%- comment -%}\n  1) Detect wholesale customers by tag\n  2) Only render the notice & JS if is_wholesale == true\n{%- endcomment -%}\n\n{% assign wholesale_tags = \"Wholesale-Gold,Wholesale-Silver,Wholesale-Bronze,gold-dealer,silver-dealer,bronze-dealer\" | split: \",\" %}\n{% assign is_wholesale = false %}\n{% if customer %}\n  {% for tag in wholesale_tags %}\n    {% if customer.tags contains tag %}\n      {% assign is_wholesale = true %}\n      {% break %}\n    {% endif %}\n  {% endfor %}\n{% endif %}\n\n{%- comment -%}Check if product is in LAST CHANCE collection{%- endcomment -%}\n{% assign is_last_chance = false %}\n{% for collection in product.collections %}\n  {% if collection.id == 343124541618 %}\n    {% assign is_last_chance = true %}\n    {% break %}\n  {% endif %}\n{% endfor %}\n\n{% if is_wholesale == false and is_last_chance == false %}\n<strong id=\"discount-message\" style=\"color: #00adee;\"></strong>\n\n<script>\n// TBG Custom Code\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n\n    function updateDiscountMessage() {\n\n        let quantityInput = document.querySelector(\".buy-buttons .quantity__input\");\n        let minusButton = document.querySelector(\".buy-buttons button[name='minus']\");\n        let plusButton = document.querySelector(\".buy-buttons button[name='plus']\");\n\n        let priceContainer = document.querySelector(\".product__title .customPriceEl\");\n        let priceElement = priceContainer ? priceContainer.querySelector(\".cusPrice\") : document.querySelector(\".product__title .cusPrice\");\n\n        let discountMessage = document.getElementById(\"discount-message\");\n\n        function isSoldOut() {\n            let addToCartButton = document.querySelector(\".product-form__submit .btn-text\");\n            return addToCartButton && addToCartButton.innerText.trim() === \"Sold Out\";\n        }\n\n        function getPrice() {\n            if (!priceElement) return 0;\n            let priceText = priceElement.textContent.trim()\n                .replace(\"Rs.\", \"\")\n                .replace(\"$\", \"\")\n                .replace(/,/g, \"\")\n                .trim();\n            let price = parseFloat(priceText);\n            return isNaN(price) ? 0 : price;\n        }\n\n        function calculateDiscount(qty) {\n            if (isSoldOut()) {\n                discountMessage.innerHTML = \"\";\n                return;\n            }\n\n            let price = getPrice();\n            if (price === 0) {\n                discountMessage.innerHTML = \"\";\n                return;\n            }\n\n            let save10Value = (price * 2 * 0.10).toFixed(2);\n            let save20Value = (price * 3 * 0.20).toFixed(2);\n\n            if (qty === 1) {\n                discountMessage.innerHTML = `<strong style=\"color: #00adee;\">BUY 2 SAVE 10% ($${save10Value}) <br>BUY 3 SAVE 20% ($${save20Value})</strong>`;\n            } else if (qty === 2) {\n                discountMessage.innerHTML = `<strong style=\"color: #00adee;\">BUY 3 SAVE 20% ($${save20Value})</strong>`;\n            } else {\n                discountMessage.innerHTML = \"\";\n            }\n        }\n\n        function updateMessage() {\n            let quantity = parseInt(quantityInput ? quantityInput.value : 0, 10);\n            calculateDiscount(quantity);\n        }\n\n        function observePriceChanges() {\n            if (!priceContainer) return;\n            const observer = new MutationObserver(() => {\n                priceElement = priceContainer.querySelector(\".cusPrice\");\n                updateMessage();\n            });\n            observer.observe(priceContainer, { childList: true, subtree: true });\n        }\n\n        if (quantityInput) {\n            quantityInput.addEventListener(\"input\", updateMessage);\n            quantityInput.addEventListener(\"change\", updateMessage);\n        }\n\n        if (minusButton) {\n            minusButton.addEventListener(\"click\", () => setTimeout(updateMessage, 50));\n        }\n        if (plusButton) {\n            plusButton.addEventListener(\"click\", () => setTimeout(updateMessage, 50));\n        }\n\n        observePriceChanges();\n        updateMessage();\n    }\n\n    updateDiscountMessage();\n});\n// End TBG Custom Code\n</script>\n{% endif %}\n<!-- End TBG Custom Code -->"
