        "liquid_XMxet3": {
          "type": "liquid",
          "settings": {
            "liquid": "{% capture 'meta_data' %}\n{% for variant in product.variants %}\n  {{ variant.id}}: '{{ variant.metafields.custom.estimated_shipping2 | raw }}' {%- comment -%} Replace it with your NAMESPACE.KEY value {%- endcomment -%}\n  {% unless forloop.last %},{% endunless %}\n{% endfor %}\n{% endcapture %}\n\n<script>\n  let metaData = { {{ meta_data }} };\n  \n  document.addEventListener(\"DOMContentLoaded\", function() {\n    var selector = document.querySelector('input[name=id]');\n    var meta = document.querySelector('#test');\n\n    // Function to update metafield data\n    function updateMetaField() {\n      let variant_id = selector ? selector.value : null;\n      if(variant_id && metaData[variant_id]) {\n        meta.innerHTML = metaData[variant_id];\n      } else {\n        meta.innerHTML = \"\";\n      }\n    }\n\n    // Initial load for pre-selected variant\n    updateMetaField();\n\n    // Update on variant change\n    if(selector) {\n      selector.addEventListener('change', function() {\n        updateMetaField();\n      });\n    }\n  });\n</script>"
          }
        },
        "text_XiPGam": {
          "type": "text",
          "disabled": true,
          "settings": {
            "icon": "none",
            "iwidth": "custom",
            "icon_width": 20,
            "text": "<strong>Add to Cart - </strong>ships within 24-48 hours. <strong>// Preorder</strong> - ships 2-4 weeks out. <strong>// Notify Me </strong>- secures your spot on the priority list.",
            "text_size": "text-sm"
          }
        },
        "liquid_3QhEqF": {
          "type": "liquid",
          "disabled": true,
          "settings": {
            "liquid": "<strong id=\"discount-message\" style=\"color: red;\"></strong>\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n    function updateDiscountMessage() {\n        let quantityInput = document.querySelector(\".buy-buttons .quantity__input\");\n        let minusButton = document.querySelector(\".buy-buttons button[name='minus']\");\n        let plusButton = document.querySelector(\".buy-buttons button[name='plus']\");\n        let priceContainer = document.querySelector(\".product__price\");\n        let priceElement = priceContainer ? priceContainer.querySelector(\".price__regular\") : null;\n        let discountMessage = document.getElementById(\"discount-message\");\n\n        function isSoldOut() {\n            let addToCartButton = document.querySelector(\".product-form__submit .btn-text\");\n            return addToCartButton && addToCartButton.innerText.trim() === \"Sold Out\";\n        }\n\n        function getPrice() {\n            if (!priceElement) return 0;\n            let priceText = priceElement.textContent.trim().replace(\"$\", \"\").replace(\",\", \"\");\n            let price = parseFloat(priceText);\n            return isNaN(price) ? 0 : price;\n        }\n\n        function calculateDiscount(qty) {\n            if (isSoldOut()) {\n                discountMessage.innerHTML = \"\";\n                return;\n            }\n\n            let price = getPrice();\n            if (price === 0) return;\n\n            let save5Value = (price * 2 * 0.05).toFixed(2);\n            let save10Value = (price * 3 * 0.10).toFixed(2);\n\n            if (qty === 1) {\n                discountMessage.innerHTML = `<strong style=\"color: red;\">BUY 2 SAVE 5% ($${save5Value}) AND BUY 3 SAVE 10% ($${save10Value})</strong>`;\n            } else if (qty === 2) {\n                discountMessage.innerHTML = `<strong style=\"color: red;\">BUY 3 SAVE 10% ($${save10Value})</strong>`;\n            } else {\n                discountMessage.innerHTML = \"\";\n            }\n        }\n\n        function updateMessage() {\n            let quantity = parseInt(quantityInput.value, 10);\n            calculateDiscount(quantity);\n        }\n\n        function observePriceChanges() {\n            if (!priceContainer) return;\n            const observer = new MutationObserver(() => {\n                priceElement = priceContainer.querySelector(\".price__regular\"); // Update reference\n                updateMessage(); // Recalculate discount\n            });\n\n            observer.observe(priceContainer, { childList: true, subtree: true });\n        }\n\n        quantityInput.addEventListener(\"input\", updateMessage);\n        quantityInput.addEventListener(\"change\", updateMessage);\n\n        if (minusButton) minusButton.addEventListener(\"click\", () => setTimeout(updateMessage, 50));\n        if (plusButton) plusButton.addEventListener(\"click\", () => setTimeout(updateMessage, 50));\n\n        observePriceChanges(); // Watch for price updates\n        updateMessage(); // Initial discount calculation\n    }\n\n    updateDiscountMessage();\n});\n</script>"
          }
        },
