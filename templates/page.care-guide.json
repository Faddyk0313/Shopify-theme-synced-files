 .cus_item-sub {\n        font-size: 13px;\n        color: #888;\n        line-height: 1.5;\n      }\n      .cus_tbg-care .cus_danger-badge {\n        display: inline-block;\n        font-size: 10px;\n        font-weight: 700;\n        letter-spacing: 1.5px;\n        text-transform: uppercase;\n        background: #ff3333;\n        color: #fff;\n        padding: 2px 7px;\n        border-radius: 4px;\n        margin-left: 6px;\n        vertical-align: middle;\n      }\n      .cus_tbg-care .cus_void-box {\n        background: #1a0808;\n        border: 0.5px solid #3d1010;\n        border-radius: 10px;\n        padding: 14px 16px;\n      }\n      .cus_tbg-care .cus_void-title {\n        \/* font-family: \"Barlow Condensed\", sans-serif; *\/\n        font-weight: 700;\n        font-size: 12px;\n        letter-spacing: 2px;\n        text-transform: uppercase;\n        color: #ff4444;\n        margin-bottom: 10px;\n      }\n      .cus_tbg-care .cus_void-list {\n        display: flex;\n        flex-direction: column;\n        gap: 6px;\n      }\n      .cus_tbg-care .cus_void-item {\n        display: flex;\n        gap: 10px;\n        align-items: center;\n        font-size: 13px;\n        color: #cc6666;\n      }\n      .cus_tbg-care .cus_void-x {\n        width: 16px;\n        height: 16px;\n        border-radius: 50%;\n        background: #3d1010;\n        border: 0.5px solid #663333;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        flex-shrink: 0;\n        font-size: 9px;\n        color: #ff4444;\n        font-weight: 700;\n      }\n      .cus_tbg-care .cus_pro-box {\n        background: #0d1a00;\n        border: 0.5px solid #2a4400;\n        border-radius: 10px;\n        padding: 14px 16px;\n      }\n      .cus_tbg-care .cus_pro-title {\n        \/* font-family: \"Barlow Condensed\", sans-serif; *\/\n        font-weight: 700;\n        font-size: 12px;\n        letter-spacing: 2px;\n        text-transform: uppercase;\n        color: #ccff00;\n        margin-bottom: 10px;\n      }\n      .cus_tbg-care .cus_pro-item {\n        display: flex;\n        gap: 10px;\n        align-items: flex-start;\n        font-size: 13px;\n        color: #99cc44;\n        line-height: 1.5;\n        margin-bottom: 10px;\n      }\n      .cus_tbg-care .cus_pro-item:last-child {\n        margin-bottom: 0;\n      }\n      .cus_tbg-care .cus_pro-check {\n        width: 16px;\n        height: 16px;\n        border-radius: 50%;\n        background: #1a3300;\n        border: 0.5px solid #446600;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        flex-shrink: 0;\n        margin-top: 1px;\n      }\n      .cus_tbg-care .cus_antimicrobial-bar {\n        background: #0d1a00;\n        border: 0.5px solid #2a4400;\n        border-radius: 10px;\n        padding: 14px 16px;\n        display: flex;\n        align-items: center;\n        gap: 14px;\n      }\n      .cus_tbg-care .cus_stat-circle {\n        width: 56px;\n        height: 56px;\n        border-radius: 50%;\n        background: #ccff00;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        flex-shrink: 0;\n      }\n      .cus_tbg-care .cus_stat-num {\n        \/* font-family: \"Barlow Condensed\", sans-serif; *\/\n        font-weight: 900;\n        font-size: 14px;\n        color: #0a0a0a;\n        line-height: 1;\n      }\n      .cus_tbg-care .cus_stat-pct {\n        \/* font-family: \"Barlow Condensed\", sans-serif; *\/\n        font-weight: 700;\n        font-size: 11px;\n        color: #0a0a0a;\n        line-height: 1;\n      }\n      .cus_tbg-care .cus_stat-text {\n        flex: 1;\n      }\n      .cus_tbg-care .cus_stat-label {\n        font-weight: 600;\n        font-size: 13px;\n        color: #ccff00;\n        margin-bottom: 3px;\n      }\n      .cus_tbg-care .cus_stat-desc {\n        font-size: 12px;\n        color: #668833;\n        line-height: 1.45;\n      }\n      .cus_tbg-care .cus_notice-box {\n        background: #111;\n        border: 0.5px solid #2a2a2a;\n        border-left: 3px solid #ccff00;\n        border-radius: 10px;\n        padding: 16px 18px;\n      }\n      .cus_tbg-care .cus_notice-title {\n        \/* font-family: \"Barlow Condensed\", sans-serif; *\/\n        font-weight: 700;\n        font-size: 12px;\n        letter-spacing: 2px;\n        text-transform: uppercase;\n        color: #ccff00;\n        margin-bottom: 8px;\n      }\n      .cus_tbg-care .cus_notice-text {\n        font-size: 13px;\n        color: #888;\n        line-height: 1.6;\n      }\n      .cus_tbg-care .cus_notice-text strong {\n        color: #bbb;\n        font-weight: 600;\n      }\n      .cus_tbg-care .cus_footer {\n        text-align: center;\n        margin-top: 20px;\n        padding-top: 20px;\n        border-top: 0.5px solid #1a1a1a;\n      }\n      .cus_tbg-care .cus_footer-line {\n        \/* font-family: \"Barlow Condensed\", sans-serif; *\/\n        font-weight: 700;\n        font-size: 11px;\n        letter-spacing: 3px;\n        text-transform: uppercase;\n        color: #444;\n      }\n      .cus_tbg-care .cus_footer-sub {\n        margin-top: 4px;\n        font-size: 11px;\n        color: #333;\n      }\n    <\/style>\n<div class=\"cus_tbg-care\">\n    <div class=\"cus_wrapper\">\n      <div class=\"cus_header\">\n        <div class=\"cus_brand\">Titan BattleGear<\/div>\n        <h2 class=\"cus_title\">Care Instructions<\/h2>\n        <div class=\"cus_intro\">\n          Our baselayers are built tough, but even tough gear appreciates a\n          little respect. Follow these tips to keep your Titan performing at its\n          best.\n        <\/div>\n      <\/div>\n\n      <!-- WASHING -->\n      <div class=\"cus_section\">\n        <div class=\"cus_section-header\">\n          <div class=\"cus_section-icon\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\">\n              <circle cx=\"12\" cy=\"12\" r=\"8\" stroke=\"#0a0a0a\" stroke-width=\"2\" \/>\n              <path\n                d=\"M8 12c1-2 5-2 6 0s4 2 6 0\"\n                stroke=\"#0a0a0a\"\n                stroke-width=\"1.5\"\n                stroke-linecap=\"round\"\n                fill=\"none\"\n              \/>\n            <\/svg>\n          <\/div>\n          <div class=\"cus_section-title\">Washing<\/div>\n        <\/div>\n        <div class=\"cus_section-body\">\n          <div class=\"cus_item\">\n            <div class=\"cus_item-dot\"><\/div>\n            <div class=\"cus_item-text\">\n              <div class=\"cus_item-label\">\n                Machine wash cold — gentle cycle, mild detergent\n              <\/div>\n              <div class=\"cus_item-sub\">\n                Cold water, mild detergent. Think spa day, not power wash. Your\n                BattleGear has been through enough already.\n              <\/div>\n            <\/div>\n          <\/div>\n\n          <div class=\"cus_item\">\n            <div class=\"cus_item-dot\"><\/div>\n            <div class=\"cus_item-text\">\n              <div class=\"cus_item-label\">Low tumble dry — no heat<\/div>\n              <div class=\"cus_item-sub\">\n                Your baselayer is built for the ice, not the sauna. Low and slow\n                wins every time — heat degrades the A9 cut protection.\n              <\/div>\n            <\/div>\n          <\/div>\n\n          <div class=\"cus_item\">\n            <div class=\"cus_item-dot\"><\/div>\n            <div class=\"cus_item-text\">\n              <div class=\"cus_item-label\">\n                Keep away from velcro and abrasive materials\n              <\/div>\n              <div class=\"cus_item-sub\">\n                TITANOTEX is tough against blades — not against velcro. Ironic,\n                but here we are.\n              <\/div>\n            <\/div>\n          <\/div>\n\n          <div class=\"cus_item\">\n            <div class=\"cus_item-dot\"><\/div>\n            <div class=\"cus_item-text\">\n              <div class=\"cus_item-label\">Wash separately from heavy garments<\/div>\n              <div class=\"cus_item-sub\">\n                Jeans, jackets, and zippers like to pick fights with performance\n                fabrics. Keep them out of the mix and let your BattleGear have\n                the machine to itself.\n              <\/div>\n            <\/div>\n          <\/div>\n\n          <div class=\"cus_void-box\">\n            <div class=\"cus_void-title\">\n              Warranty Killers <span class=\"cus_danger-badge\">Void<\/span>\n            <\/div>\n            <div class=\"cus_void-list\">\n              <div class=\"cus_void-item\">\n                <div class=\"cus_void-x\">✕<\/div>\n                Bleach — absolutely not, ever, under any circumstances\n              <\/div>\n              <div class=\"cus_void-item\">\n                <div class=\"cus_void-x\">✕<\/div>\n                Dry cleaning — your gear is not a suit\n              <\/div>\n              <div class=\"cus_void-item\">\n                <div class=\"cus_void-x\">✕<\/div>\n                Heated drying or hot water — kills cut protection\n              <\/div>\n            <\/div>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <!-- AFTER USE -->\n      <div class=\"cus_section\">\n        <div class=\"cus_section-header\">\n          <div class=\"cus_section-icon\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\">\n              <path\n                d=\"M12 3v10M12 13l-3 3M12 13l3 3\"\n                stroke=\"#0a0a0a\"\n                stroke-width=\"2\"\n                stroke-linecap=\"round\"\n                stroke-linejoin=\"round\"\n              \/>\n              <path\n                d=\"M5 19h14\"\n                stroke=\"#0a0a0a\"\n                stroke-width=\"2\"\n                stroke-linecap=\"round\"\n              \/>\n            <\/svg>\n          <\/div>\n          <div class=\"cus_section-title\">After Use<\/div>\n        <\/div>\n        <div class=\"cus_section-body\">\n          <div class=\"cus_item\">\n            <div class=\"cus_item-dot\"><\/div>\n            <div class=\"cus_item-text\">\n              <div class=\"cus_item-label\">Hang to dry immediately<\/div>\n              <div class=\"cus_item-sub\">\n                Off the ice and onto a hanger. Don't let it sit in a pile — wet\n                gear stewing in its own glory is a smell you'll never forget.\n              <\/div>\n            <\/div>\n          <\/div>\n\n          <div class=\"cus_antimicrobial-bar\">\n            <div class=\"cus_stat-circle\">\n              <div class=\"cus_stat-num\">99.99<\/div>\n              <div class=\"cus_stat-pct\">%<\/div>\n            <\/div>\n            <div class=\"cus_stat-text\">\n              <div class=\"cus_stat-label\">\n                Micro-Texpur® Antimicrobial Protection\n              <\/div>\n              <div class=\"cus_stat-desc\">\n                Built-in defense against bacteria, odor, mold, and mildew. It's\n                doing heavy lifting — but it's not a reason to leave your gear\n                in the bag.\n              <\/div>\n            <\/div>\n          <\/div>\n\n          <div class=\"cus_item\">\n            <div class=\"cus_item-dot\"><\/div>\n            <div class=\"cus_item-text\">\n              <div class=\"cus_item-label\">Don't leave it in the hockey bag<\/div>\n              <div class=\"cus_item-sub\">\n                The hockey bag is where equipment goes to marinate. Your\n                BattleGear has serious science protecting it — don't make it\n                fight harder than it has to.\n              <\/div>\n            <\/div>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <!-- PRO TIPS -->\n      <div class=\"cus_section\">\n        <div class=\"cus_section-header\">\n          <div class=\"cus_section-icon\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\">\n              <polygon\n                points=\"12,2 15,9 22,9 16.5,14 18.5,21 12,17 5.5,21 7.5,14 2,9 9,9\"\n                stroke=\"#0a0a0a\"\n                stroke-width=\"1.5\"\n                stroke-linejoin=\"round\"\n                fill=\"none\"\n              \/>\n            <\/svg>\n          <\/div>\n          <div class=\"cus_section-title\">Pro Tips<\/div>\n        <\/div>\n        <div class=\"cus_section-body\">\n          <div class=\"cus_pro-box\">\n            <div class=\"cus_pro-title\">Level Up Your Wash Routine<\/div>\n            <div class=\"cus_pro-item\">\n              <div class=\"cus_pro-check\">\n                <svg width=\"8\" height=\"6\" viewBox=\"0 0 8 6\" fill=\"none\">\n                  <path\n                    d=\"M1 3l2 2 4-4\"\n                    stroke=\"#CCFF00\"\n                    stroke-width=\"1.5\"\n                    stroke-linecap=\"round\"\n                    stroke-linejoin=\"round\"\n                  \/>\n                <\/svg>\n              <\/div>\n              <div>\n                Wash in a delicates mesh laundry bag — it keeps the TITANOTEX\n                fabric protected and your baselayer from tangling with anything\n                it shouldn't.\n              <\/div>\n            <\/div>\n            <div class=\"cus_pro-item\">\n              <div class=\"cus_pro-check\">\n                <svg width=\"8\" height=\"6\" viewBox=\"0 0 8 6\" fill=\"none\">\n                  <path\n                    d=\"M1 3l2 2 4-4\"\n                    stroke=\"#CCFF00\"\n                    stroke-width=\"1.5\"\n                    stroke-linecap=\"round\"\n                    stroke-linejoin=\"round\"\n                  \/>\n                <\/svg>\n              <\/div>\n              <div>\n                Avoid crumpling into a ball and leaving in the road. We probably\n                don't need to say this — but we said it anyway.\n              <\/div>\n            <\/div>\n            <div class=\"cus_pro-item\">\n              <div class=\"cus_pro-check\">\n                <svg width=\"8\" height=\"6\" viewBox=\"0 0 8 6\" fill=\"none\">\n                  <path\n                    d=\"M1 3l2 2 4-4\"\n                    stroke=\"#CCFF00\"\n                    stroke-width=\"1.5\"\n                    stroke-linecap=\"round\"\n                    stroke-linejoin=\"round\"\n                  \/>\n                <\/svg>\n              <\/div>\n              <div>\n                Skip the fabric softener. It coats the fibers and quietly\n                reduces performance over time. Your gear doesn't need to smell\n                like lavender to be elite.\n              <\/div>\n            <\/div>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <!-- PRODUCT NOTICE -->\n      <div class=\"cus_notice-box\">\n        <div class=\"cus_notice-title\">Product Notice<\/div>\n        <div class=\"cus_notice-text\">\n          Our gear is made for performance and durability, but\n          <strong\n            >damage caused by velcro battles, zipper attacks, or rough washing\n            is not considered a manufacturing defect.<\/strong\n          >\n          Treat it right, and your Titan will be ready for battle every time.\n        <\/div>\n      <\/div>\n\n      <div class=\"cus_footer\">\n        <div class=\"cus_footer-line\">Together We Conquer<\/div>\n        <div class=\"cus_footer-sub\">Questions? sales@titanbattlegear.com<\/div>\n      <\/div>\n    <\/div>\n<\/div>","color_text":"","color_background":"#000000","gradient_background":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":24,"padding_bottom":44,"divider":false,"narrow":false,"rounded":false}},"multicolumn_iapmqN":{"type":"multicolumn","blocks":{"column_VNdEzX":{"type":"column","settings":{"show_border":false,"text_ali