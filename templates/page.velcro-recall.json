{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"heading_size":"title-xl tracking-heading","heading_alignment":"text-left","heading_tag":"h1","text_size":"text-base","padding_top":72,"padding_bottom":120,"divider":false,"narrow":true,"rounded":false}},"image_with_text_overlay_GgCHTP":{"type":"image-with-text-overlay","blocks":{"heading_Xxahj7":{"type":"heading","settings":{"heading":"velcro recall","heading_size":"title-md","heading_tag":"h2","highlighted_text":"none","highlighted_scribble":"circle"}},"subheading_bAF7yH":{"type":"subheading","settings":{"subheading":"**ALL IN STOCK VELCRO SHIRTS HAVE OUR NEW LONG LASTING VELCRO**","subheading_size":"subtitle-md","secondary_color":true}}},"block_order":["heading_Xxahj7","subheading_bAF7yH"],"settings":{"transparent_header":false,"image":"shopify:\/\/shop_images\/BANNER_VELCRO_RECALL.png","image_height":"adapt","content_width":"medium","content_position":"md:items-end md:justify-start","text_alignment":"left","image_mobile":"shopify:\/\/shop_images\/banner_velcro_mobile.jpg","image_height_mobile":"adapt","content_position_mobile":"items-center justify-center","text_alignment_mobile":"center","color_text":"#ffffff","color_highlight":"#e2fb31","gradient_highlight":"","color_button_text":"#171717","color_button_background":"#ffffff","color_button_gradient":"","color_overlay":"#00adee","overlay_opacity":0,"padding_top":0,"padding_bottom":36,"divider":false,"full_width":false,"rounded":true,"enable_parallax":false,"parallax_direction":"vertical"}},"image-with-text":{"type":"image-with-text","blocks":{"icon_bpQyBB":{"type":"icon","settings":{"icon":"none","icon_width":48}},"subheading_fh3B33":{"type":"subheading","settings":{"subheading":"","subheading_size":"subtitle-md","secondary_color":true}},"text-1":{"type":"text","settings":{"text":"<h3>Letter from our CEO<\/h3><p><br\/>Dear Valued Titan Customer,<\/p><p>We have become aware that some units from the batch of production between September 13, 2024 and December 12, 2024 are experiencing velcro fastening issues. <\/p><p>Our California-based Velcro provider has confirmed that the loop-side parts we received for that production are indeed fatiguing faster than their guaranteed lifecycle (300 cycles).<\/p><p>They have provided us with a more durable loop-side replacement part (10,000 cycles vs 300 cycles).<\/p><p>We stand by our Battlegear and can provide you with two solutions:<\/p><p><strong>Option  1:<\/strong><\/p><p><strong>Titan will provide you with a return label to send back your shirt for our team to replace the Velcro loop-side part, and then return your repaired shirt to you as soon as possible.<\/strong><\/p>","text_font":"body","text_size":"subtext-sm","text_max_size":32,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}},"text_3bzqBK":{"type":"text","settings":{"text":"<p><strong>Option 2:<\/strong><\/p><p><strong>Titan will send you the new loop-side part. Please take the new loop-side part to your local tailor\/alterations specialist to replace the part.<\/strong><\/p><p><strong>Once the repair is completed, please send an email to <\/strong><a href=\"mailto:info@titanbattlegear.com\"><span style=\"text-decoration:underline\"><strong>info@titanbattlegear.com<\/strong><\/span><\/a><strong> with the receipt from the alteration shop for reimbursement.<\/strong><\/p><p>We apologize for this inconvenience, and have added additional quality control measures when receiving vendor-produced parts and materials before advancing through our own production.<\/p><p>Thank you for your commitment to safety and style with Titan Battlegear!<\/p><p>Together We Conquer,<\/p>","text_font":"body","text_size":"subtext-sm","text_max_size":32,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}},"button_JKb99G":{"type":"button","settings":{"button_label":"SUBMIT REQUEST","button_link":"#shopify-section-template--18081187889330__rich_text_h6NANT","button_size":"sm","button_external":false,"button_icon":false}},"image_K3NmeP":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/firma.svg","image_width":"custom","image_max_width":330,"image_max_width_mobile":280}},"text-2":{"type":"text","settings":{"text":"<p><em>- <\/em>Andries de Villiers, Founder & CEO<\/p>","text_font":"heading","text_size":"subtext-md","text_max_size":32,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}},"liquid_i8nw9Y":{"type":"liquid","settings":{"liquid":""}}},"block_order":["icon_bpQyBB","subheading_fh3B33","text-1","text_3bzqBK","button_JKb99G","image_K3NmeP","text-2","liquid_i8nw9Y"],"settings":{"image":"shopify:\/\/shop_images\/VELCRO_NICK_CENTER.png","image_height":"adapt","image_width":"medium","layout":"text_first","text_alignment":"left","content_position":"align-self-center","image_mobile":"shopify:\/\/shop_images\/VELCRO_NICK_CENTER.png","image_height_mobile":"adapt","text_alignment_mobile":"left","color_text":"#ffffff","color_background":"rgba(0,0,0,0)","gradient_background":"","color_background_2":"#171717","gradient_background_2":"","color_highlight":"","gradient_highlight":"","color_button_text":"#171717","color_button_background":"#ffffff","color_button_gradient":"linear-gradient(54deg, rgba(114, 255, 179, 1) 14%, rgba(255, 250, 99, 1) 85%)","padding_top":0,"padding_bottom":36,"divider":false,"full_width":false,"rounded":false,"enable_parallax":false,"parallax_direction":"vertical"}},"rich_text_h6NANT":{"type":"rich-text","blocks":{"heading_mq4dYw":{"type":"heading","settings":{"heading":"OPTION 1: TIMELINE","heading_size":"title-sm","heading_tag":"h2","highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["heading_mq4dYw"],"settings":{"text_alignment":"left","text_alignment_mobile":"left","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label"