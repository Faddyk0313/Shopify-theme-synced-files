lor_button_background":"","color_button_gradient":"","padding_top":0,"padding_bottom":20,"divider":false,"narrow":false,"rounded":false}},"image_with_text_aNyr8W":{"type":"image-with-text","blocks":{"heading_HaUfxn":{"type":"heading","settings":{"heading":"1. Removing the Velcro","heading_size":"title-sm","heading_tag":"h4","highlighted_text":"none","highlighted_scribble":"circle"}},"text_9yFE33":{"type":"text","settings":{"text":"<ul><li>Use a seam ripper to lift stitches from the smooth fabric side without damaging it.<\/li><li>Break the longest stitches first for easier removal.<\/li><li>Gently pull loose threads to detach the Velcro.<\/li><li>Repeat until the Velcro is fully removed.<\/li><\/ul>","text_font":"body","text_size":"subtext-md","text_max_size":32,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}},"heading_FY6ihV":{"type":"heading","settings":{"heading":"2. Sewing the Velcro Loop","heading_size":"title-sm","heading_tag":"h4","highlighted_text":"none","highlighted_scribble":"circle"}},"text_wLm83B":{"type":"text","settings":{"text":"<ul><li>Align the new Velcro in the original position.<\/li><li>Start stitching at the outer edge, aligning the presser foot with the Velcro.<\/li><li>Turn corners by keeping the needle down, lifting the presser foot, and rotating the fabric.<\/li><li>Reinforce stitching at the starting point and trim loose threads.<\/li><li>Flip the collar and repeat stitching from the fabric side, following the first stitch line.<\/li><\/ul>","text_font":"body","text_size":"subtext-md","text_max_size":32,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["heading_HaUfxn","text_9yFE33","heading_FY6ihV","text_wLm83B"],"settings":{"image":"shopify:\/\/shop_images\/costurera_foto.jpg","image_height":"750px","image_width":"small","layout":"image_first","text_alignment":"left","content_position":"align-self-center","image_mobile":"shopify:\/\/shop_images\/costurer