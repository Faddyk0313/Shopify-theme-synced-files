s\n  \n      \/\/ clone logic…\n      const firstClone = videoCards[0].cloneNode(true);\n      const lastClone  = videoCards[videoCards.length - 1].cloneNode(true);\n      carousel.appendChild(firstClone);\n      carousel.insertBefore(lastClone, carousel.firstChild);\n      const allCards = Array.from(carousel.children);\n  \n      function calculateCardWidth() {\n        return allCards[0].offsetWidth + gap;\n      }\n  \n      function updateCarousel(animate = true) {\n        const cardWidth   = calculateCardWidth();\n        const offset      = currentIndex * cardWidth;\n        const isLarge     = window.innerWidth >= 1024;\n        carousel.style.transition = animate ? \"transform 0.5s ease\" : \"none\";\n        carousel.style.transform  = isLarge\n          ? `translateX(calc(-${offset}px + 15%))`\n          : `translateX(-${offset}px)`;\n  \n        \/\/ fade in\/out\n        allCards.forEach((card, i) => {\n          card.classList.remove(\"!opacity-100\", \"opacity-0\", \"lg:opacity-40\");\n          card.classList.add(i === currentIndex ? \"!opacity-100\" : \"opacity-0\", \"lg:opacity-40\");\n        });\n  \n        \/\/ 3) Update the button’s link to the active video\n        const activeFrame = allCards[currentIndex].querySelector('iframe');\n        if (activeFrame) {\n          \/\/ src is like \"https:\/\/www.youtube.com\/embed\/VIDEO_ID?…\"\n          const embedSrc = activeFrame.src;\n          const videoID  = embedSrc.split('\/embed\/')[1].split('?')[0];\n          viewLink.href  = `https:\/\/www.youtube.com\/watch?v=${videoID}`;\n        }\n      }\n  \n      function shiftRight() {\n        if (currentIndex >= allCards.length - 1) return;\n        currentIndex++;\n        updateCarousel();\n        if (currentIndex === allCards.length - 1) {\n          setTimeout(() => { currentIndex = 1; updateCarousel(false); }, 510);\n        }\n      }\n  \n      function shiftLeft() {\n        if (currentIndex <= 0) return;\n        currentIndex--;\n        updateCarousel();\n        if (currentIndex === 0) {\n          setTimeout(() => { currentIndex = allCards.length - 2; updateCarousel(false); }, 510);\n        }\n      }\n  \n      leftBtn.addEventListener(\"click\", shiftLeft);\n      rightBtn.addEventListener(\"click\", shiftRight);\n      window.addEventListener(\"resize\", () => updateCarousel(false));\n  \n      \/\/ initial setup\n      updateCarousel(false);\n    });\n  <\/script>","color_text":"","color_background":"","gradient_background":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":72,"divider":false,"narrow":false,"rounded":false}},"custom_liquid_dFWBrM":{"type":"custom-liquid","settings":{"liquid":"<link\n  rel=\"stylesheet\"\n  href=\"https:\/\/cdn.jsdelivr.net\/npm\/swiper@11\/swiper-bundle.min.css\"\n\/>\n<style>\n  \/* Live *\/\n  #shopify-section-template--18467306668210__custom_liquid_dFWBrM .page-width {\n    padding: 0 !important;\n  }\n\n  \/* Custom *\/\n  #shopify-section-template--18530212282546__custom_liquid_dFWBrM .page-width {\n    padding: 0 !important;\n  }\n\n  .slider-wrapper {\n    overflow: hidden;\n    margin-inline: 0px;\n    margin-bottom: 40px;\n  }\n\n  .slider-wrapper .swiper-pagination-bullet {\n    background: #000000;\n    height: 12px;\n    width: 12px;\n  }\n\n  .slider-wrapper .swiper-slide-button {\n    margin-top: -50px;\n    bottom: 0;\n    top: 102%;\n  }\n\n  .slider-wrapper .swiper-button-prev {\n    left: 30px;\n  }\n\n  .slider-wrapper .swiper-button-next {\n    right: 30px;\n  }\n\n  @media (min-width: 768px) {\n    .slider-wrapper .swiper-button-prev {\n      left: 40px;\n    }\n\n    .slider-wrapper .swiper-button-next {\n      right: 40px;\n    }\n  }\n\n  .swiper-slide-button::after {\n    display: none;\n  }\n\n  \/* alternate background for each category carousel *\/\n  #sliders-container > section:nth-of-type(odd) {\n    background: #ffffff;\n  }\n\n  \/* 1st, 3rd, 5th… *\/\n  #sl