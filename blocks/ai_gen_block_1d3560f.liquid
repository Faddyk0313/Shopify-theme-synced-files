{% doc %}
  @prompt
    embedded UGC feed carousel of instagram post posts from brand ambassadors , the possibility to have different instagram post from different  accounts so we can showcase specific post. We need to be able to choose if we show it on carousel view in desktop and also in mobile  or not , being able to add a #under the image , good start , but I need the instagram account show up without hoover , so is always showing on mobile , also need the aspect ratio or size  of the image on mobile being able to be controlled. and if is possible to keep all the post the same size , I need the amount of copy showing o each post being limited to a total amount of characters and if it surpasses it needs to show a read more button , perfect, but I need now to be able to post a max of 16 post
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ugc-feed-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-ugc-feed-container-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
  }

  .ai-ugc-feed-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-ugc-feed-carousel-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.grid_gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-ugc-feed-carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-ugc-feed-carousel-{{ ai_gen_id }} .ai-ugc-post-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.desktop_columns | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.desktop_columns }});
    scroll-snap-align: start;
  }

  .ai-ugc-post-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.post_background_color }};
    border-radius: {{ block.settings.post_border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-ugc-post-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.desktop_image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-ugc-post-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-ugc-post-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-ugc-post-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-ugc-post-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.7) 100%);
    padding: 16px;
    display: flex;
    align-items: center;
  }

  .ai-ugc-post-account-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: 14px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-ugc-post-account-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-ugc-post-content-{{ ai_gen_id }} {
    padding: {{ block.settings.caption_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-ugc-post-caption-{{ ai_gen_id }} {
    color: {{ block.settings.caption_text_color }};
    font-size: {{ block.settings.caption_font_size }}px;
    line-height: 1.4;
    margin: 0;
  }

  .ai-ugc-post-caption-{{ ai_gen_id }}.truncated {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-ugc-read-more-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.read_more_color }};
    font-size: {{ block.settings.caption_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    padding: 4px 0 0 0;
    text-align: left;
    text-decoration: underline;
  }

  .ai-ugc-read-more-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-ugc-carousel-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 24px;
  }

  .ai-ugc-carousel-button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_icon_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-ugc-carousel-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-ugc-carousel-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-ugc-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-ugc-empty-state-{{ ai_gen_id }} h3 {
    font-size: 18px;
    margin-bottom: 8px;
    color: #333;
  }

  .ai-ugc-empty-state-{{ ai_gen_id }} p {
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-ugc-feed-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.mobile_columns }}, 1fr);
    }

    .ai-ugc-feed-carousel-{{ ai_gen_id }} .ai-ugc-post-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.mobile_columns | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.mobile_columns }});
    }

    .ai-ugc-post-image-wrapper-{{ ai_gen_id }} {
      padding-bottom: {{ block.settings.mobile_image_aspect_ratio }}%;
    }

    {% if block.settings.mobile_layout == 'carousel' %}
      .ai-ugc-feed-grid-{{ ai_gen_id }} {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
      }

      .ai-ugc-feed-grid-{{ ai_gen_id }}::-webkit-scrollbar {
        display: none;
      }

      .ai-ugc-feed-grid-{{ ai_gen_id }} .ai-ugc-post-{{ ai_gen_id }} {
        flex: 0 0 calc((100% - ({{ block.settings.mobile_columns | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.mobile_columns }});
        scroll-snap-align: start;
      }
    {% endif %}
  }
{% endstyle %}

<ugc-feed-{{ ai_gen_id }} class="ai-ugc-feed-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ugc-feed-container-{{ ai_gen_id }}">
    {% assign has_posts = false %}
    {% for i in (1..16) %}
      {% liquid
        assign post_image_key = 'post_' | append: i | append: '_image'
        assign post_account_key = 'post_' | append: i | append: '_account'
        assign post_caption_key = 'post_' | append: i | append: '_caption'
        assign post_link_key = 'post_' | append: i | append: '_link'
        
        assign post_image = block.settings[post_image_key]
        assign post_account = block.settings[post_account_key]
        assign post_caption = block.settings[post_caption_key]
        assign post_link = block.settings[post_link_key]
        
        if post_image != blank or post_account != blank or post_caption != blank
          assign has_posts = true
        endif
      %}
    {% endfor %}

    {% if has_posts %}
      <div class="{% if block.settings.desktop_layout == 'carousel' %}ai-ugc-feed-carousel-{{ ai_gen_id }}{% else %}ai-ugc-feed-grid-{{ ai_gen_id }}{% endif %}" data-carousel>
        {% for i in (1..16) %}
          {% liquid
            assign post_image_key = 'post_' | append: i | append: '_image'
            assign post_account_key = 'post_' | append: i | append: '_account'
            assign post_caption_key = 'post_' | append: i | append: '_caption'
            assign post_link_key = 'post_' | append: i | append: '_link'
            
            assign post_image = block.settings[post_image_key]
            assign post_account = block.settings[post_account_key]
            assign post_caption = block.settings[post_caption_key]
            assign post_link = block.settings[post_link_key]
          %}

          {% if post_image != blank or post_account != blank or post_caption != blank %}
            <div class="ai-ugc-post-{{ ai_gen_id }}">
              {% if post_link != blank %}
                <a href="{{ post_link }}" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: contents;">
              {% endif %}
              
              <div class="ai-ugc-post-image-wrapper-{{ ai_gen_id }}">
                {% if post_image %}
                  <img
                    src="{{ post_image | image_url: width: 800 }}"
                    alt="{{ post_account | escape }}"
                    class="ai-ugc-post-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {% else %}
                  <div class="ai-ugc-post-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if post_account != blank %}
                  <div class="ai-ugc-post-overlay-{{ ai_gen_id }}">
                    <div class="ai-ugc-post-account-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                      @{{ post_account }}
                    </div>
                  </div>
                {% endif %}
              </div>

              {% if post_caption != blank %}
                <div class="ai-ugc-post-content-{{ ai_gen_id }}">
                  <p class="ai-ugc-post-caption-{{ ai_gen_id }} {% if post_caption.size > block.settings.caption_character_limit %}truncated{% endif %}" data-full-text="{{ post_caption | escape }}" data-char-limit="{{ block.settings.caption_character_limit }}">
                    {% if post_caption.size > block.settings.caption_character_limit %}
                      {{ post_caption | truncate: block.settings.caption_character_limit }}
                    {% else %}
                      {{ post_caption }}
                    {% endif %}
                  </p>
                  {% if post_caption.size > block.settings.caption_character_limit %}
                    <button class="ai-ugc-read-more-{{ ai_gen_id }}" data-read-more>Read more</button>
                  {% endif %}
                </div>
              {% endif %}

              {% if post_link != blank %}
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.desktop_layout == 'carousel' and block.settings.show_carousel_controls %}
        <div class="ai-ugc-carousel-controls-{{ ai_gen_id }}">
          <button class="ai-ugc-carousel-button-{{ ai_gen_id }}" data-prev aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button class="ai-ugc-carousel-button-{{ ai_gen_id }}" data-next aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-ugc-empty-state-{{ ai_gen_id }}">
        <h3>No Instagram posts yet</h3>
        <p>Add images and captions to showcase your brand ambassadors</p>
      </div>
    {% endif %}
  </div>
</ugc-feed-{{ ai_gen_id }}>

<script>
  (function() {
    class UgcFeed{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.carousel = this.querySelector('[data-carousel]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.readMoreButtons = this.querySelectorAll('[data-read-more]');

        if (this.carousel && this.prevButton && this.nextButton) {
          this.setupCarousel();
        }

        if (this.readMoreButtons.length > 0) {
          this.setupReadMore();
        }
      }

      setupCarousel() {
        const scrollAmount = this.carousel.offsetWidth;

        this.prevButton.addEventListener('click', () => {
          this.carousel.scrollBy({
            left: -scrollAmount,
            behavior: 'smooth'
          });
        });

        this.nextButton.addEventListener('click', () => {
          this.carousel.scrollBy({
            left: scrollAmount,
            behavior: 'smooth'
          });
        });
      }

      setupReadMore() {
        this.readMoreButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            
            const caption = button.previousElementSibling;
            const fullText = caption.getAttribute('data-full-text');
            const isExpanded = caption.classList.contains('expanded');

            if (isExpanded) {
              const charLimit = parseInt(caption.getAttribute('data-char-limit'));
              caption.textContent = fullText.substring(0, charLimit) + '...';
              caption.classList.remove('expanded');
              button.textContent = 'Read more';
            } else {
              caption.textContent = fullText;
              caption.classList.add('expanded');
              caption.classList.remove('truncated');
              button.textContent = 'Read less';
            }
          });
        });
      }
    }

    customElements.define('ugc-feed-{{ ai_gen_id }}', UgcFeed{{ ai_gen_id }});
  })();
</script>

