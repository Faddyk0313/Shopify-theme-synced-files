{% doc %}
  @prompt
    a gallery with a collage style to showcase lifestyle pictures of our products, we need to be able to adjust spec ratio of each image , it needs to show a selector for aspect ratio , on mobile it has to be simple , one row each image , this whole idea should be a classic collage with classic sutomisation , perfecto ahora añade opción de agregar mas fotos en caso de que queramos tener mas de 6 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collage-gallery-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-collage-gallery__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collage-gallery__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-collage-gallery__title-{{ ai_gen_id }} {
    margin: 0 0 12px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-collage-gallery__description-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
  }

  .ai-collage-gallery__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: {{ block.settings.row_height }}px;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-collage-gallery__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--1 {
    grid-column: span {{ block.settings.image_1_width }};
    grid-row: span {{ block.settings.image_1_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--2 {
    grid-column: span {{ block.settings.image_2_width }};
    grid-row: span {{ block.settings.image_2_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--3 {
    grid-column: span {{ block.settings.image_3_width }};
    grid-row: span {{ block.settings.image_3_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--4 {
    grid-column: span {{ block.settings.image_4_width }};
    grid-row: span {{ block.settings.image_4_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--5 {
    grid-column: span {{ block.settings.image_5_width }};
    grid-row: span {{ block.settings.image_5_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--6 {
    grid-column: span {{ block.settings.image_6_width }};
    grid-row: span {{ block.settings.image_6_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--7 {
    grid-column: span {{ block.settings.image_7_width }};
    grid-row: span {{ block.settings.image_7_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--8 {
    grid-column: span {{ block.settings.image_8_width }};
    grid-row: span {{ block.settings.image_8_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--9 {
    grid-column: span {{ block.settings.image_9_width }};
    grid-row: span {{ block.settings.image_9_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--10 {
    grid-column: span {{ block.settings.image_10_width }};
    grid-row: span {{ block.settings.image_10_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--11 {
    grid-column: span {{ block.settings.image_11_width }};
    grid-row: span {{ block.settings.image_11_height }};
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}--12 {
    grid-column: span {{ block.settings.image_12_width }};
    grid-row: span {{ block.settings.image_12_height }};
  }

  .ai-collage-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-collage-gallery__item-{{ ai_gen_id }}:hover .ai-collage-gallery__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-collage-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-collage-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collage-gallery__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #666;
    text-align: center;
    padding: 6px 12px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-collage-gallery__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      grid-auto-rows: {{ block.settings.mobile_row_height }}px;
    }

    .ai-collage-gallery__item-{{ ai_gen_id }}--1,
    .ai-collage-gallery__item-{{ ai_gen_id }}--2,
    .ai-collage-gallery__item-{{ ai_gen_id }}--3,
    .ai-collage-gallery__item-{{ ai_gen_id }}--4,
    .ai-collage-gallery__item-{{ ai_gen_id }}--5,
    .ai-collage-gallery__item-{{ ai_gen_id }}--6,
    .ai-collage-gallery__item-{{ ai_gen_id }}--7,
    .ai-collage-gallery__item-{{ ai_gen_id }}--8,
    .ai-collage-gallery__item-{{ ai_gen_id }}--9,
    .ai-collage-gallery__item-{{ ai_gen_id }}--10,
    .ai-collage-gallery__item-{{ ai_gen_id }}--11,
    .ai-collage-gallery__item-{{ ai_gen_id }}--12 {
      grid-column: span 1;
      grid-row: span 1;
    }

    .ai-collage-gallery__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-collage-gallery__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-collage-gallery__header-{{ ai_gen_id }} {
      margin-bottom: 24px;
    }
  }
{% endstyle %}

<div class="ai-collage-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collage-gallery__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.description != blank %}
      <div class="ai-collage-gallery__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-collage-gallery__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-collage-gallery__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-collage-gallery__grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign image = block.settings[image_key] %}
        
        {% if image %}
          <div class="ai-collage-gallery__item-{{ ai_gen_id }} ai-collage-gallery__item-{{ ai_gen_id }}--{{ i }}">
            <img
              src="{{ image | image_url: width: 1200 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-collage-gallery__image-{{ ai_gen_id }}"
            >
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

