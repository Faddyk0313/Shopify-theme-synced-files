{% doc %}
  @prompt
    "Create a custom Shopify Liquid section for a YouTube video. Please include the following features and schema settings:
    
    1. Core Elements:
    
    Video: A YouTube video embedded via a URL link. Include an option in the schema to add a separate video URL specifically for mobile devices.
    
    Play Button: A custom play button overlay on top of the video thumbnail. When clicked, the video should autoplay with sound.
    
    Text Area: Spaces for a Heading and a Subheading.
    
    2. Layout & Responsiveness:
    
    Desktop: The text area (heading/subheading) must be aligned to the left, and the video placed on the right (a 50/50 split layout).
    
    Mobile: The layout should stack, with the text area positioned directly above the video.
    
    3. Customization Settings (Schema):
    Please add settings so I can customize the following from the Shopify Theme Editor:
    
    Section background color.
    
    Top and bottom padding for the section.
    
    Font sizes for both the Heading and Subheading.
    
    Size and color adjustments for the custom Play button icon.", NEED TO BE ABLE TO CONTROL DE TEXT COLOR OF HEADER AND SUBHEADER INDIVIDUALLY , also need to be able to choose the text alignment and position on desktop and mobile individually , WANT TO CONTROL TEXT SIZE ON MOBILE AND DESKTOP INDIVUDUALLY , LE ME CONTROL DE NARROW OF THE CONTENT  PAGE ON DESKTOP TO MAKE IT FULL OR NARROW , LET ME ADD AS OPTIONAL A COVER IMAGE OF THE VIDEO IN MOBILE AND DESKTOP
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-youtube-section-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.section_background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    width: 100%;
  }

  .ai-youtube-container-{{ ai_gen_id }} {
    {% if block.settings.content_width == 'narrow' %}
      max-width: 1200px;
    {% else %}
      max-width: 1900px;
    {% endif %}
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-youtube-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .ai-youtube-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: {{ block.settings.text_alignment_desktop }};
    {% if block.settings.text_position_desktop == 'left' %}
      order: 1;
    {% else %}
      order: 2;
    {% endif %}
  }

  .ai-youtube-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_font_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-youtube-subheading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subheading_font_size_desktop }}px;
    color: {{ block.settings.subheading_color }};
    line-height: 1.5;
  }

  .ai-youtube-video-container-{{ ai_gen_id }} {
    {% if block.settings.text_position_desktop == 'left' %}
      order: 2;
    {% else %}
      order: 1;
    {% endif %}
  }

  .ai-youtube-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #000000;
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-youtube-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-youtube-thumbnail-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-youtube-thumbnail-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-youtube-play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.play_button_size }}px;
    height: {{ block.settings.play_button_size }}px;
    background-color: {{ block.settings.play_button_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, opacity 0.3s ease;
    z-index: 2;
    opacity: 0.95;
  }

  .ai-youtube-play-button-{{ ai_gen_id }}:hover {
    transform: translate(-50%, -50%) scale(1.1);
    opacity: 1;
  }

  .ai-youtube-play-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.play_button_size }}px * 0.4);
    height: calc({{ block.settings.play_button_size }}px * 0.4);
    margin-left: calc({{ block.settings.play_button_size }}px * 0.05);
    fill: {{ block.settings.play_button_icon_color }};
  }

  .ai-youtube-hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-youtube-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-youtube-text-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_alignment_mobile }};
      {% if block.settings.text_position_mobile == 'top' %}
        order: 1;
      {% else %}
        order: 2;
      {% endif %}
    }

    .ai-youtube-video-container-{{ ai_gen_id }} {
      {% if block.settings.text_position_mobile == 'top' %}
        order: 2;
      {% else %}
        order: 1;
      {% endif %}
    }

    .ai-youtube-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }

    .ai-youtube-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_font_size_mobile }}px;
    }

    .ai-youtube-play-button-{{ ai_gen_id }} {
      width: calc({{ block.settings.play_button_size }}px * 0.8);
      height: calc({{ block.settings.play_button_size }}px * 0.8);
    }

    .ai-youtube-play-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.play_button_size }}px * 0.32);
      height: calc({{ block.settings.play_button_size }}px * 0.32);
      margin-left: calc({{ block.settings.play_button_size }}px * 0.04);
    }
  }
{% endstyle %}

<youtube-video-{{ ai_gen_id }} class="ai-youtube-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-youtube-container-{{ ai_gen_id }}">
    <div class="ai-youtube-wrapper-{{ ai_gen_id }}">
      <div class="ai-youtube-text-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-youtube-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <div class="ai-youtube-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
      </div>

      <div class="ai-youtube-video-container-{{ ai_gen_id }}">
        {% liquid
          assign desktop_video_url = block.settings.youtube_url
          assign mobile_video_url = block.settings.youtube_url_mobile
          
          if mobile_video_url == blank
            assign mobile_video_url = desktop_video_url
          endif

          assign desktop_video_id = ''
          assign mobile_video_id = ''

          if desktop_video_url contains 'youtube.com/watch?v='
            assign desktop_video_id = desktop_video_url | split: 'watch?v=' | last | split: '&' | first
          elsif desktop_video_url contains 'youtu.be/'
            assign desktop_video_id = desktop_video_url | split: 'youtu.be/' | last | split: '?' | first
          endif

          if mobile_video_url contains 'youtube.com/watch?v='
            assign mobile_video_id = mobile_video_url | split: 'watch?v=' | last | split: '&' | first
          elsif mobile_video_url contains 'youtu.be/'
            assign mobile_video_id = mobile_video_url | split: 'youtu.be/' | last | split: '?' | first
          endif

          assign use_custom_cover_desktop = false
          assign use_custom_cover_mobile = false

          if block.settings.cover_image_desktop != blank
            assign use_custom_cover_desktop = true
          endif

          if block.settings.cover_image_mobile != blank
            assign use_custom_cover_mobile = true
          endif
        %}

        <div class="ai-youtube-video-wrapper-{{ ai_gen_id }}">
          {% if use_custom_cover_desktop %}
            <img
              class="ai-youtube-thumbnail-{{ ai_gen_id }} ai-youtube-thumbnail-desktop-{{ ai_gen_id }}"
              src="{{ block.settings.cover_image_desktop | image_url: width: 1920 }}"
              alt="{{ block.settings.cover_image_desktop.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.cover_image_desktop.width }}"
              height="{{ block.settings.cover_image_desktop.height }}"
              data-video-id="{{ desktop_video_id }}"
            >
          {% elsif desktop_video_id != blank %}
            <img
              class="ai-youtube-thumbnail-{{ ai_gen_id }} ai-youtube-thumbnail-desktop-{{ ai_gen_id }}"
              src="https://img.youtube.com/vi/{{ desktop_video_id }}/maxresdefault.jpg"
              alt="Video thumbnail"
              loading="lazy"
              data-video-id="{{ desktop_video_id }}"
            >
          {% endif %}

          {% if use_custom_cover_mobile %}
            <img
              class="ai-youtube-thumbnail-{{ ai_gen_id }} ai-youtube-thumbnail-mobile-{{ ai_gen_id }} ai-youtube-hidden-{{ ai_gen_id }}"
              src="{{ block.settings.cover_image_mobile | image_url: width: 1000 }}"
              alt="{{ block.settings.cover_image_mobile.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.cover_image_mobile.width }}"
              height="{{ block.settings.cover_image_mobile.height }}"
              data-video-id="{{ mobile_video_id }}"
            >
          {% elsif mobile_video_id != blank and mobile_video_id != desktop_video_id %}
            <img
              class="ai-youtube-thumbnail-{{ ai_gen_id }} ai-youtube-thumbnail-mobile-{{ ai_gen_id }} ai-youtube-hidden-{{ ai_gen_id }}"
              src="https://img.youtube.com/vi/{{ mobile_video_id }}/maxresdefault.jpg"
              alt="Video thumbnail"
              loading="lazy"
              data-video-id="{{ mobile_video_id }}"
            >
          {% endif %}

          <button
            class="ai-youtube-play-button-{{ ai_gen_id }}"
            aria-label="Play video"
          >
            <svg
              class="ai-youtube-play-icon-{{ ai_gen_id }}"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>

          <iframe
            class="ai-youtube-video-{{ ai_gen_id }} ai-youtube-hidden-{{ ai_gen_id }}"
            src=""
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</youtube-video-{{ ai_gen_id }}>

<script>
  (function() {
    class YoutubeVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.playButton = this.querySelector('.ai-youtube-play-button-{{ ai_gen_id }}');
        this.iframe = this.querySelector('.ai-youtube-video-{{ ai_gen_id }}');
        this.thumbnailDesktop = this.querySelector('.ai-youtube-thumbnail-desktop-{{ ai_gen_id }}');
        this.thumbnailMobile = this.querySelector('.ai-youtube-thumbnail-mobile-{{ ai_gen_id }}');
        this.currentThumbnail = null;
      }

      connectedCallback() {
        this.updateThumbnail();
        window.addEventListener('resize', () => this.updateThumbnail());
        
        if (this.playButton) {
          this.playButton.addEventListener('click', () => this.playVideo());
        }

        if (this.thumbnailDesktop) {
          this.thumbnailDesktop.addEventListener('click', () => this.playVideo());
        }

        if (this.thumbnailMobile) {
          this.thumbnailMobile.addEventListener('click', () => this.playVideo());
        }
      }

      updateThumbnail() {
        const isMobile = window.innerWidth < 750;
        
        if (isMobile && this.thumbnailMobile) {
          if (this.thumbnailDesktop) {
            this.thumbnailDesktop.classList.add('ai-youtube-hidden-{{ ai_gen_id }}');
          }
          this.thumbnailMobile.classList.remove('ai-youtube-hidden-{{ ai_gen_id }}');
          this.currentThumbnail = this.thumbnailMobile;
        } else {
          if (this.thumbnailDesktop) {
            this.thumbnailDesktop.classList.remove('ai-youtube-hidden-{{ ai_gen_id }}');
            this.currentThumbnail = this.thumbnailDesktop;
          }
          if (this.thumbnailMobile) {
            this.thumbnailMobile.classList.add('ai-youtube-hidden-{{ ai_gen_id }}');
          }
        }
      }

      playVideo() {
        if (!this.currentThumbnail || !this.iframe) return;

        const videoId = this.currentThumbnail.dataset.videoId;
        if (!videoId) return;

        this.iframe.src = 'https://www.youtube.com/embed/' + videoId + '?autoplay=1&mute=0';
        
        if (this.thumbnailDesktop) {
          this.thumbnailDesktop.classList.add('ai-youtube-hidden-{{ ai_gen_id }}');
        }
        if (this.thumbnailMobile) {
          this.thumbnailMobile.classList.add('ai-youtube-hidden-{{ ai_gen_id }}');
        }
        if (this.playButton) {
          this.playButton.classList.add('ai-youtube-hidden-{{ ai_gen_id }}');
        }
        this.iframe.classList.remove('ai-youtube-hidden-{{ ai_gen_id }}');
      }
    }

    customElements.define('youtube-video-{{ ai_gen_id }}', YoutubeVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "YouTube video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "YouTube URL",
      "info": "Enter the full YouTube URL (e.g., https://www.youtube.com/watch?v=VIDEO_ID)"
    },
    {
      "type": "text",
      "id": "youtube_url_mobile",
      "label": "YouTube URL for mobile",
      "info": "Optional: Use a different video on mobile devices"
    },
    {
      "type": "header",
      "content": "Cover images"
    },
    {
      "type": "image_picker",
      "id": "cover_image_desktop",
      "label": "Cover image for desktop",
      "info": "Optional: Use a custom cover image instead of YouTube thumbnail"
    },
    {
      "type": "image_picker",
      "id": "cover_image_mobile",
      "label": "Cover image for mobile",
      "info": "Optional: Use a custom cover image for mobile"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Watch our story"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#171717"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Discover what makes us different and why our customers love what we do.</p>"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#171717"
    },
    {
      "type": "header",
      "content": "Text size on desktop"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "label": "Heading size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "subheading_font_size_desktop",
      "label": "Subheading size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Text size on mobile"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheading_font_size_mobile",
      "label": "Subheading size",
      "min": 12,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout on desktop"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        {
          "value": "full",
          "label": "Full width"
        },
        {
          "value": "narrow",
          "label": "Narrow"
        }
      ],
      "default": "full"
    },
    {
      "type": "select",
      "id": "text_position_desktop",
      "label": "Text position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_alignment_desktop",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout on mobile"
