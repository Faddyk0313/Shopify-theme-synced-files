{% doc %}
  @prompt
    EVENT CALENDAR BOX STYLE , WITH THE NAME AND DATE OF THE EVENT INSIDE THE BOX OF EACH DATE AND A BUTTON TO LEARN MORE
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-event-calendar-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-event-calendar__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-event-calendar__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 40px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-event-calendar__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-event-calendar__event-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-event-calendar__event-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-event-calendar__date-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.date_box_background }};
    color: {{ block.settings.date_box_text_color }};
    border-radius: {{ block.settings.date_box_border_radius }}px;
    padding: 16px;
    text-align: center;
    min-height: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .ai-event-calendar__day-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    line-height: 1;
    margin: 0;
  }

  .ai-event-calendar__month-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 4px 0 0;
  }

  .ai-event-calendar__event-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.event_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.event_name_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-event-calendar__event-time-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.event_time_color }};
    margin: 0;
  }

  .ai-event-calendar__event-description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.event_description_color }};
    line-height: 1.5;
    margin: 0;
    flex-grow: 1;
  }

  .ai-event-calendar__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    transition: background-color 0.3s ease;
  }

  .ai-event-calendar__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-event-calendar__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-event-calendar__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-event-calendar__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-event-calendar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-event-calendar__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-event-calendar__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% assign has_events = false %}
    {% for i in (1..6) %}
      {% assign event_enabled_key = 'event_' | append: i | append: '_enabled' %}
      {% if block.settings[event_enabled_key] %}
        {% assign has_events = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% if has_events %}
      <div class="ai-event-calendar__grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign event_enabled_key = 'event_' | append: i | append: '_enabled'
            assign event_name_key = 'event_' | append: i | append: '_name'
            assign event_date_key = 'event_' | append: i | append: '_date'
            assign event_time_key = 'event_' | append: i | append: '_time'
            assign event_description_key = 'event_' | append: i | append: '_description'
            assign event_link_key = 'event_' | append: i | append: '_link'

            assign event_enabled = block.settings[event_enabled_key]
            assign event_name = block.settings[event_name_key]
            assign event_date = block.settings[event_date_key]
            assign event_time = block.settings[event_time_key]
            assign event_description = block.settings[event_description_key]
            assign event_link = block.settings[event_link_key]
          %}

          {% if event_enabled %}
            <div class="ai-event-calendar__event-{{ ai_gen_id }}">
              <div class="ai-event-calendar__date-box-{{ ai_gen_id }}">
                {% if event_date != blank %}
                  {% assign date_parts = event_date | split: '-' %}
                  {% assign year = date_parts[0] %}
                  {% assign month = date_parts[1] %}
                  {% assign day = date_parts[2] %}
                  
                  <div class="ai-event-calendar__day-{{ ai_gen_id }}">{{ day | plus: 0 }}</div>
                  
                  {% case month %}
                    {% when '01' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Jan</div>
                    {% when '02' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Feb</div>
                    {% when '03' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Mar</div>
                    {% when '04' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Apr</div>
                    {% when '05' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">May</div>
                    {% when '06' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Jun</div>
                    {% when '07' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Jul</div>
                    {% when '08' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Aug</div>
                    {% when '09' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Sep</div>
                    {% when '10' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Oct</div>
                    {% when '11' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Nov</div>
                    {% when '12' %}
                      <div class="ai-event-calendar__month-{{ ai_gen_id }}">Dec</div>
                  {% endcase %}
                {% else %}
                  <div class="ai-event-calendar__day-{{ ai_gen_id }}">--</div>
                  <div class="ai-event-calendar__month-{{ ai_gen_id }}">---</div>
                {% endif %}
              </div>

              {% if event_name != blank %}
                <h3 class="ai-event-calendar__event-name-{{ ai_gen_id }}">{{ event_name }}</h3>
              {% endif %}

              {% if event_time != blank %}
                <p class="ai-event-calendar__event-time-{{ ai_gen_id }}">{{ event_time }}</p>
              {% endif %}

              {% if event_description != blank %}
                <p class="ai-event-calendar__event-description-{{ ai_gen_id }}">{{ event_description }}</p>
              {% endif %}

              {% if event_link != blank %}
                <a href="{{ event_link }}" class="ai-event-calendar__button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-event-calendar__empty-state-{{ ai_gen_id }}">
        Next, enable and configure your events
      </div>
    {% endif %}
  </div>
</div>

