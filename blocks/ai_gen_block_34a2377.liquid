    {
      "type": "range",
      "id": "text_size",
      "label": "Promo text size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "label": "Mobile promo text size",
      "min": 13,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_button_text_size",
      "label": "Mobile button text size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
