{% doc %}
  @prompt
    Generate a section that displays 16:9 aspect ratio videos in a carousel/slider layout. The videos should be able to be chosen from library.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-video-carousel__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-video-carousel__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
  }

  .ai-video-carousel__slide-{{ ai_gen_id }} {
    min-width: 100%;
    position: relative;
    aspect-ratio: 16 / 9;
    background-color: #000000;
  }

  .ai-video-carousel__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
    fill: #ffffff;
  }

  .ai-video-carousel__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: #ffffff;
    font-size: 14px;
    text-align: center;
    opacity: 0.7;
  }

  .ai-video-carousel__controls-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 {{ block.settings.control_padding }}px;
    pointer-events: none;
  }

  .ai-video-carousel__button-{{ ai_gen_id }} {
    width: {{ block.settings.control_size }}px;
    height: {{ block.settings.control_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.control_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
    transition: opacity 0.3s ease, transform 0.3s ease;
    opacity: {{ block.settings.control_opacity | divided_by: 100.0 }};
  }

  .ai-video-carousel__button-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .ai-video-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-video-carousel__button-{{ ai_gen_id }}:disabled:hover {
    transform: scale(1);
  }

  .ai-video-carousel__button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.control_size }}px * 0.5);
    height: calc({{ block.settings.control_size }}px * 0.5);
    fill: {{ block.settings.control_color }};
  }

  .ai-video-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .ai-video-carousel__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    opacity: 0.4;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-video-carousel__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-video-carousel__dot-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .ai-video-carousel__controls-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.control_padding | times: 0.5 }}px;
    }

    .ai-video-carousel__button-{{ ai_gen_id }} {
      width: {{ block.settings.control_size | times: 0.8 }}px;
      height: {{ block.settings.control_size | times: 0.8 }}px;
    }

    .ai-video-carousel__button-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.control_size | times: 0.8 }}px * 0.5);
      height: calc({{ block.settings.control_size | times: 0.8 }}px * 0.5);
    }
  }
{% endstyle %}

<video-carousel-{{ ai_gen_id }} class="ai-video-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-carousel__container-{{ ai_gen_id }}">
    <div class="ai-video-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign video = block.settings[video_key]
        %}

        {% if video != blank %}
          <div class="ai-video-carousel__slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
            {{
              video
              | video_tag:
                image_size: '1920x',
                autoplay: block.settings.autoplay,
                loop: block.settings.loop,
                controls: block.settings.show_controls,
                muted: block.settings.muted,
                class: 'ai-video-carousel__video-' | append: ai_gen_id
            }}
          </div>
        {% endif %}
      {% endfor %}

      {% assign has_videos = false %}
      {% for i in (1..8) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign video = block.settings[video_key]
        %}
        {% if video != blank %}
          {% assign has_videos = true %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% unless has_videos %}
        <div class="ai-video-carousel__slide-{{ ai_gen_id }}">
          <div class="ai-video-carousel__placeholder-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <div class="ai-video-carousel__empty-state-{{ ai_gen_id }}">
              Next, add videos from your library
            </div>
          </div>
        </div>
      {% endunless %}
    </div>

    {% if has_videos %}
      <div class="ai-video-carousel__controls-{{ ai_gen_id }}">
        <button
          class="ai-video-carousel__button-{{ ai_gen_id }} ai-video-carousel__prev-{{ ai_gen_id }}"
          aria-label="Previous video"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
          </svg>
        </button>
        <button
          class="ai-video-carousel__button-{{ ai_gen_id }} ai-video-carousel__next-{{ ai_gen_id }}"
          aria-label="Next video"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
          </svg>
        </button>
      </div>

      <div class="ai-video-carousel__dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</video-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-video-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-video-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-video-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-video-carousel__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-video-carousel__dots-{{ ai_gen_id }}');

        if (this.slides.length <= 1) return;

        this.createDots();
        this.setupEventListeners();
        this.updateCarousel();

        {% if block.settings.auto_rotate %}
          this.startAutoplay();
        {% endif %}
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-video-carousel__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to video ${index + 1}`);
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });

        this.dots = this.querySelectorAll('.ai-video-carousel__dot-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.auto_rotate %}
            this.startAutoplay();
          {% endif %}
        });

        let touchStartX = 0;
        let touchEndX = 0;

        this.track.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.track.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.next();
          } else {
            this.prev();
          }
        }
      }

      prev() {
        this.currentIndex = this.currentIndex > 0 ? this.currentIndex - 1 : this.slides.length - 1;
        this.updateCarousel();
        this.resetAutoplay();
      }

      next() {
        this.currentIndex = this.currentIndex < this.slides.length - 1 ? this.currentIndex + 1 : 0;
        this.updateCarousel();
        this.resetAutoplay();
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
        this.resetAutoplay();
      }

      updateCarousel() {
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        if (this.prevButton) {
          this.prevButton.disabled = false;
        }

        if (this.nextButton) {
          this.nextButton.disabled = false;
        }

        if (this.dots) {
          this.dots.forEach((dot, index) => {
            dot.classList.toggle('active', index === this.currentIndex);
          });
        }

        this.pauseAllVideos();
        const currentVideo = this.slides[this.currentIndex].querySelector('video');
        if (currentVideo && {{ block.settings.autoplay }}) {
          currentVideo.play();
        }
      }

      pauseAllVideos() {
        this.slides.forEach(slide => {
          const video = slide.querySelector('video');
          if (video) {
            video.pause();
          }
        });
      }

      startAutoplay() {
        {% if block.settings.auto_rotate %}
          this.stopAutoplay();
          this.autoplayInterval = setInterval(() => {
            this.next();
          }, {{ block.settings.rotate_interval }} * 1000);
        {% endif %}
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        {% if block.settings.auto_rotate %}
          this.stopAutoplay();
          this.startAutoplay();
        {% endif %}
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('video-carousel-{{ ai_gen_id }}', VideoCarousel{{ ai_gen_id }});
  })();
</script>

