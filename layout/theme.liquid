          min-height: 70vh;
        }

        .shopify-policy__body iframe,
        .page iframe {
          min-height: 70vh;
          width: 100%;
          display: block;
        }

        .page [id*="locator"],
        .page [class*="locator"] {
          min-height: 70vh;
        }
