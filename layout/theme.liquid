              margin: 0 auto 20px auto;
            "
          ></div>
          Reloading...
        </div>
      </div>

      <script>
        // Declare protection interval globally so it can be accessed everywhere
        let protectionInterval;

        document.addEventListener('DOMContentLoaded', function () {
          const modal = document.getElementById('warningMsg');

          // --- Check if URL has discount hash or parameter ---
          const urlParams = new URLSearchParams(window.location.search);
          const hasDiscountParam = urlParams.get('discountApplied') === 'true';
          const hasDiscountHash =
            window.location.hash === '#discountApplied=true' || window.location.hash === '#discount-applied';

          // If no discount parameter or hash, don't show modal
          if (!hasDiscountParam && !hasDiscountHash) {
            return;
          }

          // --- Early exit if form already submitted this session ---
          const formSubmitted = localStorage.getItem('klaviyo_home_form_submitted');
          if (formSubmitted === 'true') {
            return;
          }

          // --- Show modal since conditions are met ---
          if (modal) {
            modal.removeAttribute('hidden');
            modal.setAttribute('active', '');
          }

          // DOM Protection: Reload if modal is removed illegitimately
          protectionInterval = setInterval(() => {
            const modalExists = document.getElementById('warningMsg');
            const isFormSubmitted = localStorage.getItem('klaviyo_home_form_submitted') === 'true';

            if (!modalExists && !isFormSubmitted) {
              const protectionOverlay = document.getElementById('protectionOverlay');
              if (protectionOverlay) {
                protectionOverlay.style.display = 'flex';
                protectionOverlay.offsetHeight; // Force repaint
              }

              clearInterval(protectionInterval);
              location.reload();
            }
          }, 100);

          // Fetch discount code from Shopify cart
          let appliedDiscountCode = '';

          async function getAppliedDiscountCode() {
            try {
              const response = await fetch('/cart.js');
              const cart = await response.json();

              // Check for applied discount code
              if (cart.cart_level_discount_applications && cart.cart_level_discount_applications.length > 0) {
                appliedDiscountCode = cart.cart_level_discount_applications[0].title;
              } else if (cart.discount_codes && cart.discount_codes.length > 0) {
                const discountData = cart.discount_codes[0];
                // discount_codes can be an object with 'code' property or just a string
                appliedDiscountCode = typeof discountData === 'object' ? discountData.code : discountData;
              }

              return appliedDiscountCode;
            } catch (error) {
              console.error('Error fetching cart:', error);
              return '';
            }
          }

          // Get discount code before monitoring form
          getAppliedDiscountCode().then(() => {
            monitorKlaviyoForm();
          });

          // Fill the team input in the 3rd form row
          function fillTeamInput(scope) {
            const root = scope || document;
            const teamInput = root.querySelector('div[data-testid="form-row"]:nth-of-type(3) input');
            if (teamInput && !teamInput.__tbg_filled) {
              const val = appliedDiscountCode || 'No discount applied';
              teamInput.value = val;
              teamInput.setAttribute('value', val);
              // Dispatch events so Klaviyo registers the value
              teamInput.dispatchEvent(new Event('input', { bubbles: true }));
              teamInput.dispatchEvent(new Event('change', { bubbles: true }));
              teamInput.__tbg_filled = true;
            }
          }

          function monitorKlaviyoForm() {
            const formContainer = document.querySelector('.klaviyo-form-XGjnGj');
            const loader = document.getElementById('klaviyo-loader');
            if (!formContainer) return;

            let formWasLoaded = false;
            let previousContent = '';

            function checkFormStatus() {
              const currentContent = formContainer.innerHTML.trim();
              const isEmpty = currentContent === '';
              const hasContent = !isEmpty;

              // Hide loader once content appears and fill team input
              if (hasContent && !formWasLoaded) {
                formWasLoaded = true;
                if (loader) loader.classList.add('hidden');
                fillTeamInput(formContainer);
              }

              if (formWasLoaded) {
                const hasFormTag = formContainer.querySelector('form');
                const hasInputs = formContainer.querySelector('input');
                const noFormElements = !hasFormTag || !hasInputs;
                const contentReduced = currentContent.length < 200 && previousContent.length > 1000;

                const modalStillExists = document.getElementById('warningMsg');

                if ((isEmpty || noFormElements || contentReduced) && modalStillExists) {
                  localStorage.setItem('klaviyo_home_form_submitted', 'true');
                  if (modal) {
                    modal.removeAttribute('active');
                    modal.style.display = 'none';
                    modal.setAttribute('hidden', '');
                  }
                  clearInterval(protectionInterval);
                  clearInterval(interval);
                  observer.disconnect();
                }
              }

              previousContent = currentContent;
            }

            // Poll every 500ms
            const interval = setInterval(() => {
              fillTeamInput(formContainer);
              checkFormStatus();
            }, 500);

            // Observe dynamic injections
            const observer = new MutationObserver(() => {
              fillTeamInput(formContainer);
              checkFormStatus();
            });
            observer.observe(formContainer, { childList: true, subtree: true, attributes: true });

            fillTeamInput(formContainer);
            checkFormStatus();
          }
        });
      </script>
    {% endif %}

   
    {% if page.handle == 'loyalty-program' %}
      <script>
        document.addEventListener('DOMContentLoaded', function () {
          try {
            var params = new URLSearchParams(window.location.search);
            if (params.get('cus_scroll') !== 'true') return;
            var selector = '#shopify-section-template--20096522387634__1736868115d3f15627';
            var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            var behavior = prefersReduced ? 'auto' : 'smooth';
            var mobileFixedTop = window.matchMedia('(max-width: 767px)').matches ? 3800 : null;
            var start = Date.now();
            var maxWaitMs = 100;

            function alignTarget(target) {
              var endTime = Date.now() + 100;
              var firstScroll = true;
              function keepAligning() {
                if (!document.body.contains(target) || Date.now() > endTime) return;
                var currentBehavior = firstScroll ? behavior : 'auto';
                firstScroll = false;
                if (mobileFixedTop !== null) {
                  if (Math.abs(window.scrollY - mobileFixedTop) <= 1) return;
                  window.scrollTo({ top: mobileFixedTop, behavior: currentBehavior });
                } else {
                  var rectTop = target.getBoundingClientRect().top;
                  if (Math.abs(rectTop) <= 1) return;
                  var scrollTop = window.scrollY + rectTop;
                  window.scrollTo({ top: scrollTop, behavior: currentBehavior });
                }
                window.setTimeout(keepAligning, 120);
              }
              keepAligning();
            }

            function waitForTarget() {
              var target = document.querySelector(selector);
              if (target) {
                alignTarget(target);
                return;
              }
              if (Date.now() - start < maxWaitMs) {
                window.setTimeout(waitForTarget, 120);
              }
            }

            waitForTarget();
          } catch (e) {
            return;
          }
        });
      </script>
