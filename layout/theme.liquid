    {%- if request.page_type == 'policy' -%}
      <style>
        .shopify-policy__title {
          font-size: var(--text-h2);
          line-height: 1.3;
          font-family: var(--font-heading-family);
          font-style: var(--font-heading-style);
          font-weight: var(--font-heading-weight);
          letter-spacing: var(--font-heading-letter-spacing);
          text-transform: var(--font-heading-text-transform);
        }

        .shopify-policy__body .rte {
          font-size: var(--text-base);
          line-height: 1.6;
        }
      </style>
      <script>
        document.addEventListener('DOMContentLoaded', function () {
          var policyBody = document.querySelector('.shopify-policy__body');
          if (!policyBody) return;

          policyBody.querySelectorAll('a:not([href])').forEach(function (anchor) {
            var replacement = document.createElement('span');

            Array.from(anchor.attributes).forEach(function (attr) {
              replacement.setAttribute(attr.name, attr.value);
            });

            replacement.removeAttribute('role');
            replacement.innerHTML = anchor.innerHTML;
            anchor.replaceWith(replacement);
          });
        });
      </script>
    {%- endif -%}

