        window.addEventListener('load', function () {
          runWhenIdle(loadDeferredTrackers);
        });
      })();
    </script>

    <script>
      // TBG Custom Code
      (function () {
        function runWhenIdle(callback) {
          if ('requestIdleCallback' in window) {
            requestIdleCallback(callback, { timeout: 2500 });
            return;
          }
          setTimeout(callback, 1200);
        }

        async function syncAmbassadorCode() {
        try {
          if (sessionStorage.getItem('tbg_amb_sync_done') === '1') return;
          const res = await fetch('/cart.js');
          const cart = await res.json();

          const ambCodes = (cart.discount_codes || [])
            .filter(dc => dc.code && dc.code.startsWith('AMB-'));

          if (!ambCodes.length) {
            sessionStorage.setItem('tbg_amb_sync_done', '1');
            return;
          }

          const ambCode = ambCodes[ambCodes.length - 1].code;
          const existingCode = cart.attributes && cart.attributes.tbg_ambassador_code;

          if (existingCode === ambCode) {
            sessionStorage.setItem('tbg_amb_sync_done', '1');
            return;
          }

          await fetch('/cart/update.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              attributes: {
                tbg_ambassador_code: ambCode
              }
            })
          });
          sessionStorage.setItem('tbg_amb_sync_done', '1');

        } catch (e) {
          // fail silently
        }
        }

        window.addEventListener('load', function () {
          runWhenIdle(syncAmbassadorCode);
        });
      })();
      // End TBG Custom Code
    </script>


    <script>
      // POSTHOG METRIC: Track product card link clicks
      document.addEventListener('click', function(e) {  
        if (e.target.closest('.template-collection .pdpPageLink') && window.posthog && typeof window.posthog.capture === 'function') {  
          posthog.capture('Product Card Clicked on PLP', {  
            page_type: 'collection'  
          });  
        }  
      });  
    </script>

    <script>
      // Posthog Metric : Track dynamic checkout wallet interactions on PDP.
      (() => {
        if (window.__dynamicCheckoutPosthogTrackerInitialized) return;
        window.__dynamicCheckoutPosthogTrackerInitialized = true;

        var lastTrackedInteraction = {
          type: '',
          timestamp: 0
        };

        function normalizeWalletType(rawValue) {
          var value = (rawValue || '').toLowerCase();
          if (!value) return 'unknown';
          if (value.indexOf('shop') > -1) return 'shop_pay';
          if (value.indexOf('apple') > -1) return 'apple_pay';
          if (value.indexOf('google') > -1 || value.indexOf('g pay') > -1 || value.indexOf('gpay') > -1) return 'google_pay';
          if (value.indexOf('paypal') > -1 || value.indexOf('pay pal') > -1) return 'paypal';
          if (value.indexOf('buy it now') > -1) return 'buy_it_now';
          if (value.indexOf('pay') > -1) return 'other';
          return 'unknown';
        }

        function getEventPath(event) {
          if (event && typeof event.composedPath === 'function') {
            return event.composedPath();
          }

          var path = [];
          var node = event && event.target;
          while (node) {
            path.push(node);
            node = node.parentNode;
          }
          path.push(window);
          return path;
        }

        function isElement(node) {
          return node && node.nodeType === 1;
        }

        function getAttr(node, name) {
          return isElement(node) && typeof node.getAttribute === 'function' ? node.getAttribute(name) : '';
        }

        function findDynamicCheckoutRoot(path) {
          for (var i = 0; i < path.length; i += 1) {
            var node = path[i];
            if (!isElement(node)) continue;
            if (node.matches && node.matches('.shopify-payment-button')) {
              return node;
            }
          }

          return null;
        }

        function detectWalletInfo(path, dynamicCheckoutRoot) {
          for (var i = 0; i < path.length; i += 1) {
            var node = path[i];
            if (!isElement(node)) continue;

            var tagName = (node.tagName || '').toLowerCase();
            if (
              tagName === 'shop-pay-wallet-button' ||
              tagName === 'apple-pay-button' ||
              tagName === 'google-pay-button' ||
              tagName === 'paypal-button'
            ) {
              return { raw: tagName, type: normalizeWalletType(tagName) };
            }

            var attrCandidates = [
              getAttr(node, 'aria-label'),
              getAttr(node, 'data-testid'),
              getAttr(node, 'name'),
              getAttr(node, 'wallet-instrument-name'),
              getAttr(node, 'call-to-action'),
              getAttr(node, 'recommended'),
              getAttr(node, 'fallback')
            ];

            for (var j = 0; j < attrCandidates.length; j += 1) {
              var attrValue = attrCandidates[j];
              var attrType = normalizeWalletType(attrValue);
              if (attrType !== 'unknown') {
                return { raw: attrValue, type: attrType };
              }
            }
          }

          var checkoutText = dynamicCheckoutRoot && dynamicCheckoutRoot.innerText ? dynamicCheckoutRoot.innerText.trim() : '';
          if (checkoutText) {
            var textType = normalizeWalletType(checkoutText);
            if (textType !== 'unknown') return { raw: checkoutText, type: textType };
          }

          return { raw: 'unknown', type: 'unknown' };
        }

        function trackDynamicCheckoutInteraction(event) {
          if (!window.posthog || typeof window.posthog.capture !== 'function') return;

          var path = getEventPath(event);
          var dynamicCheckoutRoot = findDynamicCheckoutRoot(path);
          if (!dynamicCheckoutRoot) return;

          var walletInfo = detectWalletInfo(path, dynamicCheckoutRoot);
          var now = Date.now();

          if (lastTrackedInteraction.type === walletInfo.type && now - lastTrackedInteraction.timestamp < 1000) {
            return;
          }

          lastTrackedInteraction.type = walletInfo.type;
          lastTrackedInteraction.timestamp = now;

          window.posthog.capture('Dynamic Checkout Clicked on PDP', {
            page_type: 'product',
            wallet_type: walletInfo.type,
            wallet_label_raw: walletInfo.raw,
            interaction_event: event.type
          });
        }

        document.addEventListener('pointerdown', trackDynamicCheckoutInteraction, true);
        document.addEventListener('click', trackDynamicCheckoutInteraction, true);
      })();
    </script>
    
    {%- if request.design_mode == false and settings.preload_links -%}
      <script src="{{ 'instant-page.js' | asset_url }}" type="module" fetchpriority="low" defer="defer"></script>
    {%- endif -%}
  </body>
</html>
