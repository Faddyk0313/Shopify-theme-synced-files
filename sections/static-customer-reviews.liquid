<div id="sliders-container" class="">
  {% assign last_outer = headings.size | minus: 1 %} {% assign total_cards =
  product_titles.size | minus: 1 %} {% for i in (0..last_outer) %}
  <section class="py-20">
    <!-- Stars, Heading, description -->
    <div class="max-w-6xl mx-auto text-center px-[20px]">
      <div class="flex justify-center mb-4 space-x-2">
        {% for i in (1..5) %}
        <img
          src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/pointed-star.png?v=1745741039"
          alt="Pointed Star"
          class="w-10 h-10"
        />
        {% endfor %}
      </div>
      <h2 class="text-3xl sm:text-4xl font-semibold mb-2">{{ headings[i] }}</h2>
      <p class="text-sm text-gray-700 mb-6">{{ descriptions[i] }}</p>
    </div>

    <!-- Videos Carousel -->
    {% assign section_video_links = video_groups_raw[i] | split: "|" %} {% if
    section_video_links.size > 0 %}
    <div class="swiper video-swiper px-[20px] md:px-[30px]">
      <div class="slider-wrapper videos videos-wrapper my-5">
        <div class="mb-5 swiper-wrapper">
          {% for link in section_video_links %}
          {% assign video_url = link | strip %}
          {% assign clean_video_url = video_url | split: "?" | first %}
          {% assign video_id = "" %}
          {% if video_url contains "/embed/" %}
          {% assign video_id = clean_video_url | split: "/embed/" | last | split: "/" | first %}
          {% elsif video_url contains "/shorts/" %}
          {% assign video_id = clean_video_url | split: "/shorts/" | last | split: "/" | first %}
          {% elsif video_url contains "/live/" %}
          {% assign video_id = clean_video_url | split: "/live/" | last | split: "/" | first %}
          {% elsif video_url contains "youtu.be/" %}
          {% assign video_id = clean_video_url | split: "youtu.be/" | last | split: "/" | first %}
          {% elsif video_url contains "v=" %}
          {% assign video_id = video_url | split: "v=" | last | split: "&" | first %}
          {% endif %}
          {% if video_id != blank %}
          {% assign embed_url = "https://www.youtube.com/embed/" | append: video_id %}
          {% else %}
          {% assign embed_url = video_url %}
          {% endif %}
          {% if embed_url != blank %}
          <iframe
            class="min-h-[454px] swiper-slide w-full aspect-video rounded-2xl"
            src="{{ embed_url }}"
            frameborder="0"
            allowfullscreen
          ></iframe>
          {% endif %}
          {% endfor %}
        </div>
        <div class="swiper-pagination"></div>
        <div
          class="swiper-slide-button swiper-button-prev text-black !absolute !inset-auto !bottom-0 !left-[40px]"
        >
          {%- render 'icon', icon: 'arrow-left-long', class: 'transform' -%}
        </div>
        <div
          class="swiper-slide-button swiper-button-next text-black !absolute !inset-auto !bottom-0 !right-[40px]"
        >
          {%- render 'icon', icon: 'arrow-right-long', class: 'transform' -%}
        </div>
      </div>
    </div>
    {% endif %}

    <!-- Cards Carousel -->
    <div class="swiper px-[20px] md:px-[30px]">
      <div class="slider-wrapper cards my-5">
        <div class="mb-5 swiper-wrapper">
          <!-- ${reviews
              .map(
                (r) => ` -->
          {% assign starting_card_index = i | times: 3 %} {% assign
          ending_card_index_raw = i | plus: 1 | times: 3 | minus: 1 %} {% assign
          ending_card_index = ending_card_index_raw %} {% if
          ending_card_index_raw > total_cards %} {% assign ending_card_index =
          total_cards %} {% endif %} {% for k in
          (starting_card_index..ending_card_index) %}
          <div
            class="max-h-[300px ] h-[300px] overflow-y-scroll bg-white border border-gray-200 rounded-2xl p-6 text-left shadow-sm swiper-slide"
          >
            <p class="mb-3 text-sm">
              about
              <span class="underline underline-offset-2"
                >{{ product_titles[k] }}</span
              >
            </p>
            <div class="flex justify-between items-center mb-2">
              <div class="flex items-center gap-1">
                {% for i in (1..ratings[k]) %}
                <img
                  src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/pointed-star.png?v=1745741039"
                  alt="Pointed Star"
                  class="w-4 h-4"
                />
                {% endfor %}
              </div>
              <p class="text-[12px] text-gray-500">{{ dates[k] }}</p>
            </div>

            <div class="flex items-center mb-4 gap-2">
              <div class="relative">
                <img
                  src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/user.png?v=1745741939"
                  alt="Profile Icon"
                  class="w-10 h-10 p-[6px] bg-[#efefef] rounded-xl"
                />
                {% if verified[k] %}
                <img
                  src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/check-circle.png?v=1745741991"
                  alt="Verified"
                  class="absolute right-0 bottom-0 w-4 h-4"
                />
                {% endif %}
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <p class="text-sm">
                    {% assign parts = names[k] | split: " " %} {% if parts.size
                    > 1 %} {{ parts[0] }} {{ parts.last | slice: 0,1 }}. {% else
                    %} {{ parts[0] }} {% endif %}
                  </p>
                  {% if verified[k] %}
                  <span
                    class="bg-black text-white text-[11px] px-2 rounded-[5px]"
                    >Verified</span
                  >
                  {% endif %}
                </div>
                <div>
                  <img
                    src="https://judgeme-public-images.imgix.net/judgeme/flags/US.svg"
                    alt="American Flag"
                    class="w-4 h-4 ml-2"
                  />
                </div>
              </div>
            </div>

            <p class="font-bold mb-2">{{ titles[k] }}</p>
            <p style="color: #333333; line-height: 1.5" class="mb-4">
              {{ bodies[k] }}
            </p>
          </div>
          {% endfor %}

          <!-- `
              )
              .join("")} -->
        </div>
        <div class="swiper-pagination"></div>
        <div
          class="swiper-slide-button swiper-button-prev text-black !absolute !inset-auto !bottom-0 !left-[40px]"
        >
          {%- render 'icon', icon: 'arrow-left-long', class: 'transform' -%}
        </div>
        <div
          class="swiper-slide-button swiper-button-next text-black !absolute !inset-auto !bottom-0 !right-[40px]"
        >
          {%- render 'icon', icon: 'arrow-right-long', class: 'transform' -%}
        </div>
      </div>
    </div>
  </section>
  {% endfor %}
</div>

<script defer>
  // TBG Custom Code
  document.addEventListener("DOMContentLoaded", () => {
    const sectionRoot = document.getElementById("shopify-section-{{ section.id }}");
    const container = document.getElementById("sliders-container");

    if (!sectionRoot || !container || sectionRoot.dataset.tbgSwiperLazyInit === "true") return;
    sectionRoot.dataset.tbgSwiperLazyInit = "true";

    function loadSwiperAssets() {
      if (window.__tbgSwiperAssetsPromise) return window.__tbgSwiperAssetsPromise;

      window.__tbgSwiperAssetsPromise = new Promise((resolve, reject) => {
        const cssHref = "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css";
        const jsSrc = "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js";

        const finalize = () => {
          if (window.Swiper) {
            resolve(window.Swiper);
          } else {
            reject(new Error("Swiper failed to initialize"));
          }
        };

        if (!document.querySelector(`link[data-tbg-swiper-css="${cssHref}"]`)) {
          const css = document.createElement("link");
          css.rel = "stylesheet";
          css.href = cssHref;
          css.setAttribute("data-tbg-swiper-css", cssHref);
          document.head.appendChild(css);
        }

        if (window.Swiper) {
          finalize();
          return;
        }

        const existingScript = document.querySelector(`script[data-tbg-swiper-js="${jsSrc}"]`);
        if (existingScript) {
          existingScript.addEventListener("load", finalize, { once: true });
          existingScript.addEventListener("error", reject, { once: true });
          return;
        }

        const script = document.createElement("script");
        script.src = jsSrc;
        script.defer = true;
        script.setAttribute("data-tbg-swiper-js", jsSrc);
        script.addEventListener("load", finalize, { once: true });
        script.addEventListener("error", reject, { once: true });
        document.head.appendChild(script);
      });

      return window.__tbgSwiperAssetsPromise;
    }

    async function initStaticCustomerReviews() {
      await loadSwiperAssets();

      if (container.dataset.tbgSwiperRendered === "true") return;
      container.dataset.tbgSwiperRendered = "true";

    const getYouTubeEmbedUrl = (url) => {
      const value = url.trim();
      const id =
        value.match(/\/embed\/([^?&/]+)/)?.[1] ||
        value.match(/\/shorts\/([^?&/]+)/)?.[1] ||
        value.match(/\/live\/([^?&/]+)/)?.[1] ||
        value.match(/youtu\.be\/([^?&/]+)/)?.[1] ||
        value.match(/[?&]v=([^?&/]+)/)?.[1];

      return id ? `https://www.youtube.com/embed/${id}` : value;
    };

    const parseVideoLinks = (links) =>
      links
        .split(/\r?\n|\|/)
        .map(getYouTubeEmbedUrl)
        .filter(Boolean);

    // 0) Dynamic video links per category
    const videosLinks = {
      Safety: {
        links: parseVideoLinks({{ section.settings.safety_video_links | default: "https://youtube.com/embed/OJ6Q2yBqvZg|https://youtube.com/embed/ZOWaLBbtkr0|https://youtube.com/embed/_PZO1Ve-V9w|https://youtube.com/embed/tie4wG4W9kU" | json }}),
      },
      "Quality & Durability": {
        links: parseVideoLinks({{ section.settings.quality_video_links | default: "https://youtube.com/embed/fWI24iSBg7I?feature=shared|https://youtube.com/embed/3pcaPE19zFc?feature=share|https://youtube.com/embed/6KVh51I0e3M" | json }}),
      },
      "Comfort & Fit": {
        links: parseVideoLinks({{ section.settings.comfort_video_links | default: "https://youtube.com/embed/9TDi4Ylxzzs|https://youtube.com/embed/fuYP4wJsfgk?feature=shared|https://youtube.com/embed/QceW1c_NAwA?feature=shared|https://youtube.com/embed/88PEJh6wWLk?feature=share|https://www.youtube.com/embed/h8x_v8PgqN8?si=busduuEU4dD-vvYZ" | json }}),
      },
      "Style & Color": {
        links: parseVideoLinks({{ section.settings.style_video_links | default: "https://youtube.com/embed/eOWHBducRmk?feature=share|https://youtube.com/embed/-hukY2U-Vic?feature=share|https://youtube.com/embed/HjKNSR0iCs4" | json }}),
      },
      "No Velcro": {
        links: parseVideoLinks({{ section.settings.no_velcro_video_links | default: "https://youtube.com/embed/c3NkJ3ijg3Q?feature=shared|https://youtube.com/embed/M5_NzkX7pXA?feature=shared" | json }}),
      },
      "I Simply Love It": {
        links: parseVideoLinks({{ section.settings.love_it_video_links | default: "https://www.youtube.com/embed/h8x_v8PgqN8?si=busduuEU4dD-vvYZ|https://www.youtube.com/embed/5KJoBB2XAaY" | json }}),
      },
    };

    const sectionInfo = {
      Safety: {
        heading: "Safety Reviews",
        subheading:
          "See how Titan’s built-in, A9 cut-resistant protection gives players peace of mind every time they hit the ice.",
      },
      "Quality & Durability": {
        heading: "Performance, Durability & Quality Reviews",
        subheading:
          "Players talk about how Titan gear holds up under pressure - game after game, season after season.",
      },
      "Comfort & Fit": {
        heading: "Comfort & Fit Reviews",
        subheading:
          "From practice to playoffs, hear how Titan stays comfortable, secure, and distraction-free.",
      },
      "Style & Color": {
        heading: "Style & Color Reviews",
        subheading:
          "Bold colors. Team vibes. Real feedback on how Titan looks and feels out there.",
      },
      "No Velcro": {
        heading: "No Velcro Reviews",
        subheading:
          "No scratchy straps, no shifting collars - just the freedom to focus on the game.",
      },
      "I Simply Love It": {
        heading: "“I Just Love It” Reviews",
        subheading:
          "Sometimes it’s not one thing - it’s everything. These reviews say it all.",
      },
    };

    // 1) Define your exact order:
    const categories = [
      "Safety",
      "Quality & Durability",
      "Comfort & Fit",
      "Style & Color",
      "No Velcro",
      "I Simply Love It",
    ];

    try {
      const res = await fetch(
        "https://hocky-name-generator-seven.vercel.app/api/reviews"
      );
      const { groupedReviews } = await res.json();

      const restEntries = Object.entries(groupedReviews).slice(1);
      // (optionally) sort restEntries here…
      const restObj = Object.fromEntries(restEntries);

      await new Promise((resolve) => setTimeout(resolve, 1000));

      container.innerHTML = "";

      categories.forEach((category) => {
        const reviews = restObj[category] || [];
        // 1) Category section
        const section = document.createElement("section");
        section.className = "py-20";

        // 1) Stars + heading
        section.innerHTML = `
                <div class="max-w-6xl mx-auto text-center px-[20px]">
                    <div class="flex justify-center mb-4 space-x-2">
                        ${Array.from({ length: 5 })
                          .map(
                            () => `
                            <img src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/pointed-star.png?v=1745741039"
                                 alt="Pointed Star" class="w-10 h-10">
                        `
                          )
                          .join("")}
                    </div>
                    <h2 class="text-3xl sm:text-4xl font-semibold mb-2">
                        ${sectionInfo[category].heading}
                    </h2>
                    <p class="text-sm text-gray-700 mb-6">
                    ${sectionInfo[category].subheading}
                    </p>
                </div>
            `.trim();

        // 2) --- Video carousel ---
        if (videosLinks[category].links.length > 0) {
          const videoSwiper = document.createElement("div");
          videoSwiper.className = "swiper video-swiper px-[20px] md:px-[30px]";
          videoSwiper.innerHTML = `
                      <div class="slider-wrapper videos videos-wrapper  my-5 ">
                          <div class="mb-5 swiper-wrapper">
                              ${videosLinks[category].links
                                .map(
                                  (link) => ` 
                                  <iframe class="min-h-[454px]  swiper-slide w-full aspect-video rounded-2xl"
                                          src="${link}" frameborder="0" allowfullscreen></iframe>
                              `
                                )
                                .join("")}
                          </div>
                          <div class="swiper-pagination"></div>
                          <div class="swiper-slide-button swiper-button-prev text-black !absolute !inset-auto  !bottom-0 !left-[40px]   ">{%- render 'icon', icon: 'arrow-left-long', class: 'transform' -%}</div>
                          <div class="swiper-slide-button swiper-button-next text-black !absolute !inset-auto  !bottom-0 !right-[40px]  ">{%- render 'icon', icon: 'arrow-right-long', class: 'transform' -%}</div>    
                      </div>
                    `;
          section.appendChild(videoSwiper);
        }
        // 3) --- Reviews carousel ---
        const sliderWrapper = document.createElement("div");
        sliderWrapper.className = "swiper px-[20px] md:px-[30px]";
        sliderWrapper.innerHTML = `
                <div class="slider-wrapper cards my-5 ">
                    <div class="mb-5 swiper-wrapper">
                        ${reviews
                          .filter((r) => r.rating > 3)
                          .map(
                            (r) => `
                            <div class="max-h-[300px ] h-[300px] overflow-y-scroll bg-white border border-gray-200 rounded-2xl p-6 text-left shadow-sm swiper-slide">
                                <p class="mb-3 text-sm">about <span class="underline underline-offset-2">${
                                  r.product_title
                                }</span></p>
                                <div class="flex justify-between items-center mb-2">
                                    <div class="flex items-center gap-1">
                                        ${Array.from({ length: r.rating })
                                          .map(
                                            () => `
                                            <img src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/pointed-star.png?v=1745741039"
                                                 alt="Pointed Star" class="w-4 h-4">
                                        `
                                          )
                                          .join("")}
                                    </div>
                                    <p class="text-[12px] text-gray-500">
                                        ${new Date(
                                          r.created_at
                                        ).toLocaleDateString("en-US", {
                                          year: "numeric",
                                          month: "2-digit",
                                          day: "2-digit",
                                        })}
                                    </p>
                                </div>
                                <div class="flex items-center mb-4 gap-2">
                                    <div class='relative'>
                                        <img src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/user.png?v=1745741939"
                                             alt="Profile Icon" class="w-10 h-10 p-[6px] bg-[#efefef] rounded-xl">
                                        <img src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/check-circle.png?v=1745741991"
                                             alt="Profile Icon" class="absolute right-0 bottom-0 w-4 h-4">
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-2">
                                           <p class="text-sm">${(() => {
                                             const parts = r.reviewer.name
                                               .trim()
                                               .split(" ");
                                             if (parts.length > 1) {
                                               return `${parts[0]} ${
                                                 parts[parts.length - 1][0]
                                               }.`;
                                             } else {
                                               return parts[0]; // just first name, no dot
                                             }
                                           })()}</p>
                                            ${
                                              r.verified == "verified-purchase"
                                                ? '<span class="bg-black text-white text-[11px] px-2 rounded-[5px]">Verified</span>'
                                                : ""
                                            }
                                        </div>
                                        <div>
                                            <img src="https://judgeme-public-images.imgix.net/judgeme/flags/US.svg"
                                                 alt="American Flag" class="w-4 h-4 ml-2">
                                        </div>
                                    </div>
                                </div>
                                ${
                                  r.pictures[0]
                                    ? `${r.pictures.map(
                                        (picture) =>
                                          `<img src="${picture.urls["original"]}" alt="picture" class="mb-2">`
                                      )}`
                                    : ""
                                }
                                <p class="font-bold mb-2">${
                                  r.title
                                    ? `<p class="font-bold mb-2">${r.title}</p>`
                                    : ""
                                }</p>
                                <p style="color: #333333; line-height: 1.5;" class=" mb-4">${
                                  r.body
                                }</p>
                                
                            </div>
                        `
                          )
                          .join("")}
                    </div>
                    <div class="swiper-pagination"></div>
                    <div class="swiper-slide-button swiper-button-prev text-black !absolute !inset-auto  !bottom-0 !left-[40px]   ">{%- render 'icon', icon: 'arrow-left-long', class: 'transform' -%}</div>
                    <div class="swiper-slide-button swiper-button-next text-black !absolute !inset-auto  !bottom-0 !right-[40px]  ">{%- render 'icon', icon: 'arrow-right-long', class: 'transform' -%}</div>    
                </div>
            `;
        section.appendChild(sliderWrapper);

        // 4) add section to the DOM
        container.appendChild(section);
      });

      // 5) Initialize all Swipers
      container.querySelectorAll(".slider-wrapper.cards").forEach((wrapper) => {
        new Swiper(wrapper, {
          loop: true,
          spaceBetween: 10,
          pagination: {
            el: wrapper.querySelector(".swiper-pagination"),
            clickable: true,
            dynamicBullets: true,
          },
          navigation: {
            nextEl: wrapper.querySelector(".swiper-button-next"),
            prevEl: wrapper.querySelector(".swiper-button-prev"),
          },
          breakpoints: {
            0: { slidesPerView: 1 },
            530: { slidesPerView: 2 },
            800: { slidesPerView: 3 },
          },
        });
      });
      // 5) Initialize all Swipers
      container.querySelectorAll(".slider-wrapper.videos").forEach((wrapper) => {
        new Swiper(wrapper, {
          loop: true,
          spaceBetween: 10,
          pagination: {
            el: wrapper.querySelector(".swiper-pagination"),
            clickable: true,
            dynamicBullets: true,
          },
          navigation: {
            nextEl: wrapper.querySelector(".swiper-button-next"),
            prevEl: wrapper.querySelector(".swiper-button-prev"),
          },
          breakpoints: {
            0: { slidesPerView: 1.3 },
            530: { slidesPerView: 2 },
            800: { slidesPerView: 3 },
          },
        });
      });
    } catch (err) {
      console.error("Failed to load reviews:", err);
    }

    }

    if (!("IntersectionObserver" in window)) {
      initStaticCustomerReviews();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        observer.disconnect();
        initStaticCustomerReviews();
      },
      {
        rootMargin: "1200px 0px",
      }
    );

    observer.observe(sectionRoot);
  });
</script>

{% schema %}
