    },
    {
      "type": "textarea",
      "id": "love_it_video_links",
      "label": "I Just Love It video links",
      "default": "https://www.youtube.com/embed/h8x_v8PgqN8?si=busduuEU4dD-vvYZ\nhttps://www.youtube.com/embed/5KJoBB2XAaY"
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews Grouped",
      "category": "Custom"
    }
  ]
}
{% endschema %}
