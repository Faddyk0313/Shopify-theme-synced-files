  "name": "Customer Reviews Grouped",
  "settings": [
    {
      "type": "header",
      "content": "Guideline",
      "info": "Paste one YouTube video link per line. Normal watch links, Shorts links, youtu.be links and embed links are supported."
    },
    {
      "type": "textarea",
      "id": "safety_video_links",
      "label": "Safety video links",
      "default": "https://youtube.com/embed/OJ6Q2yBqvZg\nhttps://youtube.com/embed/ZOWaLBbtkr0\nhttps://youtube.com/embed/_PZO1Ve-V9w\nhttps://youtube.com/embed/tie4wG4W9kU"
    },
    {
      "type": "textarea",
      "id": "quality_video_links",
      "label": "Quality and durability video links",
      "default": "https://youtube.com/embed/fWI24iSBg7I?feature=shared\nhttps://youtube.com/embed/3pcaPE19zFc?feature=share\nhttps://youtube.com/embed/6KVh51I0e3M"
    },
    {
      "type": "textarea",
      "id": "comfort_video_links",
      "label": "Comfort and fit video links",
      "default": "https://youtube.com/embed/9TDi4Ylxzzs\nhttps://youtube.com/embed/fuYP4wJsfgk?feature=shared\nhttps://youtube.com/embed/QceW1c_NAwA?feature=shared\nhttps://youtube.com/embed/88PEJh6wWLk?feature=share\nhttps://www.youtube.com/embed/h8x_v8PgqN8?si=busduuEU4dD-vvYZ"
    },
    {
      "type": "textarea",
      "id": "style_video_links",
      "label": "Style and color video links",
      "default": "https://youtube.com/embed/eOWHBducRmk?feature=share\nhttps://youtube.com/embed/-hukY2U-Vic?feature=share\nhttps://youtube.com/embed/HjKNSR0iCs4"
    },
    {
      "type": "textarea",
      "id": "no_velcro_video_links",
      "label": "No Velcro video links",
