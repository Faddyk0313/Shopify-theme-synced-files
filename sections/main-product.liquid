<style>
  .product__inventory span:first-child {
    font-size: 15px;
    color: red;
    font-weight: bold;
  }
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      {%- assign media_ratio = section.settings.media_size | divided_by: 50.0 -%}
      --product-grid: auto / minmax(0, {{ media_ratio }}fr) minmax(0, {{ 2.0 | minus: media_ratio }}fr);
    }
  }

  {%- assign first_media = product.selected_or_first_available_variant.featured_media | default: product.media.first -%}
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      --first-aspect-ratio: {{ first_media.aspect_ratio | default: first_media.preview_image.aspect_ratio }};
    }
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} {
      --first-aspect-ratio: {{ first_media.aspect_ratio | default: first_media.preview_image.aspect_ratio }};
    }
  }
  {% comment %} tbg custom code {% endcomment %}
    {%- if section.settings.image_ratio_mobile == 'adapt_first' -%}
      @media screen and (max-width: 767px) {
        #SliderGallery-{{ section.id }}-{{ product.id }} .mobile\:media--adapt_first>:is(img, svg, video-media) {
          aspect-ratio: {{ first_media.aspect_ratio }};
        }
      }
    {%- endif -%}

    {%- if section.settings.gallery_layout == 'thumbnail' and section.settings.image_ratio == 'adapt_first' -%}
      @media screen and (min-width: 768px) {
        #SliderGallery-{{ section.id }}-{{ product.id }} .media--adapt_first>:is(img, svg, video-media) {
          aspect-ratio: {{ first_media.aspect_ratio }};
        }
      }
    {%- endif -%}
    .rio-options * {
      overflow: clip;
    }

    #warningMsg .drawer__title {
      font-size:20px !important;

    }
    @media (min-width: 786px) {
      #warningMsg .drawer__title {
        font-size:40px !important;

      }
    }
    #warningMsg[active] .drawer__inner {
      opacity: 1;
      transform: scale(1);
      transition: all .8s cubic-bezier(.7,0,.2,1);
      pointer-events: all !important;

    }

    #warningMsg:not([active]) .drawer__inner {
      opacity: 0;
      transform: scale(0.95);
      pointer-events: none;
    }

    #warningModalOverlay {
      background-color: rgb(var(--color-overlay) / .7);
      transition: all .8s cubic-bezier(.7,0,.2,1);
      opacity: 0;
      pointer-events: none;

    }

    #warningMsg[active] #warningModalOverlay {
      opacity: 1;
      pointer-events: all;
      cursor: default !important;
    }

    @media (max-width: 640px) {
      #warningMsg {
        transition: all .8s cubic-bezier(.7,0,.2,1);
        opacity: 1;
        transform: translateY(100%);
      }

      #warningMsg:not([active]) .drawer__inner {
        opacity: 1;
        pointer-events: none;
      }

      #warningMsg[active] {
        pointer-events: all;
        transform: translateY(0);
      }

      #warningMsg #warningModalOverlay {
      transition: all 2s cubic-bezier(.7,0,.2,1);
        transform: translate(0px);
      }
      #warningMsg[active] #warningModalOverlay {
        opacity: 1;

      }
    }

    .modal-visible * { pointer-events: none; }
    .modal-visible #warningMsg,
    .modal-visible #warningMsg * { pointer-events: auto; }

    @media (max-width: 640px) {
      .tbg-custom-select__button,
      .buy-buttons .quantity,
      .button.button--primary.button--fixed {
        min-height: 52px !important;
        max-height: 52px !important;
      }
    }
</style>

<style>
  .klaviyo-loader {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 1;
  }

  .spinner {
    border: 3px solid #f3f3f3;
    border-top: 3px solid #333;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    animation: spin 1s linear infinite;
    margin: 0 auto 10px;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .klaviyo-loader.hidden {
    display: none;
  }
</style>

{% if product.handle == 'bg-2-0-ls-neck-guard-shirt-pink-frost' %}
  <style>
    .details__content.rte.text-sm.text-opacity img[src*="safety_scale_for_collapsible.svg"] {
      display: none !important;
    }
  </style>
{% endif %}
{%- comment -%}TBG Custom Code{%- endcomment -%}

{%- liquid
  assign product_form_id = 'ProductForm-' | append: section.id | append: '-' | append: product.id
  assign media_count = product.media.size
  assign first_3d_model = product.media | where: 'media_type', 'model' | first
  assign icon_list_block = section.blocks | where: 'type', 'icon_list' | first
-%}

{%- if first_3d_model -%}
  <link rel="stylesheet" href="{{ 'model-viewer.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript>{{ 'model-viewer.css' | asset_url | stylesheet_tag }}</noscript>
  <link
    id="ModelViewerStyle"
    rel="stylesheet"
    href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
    media="print"
    onload="this.media='all'"
  />
  <link
    id="ModelViewerOverride"
    rel="stylesheet"
    href="{{ 'model-viewer-ui.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  />
{%- endif -%}

{%- if product.quantity_price_breaks_configured? -%}
  <link rel="stylesheet" href="{{ 'volume-pricing.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript>{{ 'volume-pricing.css' | asset_url | stylesheet_tag }}</noscript>
  <script src="{{ 'volume-pricing.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if icon_list_block -%}
  {%- capture icon_list_render -%}
    {%- if settings.product_icon_list_metafield != blank -%}
      {%- liquid
        assign metafield_parts = settings.product_icon_list_metafield | split: '.'
        assign metafield_namespace = metafield_parts | first
        assign metafield_key = metafield_parts | last
        assign metafield = product.metafields[metafield_namespace][metafield_key]
      -%}
      {%- if metafield.value != blank and metafield.list? -%}
        <div class="product__highlights{% if icon_list_block.settings.heading != blank %} with-heading flex flex-col gap-5 relative{% endif %}{% if icon_list_block.settings.show_below_media %} below-media{% endif %}" {{ icon_list_block.shopify_attributes }}>
          {%- if icon_list_block.settings.heading != blank -%}
            <p class="font-medium leading-tight md:text-lg">{{ icon_list_block.settings.heading | escape }}</p>
          {%- endif -%}
          <scroll-shadow class="product-card__spec block overflow-hidden">
            <div class="product-card__icons flex flex-nowrap{% unless icon_list_block.settings.enable_carousel %} lg:flex-wrap{% endunless %}" is="icons-carousel" tabindex="0">
              {%- for item in metafield.value -%}
                <div class="product-card__icon shrink-0">
                  <div class="flex flex-col items-center md:flex-row md:items-start gap-2">
                    {%- if item.icon.value != blank -%}
                      {%- assign icon_alt = item.icon.value.alt | default: item.title | escape -%}
                      {%- assign max_width = item.icon.value.width -%}
                      <figure class="shrink-0 media media--transparent relative inline-block">
                        {%- capture sizes -%}32px{%- endcapture -%}
                        {%- capture widths -%}{{ 32 | times: 1.5 | at_most: max_width | round }}, {{ 32 | times: 2 | at_most: max_width }}, {{ 32 | times: 3 | at_most: max_width }}{%- endcapture -%}
                        {{- item.icon.value | image_url: width: max_width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: icon_alt, class: 'w-full h-full', is: 'lazy-image' -}}
                      </figure>
                    {%- endif -%}
                    <div class="flex flex-col items-center md:items-start gap-1 text-center md:text-left text-sm font-medium leading-none">
                      {{- item.title -}}
                      {%- if item.description != blank -%}
                        <p class="text-opacity font-normal text-xs leading-tight">{{ item.description }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <template>
              <slot></slot>
              <s dir="{% render 'direction' %}" style="--t: 0;--b: 0;--l: 0;--r: 0;">
                <span class="l"></span>
                <span class="r"></span>
              </s>
              <style>
                :host{display:inline-block;position:relative}:host([hidden]){display:none}
                s{position:absolute;inset:0;pointer-events:none;}
                s span{position:absolute;inset-block:0;width:clamp(var(--sp-12),4.73vw,var(--sp-23));opacity:0;transition:opacity var(--animation-short);}
                s .l{inset-inline-start:0;opacity:var(--l);background:linear-gradient(90deg,rgb(var(--color-background)) 0%,transparent 100%);}
                s .r{inset-inline-end:0;opacity:var(--r);background:linear-gradient(270deg,rgb(var(--color-background)) 0%,transparent 100%);}
                s[dir=rtl] :is(.icon-chevron-left,.icon-chevron-right){transform:scaleX(-1);}
              </style>
            </template>
          </scroll-shadow>
        </div>
      {%- endif -%}
    {%- endif -%}
  {%- endcapture -%}
{%- endif  -%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if media_count > 0 %}{% if section.settings.full_width %} page-width--full{% endif %}{% else %} page-width--narrow{% endif %} relative">
    <div class="featured-product product product--{{ section.settings.gallery_layout }}{% if media_count == 0 %} no-media{% endif %} flex flex-col items-start lg:grid gap-5 w-full relative">
      {%- if media_count > 0 -%}
        <div class="product__gallery-container{% if section.settings.enable_sticky_info %} lg:sticky{% endif %} flex flex-col gap-0 md:gap-8 relative w-full">
          {% comment %} TBG custom Code {% endcomment %}
          {%- if section.settings.show_breadcrumb -%}
            {%- render 'product-breadcrumb', product: product, mobileOnly: true -%}
          {%- endif -%}
          {% comment %} TBG custom Code {% endcomment %}
          {%- render 'product-media-gallery',
            product: product,
            product_id: product.id,
            section_id: section.id,
            gallery_layout: section.settings.gallery_layout,
            thumbnail_position: section.settings.thumbnail_position,
            image_ratio: section.settings.image_ratio,
            image_ratio_mobile: section.settings.image_ratio_mobile,
            image_zoom: section.settings.image_zoom,
            image_fill: settings.product_image_fill,
            mobile_layout: section.settings.mobile_layout,
            mobile_thumbnail: section.settings.mobile_thumbnail,
            hide_variants: section.settings.hide_variants,
            enable_video_autoplay: section.settings.enable_video_autoplay,
            enable_video_looping: section.settings.enable_video_looping,
            first_3d_model: first_3d_model,
            product_form_id: product_form_id
          -%}

          {%- liquid
            if icon_list_block and icon_list_block.settings.show_below_media
              echo icon_list_render
            endif
          -%}
        </div>
      {%- endif -%}

      <product-info
        id="ProductInfo-{{ section.id }}-{{ product.id }}"
        class="product__info{% if section.settings.enable_sticky_info %} lg:sticky{% endif %} block w-full"
        data-animate="fade-up"
        data-immediate
        data-section-id="{{ section.id }}"
        data-product-id="{{ product.id }}"
        data-product-url="{{ product.url }}"
        data-update-url="true"
        form="{{ product_form_id }}"
      >
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {%- render block -%}

            {%- when 'breadcrumb' -%}
              {%- render 'product-breadcrumb', product: product, block: block -%}
            
            {%- comment -%}TBG Custom Code{%- endcomment -%}
            {%- when 'subheader' -%}
              {% render 'sub-header' product: product %}
            {%- when 'related_size_products' -%}
              <style>
                @media (max-width: 767px) {
                  .related-products-carousel {
                    overflow-y: hidden;
                    overflow-x: auto;
                    scroll-snap-type: x mandatory;
                    overscroll-behavior-x: contain;
                    scroll-behavior: smooth;
                    padding-inline: 10px;
                    margin-inline: -10px;
                    scroll-padding-inline: 10px;
                    padding-block: 10px;
                  }
                  .related-products-carousel__list {
                    flex-wrap: nowrap !important;
                    width: max-content;
                    min-width: 100%;
                  }
                  .titlecus,
                  #instockTagline {
                    display: none;
                  }
                }
                @media (min-width: 768px) {
                  .related-products-carousel {
                    overflow: visible;
                    margin-inline: 0;
                    padding-inline: 0;
                    scroll-snap-type: none;
                  }
                  .related-products-carousel__list {
                    width: 100%;
                  }
                }
                .related-product-item {
                  display: none;
                  position: relative;
                  flex: 0 0 auto;
                  scroll-snap-align: start;
                }
                .related-product-item:hover magnet-element,
                .related-product-item.active magnet-element {
                  box-shadow: 0px 0px 0px 2px black;
                  border-radius: 5px;
                }
                .related-product-item.soldout magnet-element {
                  box-shadow: 0px 0px 0px 2px #dbdbdb !important;
                }
                .related-product-item.soldout {
                  opacity: 0.65;
                }
                .soldoutMargin {
                  margin-left: calc(clamp(var(--sp-10), 3.368vw, var(--sp-16)) + 16px);
                }
                .related-product-item.soldout::after {
                  content: '';
                  position: absolute;
                  inset: 0;
                  pointer-events: none;
                  background: linear-gradient(
                    135deg,
                    transparent 0%,
                    transparent calc(50% - 1px),
                    rgba(255, 0, 0, 0.9) 50%,
                    transparent calc(50% + 1px),
                    transparent 100%
                  );
                  transform: scale(1.2);
                  border-radius: 8px;
                }
                .carouselBtnsGrp {
                  position: relative;
                }
                .carouselBtnsGrp .cus_leftCarouselBtn,
                .carouselBtnsGrp .cus_rightCarouselBtn {
                  display: block;
                  background-color: #f2f2f2;
                  padding-block: 1rem;
                  border: 0;
                }
                .carouselBtnsGrp .cus_leftCarouselBtn,
                .carouselBtnsGrp .cus_rightCarouselBtn {
                  position: absolute;
                  z-index: 999;
                  top: 50%;
                  transform: translateY(-50%);
                  font-size: 2rem;
                }
                .carouselBtnsGrp .cus_leftCarouselBtn {
                  padding-left: 8px;
                  transform: translate(-10px, -50%);
                  left: 0;
                }
                .carouselBtnsGrp .cus_rightCarouselBtn {
                  right: 0;
                }
                .carouselBtnsGrp .cus_leftCarouselBtn[disabled],
                .carouselBtnsGrp .cus_rightCarouselBtn[disabled] {
                  opacity: 0.3;
                }

                @media (min-width: 768px) {
                  .carouselBtnsGrp .cus_leftCarouselBtn,
                  .carouselBtnsGrp .cus_rightCarouselBtn {
                    display: none;
                  }
                }
                .carouselBtnsGrp .cus_leftCarouselBtn[hidden],
                .carouselBtnsGrp .cus_rightCarouselBtn[hidden] {
                  display: none !important;
                }
              </style>
              <div
                class="relative carouselBtnsGrp"
                style="margin: 0; margin-top: 12px;"
                id="related-size-products-{{ section.id }}-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.heading != blank -%}
                  {%- liquid
                    assign title_parts = product.title | split: ' - '
                    assign color_in_title = title_parts | last
                  -%}
                  <div class="flex gap-2 titlecus">
                    {{ block.settings.heading | escape }}
                    <span class="font-medium">
                      {{- product.metafields.sibling.color.value | default: color_in_title -}}
                    </span>
                  </div>
                  <div
                    id="instockTagline"
                    class="font-medium"
                    style="margin-top:1px; margin-bottom: 10px; font-size:10px;"
                  ></div>
                {%- endif -%}
                <slider-element
                  id="carousel-{{ section.id }}-{{ block.id }}"
                  class="related-products-carousel slider block"
                  selector=".related-product-item"
                >
                <ul class="related-products-carousel__list swatches swatches--round-slight swatches--variant flex items-start flex-wrap gap-4">
                  {%- comment -%}TBG custom code{%- endcomment -%}
                  {%- assign curated_related_products = product.metafields['custom']['product_variations'].value -%}
                  {%- if curated_related_products != blank -%}
                    {%- for prod in curated_related_products -%}
                      {%- assign available_sizes = '' -%}

                      {%- for variant in prod.variants -%}
                        {%- if variant.inventory_quantity > 0 or variant.inventory_policy == 'continue' -%}
                          {%- for i in (1..3) -%}
                            {%- case i -%}
                              {%- when 1 -%}
                                {%- assign option_value = variant.option1 -%}
                              {%- when 2 -%}
                                {%- assign option_value = variant.option2 -%}
                              {%- when 3 -%}
                                {%- assign option_value = variant.option3 -%}
                            {%- endcase -%}

                            {%- if option_value != blank -%}
                              {%- unless available_sizes contains option_value -%}
                                {%- if available_sizes == blank -%}
                                  {%- assign available_sizes = option_value -%}
                                {%- else -%}
                                  {%- assign available_sizes = available_sizes | append: ',' | append: option_value -%}
                                {%- endif -%}
                              {%- endunless -%}
                            {%- endif -%}
                          {%- endfor -%}
                        {%- endif -%}
                      {%- endfor -%}

                      {%- if available_sizes != blank -%}
                        <li
                          data-available-sizes="{{ available_sizes }}"
                          data-product-id="{{ prod.id }}"
                          data-tbg-related-product
                          data-tbg-product-url="{{ prod.url }}"
                          class="related-product-item block"
                        >
                          <magnet-element class="block">
                            <a
                              href="{{ prod.url }}"
                              data-tbg-related-link
                              class="related-product-item-img color-swatch with-image block relative aspect- mobile:aspect- aspect-contain"
                              title="{{ prod.title | escape }}"
                              style="--swatch-background: {{ prod.featured_image | image_url: width: 144 }}; --swatch-background-image: url({{ prod.featured_image | image_url: width: 144 }});"
                            >
                              {%- assign mf_value = prod.metafields.sibling.color.value -%}
                              {%- assign title_parts = prod.title | split: '-' -%}
                              {%- assign title_suffix = title_parts | last | strip -%}

                              <span class="tooltip opacity-0 pointer-events-none text-xs rounded-full z-10">
                                {%- if mf_value != blank -%}
                                  {{ mf_value | escape }}
                                {%- else -%}
                                  {{ title_suffix | escape }}
                                {%- endif -%}
                                </span>
                              </a>
                          </magnet-element>
