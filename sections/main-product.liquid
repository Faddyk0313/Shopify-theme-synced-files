<style>
  button.product-form__submit.button.button--primary.button--fixed,
  button.product-form__alert.button.button--primary.button--fixed {
    background: black !important;
    padding-block: 0;
  }
  button.product-form__submit.button.button--primary.button--fixed .btn-text,
  button.product-form__alert.button.button--primary.button--fixed .btn-text {
    background: -webkit-linear-gradient(45deg, #72ffb3 14%, #fffa63 85%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  button.product-form__submit.button.button--primary.button--fixed .btn-fill,
  button.product-form__alert.button.button--primary.button--fixed .btn-fill {
    background: linear-gradient(54deg, #72ffb3 14%, #fffa63 85%) !important;
  }
  button.product-form__alert.button.button--primary.button--fixed .btn-fill {
    display: none;
  }
  @media (min-width: 1024px) {
    button.product-form__alert.button.button--primary.button--fixed .btn-fill {
      display: block;
    }

    button.product-form__submit.button.button--primary.button--fixed:hover .btn-text,
    button.product-form__alert.button.button--primary.button--fixed:hover .btn-text {
      background: transparent;
      -webkit-text-fill-color: #000;
      -webkit-background-clip: border-box;
    }
  }
</style>

