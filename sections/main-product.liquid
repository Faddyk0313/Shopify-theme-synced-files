<script>
  window.variantAvailability = {
    {% for variant in product.variants %}
      "{{ variant.title }}": {
        available: {% if variant.inventory_quantity > 0 %}true{% else %}false{% endif %},
        inventoryPolicy: {{ variant.inventory_policy | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };
  // Related Products Size Filtering
  (() => {
    let updateFrame = null;

    function refreshRelatedProductsCarousel(carousel) {
      if (!carousel) return;

      requestAnimationFrame(() => {
        if (typeof carousel.reset === 'function') {
          carousel.reset();
        }

        carousel.currentPage = 1;

        if (typeof carousel.scrollToPosition === 'function') {
          carousel.scrollToPosition(0, true);
        } else {
          carousel.scrollLeft = 0;
        }

        if (typeof carousel.updateButtons === 'function') {
          carousel.updateButtons();
        }

        if (typeof carousel.updateTabindex === 'function') {
          carousel.updateTabindex();
        }

        carousel.dispatchEvent(
          new CustomEvent('slider:change', {
            detail: {
              currentPage: 1,
              currentElement:
                typeof carousel.selected === 'function' ? carousel.selected(0) : carousel.querySelector('.related-product-item:not([style*="display: none"])'),
            },
          })
        );
      });
    }

    function getSelectedSize() {
      // New button/swatch picker (preferred)
      const sizeRadio =
        document.querySelector('variant-picker fieldset[data-option-slug="size"] input[type="radio"]:checked') ||
        document.querySelector('.variant-picker fieldset[data-option-slug="size"] input[type="radio"]:checked') ||
        document.querySelector('.swatches li input[type="radio"][name^="Size-"]:checked');

      if (sizeRadio && sizeRadio.value) return sizeRadio.value;

      // Old dropdown picker fallback
      const nativeSelect = document.querySelector('select[name="options[Size]"]');
      const customSelect = document.querySelector('.tbg-custom-select[data-name="options[Size]"]');

      if (nativeSelect && nativeSelect.value) return nativeSelect.value;

      if (customSelect) {
        const selectedOption = customSelect.querySelector(
          '.tbg-custom-select__item[aria-selected="true"]'
        );
        return selectedOption?.getAttribute('data-value') || null;
      }

      return null;
    }

    function matchesSelectedSize(size, selectedSize) {
      size = typeof size === 'string' ? size : size == null ? '' : String(size);
      selectedSize =
        typeof selectedSize === 'string' ? selectedSize : selectedSize == null ? '' : String(selectedSize);

      if (size === selectedSize) return true;

      if (!selectedSize.includes('/')) {
        if (size.includes('/')) {
          const rangeParts = size.split('/');
          return rangeParts[0] === selectedSize;
        }
      }

      if (selectedSize.includes('/')) {
        const selectedParts = selectedSize.split('/');
        return size === selectedParts[0];
      }

      return false;
    }

    function updateRelatedProductState(selectedSize) {
      const instockTagline = document.querySelector('#instockTagline');
      const currentProd = document.querySelector('.currentprod');

      if (instockTagline) {
        instockTagline.textContent = selectedSize ? `IN STOCK - ${selectedSize}` : 'IN STOCK';
      }

      if (!selectedSize) {
        if (currentProd) {
          currentProd.classList.remove('soldout');
        }
        if (instockTagline) {
          instockTagline.classList.remove('soldoutMargin');
        }
        return;
      }

      const currentVariantState = window.variantAvailability?.[selectedSize];
      const isSoldOutState = currentVariantState
        ? !currentVariantState.available && currentVariantState.inventoryPolicy !== 'continue'
        : false;

      if (currentProd) {
        currentProd.classList.toggle('soldout', isSoldOutState);
      }

      if (instockTagline) {
        instockTagline.classList.toggle('soldoutMargin', isSoldOutState);
      }
    }

    function filterRelatedProducts() {
      updateFrame = null;

      const selectedSize = getSelectedSize();
      const carousels = document.querySelectorAll('.related-products-carousel');

      carousels.forEach((carousel) => {
        const allItems = carousel.querySelectorAll('.related-product-item');

        allItems.forEach((item) => {
          if (!selectedSize) {
            item.style.display = 'block';
            return;
          }

          const availableSizes = item.getAttribute('data-available-sizes');
          if (!availableSizes) {
            item.style.display = 'none';
            return;
          }

          const sizesArray = availableSizes.split(',');
          const hasMatch = sizesArray.some((size) => matchesSelectedSize(size, selectedSize));
          item.style.display = hasMatch ? 'block' : 'none';
        });

        refreshRelatedProductsCarousel(carousel);
      });

      updateRelatedProductState(selectedSize);
    }

    function scheduleRelatedProductsUpdate() {
      if (updateFrame !== null) return;
      updateFrame = requestAnimationFrame(filterRelatedProducts);
    }

    document.addEventListener('change', (e) => {
      if (
        e.target?.matches?.('variant-picker fieldset[data-option-slug="size"] input[type="radio"]') ||
        e.target?.matches?.('.variant-picker fieldset[data-option-slug="size"] input[type="radio"]') ||
        e.target?.matches?.('.swatches li input[type="radio"][name^="Size-"]') ||
        e.target?.matches?.('select[data-tbg-enhance="custom-select"]') ||
        e.target?.matches?.('select[name="options[Size]"]')
      ) {
        scheduleRelatedProductsUpdate();
      }
    });

    document.addEventListener('click', (e) => {
      if (e.target?.matches?.('.tbg-custom-select__item')) {
        scheduleRelatedProductsUpdate();
      }
    });

    [
      'variant:change',
      'product:variant-change',
      'theme:variant:change',
      'product:updated',
      'shopify:section:load'
    ].forEach((evt) => {
      document.addEventListener(evt, scheduleRelatedProductsUpdate);
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scheduleRelatedProductsUpdate, { once: true });
    } else {
      scheduleRelatedProductsUpdate();
    }
  })();
</script>

