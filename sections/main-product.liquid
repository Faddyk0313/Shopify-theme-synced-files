  <!-- TBG Custom Code -->
  <!-- Explaination -->
  {% comment %}
    Main Functionality
     Checks URL Parameters (script.html:13-19)
     Looks for a size_selected=true parameter in the URL
     If present, exits early to avoid interfering with manual size selections
     Retrieves User's Preferred Size (script.html:22)
     Reads userSize from browser localStorage (likely saved from a previous interaction)
     Gets Product Data (script.html:24-29)
     Fetches product information from a hidden JSON element on the page
     Uses Shopify Liquid templating: {{ product.id }}
     Selects a Variant (script.html:33-42)
     First priority: Tries to find a variant matching the user's saved size preference
     Fallback: If no match or no saved preference, selects the first variant with available inventory (inventory_quantity > 0)
     Auto-Selects the Size (script.html:44-54)
     Updates the size dropdown (<select>) on the page
     Adds a customActive class
     Triggers a change event to update the product form
  {% endcomment %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // TBG Custom Code: normalize stored size values before matching.
      function toSafeString(value) {
        if (typeof value === 'string') return value;
        if (value == null) return '';
        return String(value);
      }

      // Check if user came from size selection section
      const urlParams = new URLSearchParams(window.location.search);
      const sizeSelected = urlParams.get('size_selected');

      // Don't auto-select if user already selected a size from the section
      if (sizeSelected === 'true') {
        return;
      }

      // TBG Custom Code: compare against the current variant in the URL before firing variant-change logic.
      const currentVariantParam = toSafeString(urlParams.get('variant'));

      // Get the user's preferred size from localStorage
      const userSize = toSafeString(localStorage.getItem('userSize'));

      const productEl = document.getElementById('ProductJsonAdditional-{{ product.id }}');
      if (!productEl) return;

      const product = JSON.parse(productEl.textContent);
      let variantToSelect = null;

      // If user has a preferred size in localStorage, try to find a matching variant
      if (userSize) {
        variantToSelect = product.variants.find((v) => {
          const variantTitle = toSafeString(v && v.title);

          // Exact match
          if (variantTitle === userSize) return true;

          // If userSize is range (e.g., YTH-SM/MD), match any part (YTH-SM or YTH-MD)
          if (userSize.includes('/')) {
            const userParts = userSize.split('/');
            return userParts.includes(variantTitle);
          }

          // If variant title is range (e.g., YTH-SM/MD) and userSize is normal (YTH-MD)
          if (variantTitle.includes('/')) {
            const parts = variantTitle.split('/');
            // Extract prefix from first part (YTH-SM -> YTH)
            const prefix = parts[0].substring(0, parts[0].lastIndexOf('-') + 1);
            // Build full size names: [YTH-SM, YTH-MD]
            const fullSizes = parts.map((p, i) => (i === 0 ? p : prefix + p));
            return fullSizes.includes(userSize);
          }

          return false;
        });
      }

      // If no matching size found or no userSize in localStorage, fall back to first available
      if (!variantToSelect) {
        variantToSelect = product.variants.find((v) => v.inventory_quantity > 0);
      }

      if (variantToSelect) {
        // Force select this variant
        const selectEl = document.querySelector(
          `#ProductInfo-{{ section.id }}-{{ product.id }} select[name="options[Size]"]`
        );
        if (selectEl) {
          const variantToSelectId = toSafeString(variantToSelect.id);
          const currentSelectedVariantId = toSafeString(product.selected_or_first_available_variant && product.selected_or_first_available_variant.id);

          selectEl.classList.add('customActive');

          // TBG Custom Code: avoid a corrective AJAX refresh when the PDP already loaded on the intended variant.
          if (currentVariantParam === variantToSelectId || currentSelectedVariantId === variantToSelectId) {
            return;
          }

          selectEl.value = variantToSelect.title;
          selectEl.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
    });
  </script>
  <!-- End TBG Custom Code -->
  <!-- TBG Custom Code -->
  <script>
    (() => {
      if (window.__tbgRelatedVariantLinksInitialized) return;
      window.__tbgRelatedVariantLinksInitialized = true;

      const ITEM_SELECTOR = '[data-tbg-related-product]';
      const LINK_SELECTOR = '[data-tbg-related-link]';

      function toSafeString(value) {
        if (typeof value === 'string') return value;
        if (value == null) return '';
        return String(value);
      }

      function findVariantForUserSize(variants, userSize) {
        if (!userSize || !Array.isArray(variants)) return null;

        return variants.find((variant) => {
          const variantTitle = toSafeString(variant && variant.title);

          if (variantTitle === userSize) return true;

          if (userSize.includes('/')) {
            const userParts = userSize.split('/');
            return userParts.includes(variantTitle);
          }

          if (variantTitle.includes('/')) {
            const parts = variantTitle.split('/');
            const prefix = parts[0].substring(0, parts[0].lastIndexOf('-') + 1);
            const fullSizes = parts.map((part, index) => (index === 0 ? part : prefix + part));
            return fullSizes.includes(userSize);
          }

          return false;
        }) || null;
      }

      function updateRelatedProductLink(item) {
        if (!item) return;

        const productUrl = toSafeString(item.getAttribute('data-tbg-product-url'));
        const variantsNode = item.querySelector('[data-tbg-related-variants]');
        const userSize = toSafeString(localStorage.getItem('userSize'));
        if (!productUrl || !variantsNode || !userSize) return;

        let variants = [];
        try {
          variants = JSON.parse(variantsNode.textContent.trim());
        } catch (error) {
          return;
        }

        const matchedVariant = findVariantForUserSize(variants, userSize);
        if (!matchedVariant || !matchedVariant.id) return;

        const matchedVariantId = toSafeString(matchedVariant.id);
        if (item.dataset.tbgMatchedVariantId === matchedVariantId) return;

        item.querySelectorAll(LINK_SELECTOR).forEach((link) => {
          const href = toSafeString(link.getAttribute('href'));
          if (!href) return;

          const url = new URL(href, window.location.origin);
          if (url.pathname !== new URL(productUrl, window.location.origin).pathname) return;

          url.searchParams.set('variant', matchedVariant.id);
          link.setAttribute('href', `${url.pathname}${url.search}${url.hash}`);
        });

        item.dataset.tbgMatchedVariantId = matchedVariantId;
      }

      function enhanceRelatedProductLinks(scope = document) {
        scope.querySelectorAll(ITEM_SELECTOR).forEach(updateRelatedProductLink);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => enhanceRelatedProductLinks(document));
      } else {
        enhanceRelatedProductLinks(document);
      }

      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (node.nodeType !== 1) return;
            if (node.matches?.(ITEM_SELECTOR)) {
              updateRelatedProductLink(node);
              return;
            }
            if (node.querySelector?.(ITEM_SELECTOR)) {
              enhanceRelatedProductLinks(node);
            }
          });
        });
      });

      observer.observe(document.documentElement, { childList: true, subtree: true });
    })();
  </script>
  <!-- End TBG Custom Code -->
  
