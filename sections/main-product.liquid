                    Restock every 4-6 weeks - Secure your spot on the waitlist today
                  </p>
                </div>

                <script>
                  // TBG Custom Code
                  (function () {
                    const sectionRoot =
                      document.currentScript && document.currentScript.closest('[id^="shopify-section-"]');
                    let updateFrame = 0;

                    function toggleRestockMsg() {
                      const scope = sectionRoot || document;
                      const alertEl = scope.querySelector('.product-form__alert.backInStock');
                      const restockMsg = scope.querySelector('.restockMsg');
                      if (!restockMsg) return;

                      const shouldShow = !!alertEl && !alertEl.hidden && window.getComputedStyle(alertEl).display !== 'none';
                      const nextDisplay = shouldShow ? 'block' : 'none';

                      if (restockMsg.style.display !== nextDisplay) {
                        restockMsg.style.display = nextDisplay;
                      }
                    }

                    function scheduleToggle() {
                      if (updateFrame) return;
                      updateFrame = requestAnimationFrame(function () {
                        updateFrame = 0;
                        toggleRestockMsg();
                      });
                    }

                    scheduleToggle();

                    ['variant:change', 'product:variant-change', 'product-info:variant-change'].forEach(function (eventName) {
                      document.addEventListener(eventName, scheduleToggle);
                    });

                    if (sectionRoot) {
                      const observer = new MutationObserver(scheduleToggle);
                      observer.observe(sectionRoot, {
                        childList: true,
                        subtree: true,
                        attributes: true,
                        attributeFilter: ['class', 'style', 'hidden'],
                      });
                    }
                  })();
                  // End TBG Custom Code
