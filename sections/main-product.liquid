<script>
  // POSTHOG METRIC - PDP Max Scroll Depth
  // Sends one event per PDP visit with the highest scroll percentage reached before the page is hidden or unloaded.
  (() => {
    if (window.__pdpMaxScrollTrackerInitialized) return;
    window.__pdpMaxScrollTrackerInitialized = true;

    let maxScrollPercent = 0;
    let sent = false;
    let ticking = false;

    function getScrollableHeight() {
      return Math.max(
        document.documentElement.scrollHeight,
        document.body ? document.body.scrollHeight : 0
      ) - window.innerHeight;
    }

    function updateMaxScroll() {
      ticking = false;

      const scrollableHeight = getScrollableHeight();
      const scrollTop = Math.max(
        window.pageYOffset,
        document.documentElement.scrollTop,
        document.body ? document.body.scrollTop : 0,
        0
      );

      const currentPercent = scrollableHeight > 0
        ? Math.min(100, Math.max(0, (scrollTop / scrollableHeight) * 100))
        : 100;

      if (currentPercent > maxScrollPercent) {
        maxScrollPercent = currentPercent;
      }
    }

    function queueUpdate() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(updateMaxScroll);
    }

    function sendMaxScroll() {
      if (sent || !window.posthog || typeof window.posthog.capture !== 'function') return;

      updateMaxScroll();
      sent = true;

      window.posthog.capture('PDP Max Scroll Depth', {
        page_type: 'product',
        product_id: {{ product.id | json }},
        product_handle: {{ product.handle | json }},
        product_title: {{ product.title | json }},
        max_scroll_percent: Math.round(maxScrollPercent * 100) / 100
      });
    }

    queueUpdate();

    window.addEventListener('scroll', queueUpdate, { passive: true });
    window.addEventListener('resize', queueUpdate, { passive: true });
    window.addEventListener('load', queueUpdate);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') {
        sendMaxScroll();
      }
    });
    window.addEventListener('pagehide', sendMaxScroll);
    window.addEventListener('beforeunload', sendMaxScroll);
  })();
</script>

