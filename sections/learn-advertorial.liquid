<style>
  @import url('https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&family=Teko:wght@300..700&display=swap');

  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .cus_font_roboto {
    font-family: "Roboto", sans-serif !important;
  }
  .cus_font_teko {
    font-family: "Teko", sans-serif !important;
  }
  .cus_header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: black;
    padding-block: 1rem;
    position: sticky;
    z-index: 99;
    top: 0;
  }
  .cus_header_logo {
    filter: invert(1);
  }
  .cus_header_logo,
  .made_in_usa_img {
    width: 150px;
  }

  #shopify-section-{{ section.id }} .highlighted-text.animated[data-style=full_text] {
    line-height: 0.6;
    padding: 8px 5px 2px 5px;
  }

  .tag_line {
    color: white;
    font-size: 1.25rem;
    text-align: center;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .product__breadcrumb {
    border: none;
    margin-bottom: 1rem;
  }
  @media (max-width: 400px) {
    .product__breadcrumb li {
      font-size: 11px !important;
    }
  }
  .product__breadcrumb li {
    color: black;
    white-space: nowrap;
  }
  .product__breadcrumb li:last-child {
    white-space: normal;
  }
  .product-title-hyphen {
    display: inline;
  }
  .product-title-mobile-break {
    display: none;
  }
  .breadcrumb li+li:before {
    content: url("https://cdn.shopify.com/s/files/1/0635/2401/2210/files/svgviewer-output_2.svg?v=1770096365");
    padding-right: 8px;
    padding-bottom: 8px;
    transform: none;
    background-color: transparent;
  }
  .rating-count {
    border-inline-start: 1px solid #4e4e4e !important;
  }
  .product__rating {
    font-weight: 600;
    color: #4e4e4e;
    margin-block: 1rem;
  }
  .rating.text-lg.leading-none {
    font-size: 1.2rem;
  }
  .rating-star::before {
    content: "\2605\2605\2605\2605\2605";
    background: black;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
  }

  .adv-sticky-bleed {
    --tbg-sticky-offset: 80px;
    width: 100%;
    position: sticky;
    top: var(--tbg-sticky-offset, 0px);
    z-index: 50;
    background: #2aa6c4;
    border-top: 1px solid rgba(255,255,255,0.25);
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }

  .adv-sticky-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 0;
  }

  .adv-tabs {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 1rem;
  }
  .adv-tabs::-webkit-scrollbar { display: none; }

  .adv-tab {
    appearance: none;
    background: transparent;
    border: 0;
    color: rgba(0,0,0,0.7);
    font-size: 2rem;
    text-transform: uppercase;
    padding: 0px 30px;
    line-height: 1;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 2px solid rgba(0,0,0,0.7);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .adv-tab.is-active,
  .adv-tab[aria-current="true"] {
    color: white;
    border-bottom-color: white;
  }

  .adv-panels {
    padding-block: 0.75rem;
    font-size: 1.6rem;
  }
  .adv-panel {
    scroll-margin-top: calc(var(--tbg-sticky-offset, 80px) + 72px);
  }
  .adv-panel + .adv-panel {
    margin-top: 2rem;
  }
  .adv-yt-embed {
    display: block;
    width: 100%;
    max-width: 220px;
    margin: 1rem 0;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
  }
  .adv-yt-embed__frame {
    display: block;
    width: 100%;
    aspect-ratio: 9 / 16 !important;
    border: 0;
  }
  .adv-yt-gallery-mobile {
    margin: 1rem 0;
  }
  .adv-yt-gallery-mobile .adv-yt-card-grid {
    gap: 1rem;
  }
  .adv-yt-gallery-mobile .card .adv-yt-embed {
    margin: 0;
    max-width: none;
    width: 100%;
  }
  .adv-yt-gallery-row {
    display: none;
    gap: 1rem;
    margin: 1rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .adv-yt-gallery-row::-webkit-scrollbar {
    display: none;
  }
  .adv-yt-gallery-row .adv-yt-embed {
    flex: 0 0 220px;
    width: 220px;
    max-width: none;
    margin: 0;
  }
  @media (min-width: 750px) {
    .breadcrumb li+li:before {
      padding-bottom: 16px;
    }
    .adv-yt-gallery-mobile {
      display: none;
    }
    .adv-yt-gallery-row {
      display: flex;
    }
  }
  @media (max-width: 749px) {
    .adv-yt-gallery-row {
      display: none;
    }
  }
  .adv-panels strong {
    font-weight: 600 !important;
    color: #008AB5
  }

  .cus_banner_img {
    margin-block: 2rem
  }

  .cus_btn_grp {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-top: 3rem;
  }

  .cus_btn {
    {% comment %} width: calc(50% - 0.5rem); {% endcomment %}
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 22px;
    min-width: 260px;
    font-size: 1.6rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    border-radius: 0;
    text-decoration: none;
    transition: transform 0.12s ease, opacity 0.12s ease;
  }

  .cus_btn:hover {
    transform: translateY(-1px);
    opacity: 0.95;
  }

  #shopify-section-{{ section.id }}  .cus_btn.is-primary {
    background: #0b4f5c;
    color: #fff !important;
    border: 2px solid #0b4f5c;
  }

  #shopify-section-{{ section.id }}  .cus_btn.is-secondary {
    background: transparent;
    color: #0b4f5c !important;
    border: 2px solid #0b4f5c;
  }

  #shopify-section-{{ section.id }} .adv-panels a {
    color: #36c !important;
  }
  @media(max-width: 768px) {
    #shopify-section-{{ section.id }} .header__logo {
      margin-inline-end: 0 !important;
    }
    #shopify-section-{{ section.id }} .tag_line {
      font-size: 10px;
    }
    .cus_header_logo,
    .made_in_usa_img {
      width: 85px;
    }
    #shopify-section-{{ section.id }} .highlighted-text.animated[data-style=full_text] {
      line-height: 0.6;
      padding: 5px 5px 0;
    }
    .adv-sticky-bleed {
      --tbg-sticky-offset: 59px;
    }
    .cus_banner_img {
      margin-block: 1rem
    }
    .cus_heading_page,
    .cus_body {
      padding-right: 1rem;
    }

    .adv-tabs {
      gap: 1rem;
    }
    .adv-tab {
      font-size: 14px;
      padding: 0 10px;
    }
    .adv-panels {
      padding-block: 0px;
      font-size: 1rem;
    }
    .cus_btn_grp {
      gap: 1rem;
      margin-top: 2rem;
    }
    .cus_btn {
      font-size: 14px;
      padding: 10px;
      min-width: 0;
    }

  }

  .alia-popup {
    position: fixed;
    inset: 0;
    z-index: 999;
    opacity: 0;
    background: rgba(0, 0, 0, 0);
    box-shadow: 0px 0px 15px black;
    transition: box-shadow 260ms ease, opacity 260ms ease, background-color 260ms ease;
    pointer-events: none;
  }
  
  .alia-popup.is-visible {
    box-shadow: none;
    opacity: 1;
    background: rgba(0, 0, 0, 0.55);
    pointer-events: auto;
  }


</style>

<div class="page-width cus_header">
