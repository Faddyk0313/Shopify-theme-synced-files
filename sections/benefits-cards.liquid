<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }
  @media screen and (max-width: 1023px) {
    #shopify-section-{{ section.id }} .slider--tablet .card-grid {
        {% comment %} --slider-item-width: 31vw; {% endcomment %}
    }
  }
  @media screen and (max-width: 639px) {
    #shopify-section-{{ section.id }} .slider--tablet .mobile\:card-grid--1 {
        {% comment %} --slider-item-width: 90vw; {% endcomment %}
        gap: 1rem !important;
    }
  }
  #shopify-section-{{ section.id }} .slide {
    position: relative;
    {% comment %} min-width: 100%; {% endcomment %}
    flex-shrink: 0;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    background-size: cover;
    background-position: center;
    color: #fff;
    height: 400px; 
  }
  #shopify-section-{{ section.id }} .slide-content {
    backdrop-filter: none;
  }
  #shopify-section-{{ section.id }} .overlay {
    display: block !important;
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 35%,
      rgba(0, 0, 0, 0) 60%
    );
    pointer-events: none;
    border-radius: 16px;
  }
  #shopify-section-{{ section.id }} .text-block {
    position: relative;
    z-index: 2;
    padding-bottom: 1rem;
  }
  #shopify-section-{{ section.id }} .small {
    font-size: 0.9rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0 0 0.25rem;
    font-weight: 500;
    opacity: 0.9;
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .main.heading {
      font-size: clamp(1.7rem, 2vw, 2.2rem) !important;
    }
  }
  #shopify-section-{{ section.id }} .subheading {
    font-size: clamp(1.5rem, 1.8vw, 2rem);
    font-weight: 600;
    margin: 0;
    font-family: Armourmd;
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .subheading {
    font-size: clamp(1.7rem, 2vw, 2.2rem);
    }
  }
  #shopify-section-{{ section.id }} .paragraph {
    font-size: 15px;
    margin: 0;
    margin-top: 7px;
    line-height: 1.4;
  }

  /* Desktop: show all slides stacked side by side */
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .slides {
      flex-wrap: nowrap;
      gap: 16px;
      transform: none !important;
    }
  }
</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- capture indicators -%}
      {%- if section.settings.carousel_on_desktop -%}
        <div class="indicators hidden lg:flex gap-2d5">
          <button class="button button--secondary" type="button" is="previous-button" aria-controls="Slider-{{ section.id }}" aria-label="{{ 'general.pagination.previous' | t | escape }}" disabled>
            <span class="btn-fill" data-fill></span>
            <span class="btn-text">
              {%- render 'icon', icon: 'chevron-left', class: 'transform' -%}
            </span>
          </button>
          <button class="button button--secondary" type="button" is="next-button" aria-controls="Slider-{{ section.id }}" aria-label="{{ 'general.pagination.next' | t | escape }}">
            <span class="btn-fill" data-fill></span>
            <span class="btn-text">
              {%- render 'icon', icon: 'chevron-right', class: 'transform' -%}
            </span>
          </button>
        </div>
        <p class="lg:hidden">{{ view_all }}</p>
      {%- else -%}
        <p>{{ view_all }}</p>
      {%- endif -%}
    {%- endcapture -%}
    {%- render 'section-heading', section: section, section_button: indicators -%}

    <slider-element
      id="Slider-{{ section.id }}"
      class="grid slider{% if section.settings.carousel_on_desktop %} slider--desktop{% endif %}{% if section.settings.swipe_on_mobile %} slider--tablet{% endif %}"
      selector=".card-grid>.card"
      {% if section.settings.carousel_on_desktop or section.settings.swipe_on_mobile %}
        tabindex="0"
      {% endif %}
    >
      <motion-list class="product-grid card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid">
        <!-- Slide 1 -->
        <div
          class="card product-card product-card--standard slide"
          style=" flex: 1; background-image: url('https://cdn.shopify.com/s/files/1/0635/2401/2210/files/slider_1.png?v=1753955893&width=1200');"
          aria-label="Slide 1"
        >
          <div class="overlay"></div>
          <div class="slide-content text-block">
            <p class="subheading">SAFETY SHOULDN’T</p>
            <h2 class="main heading leading-none title-md" style="color: white; margin: 0 !important">
              <split-words
                class="split-words block"
                data-animate="fade-up-large"
                data-animate-delay="250"
              >
                BE A HASSLE
              </split-words>
            </h2>
            <p class="paragraph">
              No more fights about neck guards. Titan’s built-in protection feels great, looks sharp, and players
              actually want to wear it. No reminders required.
            </p>
          </div>
        </div>
        <!-- Slide 2 -->
        <div
          class="card product-card product-card--standard slide"
          style="flex: 1;"
          data-bg="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/Artboard_3.png?v=1753955893&width=1200"
          aria-label="Slide 2"
        >
          <div class="overlay"></div>
          <div class="slide-content text-block">
            <div class="subheading">ONE WEAK SPOT PUTS</div>
            <h2 class="main heading leading-none title-md" style="color: white; margin: 0 !important">
              <split-words
                class="split-words block"
                data-animate="fade-up-large"
                data-animate-delay="250"
              >
                EVERYTHING AT RISK
              </split-words>
            </h2>
            <div class="paragraph">
              Titan BattleGear delivers the highest level of cut resistance in hockey where it counts – neck and wrists.
              Play with confidence knowing you’re fully covered.
            </div>
          </div>
        </div>
        <!-- Slide 3 -->
        <div
          class="card product-card product-card--standard slide"
          style="flex: 1;"
          data-bg="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/slider_2.png?v=1753955892&width=1200"
          aria-label="Slide 3"
        >
          <div class="overlay"></div>
          <div class="slide-content text-block">
            <p class="subheading">COMFORT THAT</p>
            <h2 class="main heading leading-none title-md" style="color: white; margin: 0 !important">
              <split-words
                class="split-words block"
                data-animate="fade-up-large"
                data-animate-delay="250"
              >
                DOESN’T QUIT
              </split-words>
            </h2>
            <p class="paragraph">
              No bulk, no shifting, no distractions. Titan moves with you and keeps you cool under pressure so you can
              focus on the game, not the gear.
            </p>
          </div>
        </div>
      </motion-list>

      {%- if section.settings.heading == blank
        and section.settings.subheading == blank
        and section.settings.description == blank
      -%}
        {%- if section.settings.carousel_on_desktop -%}
          <div class="indicators hidden lg:flex gap-2d5 items-center absolute top-0 left-0 w-full h-full pointer-events-none opacity-0 page-width">
            <button
              class="button button--primary pointer-events-auto"
              type="button"
              is="previous-button"
              aria-controls="Slider-{{ section.id }}"
              aria-label="{{ 'general.pagination.previous' | t | escape }}"
              disabled
            >
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'chevron-left', class: 'stroke-2 transform' -%}
              </span>
            </button>
            <button
              class="button button--primary pointer-events-auto"
              type="button"
              is="next-button"
              aria-controls="Slider-{{ section.id }}"
              aria-label="{{ 'general.pagination.next' | t | escape }}"
            >
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'chevron-right', class: 'stroke-2 transform' -%}
              </span>
            </button>
          </div>
        {%- endif -%}
      {%- endif -%}
    </slider-element>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const slider = document.getElementById('Slider-{{ section.id }}');
    if (!slider) return;

    const deferredSlides = slider.querySelectorAll('.slide[data-bg]');
    if (!deferredSlides.length) return;

    function loadSlideBackground(slide) {
      if (!slide || !slide.dataset.bg || slide.dataset.bgLoaded === 'true') return;
      slide.style.backgroundImage = "url('" + slide.dataset.bg + "')";
      slide.dataset.bgLoaded = 'true';
    }

    deferredSlides.forEach(function (slide) {
      const rect = slide.getBoundingClientRect();
      if (rect.top < window.innerHeight + 300 && rect.bottom > -300) {
        loadSlideBackground(slide);
      }
    });

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            loadSlideBackground(entry.target);
            observer.unobserve(entry.target);
          });
        },
        { rootMargin: '300px 0px' }
      );

      deferredSlides.forEach(function (slide) {
        if (slide.dataset.bgLoaded !== 'true') observer.observe(slide);
      });
    } else {
      deferredSlides.forEach(loadSlideBackground);
    }
  });
</script>

