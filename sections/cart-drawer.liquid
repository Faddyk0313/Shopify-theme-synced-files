<script>
  document.addEventListener('DOMContentLoaded', function () {
    function showLoaderByKey(itemKey) {
      if (!itemKey) return;
      var loader = document.getElementById('Loader-{{ section.id }}-' + itemKey);
      if (loader) loader.removeAttribute('hidden');
    }

    function showLoaderFromTarget(target) {
      if (!target) return;
      var card = target.closest('.cart-item-card');
      if (!card) return;
      var input = card.querySelector('.cart-item-card__qty-input[data-index]');
      var itemKey = input ? input.getAttribute('data-index') : null;
      showLoaderByKey(itemKey);
    }

    document.addEventListener('click', function (e) {
      var removeLink = e.target.closest('a[is="cart-remove-button"], a[is="remove-gift-wrap"]');
      if (removeLink) {
        showLoaderByKey(removeLink.getAttribute('data-index'));
        return;
      }

      var qtyBtn = e.target.closest('.cart-item-card__qty-btn');
      if (qtyBtn) {
        showLoaderFromTarget(qtyBtn);
      }
    });

    document.addEventListener('change', function (e) {
      if (e.target && e.target.classList.contains('cart-item-card__qty-input')) {
        showLoaderFromTarget(e.target);
      }
    });

    function hideAllLoaders() {
      document.querySelectorAll('#CartDrawer .cart-item-card__loader').forEach(function (loader) {
        loader.setAttribute('hidden', '');
      });
    }

    document.addEventListener('cart:updated', hideAllLoaders);
    document.addEventListener('shopify:cart:change', hideAllLoaders);
    document.addEventListener('shopify:section:load', hideAllLoaders);
  });
</script>

{%- if customer.tags contains 'Wholesale-Gold'
  or customer.tags contains 'Wholesale-Silver'
  or customer.tags contains 'Wholesale-Bronze'
-%}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const warningModal = document.getElementById('warningMsg');
      const closeBtn = document.getElementById('warningModalCloseBtn');
      const overlay = document.getElementById('warningModalOverlay');
      const checkoutUrl = '/checkout'; // ← e.g. "/checkout"

      function showModal() {
        if (!warningModal) return;
        warningModal.removeAttribute('hidden');
        requestAnimationFrame(() => warningModal.setAttribute('active', ''));
      }

      function hideModal() {
        if (!warningModal) return;
        warningModal.removeAttribute('active');
        setTimeout(() => warningModal.setAttribute('hidden', ''), 300);
      }

      // close handlers
      if (closeBtn) closeBtn.addEventListener('click', hideModal);
      if (overlay) overlay.addEventListener('click', hideModal);

      // catch *any* click on #checkoutBtn, even if it was re-inserted via AJAX
      document.addEventListener('click', function (e) {
        const btn = e.target.closest('#checkoutBtn');
        if (!btn) return;

        e.preventDefault();
        const form = btn.closest('form');
        if (!form) return;

        /**
         * Read the subtotal label (e.g. "Rs.257,600.00 PKR") and return a Number: 257600
         */
        function getCartTotalFromDOM() {
          const el = document.querySelector('.totals__subtotal-value');
          if (!el) return 0;

          // e.g. "Rs.257,600.00 PKR"
          const text = el.textContent.trim();

          // Find the first group like "257,600.00"
          const match = text.match(/[\d,]+(?:\.\d+)?/);
          if (!match) return 0;

          // Remove thousands-sep commas → "257600.00"
          const numericString = match[0].replace(/,/g, '');

          const n = parseFloat(numericString);
          return isNaN(n) ? 0 : n;
        }

        const cartTotal = getCartTotalFromDOM();
        const MIN_TOTAL_USD = 1000;
        const activeCurrency = window?.Shopify?.currency?.active || 'USD';

        function continueCheckout() {
          hideModal();
          window.location.href = checkoutUrl;
        }

        if (activeCurrency === 'USD') {
          cartTotal < MIN_TOTAL_USD ? showModal() : continueCheckout();
          return;
        }

        // non-USD: fetch rate, convert, then decide
        fetch(`https://v6.exchangerate-api.com/v6/6185cb9540aea20c153f9c0f/latest/${activeCurrency}`)
          .then((res) => res.json())
          .then((data) => {
            const rateToUSD = data.conversion_rates?.USD || 1;
            const cartTotalInUSD = cartTotal * rateToUSD;
            cartTotalInUSD < MIN_TOTAL_USD ? showModal() : continueCheckout();
            // debug it:
            // alert(
            //   `rate (${activeCurrency}→USD): ${rateToUSD}\n` +
            //   `cart in USD: ${cartTotalInUSD.toFixed(2)}\n` +
            //   `DOM label: "${document.querySelector('.totals__subtotal-value').textContent}"\n` +
            //   `DOM label converted: "${cartTotal}"`
            // );
          })
          .catch((err) => {
            alert('Currency conversion failed:', err);
          });
      });
    });
  </script>
{% elsif customer.tags contains 'bronze-dealer' %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const warningModal = document.getElementById('warningMsg');
      const closeBtn = document.getElementById('warningModalCloseBtn');
      const overlay = document.getElementById('warningModalOverlay');
      const checkoutUrl = '/checkout'; // ← e.g. "/checkout"

      function showModal() {
        if (!warningModal) return;

        // Update heading
        const headingEl = warningModal.querySelector('.drawer__title');
        if (headingEl) headingEl.textContent = 'Minimum Order Quantity Required';

        // Update paragraph content
        const paragraphs = warningModal.querySelectorAll('.drawer__scrollable .rte');
        if (paragraphs.length >= 3) {
          paragraphs[0].textContent = 'To proceed to checkout, your cart must meet the minimum quantity of 50 items.';
          paragraphs[1].textContent =
            'This requirement ensures that we can continue offering exclusive dealer pricing and services.';
          paragraphs[2].textContent =
            'Please review your cart and add more items to reach the minimum order quantity before checking out.';
        }
        warningModal.removeAttribute('hidden');
        requestAnimationFrame(() => warningModal.setAttribute('active', ''));
      }

      function hideModal() {
        if (!warningModal) return;
        warningModal.removeAttribute('active');
        setTimeout(() => warningModal.setAttribute('hidden', ''), 300);
      }

      // close handlers
      if (closeBtn) closeBtn.addEventListener('click', hideModal);
      if (overlay) overlay.addEventListener('click', hideModal);

      // catch *any* click on #checkoutBtn, even if it was re-inserted via AJAX
      document.addEventListener('click', function (e) {
        const btn = e.target.closest('#checkoutBtn');
        if (!btn) return;

        e.preventDefault();
        const form = btn.closest('form');
        if (!form) return;

        function continueCheckout() {
          hideModal();
          window.location.href = checkoutUrl;
        }

        function getTotalItemCount(callback) {
          fetch('/cart.js')
            .then((res) => res.json())
            .then((cart) => {
              const totalQuantity = cart.items.reduce((sum, item) => sum + item.quantity, 0);
              callback(totalQuantity);
            })
            .catch((err) => {
              console.error('Error fetching cart:', err);
              callback(0); // fallback
            });
        }

        // usage:
        getTotalItemCount(function (totalItems) {
          const minRequired = 50;
          totalItems < minRequired ? showModal() : continueCheckout();
        });
      });
    });
  </script>
