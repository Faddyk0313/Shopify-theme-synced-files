{%- if request.page_type != 'cart' and settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer></script>
  {%- if settings.gift_wrap_product != blank and settings.gift_wrap_product.available -%}
    <script src="{{ 'gift-wrapping.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  <style>
    .oldDesign {
      display: none;
    }
  </style>

  {%- comment -%}TBG Custom Code{%- endcomment -%}
  <style>
    @media(max-width:500px) {
      .drawer__footer-bottom .discounts {
        padding-block-end: var(--sp-4) !important;
      }
      .drawer__footer-bottom {
        padding-top: var(--sp-4) !important;
        gap: var(--sp-1) !important;
      }
      .discounts-container {
        gap: var(--sp-4) !important;
      }

      .drawer__scrollable.relative.flex {
        gap: var(--sp-5);
      }
    }
    @media (min-width: 1024px) {
      .newDesign.drawer__scrollable {
        padding: var(--sp-4) var(--sp-12);
      }
    }
    @media (max-width: 1024px) {
      .newDesign.drawer__scrollable {
        padding: var(--sp-4) var(--sp-5);
      }
    }
  </style>
  <style>
    .rebuy-widget {
      padding-block: var(--sp-5);
    }
    .rebuy-widget .rebuy-product-block {
      padding-block: 15px !important;
    }
    .rebuy-widget, .rebuy-widget .rebuy-product-block:not(:first-child) {
      border-block-start: 1px solid rgb(var(--color-border-light));
    }
    .rebuy-widget .primary-title {
      text-transform: uppercase !important;
      margin: 0 !important;
    }
    .rebuy-widget .rebuy-product-title a {
      font-size: 15px !important;
      font-family: 'Inter', sans-serif !important;
      text-transform: uppercase !important;
    }
    .rebuy-widget .rebuy-money {
      font-size: 13px !important;
      color: black !important;
    }
    .rebuy-widget .rebuy-button {
      border-radius: 10px !important;
    }
    .rebuy-product-media {
      width: auto !important;
    }
  </style>
  <style>
    .cart-popup-additional-text p {
      color: #00adee;
      font-size: 15px;
      padding-top: 7.5px;
      padding-bottom: 7.5px;
      padding-inline: var(--sp-6);
      font-weight: 700;
    }
      .one-step-away {
      font-size: 15px;
      font-weight: 700;
        padding-top: 15px;
        padding-inline: var(--sp-6);
        text-transform: uppercase;
        color: black !important;
      }

      @media (min-width: 1123px) {
        .cart-popup-additional-text p {
      padding-inline: var(--sp-12);
    }
    .one-step-away {
      padding-inline: var(--sp-12);
    }

    }

      .diagonal-strike::after {
      content: "";
      position: absolute;
      top: 50%;
      left: 0;
      width: 100%;
      height: 1px;
      background: red;
      transform: rotate(-15deg); /* changed from -15deg to 15deg */
      transform-origin: center;
    }
  </style>
  <style>
    /* Modal inner content transition */
    #warningMsg[active] .drawer__inner {
      opacity: 1;
      transform: scale(1);
      transition: all .8s cubic-bezier(.7,0,.2,1);
      pointer-events: all !important;

    }

    #warningMsg:not([active]) .drawer__inner {
      opacity: 0;
      transform: scale(0.95);
      pointer-events: none;
    }

    /* Overlay fade */
    #warningModalOverlay {
      background-color: rgb(var(--color-overlay) / .7); /* semi-transparent bg */
      transition: all .8s cubic-bezier(.7,0,.2,1);
      opacity: 0;
      pointer-events: none;
    }

    #warningMsg[active] #warningModalOverlay {
      opacity: 1;
      pointer-events: all;
    }

    @media (max-width: 640px) {
      #warningMsg {
        transition: all .8s cubic-bezier(.7,0,.2,1);
        opacity: 1;
        transform: translateY(100%);
      }

      #warningMsg:not([active]) .drawer__inner {
        opacity: 1;
        pointer-events: none;
      }

      #warningMsg[active] {
        pointer-events: all;
        transform: translateY(0);
      }

      #warningMsg #warningModalOverlay {
      transition: all 2s cubic-bezier(.7,0,.2,1);
        transform: translate(0px);
      }
      #warningMsg[active] #warningModalOverlay {
        opacity: 1;

      }
    }


    [data-rounded-block=round] .drawer--end .drawer__inner {
      border-end-start-radius: clamp(0.625rem, 1.053vw, 1.25rem);
      border-start-start-radius: clamp(0.625rem, 1.053vw, 1.25rem);
    }
  </style>

  <style>
    #shopify-section-{{ section.id }} {
      --section-padding-top: {{ section.settings.padding_top }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .diagonal-strike {
      color: gray;
      position: relative;
    }
    .diagonal-strike::after {
      content: "";
      position: absolute;
      top: 50%;
      left: 0;
      width: 100%;
      height: 1px;
      background: red;
      transform: rotate(-15deg); /* changed from -15deg to 15deg */
      transform-origin: center;
    }
    h1.cartheading {
      font-size: 42px;
      margin: 0;
    }
    .cartheading {
      font-size: 36px;
      margin-top: 7px;
    }
    .savingsLine {
      font-size: 17px;
    }
    .titleWrapperCont {
      gap: var(--sp-8)
    }

    #mobileiconssvg {
      display: none
    }
    .desktopiconssvg {
      display: block
    }
    .desktopVer.cart__sidebar {
      border-radius: var(--rounded-button);
      padding: 1.3rem !important;
      background-color: white !important;
    }
    .cart__sidebar .totals {
      padding-block: var(--sp-6) !important;
      border-block-start: 1px solid rgb(var(--color-border-light)) !important;
      border-block-end: 1px solid rgb(var(--color-border-light)) !important;
    }
    .cart-item-card {
      position: relative;
      background: #f2f2f2;
      border-radius: var(--rounded-button);
      padding: 1rem;
      {% comment %} border: 1px solid rgb(var(--color-border-light));
      box-shadow: 0 16px 35px rgba(15, 15, 15, 0.08); {% endcomment %}
    }
    .cart-item-card__remove {
      position: absolute;
      top: 1rem;
      right: 1rem;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      z-index: 2;
    }
    .cart-item-card__loader {
      top: 0.15rem;
      right: 2rem;
      display: flex;
      justify-content: center;
    }
    .cart-item-card__loader[hidden] {
      display: none !important;
    }
    .cart-item-card__remove-link {
      width: 18px;
      height: 18px;
      display: grid;
      place-items: center;
    }
    .cart-item-card__remove-icon {
      width: 100%;
      height: 100%;
    }
    .cart-item-card__media {
      flex-shrink: 0;
      width: 90px;
    }
    .noDiscount.cart-item-card__media {
      flex-shrink: 0;
      width: 80px;
      scale: 1.2;
    }
    .cart-item-card__media .media {
      width: 100%;
      height: 100%;
    }
    .cart-item-card__media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .cart-item-card__details {
      min-width: 0;
      padding-right: 0.25rem;
    }
    .cart-item-card__content {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .cart-item-card__media-details {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .desktop.cart-item-card__price-info {
      display: none;
    }
    .mobile.cart-item-card__price-info {
      display: flex;
      align-self: baseline;
    }
    .desktop.cart-item-card__quantity-column {
      display: none;
    }
    .mobile.cart-item-card__quantity-column {
      display: flex;
    }
    .cart-item-card__price-info {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      align-items: start !important;
    }
    .cart-item-card__line-total {
      font-weight: 600;
      display: flex;
      justify-content: flex-end;
      min-width: 130px;
    }
    .cart-item-card__quantity-column {
      display: flex;
      justify-content: flex-end;
    }
    .flexContainer {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: end;
    }
    .cart-item-card__price-info .discounts__discount {
      background-color: #00adee;
      border-radius: 4px;
      padding-right: 0.6rem;
    }
    .cart-item-card__price-info .discounts__discount .badge.badge--highlight {
      border-radius: 4px !important;
    }
    .cart-item-card__price-info .discounts .badge--highlight {
      background-color: #baeaf7;
      color: #4aa3e7;
      font-weight: 600;
      font-size: clamp(0.4rem,0.5rem, 0.5rem);
    }
    .cart-item-card__price-info .discounts .badge--onsale {
      background-color: transparent !important;
      padding: 0 !important;
      font-size: clamp(0.4rem,0.5rem, 0.5rem);
    }

    #cus_upsell_banner.mobile,
    .cus_free-shipping.mobile {
      display: flex;
    }
    #cus_upsell_banner.desktop,
    .cus_free-shipping.desktop {
      display: none;
    }
    .cart__item-title, .horizontal-product__title {
      font-size:14px;
      font-family: 'Armourxbd';
      text-transform: uppercase;
    }
    .cart-item-card__quantity-input {
      display: flex;
      align-items: center;
      padding: 0.25rem;
      background: #fff;
      border-radius: 8px;
      border: 1px solid transparent;
      width: fit-content !important;
      height: fit-content !important;
      max-width: 90px;
    }
    .cart-item-card__quantity-input:focus-within {
      border-color: rgba(0, 0, 0, 0.2);
    }
    .cart-item-card__quantity-input--disabled {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.35rem 0.75rem;
      background: #f4f4f4;
      border-radius: 999px;
      border: 1px solid transparent;
    }
    .cart-item-card__qty-input {
      background: transparent;
      border: none;
      min-width: 20px;
      max-width: 30px;
      font-weight: 600;
      text-align: center;
      padding-inline: 0 !important;
    }
    .cart-item-card__qty-input:focus-visible {
      outline: none;
    }
    .cart-item-card__qty-btn {
      border: none;
      background: transparent;
      padding: 0.2rem 0.45rem;
      font-size: 1.25rem;
      line-height: 1;
      color: inherit;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }
    .summary_heading {
      font-size: 20px;
    }
    .cus_free-shipping .free-shipping-bar {
      padding: 0 !important;
    }
    .desktop .complementary-products__header {
      padding-bottom: 2rem;
    }
    .newDesign .drawer__footer-bottom {
      padding-top: 0 !important;
      padding-bottom: 16px !important;
    }
    .oldDesign .drawer__footer-bottom {
      padding-bottom: 16px !important;
    }
    .cartHeading.drawer__header {
      padding-top: 1rem;
      padding-bottom: 1rem;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    @media (max-width: 768px) {
      .cartHeading.drawer__header::before {
        content: none !important;
      }
      .drawer__inner:has(.newDesign) {
        border-radius: 0 !important;
        min-height: 100dvh !important;
      }
      .drawer__close::after {
        border: 1px solid rgb(var(--color-button-border) / var(--border-opacity)) !important;
      }
      .drawer__close {
        width: 2.5rem !important;
        height: 2.5rem !important;
        --buttons-border-width: 1px !important;
        right: 4px !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        opacity: 1 !important;
        pointer-events: all !important;
      }
      .cart-item-card__price-info .discounts__discount {
        padding-right: 0.3rem;
      }
      .cart-item-card__qty-btn[name='minus'] {
        padding-block: 0.2rem !important;
        padding-left: 0.45rem !important;
        padding-right: 0 !important;
      }
      .cart-item-card__qty-btn[name='plus'] {
        padding-block: 0.2rem !important;
        padding-right: 0.45rem !important;
        padding-left: 0 !important;
      }
      .cart-quantity.cart-item-card__quantity-input {
        padding: 0 !important;
      }
      .cart-item-card__quantity-input {
        font-size: 12px;
      }
      .cart-item-card {
        padding: 0.6rem;
      }
      .cart-item-card__remove {
        top: 0.75rem;
        right: 0.75rem;
      }
      .cart-item-card__line-total {
        min-width: 0;
      }
    }
    @media (max-width:1024px){
      .titleCont.desktop {
        display: none;
      }
      #cart-heading-with-total{
        {% comment %} flex-direction: column; {% endcomment %}
        align-items: center;
        justify-content: center;
      }
      #cart-heading-with-total *{
        width: fit-content;
      }
      .savingsLine {
        width: fit-content;
        margin: auto;
      }
      h1.cartheading {
        font-size: 22px;
      }
      .cartheading {
        font-size: 18px;
        margin-top: 5px;

      }
      .buttonStack .btn-text {
        font-size: 10px
      }
      .title-wrapper {
        margin-bottom: 32px
      }
      .titleWrapperCont {
        gap: var(--sp-4)
      }
      .cart__content {
        gap: var(--sp-3) !important;
      }
      .horizontal-product__title,
      .product-card__title {
        font-size: 12px;
      }
      #mobileiconssvg {
        display: block
      }
      {% comment %} #desktopiconssvg {
        display: none;
      } {% endcomment %}

      .cart-item td:not(.cart-item__quantity) {
        padding-inline: 0 !important;
      }
      .govx-id-full-wrapper {
        display: none;
      }
      .cart-item__media {
        width: 65px !important;
      }
      .cart__sidebar .totals {
        padding-block: var(--sp-3) !important;
        border-block-start: 1px solid rgb(var(--color-border-light)) !important;
        border-block-end: 1px solid rgb(var(--color-border-light)) !important;
      }
      .stickyCheckout {
        position: sticky;
        bottom: 0;
        left: 0;
        z-index: 20;
        border-radius: 0;
        margin-bottom: 0.5rem;
      }
      .cartHeading.drawer__header {
        {% comment %} padding-inline: 0; {% endcomment %}
        transform: translateX(-4px);
        padding-top: 1.5rem;
        padding-bottom: 0.5rem;
        display: flex;
        justify-content: center;
      }
    }
  </style>

  {% assign wholesale_discount = 0 %}
  {% if customer %}
    {% assign tags = customer.tags %}
    {% if tags contains 'Wholesale-Gold' %}
      {% assign wholesale_discount = 0.44 %}
    {% elsif tags contains 'Wholesale-Silver' %}
      {% assign wholesale_discount = 0.37 %}
    {% elsif tags contains 'Wholesale-Bronze' %}
      {% assign wholesale_discount = 0.30 %}
    {% elsif tags contains 'gold-dealer' %}
      {% assign wholesale_discount = 0.30 %}
    {% elsif tags contains 'silver-dealer' %}
      {% assign wholesale_discount = 0.25 %}
    {% elsif tags contains 'bronze-dealer' %}
      {% assign wholesale_discount = 0.20 %}
    {% endif %}
  {% endif %}
  {%- comment -%}TBG Custom Code{%- endcomment -%}

  {%- liquid
    assign section_rendering_api = false
    if section.index == null
      assign section_rendering_api = true
    endif
  -%}
  <cart-drawer
    id="CartDrawer"
    class="cart-drawer drawer drawer--end z-35 fixed bottom-0 left-0 h-full w-full pointer-events-none"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'general.cart.title' | t | escape }}"
    data-section-id="{{ section.id }}"
    shopify-design-mode
    hidden
  >
    <overlay-element
      class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none"
      aria-controls="CartDrawer"
      aria-expanded="false"
    ></overlay-element>
    <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
      <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative" tabindex="0">
        <ul class="drawer__tabs flex gap-10" is="tab-list">
          <li>
            <button
              class="drawer__tab relative"
              type="button"
              aria-controls="MiniCart-{{ section.id }}"
              aria-expanded="true"
            >
              <span class="drawer__title heading lg:text-3xl text-2xl leading-none tracking-tight">
                {{- 'general.cart.title' | t -}}
              </span>
              <cart-count
                class="count absolute font-medium text-xs lg:text-sm leading-none"
                aria-label="{{ 'general.cart.cart_count' | t: count: cart.item_count | escape }}"
                {% if cart == empty %}
                  hidden
                {% endif %}
              >
                {{- cart.item_count -}}
              </cart-count>
            </button>
          </li>
          {%- if section.settings.recent_products_enabled -%}
            <li>
              <button
                class="drawer__tab"
                type="button"
                aria-controls="RecentlyViewed-{{ section.id }}"
                aria-expanded="false"
              >
                <span class="drawer__title heading lg:text-3xl text-2xl leading-none tracking-tight">
                  {{- section.settings.recent_products_heading | escape -}}
                </span>
              </button>
            </li>
          {%- endif -%}
        </ul>
        <button
          class="button button--secondary button--close drawer__close hidden sm:flex items-center justify-center"
          type="button"
          is="hover-button"
          aria-controls="CartDrawer"
          aria-expanded="false"
          aria-label="{{ 'general.accessibility.close' | t | escape }}"
        >
          <span class="btn-fill" data-fill></span>
          <span class="btn-text">
            {%- render 'icon', icon: 'close', size: 'sm' -%}
          </span>
        </button>
      </gesture-element>

      <div class="drawer__content opacity-0 invisible flex flex-col h-full grow shrink">
        <div id="MiniCart-{{ section.id }}" class="drawer__panel opacity-0 flex flex-col overflow-hidden" open>
          <span class="sr-only">{{ 'general.cart.title' | t }}</span>
          <div class="flex flex-col h-full">
            {%- if cart == empty -%}
              <div class="drawer__scrollable relative flex justify-center items-start grow shrink text-center">
                <div class="drawer__empty grid gap-5 md:gap-8">
                  <p class="drawer__empty-text h2 heading leading-none tracking-tight">
                    {{ 'cart.general.empty' | t }}
                  </p>
                  <div class="drawer__empty-message text-sm md:text-base leading-tight rte">
                    {{- section.settings.empty_cart_message -}}
                  </div>
                  <ul class="drawer__empty-collections grid gap-3">
                    {%- if section.settings.empty_cart_collections == blank -%}
                      <li>
                        <a class="flex items-center justify-between" href="{{ routes.all_products_collection_url }}">
                          <span class="flex items-center">{{ 'cart.general.continue_shopping' | t }}</span>
                          {%- render 'icon', icon: 'arrow-right', size: 'sm', class: 'transform' -%}
                        </a>
                      </li>
                    {%- else -%}
                      {%- for item in section.settings.empty_cart_collections -%}
                        <li>
                          <a class="flex items-center justify-between" href="{{ item.url }}">
                            <span class="flex items-center gap-3">
                              {%- if item.metafields.theme.icon.value != blank -%}
                                {%- assign icon_alt = item.metafields.theme.icon.value.alt
                                  | default: item.title
                                  | escape
                                -%}
                                {%- assign max_width = item.metafields.theme.icon.value.width -%}
                                {%- capture sizes -%}36px{%- endcapture -%}
                                {%- capture widths -%}{{ 36 | times: 1.5 | at_most: max_width | round }}, {{ 36 | times: 2 | at_most: max_width }}, {{ 36 | times: 3 | at_most: max_width }}{%- endcapture -%}
                                {{-
                                  item.metafields.theme.icon.value
                                  | image_url: width: max_width
                                  | image_tag:
                                    loading: 'lazy',
                                    sizes: sizes,
                                    widths: widths,
                                    alt: icon_alt,
                                    is: 'lazy-image'
                                -}}
                              {%- endif -%}
                              {{- item.title -}}
                            </span>
                            {%- render 'icon', icon: 'arrow-right', size: 'sm', class: 'transform' -%}
                          </a>
                        </li>
                      {%- endfor -%}
                    {%- endif -%}
                  </ul>
                </div>
              </div>
            {%- endif -%}
            <div class="newDesign drawer__scrollable flex flex-col gap-3 md:gap-5 grow shrink{% if cart == empty %} hidden{% endif %}">
              {%- liquid
                if section.settings.show_free_shipping_bar and section.settings.free_shipping_minimum_amount != blank
                  assign minimum_amounts = section.settings.free_shipping_minimum_amount | remove: ' '
                  assign show_free_shipping_bar = false

                  if minimum_amounts contains ':'
                    assign minimum_amounts = minimum_amounts | split: ','
                    for amount in minimum_amounts
                      assign amount_parts = amount | split: ':'
                      assign currency_code = amount_parts | first | upcase
                      if currency_code == cart.currency.iso_code
                        assign minimum_amount = amount_parts | last
                        assign show_free_shipping_bar = true
                        break
                      endif
                    endfor
                  else
                    assign minimum_amount = minimum_amounts
                    assign show_free_shipping_bar = true
                  endif

                  if show_free_shipping_bar
                    render 'free-shipping-bar', minimum_amount: minimum_amount
                  endif
                endif
              -%}

              {%- liquid
                if settings.gift_wrap_product != blank and settings.gift_wrap_product.available
                  assign enable_gift_wrapping = true

                  assign gift_wrap_product = settings.gift_wrap_product
                  assign gift_wrap_variant = gift_wrap_product.first_available_variant
                  assign gift_wrap_per_product = settings.gift_wrap_per_product
                  assign gift_items = cart.items | where: 'variant_id', gift_wrap_variant.id

                  unless gift_wrap_per_product
                    assign gift_wraps_in_cart = 0
                    for item in gift_items
                      assign gift_wraps_in_cart = gift_wraps_in_cart | plus: item.quantity
                    endfor
                  endunless
                endif

                assign cart_gift_wrap_items = null
              -%}
              <cart-items class="block grow" data-section-id="{{ section.id }}">
                {% comment %} Tbg custom code {% endcomment %}
                {% comment %} <ul class="horizontal-products grid" role="list"> {% endcomment %}
                <div class="cart-item-list grid gap-3 md:gap-5">
                  {%- for item in cart.items -%}
                    {%- liquid
                      assign is_gift_wrap_item = false
                      if gift_wrap_variant != null and item.id == gift_wrap_variant.id
                        assign is_gift_wrap_item = true
                      endif
                    -%}
                    {% comment %} Tbg custom code - replace below whole block with {%- capture cart_item_new -%} {% endcomment %}
                    {%- capture cart_item_new -%}
                      <article class="cart-item-card" id="CartItem-{{ item.key }}">
                        <div class="cart-item-card__content">
                          <div class="cart-item-card__media-details flex items-start md:items-center gap-4d5 md:gap-10">
                            <div class="{%- if item.line_level_discount_allocations == blank -%} noDiscount {% endif %} cart-item-card__media">
                              {%- if item.image -%}
                                {%- unless is_gift_wrap_item -%}
                                  <a class="cart-item__media media relative overflow-hidden shrink-0" href="{{ item.url }}">
                                    {%- assign max_width = item.image.width -%}
                                    {%- capture widths -%}{{ 96 | times: 1.5 | at_most: max_width | round }}, {{ 96 | times: 2 | at_most: max_width }}, {{ 96 | times: 3 | at_most: max_width }}{%- endcapture -%}
                                    {{- item.image | image_url: width: max_width | image_tag: loading: 'lazy', widths: widths, is: 'lazy-image' -}}
                                  </a>
                                {%- else -%}
                                  <figure class="cart-item__media media relative overflow-hidden shrink-0">
                                    {{- item.image | image_url: width: item.image.width | image_tag: loading: 'lazy', widths: '180,360,540', is: 'lazy-image' -}}
                                  </figure>
                                {%- endunless -%}
                              {%- endif -%}
                            </div>
                            <div class="cart-item-card__details grow flex flex-col justify-start gap-1d5">
                              <div class="grid gap-1">
                                <div class="block leading-tight">
                                  {%- unless is_gift_wrap_item -%}
                                    {%- if section.settings.show_vendor -%}
                                      <p class="text-xs text-opacity">{{ item.product.vendor }}</p>
                                    {%- endif -%}
                                    <a href="{{ item.url }}" class="cart__item-title horizontal-product__title reversed-link font-medium text-base leading-tight">
                                      {% assign title_parts = item.product.title | split: ' - ' %}
                                      {{ title_parts[0] | escape }}<br>
                                      {{ title_parts[1] | escape }}
                                    </a>
                                  {%- else -%}
                                    <p class="font-medium text-base leading-tight">{{ item.product.title | escape }}</p>
                                  {%- endunless -%}
                                </div>
                                {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != null -%}
                                  <dl class="grid gap-1d5">
                                    {%- unless item.product.has_only_default_variant -%}
                                      {%- for option in item.options_with_values -%}
                                        <div class="text-xs text-opacity leading-tight">
                                          <dt class="sr-only">{{ option.name }}:</dt>
                                          <dd class="inline">{{ option.value }}</dd>
                                        </div>
                                      {%- endfor -%}
                                    {%- endunless -%}
                                    {%- for property in item.properties -%}
                                      {%- assign property_first_char = property.first | slice: 0 -%}
                                      {%- if property.last != blank and property_first_char != '_' -%}
                                        <div class="text-xs text-opacity leading-tight">
                                          <dt class="inline">{{ property.first }}:&nbsp;</dt>
                                          <dd class="inline">
                                            {%- if property.last contains '/uploads/' -%}
                                              <a href="{{ property.last }}" class="link" target="_blank" aria-describedby="a11y-new-window-message">
                                                {{- property.last | split: '/' | last -}}
                                              </a>
                                            {%- else -%}
                                              {{- property.last -}}
                                            {%- endif -%}
                                          </dd>
                                        </div>
                                      {%- endif -%}
                                    {%- endfor -%}
                                  </dl>
                                  {%- if item.selling_plan_allocation != null -%}
                                    <p class="text-xs text-opacity">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                                  {%- endif -%}
                                {%- endif -%}
                                <div class="flexContainer">
                                  <div class="mobile cart-item-card__price-info ">
                                    <div class="price{% if item.original_price != item.final_price %} price--on-sale{% endif %} text-sm flex flex-wrap gap-1d5">
                                      {%- liquid
                                        assign money_price = item.original_price | money
                                        if settings.currency_code_enabled
                                          assign money_price = item.original_price | money_with_currency
                                        endif
                                      -%}
                                      {%- if item.original_price != item.final_price -%}
                                        <span class="sr-only">{{ 'products.price.regular_price' | t }}</span>
                                        <span class="price__sale inline-flex items-center relative">{{ money_price }}</span>
                                        <span class="sr-only">{{ 'products.price.sale_price' | t }}</span>
                                        <span class="price__regular whitespace-nowrap">
                                          {%- liquid
                                            if settings.currency_code_enabled
                                              echo item.final_price | money_with_currency
                                            else
                                              echo item.final_price | money
                                            endif
                                          -%}
                                        </span>
                                      {%- else -%}
                                        <span class="price__regular whitespace-nowrap">{{ money_price }}</span>
                                      {%- endif -%}

                                      {%- if item.variant.available and item.unit_price_measurement -%}
                                        <span class="sr-only">{{ 'products.price.unit_price' | t }}</span>
                                        <span class="unit-price flex items-center">
                                          {%- liquid
                                            capture unit_price_base_unit
                                              if item.variant.unit_price_measurement
                                                if item.variant.unit_price_measurement.reference_value != 1
                                                  echo item.variant.unit_price_measurement.reference_value
                                                endif
                                                echo item.variant.unit_price_measurement.reference_unit
                                              endif
                                            endcapture
                                          -%}
                                          ({{ item.variant.unit_price | money }}
                                          <span aria-hidden="true">/</span>
                                          <span class="sr-only">&nbsp;{{ 'general.accessibility.unit_price_separator' | t }}&nbsp;</span>
                                          {{ unit_price_base_unit }})
                                        </span>
                                      {%- endif -%}
                                    </div>
                                    {%- if item.line_level_discount_allocations != blank -%}
                                      <ul class="discounts grid gap-2" role="list" aria-label="{{ 'customer.order.discounts' | t | escape }}">
                                        {%- for discount_allocation in item.line_level_discount_allocations -%}
                                          {%- if discount_allocation.amount > 0 -%}
                                            <li class="discounts__discount text-xs flex items-center gap-1">
                                              <span class="badge badge--highlight flex items-center gap-1d5 font-medium leading-none">{{ discount_allocation.discount_application.title }}</span>
                                              <span class="badge badge--onsale flex items-center gap-1d5 font-medium leading-none">-{{ discount_allocation.amount | money }}</span>
                                            </li>
                                          {%- endif -%}
                                        {%- endfor -%}
                                      </ul>
                                    {%- endif -%}
                                    {%- liquid
                                      unless is_gift_wrap_item
                                        if gift_wrap_per_product
                                          render 'gift-wrap-selector', gift_wrap_variant: gift_wrap_variant, line_item: item, section_id: section.id, context: 'page'
                                        endif
                                      endunless
                                    -%}
                                  </div>
                                  <div class="mobile cart-item-card__quantity-column">
                                    {%- liquid
                                      assign has_qty_rules = false
                                      if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                                        assign has_qty_rules = true
                                      endif

                                      assign has_vol_pricing = false
                                      if item.variant.quantity_price_breaks.size > 0
                                        assign has_vol_pricing = true
                                      endif
                                    -%}
                                    {%- if has_qty_rules or has_vol_pricing -%}
                                      {%- capture qty_rules_vol_pricing -%}
                                        {%- if has_qty_rules -%}
                                          <div class="quantity__rules text-sm font-medium leading-tight">
                                            {%- if item.variant.quantity_rule.increment > 1 -%}
                                              <span class="divider">
                                                {{- 'products.quantity.multiples_of' | t: quantity: item.variant.quantity_rule.increment -}}
                                              </span>
                                            {%- endif -%}
                                            {%- if item.variant.quantity_rule.min > 1 -%}
                                              <span class="divider">
                                                {{- 'products.quantity.min_of' | t: quantity: item.variant.quantity_rule.min -}}
                                              </span>
                                            {%- endif -%}
                                            {%- if item.variant.quantity_rule.max != null -%}
                                              <span class="divider">
                                                {{- 'products.quantity.max_of' | t: quantity: item.variant.quantity_rule.max -}}
                                              </span>
                                            {%- endif -%}
                                          </div>
                                        {%- endif -%}
                                        {%- if has_vol_pricing -%}
                                          {{ 'volume-pricing.css' | asset_url | stylesheet_tag }}
                                          <volume-pricing class="volume-pricing grid gap-6">
                                            <span class="caption-large font-medium">{{ 'products.volume_pricing.title' | t }}</span>
                                            <ul class="list-unstyled">
                                              <li class="text-sm flex gap-2d5 justify-between">
                                                <span class="font-medium">{{ item.variant.quantity_rule.min }}+</span>
                                                {%- assign price = item.variant.price | money_with_currency -%}
                                                <span> {{ 'sections.quick_order_list.each' | t: money: price }}</span>
                                              </li>
                                              {%- for price_break in item.variant.quantity_price_breaks -%}
                                                <li class="text-sm flex gap-2d5 justify-between">
                                                  <span class="font-medium">
                                                    {{- price_break.minimum_quantity -}}
                                                    <span aria-hidden="true">+</span>
                                                  </span>
                                                  {%- assign price = price_break.price | money_with_currency -%}
                                                  <span> {{ 'sections.quick_order_list.each' | t: money: price }}</span>
                                                </li>
                                              {%- endfor -%}
                                            </ul>
                                          </volume-pricing>
                                        {%- endif -%}
                                      {%- endcapture -%}
                                    {%- endif -%}
                                    <div class="cart-quantity__info grid md:flex items-center justify-end md:justify-start gap-3 md:gap-4">
                                      {%- if has_qty_rules or has_vol_pricing -%}
                                        <hover-element class="hotspot hidden md:flex items-center justify-center relative cursor-pointer">
                                          {%- render 'icon', icon: 'info', size: 'lg' -%}
                                          <div class="hotspot__content absolute z-1 pointer-events-none cursor-default grid gap-6 items-center text-left">
                                            {{- qty_rules_vol_pricing -}}
                                          </div>
                                        </hover-element>
                                      {%- endif -%}
                                      {%- unless is_gift_wrap_item -%}
                                        <quantity-input class="cart-quantity cart-item-card__quantity-input">
                                          <button type="button" name="minus" class="cart-item-card__qty-btn" aria-label="{{ 'products.quantity.decrease' | t: product: item.product.title | escape }}">
                                            <span aria-hidden="true">-</span>
                                          </button>
                                          <input class="quantity__input input cart-item-card__qty-input"
                                            type="number"
                                            name="updates[]"
                                            aria-label="{{ 'products.quantity.input_label' | t: product: item.product.title | escape }}"
                                            id="Quantity-{{ section.id }}-{{ item.key }}"
                                            data-index="{{ item.key }}"
                                            inputmode="numeric"
                                            autocomplete="off"
                                            data-quantity-variant-id="{{ item.variant.id }}"
                                            data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                            min="0"
                                            data-min="{{ item.variant.quantity_rule.min }}"
                                            {% if item.variant.quantity_rule.max != null %}
                                              max="{{ item.variant.quantity_rule.max }}"
                                            {% endif %}
                                            step="{{ item.variant.quantity_rule.increment }}"
                                            value="{{ item.quantity }}"
                                          />
                                          <button type="button" name="plus" class="cart-item-card__qty-btn" aria-label="{{ 'products.quantity.increase' | t: product: item.product.title | escape }}">
                                            <span aria-hidden="true">+</span>
                                          </button>
                                        </quantity-input>
                                      {%- else -%}
                                        <div class="cart-item-card__quantity-input cart-item-card__quantity-input--disabled">
                                          <label class="sr-only" for="Quantity-{{ section.id }}-{{ item.key }}">
                                            {{- 'products.quantity.label' | t -}}
                                          </label>
                                          <input class="quantity__input input cart-item-card__qty-input"
                                            type="number"
                                            name="updates[]"
                                            aria-label="{{ 'products.quantity.input_label' | t: product: item.product.title | escape }}"
                                            id="Quantity-{{ section.id }}-{{ item.key }}"
                                            data-index="{{ item.key }}"
                                            inputmode="numeric"
                                            autocomplete="off"
                                            data-quantity-variant-id="{{ item.variant.id }}"
                                            data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                            min="0"
                                            data-min="{{ item.variant.quantity_rule.min }}"
                                            {% if item.variant.quantity_rule.max != null %}
                                              max="{{ item.variant.quantity_rule.max }}"
                                            {% endif %}
                                            step="{{ item.variant.quantity_rule.increment }}"
                                            value="{{ item.quantity }}"
                                            disabled
                                          />
                                        </div>
                                      {%- endunless -%}
                                      {%- if has_qty_rules or has_vol_pricing -%}
                                        <button type="button" class="md:hidden flex items-center justify-center" aria-controls="VolumePricing-{{ section.id }}-{{ item.key }}" aria-expanded="false">
                                          {%- render 'icon', icon: 'info', size: 'sm' -%}
                                        </button>
                                        <x-modal id="VolumePricing-{{ section.id }}-{{ item.key }}" class="x-modal drawer z-30 fixed bottom-0 left-0 h-full w-full pointer-events-none"
                                          role="dialog"
                                          aria-modal="true"
                                          aria-label="{{ item.product.title | escape }}"
                                          hidden
                                        >
                                          <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="VolumePricing-{{ section.id }}-{{ item.key }}" aria-expanded="false"></overlay-element>
                                          <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
                                            <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative" tabindex="0">
                                              <span class="drawer__title heading title-md grid gap-4">
                                                {{ item.product.title | escape }}
                                                {%- unless item.product.has_only_default_variant -%}
                                                  <dl class="grid gap-1d5">
                                                    {%- for option in item.options_with_values -%}
                                                      <div class="text-xs text-opacity leading-tight">
                                                        <dt class="sr-only">{{ option.name }}:</dt>
                                                        <dd class="inline">{{ option.value }}</dd>
                                                      </div>
                                                    {%- endfor -%}
                                                  </dl>
                                                {%- endunless -%}
                                              </span>
                                              <button class="button button--secondary button--close drawer__close hidden sm:flex items-center justify-center" type="button" is="hover-button" aria-controls="VolumePricing-{{ section.id }}-{{ item.key }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
                                                <span class="btn-fill" data-fill></span>
                                                <span class="btn-text">
                                                  {%- render 'icon', icon: 'close', size: 'sm' -%}
                                                </span>
                                              </button>
                                            </gesture-element>
                                            <div class="drawer__content opacity-0 invisible flex flex-col h-full grow shrink">
                                              <div class="drawer__scrollable relative flex flex-col gap-5 md:gap-7 grow shrink">
                                                <div class="text-base md:text-lg grid gap-6">
                                                  {{- qty_rules_vol_pricing -}}
                                                </div>
                                              </div>
                                            </div>
                                          </div>
                                        </x-modal>
                                      {%- endif -%}
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                          <div class="cart-item-card__remove">
                            <div id="Loader-{{ section.id }}-{{ item.key }}" class="cart-item-card__loader loader absolute right-0" hidden>
                              {%- render 'icon', icon: 'rotator', size: 'xs', class: 'animate-rotator' -%}
                            </div>
                            <a class="cart-item-card__remove-link" href="{{ item.url_to_remove }}"{% unless is_gift_wrap_item %} is="cart-remove-button"{% else %} is="remove-gift-wrap"{% endunless %} data-index="{{ item.key }}" data-no-instant aria-label="{{ 'cart.general.remove' | t }}">
                              <span class="sr-only">{{ 'cart.general.remove' | t }}</span>
                              <img class="cart-item-card__remove-icon" width="20px" height="30px" src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/TRASH_ICON_06bf17b7-c8a1-45a9-94db-fbafd8b768e3.svg?v=1769438230" />
                            </a>
                          </div>
                        </div>
                      </article>
                    {%- endcapture -%}

                    {%- liquid
                      unless is_gift_wrap_item
                        comment
                          tbg custom code
                          echo cart_item
                        endcomment
                        echo cart_item_new
                      else
                        assign cart_gift_wrap_items = cart_gift_wrap_items | append: cart_item
                      endunless
                    -%}
                  {%- endfor -%}

                  {%- liquid
                    unless gift_wrap_per_product
                      if cart_gift_wrap_items != null
                        echo cart_gift_wrap_items
                      endif
                    endunless
                    -%}
                </div>
                {% comment %} Tbg custom code </ul> {% endcomment %}
              </cart-items>

              {%- liquid
                if enable_gift_wrapping
                  if gift_wrap_per_product
                    render 'gift-wrapping-list-horizontal', gift_items: gift_items, section_id: section.id
                  else
                    render 'gift-wrapping', gift_wrap_variant: gift_wrap_variant, gift_wraps_in_cart: gift_wraps_in_cart, section_id: section.id
                  endif
                endif
              -%}

              {%- if cart != empty and section.settings.cart_recommendations_enabled -%}
                {%- liquid
                  assign first_product_id = cart.items.first.product_id
                  if enable_gift_wrapping
                    assign cart_items = cart.items | reject: 'variant_id', gift_wrap_variant.id
                    assign first_product_id = cart_items.first.product_id
                  endif
                -%}
                {%- if first_product_id != blank -%}
                  {%- render 'product-complementary',
                    section_id: section.id,
                    product_id: first_product_id,
                    image_ratio: settings.product_image_ratio,
                    image_fill: settings.product_image_fill,
                    limit: section.settings.cart_recommendations_limit,
                    heading: section.settings.cart_recommendations_heading,
                    show_vendor: section.settings.show_cart_recommendations_vendor,
                    show_price: section.settings.show_cart_recommendations_price,
                    recommendations_products: section.settings.cart_recommendations_products
                  -%}
                {%- endif -%}
              {%- endif -%}
              <div class="cart__sidebar grid gap-3" {{ block.shopify_attributes }}>
                <p
                  class="summary_heading"
                  style="
                    font-family: 'Armourxbd';
                    text-transform: uppercase;
                    padding-bottom: 0.5rem;
                    {% comment %} border-block-end: 1px solid rgb(var(--color-border-light)) !important; {% endcomment %}
                  "
                >
                  ORDER SUMMARY
                </p>
                {%- if cart.cart_level_discount_applications.size > 0 -%}
                  <ul
                    class="discounts grid gap-2"
                    role="list"
                    aria-label="{{ 'customer.order.discounts' | t | escape }}"
                  >
                    {%- for discount in cart.cart_level_discount_applications -%}
                      {%- if discount.total_allocated_amount > 0 -%}
                        <li class="discounts__discount text-sm sm:text-base flex flex-wrap items-center justify-between gap-1d5">
                          <p class="flex items-center gap-1d5">
                            {%- liquid
                              render 'icon', icon: 'discount', size: 'sm'
                              echo discount.title
                            -%}
                          </p>
                          <span class="badge badge--onsale flex items-center gap-1d5 font-medium leading-none"
                            >-{{ discount.total_allocated_amount | money -}}
                          </span>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

                <div class="totals grid gap-2">
                  <div class="flex flex-wrap items-center justify-between gap-2">
                    <p class="text-sm md:text-base font-medium leading-none">
                      {{ 'cart.general.subtotal' | t }}
                    </p>
                    <p class="totals__subtotal-value font-medium text-sm md:text-base leading-none">
                      {{ cart.original_total_price | money_with_currency }}
                    </p>
                  </div>
                  {% if cart.original_total_price != cart.total_price %}
                    <div
                      class="flex flex-wrap items-center justify-between gap-2 font-medium"
                      style="color: #00adee;"
                    >
                      <p class="text-sm md:text-base font-medium leading-none">Savings</p>
                      <p class="text-sm md:text-base font-medium leading-none">
                        -{{ cart.total_discount | money_with_currency }}
                      </p>
                    </div>
                  {% endif %}
                  {% comment %}
                    <div class="flex flex-wrap items-center justify-between gap-2">
                      <p class="text-sm md:text-base font-medium leading-none">Item(s) total</p>
                      <p class="text-sm md:text-base font-medium leading-none">
                        {{ cart.original_total_price | money_with_currency }}
                      </p>
                    </div>
                  {% endcomment %}
                  <div class="flex flex-wrap items-center justify-between gap-2">
                    <p class="text-sm md:text-base font-medium leading-none">Shipping</p>
                    <p class="text-sm md:text-base font-medium leading-none">
                      {% if cart.original_total_price >= 10000 %}
                        Free Shipping
                      {% else %}
                        Free Shipping $100+
                      {% endif %}
                    </p>
                  </div>
                </div>
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <p
                    class="font-medium summary_heading"
                    style="
                      font-size:18px;
                      font-family: 'Armourxbd';
                      text-transform: uppercase;
                      {% comment %} border-block-end: 1px solid rgb(var(--color-border-light)) !important; {% endcomment %}
                    "
                  >
                    Total
                  </p>
                  <p class="totals__subtotal-value font-bold text-base md:text-lg leading-none">
                    {{ cart.total_price | money_with_currency }}
                  </p>
                </div>

                {%- if section.settings.show_accelerated_buttons_drawer -%}
                  <div class="additional-checkout-buttons additional-checkout-buttons--vertical">
                    {{ content_for_additional_checkout_buttons }}
                  </div>
                {%- endif -%}
              </div>
            </div>
            {%- if gift_wrap_per_product and settings.gift_wrap_per_product_message != blank -%}
              <modal-element
                id="GiftWrapInfo-{{ section.id }}"
                class="modal invisible absolute bottom-0 left-0 w-full h-full"
                role="dialog"
                hidden
              >
                <overlay-element
                  class="fixed-modal opacity-0 z-1 absolute top-0 left-0 w-full h-full"
                  aria-controls="GiftWrapInfo-{{ section.id }}"
                  aria-expanded="false"
                ></overlay-element>
                <div class="modal__container flex flex-col z-3 absolute left-0 bottom-0 w-full">
                  <div class="modal__header flex items-center justify-between relative">
                    <span class="font-medium text-sm md:text-base">
                      {{- 'cart.gift_wrapping.gift_wrapping_label' | t -}}
                    </span>
                    <button
                      type="button"
                      class="close flex items-center justify-center absolute top-0 right-0"
                      is="magnet-button"
                      aria-controls="GiftWrapInfo-{{ section.id }}"
                      aria-expanded="false"
                      aria-label="{{ 'general.accessibility.close' | t | escape }}"
                    >
                      {%- render 'icon', icon: 'close' -%}
                    </button>
                  </div>
                  <div class="modal__content flex flex-col overflow-hidden">
                    <div class="modal__scrollable grid gap-4">
                      <div class="rte text-sm leading-tight">
                        {{- settings.gift_wrap_per_product_message -}}
                      </div>
                    </div>
                  </div>
                </div>
              </modal-element>
            {%- endif -%}
            {% comment %} Tbg custom code {% endcomment %}
            <div class="newDesign drawer__footer grid w-full{% if cart == empty %} hidden{% endif %}">
              {%- if section.settings.show_cart_note
                or section.settings.show_shipping_calculator
                or section.settings.add_discount_code
              -%}
                <div class="drawer__footer-top flex">
                  {%- if section.settings.show_cart_note -%}
                    <button
                      type="button"
                      class="flex gap-2d5 grow items-center justify-center"
                      aria-controls="CartNote-{{ section.id }}"
                      aria-expanded="false"
                    >
                      {%- render 'icon', icon: 'note', size: 'lg', class: 'icon-light shrink-0' -%}
                      <span class="reversed-link text-sm leading-tight">{{ 'general.cart.note.title' | t }}</span>
                    </button>
                  {%- endif -%}
                  {%- if section.settings.show_shipping_calculator -%}
                    <button
                      type="button"
                      class="flex gap-2d5 grow items-center justify-center"
                      aria-controls="ShippingCalculator-{{ section.id }}"
                      aria-expanded="false"
                    >
                      {%- unless section_rendering_api -%}
