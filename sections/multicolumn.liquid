<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }

  @media screen and (min-width: 1024px) {
    #shopify-section-{{ section.id }} .multicolumn {
      --card-grid-gap: {% if section.settings.gap == 'small' %}var(--sp-4){% elsif section.settings.gap == 'medium' %}var(--sp-6){% else %}clamp(40px, 3.5vw, 60px){% endif %};
    }
  }
</style>

{% comment %} TBG custom code {% endcomment %}

<style>

  .showCustomHeaders .multicolumn > .multicolumn-card:first-of-type::before {
    content: "SEMI CUSTOM";
    font-family: armourxbd;
    font-weight: 900;
    font-size: 35px;
    margin: 0 auto;
  }

  .showCustomHeaders .multicolumn > .multicolumn-card:last-of-type::before {
    content: "FULL CUSTOM";
    font-family: armourxbd;
    font-weight: 900;
    font-size: 35px;
    margin: 0 auto;
  }
</style>

<style>
  #images_container img {
    min-width: 100%;
  }

  @media (max-width: 650px) {
    .multicolumn > .multicolumn-card:first-of-type::before {
      font-size: 25px !important;
    }

    .multicolumn > .multicolumn-card:last-of-type::before {
      font-size: 25px !important;
    }
  }

  @media screen and (min-width: 1280px) {
    .multicolumn > .multicolumn-card {
      flex-direction: column !important;
    }
  }
</style>

{% comment %}
  {% if request.path == '/pages/teamworks2' %}
    <style>
      a.block.media:hover #images_container {
        transform: translateX(-100%) !important;
      }
    </style>
  {% endif %}
{% endcomment %}

{% if page.template_suffix == 'titan-vs-competitors' %}
  <style>
    .multicolumn-card > .grid {
      position: relative;
    }
    a.customLink {
      display: block !important;
      position: absolute;
      inset: 0;
      z-index: 10;
      cursor: pointer;
    }
    .multicolumn-card > .grid {
      transition: all 0.2s ease-in-out;
    }
    .multicolumn-card:hover > .grid {
      transform: translateY(-3px) scale(1.01);

    }
  </style>

  {% if section.settings.section_version == 'first' %}
    {% assign custom_links = 'https://www.titanbattlegear.com/blogs/hockey-safety/titan-battlegear-vs-bauer-hockey-neck-guards,https://www.titanbattlegear.com/blogs/hockey-safety/titan-battlegear-vs-ccm-hockey-neck-guards,https://www.titanbattlegear.com/blogs/hockey-safety/titan-battlegear-vs-warroad-hockey-neck-guards,https://www.titanbattlegear.com/blogs/hockey-safety/titan-battlegear-vs-shock-doctor-hockey-neck-guards'
      | split: ','
    %}
  {% elsif section.settings.section_version == 'second' %}
    {% assign custom_links = 'https://www.titanbattlegear.com,https://www.titanbattlegear.com/blogs/hockey-safety/titan-battlegear-vs-bauer-hockey-neck-guards,https://www.titanbattlegear.com/blogs/hockey-safety/titan-battlegear-vs-ccm-hockey-neck-guards,https://www.titanbattlegear.com/blogs/hockey-safety/titan-battlegear-vs-warroad-hockey-neck-guards,https://www.titanbattlegear.com/blogs/hockey-safety/titan-battlegear-vs-shock-doctor-hockey-neck-guards'
      | split: ','
    %}
    <style>
      @media (min-width: 1023px) {
        #shopify-section-{{ section.id }} .multicolumn {
          grid-template-columns: repeat(5, 1fr) !important;
        }
        #shopify-section-{{ section.id }} .multicolumn-card > .grid {
          border-radius: 20px;
        }
        #shopify-section-{{ section.id }} .multicolumn-card:hover > .grid {
          box-shadow: 0px 0px 20px #707070;
        }
      }
    </style>
  {% endif %}
{% endif %}

{% comment %} TBG custom code {% endcomment %}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- render 'section-heading', section: section -%}

    <slider-element id="Slider-{{ section.id }}" class="grid slider{% if section.settings.swipe_on_mobile %} slider--tablet{% endif %}" selector=".card-grid>.card"{% if section.settings.swipe_on_mobile %} tabindex="0"{% endif %}>
      <div class="multicolumn with-{{ section.blocks.size }} card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid relative z-1">
        {%- liquid
          assign with_gradient = false
          if section.settings.gradient_highlight != blank and section.settings.gradient_highlight != 'rgba(0,0,0,0)'
            assign with_gradient = true
          endif
        -%}
        {%- for block in section.blocks -%}
          <div class="multicolumn-card{% if block.settings.show_border %} with-border{% endif %} card flex gap-5 w-full flex-col items-start xl:flex-row md:text-{{ block.settings.text_alignment }} text-{{ block.settings.text_alignment_mobile }}" {{ block.shopify_attributes }}>
            <div class="grid gap-4 lg:gap-6 w-full">
              {%- if block.settings.video != blank -%}
                {%- capture sizes -%}(max-width: 639px) 100vw, (max-width: 767px) 74vw, {{ settings.page_width | divided_by: section.settings.columns }}px{%- endcapture -%}
                <a class="block media media--{{ block.settings.image_ratio }} media--transparent relative overflow-hidden"{% if block.settings.button_link != blank %} href="{{ block.settings.button_link }}"{% if block.settings.button_external %} target="_blank" rel="noopener noreferrer"{% endif %}{% else %} role="link" aria-disabled="true"{% endif %} aria-label="{{ block.settings.heading | escape }}">
                  {%- liquid
                    assign video_alt = block.settings.video.alt | default: block.settings.image.alt
                    assign alt = 'general.accessibility.load_video' | t: description: video_alt | escape
                    assign preview_image = block.settings.video.preview_image | default: block.settings.image

                    capture poster
                      if preview_image != blank
                        echo preview_image | image_url: width: preview_image.width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080,1600', sizes: sizes, is: 'lazy-image', class: 'inline-block', alt: alt
                      else
                        echo 'lifestyle-1' | placeholder_svg_tag: 'placeholder placeholder--transparent'
                      endif
                    endcapture
                  -%}
                  <video-media class="block" style="--aspect-ratio: {{ block.settings.video.aspect_ratio }};" autoplay>
                    {{- poster -}}
                    <template>
                      {{- block.settings.video | video_tag: playsinline: true, muted: true, autoplay: true, loop: true, controls: false, preload: 'metadata', image_size: '400x' -}}
                    </template>
                  </video-media>
                </a>
              {%- elsif block.settings.image != blank -%}
                {%- capture sizes -%}(max-width: 639px) 100vw, (max-width: 767px) 74vw, {{ settings.page_width | divided_by: section.settings.columns }}px{%- endcapture -%}
                {% comment %} TBG custom code {% endcomment %}
                <a
                  class="block media media--{{ block.settings.image_ratio }} media--transparent relative overflow-hidden"
                  {% if block.settings.button_link != blank %}
                    href="{{ block.settings.button_link }}"
                    {%- if block.settings.button_external %} target="_blank" rel="noopener"{% endif -%}
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                  aria-label="{{ block.settings.heading | escape }}"
                >
                  <div
                    id="images_container"
                    style="
                      transition: all 0.7s ease-in-out;
                      display: flex;
                      align-items: center;
                    "
                  >
                    {{-
                      block.settings.image
                      | image_url: width: block.settings.image.width
                      | image_tag:
                        loading: 'lazy',
                        widths: '180,360,540,720,900,1080,1600',
                        sizes: sizes,
                        is: 'lazy-image',
                        class: 'inline-block'
                    -}}
                    {% if request.path == '/pages/teamworks2' %}
                      {% if forloop.first %}
                        <img
                          src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/RTK_Semi_custom.jpg?v=1744193381"
                          loading="lazy"
                          widths="180,360,540,720,900,1080,1600"
                          sizes="{{ sizes }}"
                          width="800"
                          height="600"
                          is="lazy-image"
                          class="inline-block"
                        >
                      {% else %}
                        <img
                          src="https://cdn.shopify.com/s/files/1/0635/2401/2210/files/lumberjacks_full_custom.jpg?v=1744193382"
                          loading="lazy"
                          widths="180,360,540,720,900,1080,1600"
                          sizes="{{ sizes }}"
                          width="800"
                          height="600"
                          is="lazy-image"
                          class="inline-block"
                        >
                      {% endif %}
                    {% endif %}
                  </div>
                </a>
                {% comment %} TBG custom code {% endcomment %}
              {%- endif -%}

              {%- if block.settings.heading != blank or block.settings.text != blank or block.settings.button_label != blank -%}
                <div class="multicolumn-card__info grid gap-4 lg:gap-6">
                  {%- if block.settings.heading != blank -%}
                    <p class="heading {{ block.settings.heading_size }} leading-tight tracking-tight">
                      {%- render 'highlighted-text', content: block.settings.heading, style: block.settings.highlighted_text, scribble: block.settings.highlighted_scribble, gradient: with_gradient -%}
                    </p>
                  {%- endif -%}
    
                  {%- if block.settings.text != blank -%}
                    <div class="rte leading-normal">
                      {{- block.settings.text -}}
                    </div>
                  {%- endif -%}
    
                  {%- if block.settings.button_label != blank -%}
                    {% comment %} TBG custom code {% endcomment %}
                    <p id="button-group">
                      <a
                        class="button button--secondary button--fixed icon-with-text"
                        {% if block.settings.button_link != blank %}
                          href="{{ block.settings.button_link }}"
                          {%- if block.settings.button_external %} target="_blank" rel="noopener"{% endif -%}
                        {% else %}
                          role="link" aria-disabled="true"
                        {% endif %}
                        is="hover-link"
                      >
                        <span class="btn-fill" data-fill></span>
                        <span class="btn-text">
                          {%- liquid
                            echo block.settings.button_label | escape
                            if block.settings.button_icon
                              render 'icon', icon: 'arrow-right', size: 'sm', class: 'transform'
                            endif
                          -%}
                        </span>
                      </a>
                      {% if request.path == '/pages/teamworks2' %}
                        {% if forloop.first %}
                          <a
                            class="button button--secondary button--fixed icon-with-text"
                            href="https://www.titanbattlegear.com/pages/semi-custom-FORM"
                            is="hover-link"
                          >
                            <span class="btn-fill" data-fill></span>
                            <span class="btn-text">
                              Request More Info
                              {% render 'icon', icon: 'arrow-right', size: 'sm', class: 'transform' %}
                            </span>
                          </a>
                        {% endif %}
                      {% endif %}
                    </p>
                    {% comment %} TBG custom code {% endcomment %}
                  {%- endif -%}
                </div>
              {%- endif -%}
              {% comment %} TBG custom code {% endcomment %}
              {% if page.template_suffix == 'titan-vs-competitors' %}
                {% assign current_link = custom_links[forloop.index0] %}
                <a class='customLink' href="{{ current_link }}"></a>
              {% endif %}
              {% comment %} TBG custom code {% endcomment %}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </slider-element>
  </div>
</div>

{% comment %} Tbg custom code {% endcomment %}
    {% comment %} {
      "type": "checkbox",
      "id": "showCustomHeaders",
      "label": "Show Semi Custom/Full Custom headers?",
      "default": false
    }, 
    {
      "type": "select",
      "id": "section_version",
      "label": "Multiform Version",
      "options": [
        { "value": "first", "label": "First (4 images)" },
        { "value": "second", "label": "Second (5 images)" }
      ],
      "default": "first"
    },
    {% endcomment %}

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "showCustomHeaders",
      "label": "Show Semi Custom/Full Custom headers?",
      "default": false
    },
    {
      "type": "select",
      "id": "gap",
      "options": [
        {
          "value": "small",
          "label": "t:sections.multicolumn.settings.gap.options__1.label"
        },
        {
          "value": "medium",
          "label": "t:sections.multicolumn.settings.gap.options__2.label"
        },
        {
          "value": "large",
          "label": "t:sections.multicolumn.settings.gap.options__3.label"
        }
      ],
      "default": "large",
      "label": "t:sections.multicolumn.settings.gap.label"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "t:sections.global.settings.columns.label"
    },
    {
      "type": "select",
      "id": "section_version",
      "label": "Multiform Version",
      "options": [
        { "value": "first", "label": "First (4 images)" },
        { "value": "second", "label": "Second (5 images)" }
      ],
      "default": "first"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.global.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.global.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "1",
      "label": "t:sections.global.settings.columns_mobile.label"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "label": "t:sections.global.settings.swipe_on_mobile.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__heading.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.global.settings.heading.label",
      "default": "Multicolumn"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "title-sm",
          "label": "t:sections.global.settings.heading_size.options__1.label"
        },
        {
          "value": "title-md",
          "label": "t:sections.global.settings.heading_size.options__2.label"
        },
        {
          "value": "title-lg tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__3.label"
        },
        {
          "value": "title-xl tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__4.label"
        }
      ],
      "default": "title-md",
      "label": "t:sections.global.settings.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.global.settings.heading_alignment.label",
      "options": [
        {
          "value": "text-left md:items-end md:flex-row",
          "label": "t:sections.global.settings.heading_alignment.options__1.label"
        },
        {
          "value": "text-center md:items-center",
          "label": "t:sections.global.settings.heading_alignment.options__2.label"
        },
        {
          "value": "text-right md:items-end md:flex-row-reverse",
          "label": "t:sections.global.settings.heading_alignment.options__3.label"
        }
      ],
      "default": "text-center md:items-center"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.global.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.global.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.global.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.global.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.global.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.global.settings.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.global.settings.heading_tag.options__7.label"
        },
        {
          "value": "span",
          "label": "t:sections.global.settings.heading_tag.options__8.label"
        },
        {
          "value": "p",
          "label": "t:sections.global.settings.heading_tag.options__9.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.global.settings.heading_tag.label",
      "info": "t:sections.global.settings.heading_tag.info"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.global.settings.subheading.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.global.settings.description.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.global.settings.button_label.label",
      "info": "t:sections.global.settings.button_label.info"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.global.settings.button_link.label"
    },
    {
      "visible_if": "{{ section.settings.button_label != blank }}",
      "type": "checkbox",
      "id": "button_external",
      "label": "t:sections.global.settings.button_external.label",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.button_label != blank }}",
      "type": "checkbox",
      "id": "button_icon",
      "label": "t:sections.global.settings.button_icon.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__highlight.content",
      "info": "t:sections.global.settings.header__highlight.info"
    },
    {
      "type": "select",
      "id": "highlighted_text",
      "options": [
        {
          "value": "none",
          "label": "t:sections.global.settings.highlighted_text.options__1.label"
        },
        {
          "value": "text",
          "label": "t:sections.global.settings.highlighted_text.options__2.label"
        },
        {
          "value": "full_text",
          "label": "t:sections.global.settings.highlighted_text.options__3.label"
        },
        {
          "value": "half_text",
          "label": "t:sections.global.settings.highlighted_text.options__4.label"
        },
        {
          "value": "underline",
          "label": "t:sections.global.settings.highlighted_text.options__5.label"
        },
        {
          "value": "marker",
          "label": "t:sections.global.settings.highlighted_text.options__6.label"
        },
        {
          "value": "stencil",
          "label": "t:sections.global.settings.highlighted_text.options__7.label"
        },
        {
          "value": "scribble",
          "label": "t:sections.global.settings.highlighted_text.options__8.label"
        }
      ],
      "default": "none",
      "label": "t:sections.global.settings.highlighted_text.label"
    },
    {
      "visible_if": "{{ section.settings.highlighted_text == 'scribble' }}",
      "type": "select",
      "id": "highlighted_scribble",
      "options": [
        {
          "value": "circle",
          "label": "t:sections.global.settings.highlighted_scribble.options__1.label"
        },
        {
          "value": "basic-underline",
          "label": "t:sections.global.settings.highlighted_scribble.options__2.label"
        },
        {
          "value": "sketch-underline",
          "label": "t:sections.global.settings.highlighted_scribble.options__3.label"
        },
        {
          "value": "squiggle-underline",
          "label": "t:sections.global.settings.highlighted_scribble.options__4.label"
        },
        {
          "value": "squiggle-underline-2",
          "label": "t:sections.global.settings.highlighted_scribble.options__5.label"
        }
      ],
      "default": "circle",
      "label": "t:sections.global.settings.highlighted_scribble.label",
      "info": "t:sections.global.settings.highlighted_scribble.info"
    },
    {
      "visible_if": "{{ section.settings.highlighted_text != 'none' }}",
      "type": "checkbox",
      "id": "highlighted_reveal",
      "label": "t:sections.global.settings.highlighted_reveal.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__colors.content",
      "info": "t:sections.global.settings.header__colors.info"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "t:sections.global.settings.color_text.label"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "t:sections.global.settings.color_background.label"
    },
    {
      "type": "color_background",
      "id": "gradient_background",
      "label": "t:sections.global.settings.gradient_background.label"
    },
    {
      "type": "color",
      "id": "color_highlight",
      "label": "t:sections.global.settings.color_highlight.label"
    },
    {
      "type": "color_background",
      "id": "gradient_highlight",
      "label": "t:sections.global.settings.gradient_highlight.label"
    },
    {
      "type": "color",
      "id": "color_button_text",
      "label": "t:sections.global.settings.color_button_text.label"
    },
    {
      "type": "color",
      "id": "color_button_background",
      "label": "t:sections.global.settings.color_button_background.label"
    },
    {
      "type": "color_background",
      "id": "color_button_gradient",
      "label": "t:sections.global.settings.color_button_gradient.label"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__section.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_top.label",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_bottom.label",
      "default": 72
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.global.settings.divider.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.global.settings.full_width.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": false,
      "label": "t:sections.global.settings.rounded.label"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.multicolumn.blocks.column.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_border",
          "default": false,
          "label": "t:sections.multicolumn.blocks.column.settings.show_border.label"
        },
        {
          "type": "text_alignment",
