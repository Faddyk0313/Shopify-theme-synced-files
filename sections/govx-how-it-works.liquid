<style>
  #shopify-section-{{ section.id }} .govx-how {
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .govx-how__inner {
    position: relative;
  }

  #shopify-section-{{ section.id }} .govx-how__dot {
    position: absolute;
    top: 6px;
    left: 0;
    width: 46px;
    height: 46px;
    border-radius: 999px;
    background: {{ section.settings.dot_color }};
  }

  #shopify-section-{{ section.id }} .govx-how__heading {
    margin: 0;
    text-align: center;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  #shopify-section-{{ section.id }} .govx-how__grid {
    margin-top: 70px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  #shopify-section-{{ section.id }} .govx-how__step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .govx-how__step-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }

  #shopify-section-{{ section.id }} .govx-how__num {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #000;
    color: #fff;
    font-size: 22px;
    font-weight: 700;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .govx-how__title {
    margin: 0;
    text-transform: uppercase;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .govx-how__text {
    {% comment %} font-size: 24px; {% endcomment %}
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .govx-how__text p {
    margin: 0 0 20px;
  }

  #shopify-section-{{ section.id }} .govx-how__text p:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .govx-how__button-wrap {
    margin-top: 34px;
    width: 100%;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .govx-how__button {
    display: inline-block;
    min-width: 280px;
    padding: 14px 24px;
    background: #000;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-weight: 700;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .govx-how__logo-wrap {
    margin-top: 10px;
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .govx-how__logo-wrap {
      width: 100%;
      text-align: center;
    }
  }

  #shopify-section-{{ section.id }} .govx-how__logo {
    width: min(220px, 100%);
    height: auto;
    display: inline-block;
  }

  #shopify-section-{{ section.id }} .govx-how__logo-fallback {
    margin: 30px 0 0;
    display: inline-block;
    font-size: 52px;
    font-weight: 900;
    letter-spacing: 0.02em;
    line-height: 1;
    text-transform: uppercase;
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .govx-how__dot {
      top: 0;
      left: 6px;
    }

    #shopify-section-{{ section.id }} .govx-how__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 60px;
    }

    #shopify-section-{{ section.id }} .govx-how__button-wrap {
      text-align: left;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .govx-how__dot {
      width: 30px;
      height: 30px;
      top: 4px;
    }

    #shopify-section-{{ section.id }} .govx-how__grid {
      margin-top: 44px;
      gap: 30px;
    }

    #shopify-section-{{ section.id }} .govx-how__text {
      {% comment %} font-size: 18px; {% endcomment %}
    }

    #shopify-section-{{ section.id }} .govx-how__button {
      min-width: 240px;
    }
  }
</style>

<section class="govx-how">
  <div class="page-width">
    <div class="govx-how__inner">
      {%- if section.settings.show_dot -%}
        <span class="govx-how__dot" aria-hidden="true"></span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="govx-how__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="govx-how__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <article class="govx-how__step" {{ block.shopify_attributes }}>
              <div class="govx-how__step-head">
                <span class="govx-how__num">{{ forloop.index }}</span>
                {%- if block.settings.title != blank -%}
                  <h3 class="govx-how__title h2">{{ block.settings.title }}</h3>
                {%- endif -%}
              </div>

              {%- if block.settings.text != blank -%}
                <div class="govx-how__text rte" style="padding-bottom: 1rem;">{{ block.settings.text }}</div>
              {%- endif -%}

              {%- if block.settings.show_button and block.settings.button_label != blank -%}
                {%- render 'button',
                  label: block.settings.button_label,
                  link: block.settings.button_link,
                  show_icon: false
                -%}
              {%- endif -%}

              {%- if block.settings.show_logo -%}
                <div class="govx-how__logo-wrap">
                  {%- if block.settings.logo != blank -%}
                    {{
                      block.settings.logo
                      | image_url: width: 440
                      | image_tag: class: 'govx-how__logo', loading: 'lazy', alt: block.settings.logo.alt
                      | default: 'GovX'
                    }}
                  {%- else -%}
                    <span class="govx-how__logo-fallback">GovX</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Govx How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "title-xl",
      "options": [
        {
          "value": "title-lg",
          "label": "Large"
        },
        {
          "value": "title-xl",
          "label": "Extra large"
        },
        {
          "value": "title-2xl",
          "label": "2XL"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_dot",
      "label": "Show orange dot",
      "default": true
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#f98b00"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ececec"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Click"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Step text",
          "default": "<p>Click \"Verify with GovX\" anywhere on this page.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_button",
          "label": "Show button",
          "default": false
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Verify with GovX"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "show_logo",
          "label": "Show logo",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Govx How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Click",
            "text": "<p>Click \"Verify with GovX\" anywhere on this page.</p>",
            "show_button": true,
            "button_label": "Verify with GovX"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Verify",
            "text": "<p>Confirm your affiliation through secure, real-time verification.</p>",
            "show_logo": true
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Purchase",
            "text": "<p>Receive a single-use 15% off code to apply at checkout.</p><p>For future purchases, simply log in to GovX to generate a new single-use code.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
