{% assign gray_row_color = section.settings.gray_row_color %}
{% assign white_row_color = section.settings.white_row_color %}
{% if section.settings.swap_row_color_order %}
  {% assign gray_row_color = section.settings.white_row_color %}
  {% assign white_row_color = section.settings.gray_row_color %}
{% endif %}

<style>
  #shopify-section-{{ section.id }} {
    --color-background: {{ section.settings.color_background.rgb }};
  }
  #compareTablePDP {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }

  #compareTablePDP {
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    width: 100vw;
    max-width: 100vw;
  }
  #titanLogoImg {
    padding-block: 0 !important;
  }

    .cs-page-width {
      margin: 0 auto;
      padding-inline: var(--page-padding);
      padding-right: 0;
    }

    @media (min-width: 1900px) {
      .cs-page-width {
        padding-inline: 50px;
      }
    }

    #compareTablePDP .custom_header {
      font-size: 20px !important;
      color: white;
      font-weight: 600;
      letter-spacing: 1px;
    }
    @media (min-width: 500px) {
      #compareTablePDP .custom_header {
        font-size: 26px !important;
      }
    }

    #compareTablePDP .row {
      font-weight: 600;
      height: 42px;
      display: flex;
      text-align: center;
      align-items: center;
    }
    @media (min-width: 500px) {
      #compareTablePDP .row {
        height: 60px;
      }
    }

    #compareTablePDP #features .row {
      font-size: 12px;
      text-align: start !important;
    }
    @media (min-width: 500px) {
      #compareTablePDP #features .row {
        font-size: 18px;
      }
    }

    #compareTablePDP .column {
      justify-content: center;
      width: 100%;
      min-width: 115px;
    }
    #compareTablePDP .cs-bg-black {
      background-color: black;
    }
    #compareTablePDP .cs-bg-gray {
      background-color: {{ gray_row_color }};
    }
    #compareTablePDP .cs-bg-white {
      background-color: {{ white_row_color }};
    }
    #compareTablePDP .small-text {
      font-size: 10px;
      font-weight: 400;
    }
    #compareTablePDP .flex-direction-column {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    #compareTablePDP .row.column img {
      width: 20px;
      height: 20px;
    }
    #compareTablePDP .row.column {
      padding: 0;
    }
    @media (min-width: 786px) {
      #compareTablePDP .row.column {
        font-size: 20px;
      }
    }
    #compareTablePDP .row.column.custom_header img {
      width: 100%;
      height: 100%;
      padding: 5px;
      object-fit: contain;
    }
    @media (min-width: 1000px) {
      #compareTablePDP .row.column.custom_header img {
        padding: 5px;
        padding-block: 0;
      }
    }

    #compareTablePDP {
      position: relative;
    }

    /* #compareTablePDP #features {
      padding: 1rem 0;
    } */

    #compareTablePDP #columns {
      position: absolute;
      top: -15px;
      /* left: 130px; */
      right: 0;
      display: flex;
      align-items: center;

      transform: translateY(-2rem);
    }
    @media (min-width: 500px) {
      #compareTablePDP #columns {
        left: 180px;
        right: 0;
        width: calc(100vw - 180px);
      }
    }
    @media (min-width: 1000px) {
      #compareTablePDP #columns {
        left: 220px;
        right: 0;
        width: calc(100vw - 220px);
      }
    }
    @media (min-width: 1400px) {
      #compareTablePDP #columns {
        left: 250px;
        right: 0;
        width: calc(100vw - 250px);
      }
    }

    #compareTablePDP .card-wrapper {
      flex: 0 0 100%;
      border-radius: 15px;
      scroll-snap-align: start;
      overflow: visible;
  max-width: 120px;
    }

    @media (min-width: 500px) {
      #compareTablePDP .card-wrapper {
        max-width: calc(25% - 10px) !important;
        min-width: 130px;
        width: 25%;
      }
    }

    @media (max-width: 500px) {
      #compareTablePDP .card-wrapper:last-child {
        margin-right: 30px;
      }
    }

    #compareTablePDP .card-wrapper-titan {
      z-index: 10;
      overflow: visible;
      border-radius: 15px;
      min-width: 115px;
      width: fit-content;
    }

    @media (min-width: 500px) {
      #compareTablePDP .card-wrapper-titan {
        min-width: 130px;
      }
    }

    @media (min-width: 786px) {
      #compareTablePDP .card-wrapper-titan {
        min-width: 20%;
      }
    }


    #compareTablePDP #titan {
      box-shadow: 0px 5px 20px rgba(107, 107, 107, 0.4);
    }
    #compareTablePDP #titan,
    #compareTablePDP .competitor {
      padding: 15px 0;
      background: linear-gradient(to bottom, #fff, #f2f2f2);
      border-radius: 15px;
      box-shadow: 0px 5px 20px rgba(107, 107, 107, 0.4);
      width: fit-content;
    }
    @media (min-width: 500px) {
      #compareTablePDP #titan,
      #compareTablePDP .competitor {
        padding: 1rem 0;
        min-width: 100%;
      }
    }

    #compareTablePDP .competitor-grp {
      display: flex;
      padding-right: 0.7rem;
      border-radius: 15px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-padding-left: 0;
      overscroll-behavior-x: contain;
      scroll-snap-type: x mandatory;
      scroll-snap-stop: always;
      scroll-behavior: smooth;
      padding-block: 2rem;
    }
  .competitor-grp .card-wrapper {
  padding-left: 5px;
  }
    @media (min-width: 500px) {
      #compareTablePDP .competitor-grp {
        flex-grow: 1;
      }
  .competitor-grp .card-wrapper {
  padding-left: 10px;
  }
    }
  @media (max-width: 500px) {
  #compareTablePDP #columns
   {
      left: 130px;
  }
   }

  @media (min-width: 1024px) {
      #compareTablePDP .card-wrapper-titan {
  max-width: calc(150px + 2rem - 10px) !important;
     min-width: calc(150px + 2rem - 10px) !important;
  padding-left: 2rem !important;
      }
  #compareTablePDP .card-wrapper {
     max-width: 150px !important;
  min-width: 150px !important;
      }
      #compareTablePDP #columns {
          left: 180px;
          right: 0;
          width: auto;
      }

  #compareTablePDP {
      position: relative;
      left: auto;
      right: auto;
      margin-left: auto;
      margin-right: auto;
      width: auto;
      max-width: none;
  }
      #compareTablePDP .competitor-grp {
          justify-content: space-evenly;
      }
      #compareTablePDP .row.column.custom_header img {
          padding-inline:7px !important;
          padding-block: 0 !important;
      }
  div#titanLogoImgCont img#titanLogoImg {
  padding-right: 10px !important;
  padding-block: 5px !important;
  }
  div#shockDocImgCont img#shockDocImg {
  padding-inline: 15px !important;
  }
  }
  @media (min-width: 1400px) {
  #compareTablePDP #columns {
          left: 250px;
          right: 0;
          width: auto;
      }
  }
  @media (min-width: 1500px) {
  div#titanLogoImgCont img#titanLogoImg {
  padding-block: 0px !important;
  }

      #compareTablePDP .card-wrapper-titan {
  max-width: calc(190px + 3rem - 10px) !important;
  min-width: calc(190px + 3rem - 10px) !important;
  padding-left: 3rem !important;
  }
  #compareTablePDP .card-wrapper {
     max-width: 190px !important;
  min-width: 190px !important;
      }
  }
</style>

