{% schema %}
{
  "name": "Titan PDP Compare Table",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "t:sections.global.settings.color_background.label"
    },
    {
      "type": "checkbox",
      "id": "swap_row_color_order",
      "label": "Swap Row Color Order",
      "default": false
    },
    {
      "type": "color",
      "id": "gray_row_color",
      "label": "Odd Row Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "white_row_color",
      "label": "Even Row Color",
      "default": "#f2f2f2"
    }
  ],
  "presets": [
    {
      "name": "Titan PDP Compare Table"
    }
  ]
}
{% endschema %}
