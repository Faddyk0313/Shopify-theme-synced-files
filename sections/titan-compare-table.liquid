<style>
    /* @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');
        *{
          padding: 0;margin: 0;box-sizing: border-box; font-family: "Inter", sans-serif;
        } */
    /* @media screen and (min-width: 767px) {
      #shopify-section-template--18768375611570__custom_liquid_Q3Lw4g {
        display: none !important;
      }
    } */

    #shopify-section-template--18768375611570__custom_liquid_Q3Lw4g .page-width {
      padding: 0;
    }

    .cs-page-width {
      margin: 0 auto;
      padding-inline: var(--page-padding);
      padding-right: 0;
    }

    #compareTable {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    } 

    #compareTable .cus_header {
      font-size: 20px !important;
      color: white;
      font-weight: 600;
      letter-spacing: 1px;
    }
    @media (min-width: 500px) {
      #compareTable .cus_header {
        font-size: 26px !important;
      }
    }

    #compareTable .row {
      font-weight: 600;
      height: 42px;
      display: flex;
      align-items: center;
      text-align: center;
    }
    @media (min-width: 500px) {
      #compareTable .row {
        height: 60px;
      }
    }

    #compareTable #features .row {
      font-size: 12px;
      text-align: start !important;
    }
    @media (min-width: 500px) {
      #compareTable #features .row {
        font-size: 18px;
      }
    }

    #compareTable .column {
      justify-content: center;
      width: 100%;
      min-width: 115px;
    }
    #compareTable .cs-bg-black {
      background-color: black;
    }
    #compareTable .cs-bg-dark-green {
      background-color: #e5fc00;
    }
    #compareTable .cs-bg-light-green {
      background-color: #fbffc4;
    }
    #compareTable .cs-bg-white {
      background-color: white;
    }
    #compareTable .cs-bg-gray {
      background-color: #f4f4f4;
    }
    #compareTable .small-text {
      font-size: 10px;
      font-weight: 400;
    }
    #compareTable .flex-direction-column {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    #compareTable .row.column img {
      width: 20px;
      height: 20px;
    }
    #compareTable .row.column {
      padding: 0;
    }
    @media (min-width: 786px) {
      #compareTable .row.column {
        font-size: 20px;
      }
    }
    #compareTable .row.column.cus_header img {
      width: 100%;
      height: 100%;
      padding: 5px;
      object-fit: contain;
    }
    @media (min-width: 1000px) {
      #compareTable .row.column.cus_header img {
        padding: 15px;
      }
    }

    #compareTable {
      position: relative;
    }

    /* #compareTable #features {
      padding: 1rem 0;
    } */

    #compareTable #columns {
      position: absolute;
      top: -15px;
      /* left: 130px; */
      right: 0;
      display: flex;
      align-items: center;
      width: 65vw;
      gap: 5px;
    }
    @media (min-width: 500px) {
      #compareTable #columns {
        left: 180px;
        right: 0;
        gap: 10px;
        width: calc(100vw - 180px);
      }
    }
    @media (min-width: 1000px) {
      #compareTable #columns {
        left: 220px;
        right: 0;
        gap: 10px;
        width: calc(100vw - 220px);
      }
    }
    @media (min-width: 1400px) {
      #compareTable #columns {
        left: 250px;
        right: 0;
        gap: 10px;
        width: calc(100vw - 250px);
        margin-left: auto;
      }
    }
    @media (min-width: 2000px) {
      #compareTable #columns {
        width: calc(100vw - 250px);
        max-width: 1950px;
        margin-left: calc(var(--page-padding) - 2%) !important;
      }
    }

    #compareTable .card-wrapper {
      flex: 0 0 100%;
      border-radius: 15px;
      scroll-snap-align: start;
      max-width: 115px;
      overflow: visible;
    }

    @media (min-width: 500px) {
      #compareTable .card-wrapper {
        max-width: calc(25% - 10px);
        min-width: 130px;
        width: 25%;
      }
    }

    @media (max-width: 500px) {
      #compareTable .card-wrapper:last-child {
        margin-right: 30px;
      }
    }

    #compareTable .card-wrapper-titan {
      z-index: 10;
      overflow: visible;
      border-radius: 15px;
      min-width: 115px;
      width: min-content;
    }

    @media (min-width: 500px) {
      #compareTable .card-wrapper-titan {
        min-width: 130px;
      }
    }

    @media (min-width: 786px) {
      #compareTable .card-wrapper-titan {
        min-width: 20%;
      }
    }

    #compareTable #titan {
      box-shadow: 0px 5px 20px rgba(107, 107, 107, 0.4);
    }
    #compareTable #titan,
    #compareTable .competitor {
      padding: 1rem 0;
      background: linear-gradient(to bottom, white, #f2f2f2);
      border-radius: 15px;
      box-shadow: 0px 5px 20px rgba(107, 107, 107, 0.4);
      width: fit-content;
    }
    @media (min-width: 500px) {
      #compareTable #titan,
      #compareTable .competitor {
        padding: 1rem 0;
        min-width: 100%;
      }
    }

    #compareTable .competitor-grp {
      display: flex;
      box-shadow: 0px 5px 20px rgba(107, 107, 107, 0.4);
      padding-right: 0.7rem;
      border-radius: 15px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-padding-left: 0;
      overscroll-behavior-x: contain;
      scroll-snap-type: x mandatory;
      scroll-snap-stop: always;
      scroll-behavior: smooth;
      gap: 5px;
    }
    @media (min-width: 500px) {
      #compareTable .competitor-grp {
        flex-grow: 1;
        gap: 10px;
      }
    }

    #titanLogoImg {
      padding-block: 0 !important;
    }
</style>
