<style>
  /* CSS Variables */
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .section::before {
    content: none;
  }

  #shopify-section-{{ section.id }} .section {
    background-color: {{ section.settings.background_color }};
  }

  /* Logos Section */
  #shopify-section-{{ section.id }} .logos-section {
    color: #ffffff;
  }

  #shopify-section-{{ section.id }} .logos-section h2 {
    color: #ffffff;
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .logos-section .description {
    margin-bottom: 2rem;
    line-height: 1.6;
    max-width: 60%;
  }

  #shopify-section-{{ section.id }} .logo-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem;
  }

  #shopify-section-{{ section.id }} .logo-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .logo-box {
    background-color: #ffffff;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    overflow: hidden;
    width: 100%;
    max-width: 200px;
  }

  #shopify-section-{{ section.id }} .logo-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .logo-item p {
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .logo-downloads {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: auto;
  }

  #shopify-section-{{ section.id }} .logo-downloads a {
    color: #e2fb31;
    text-decoration: none;
    font-weight: 700;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .logo-downloads a:hover {
    text-decoration: underline;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .logos-section .description {
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .logo-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
</style>

<div class="section brand-logos-section">
  <!-- Logos Section -->
  <div class="page-width logos-section section--padding">
    <{{ section.settings.heading_tag }} class="{{ section.settings.heading_size }}">
      {{- section.settings.logos_heading -}}
    </{{ section.settings.heading_tag }}>
    <p class="description">{{ section.settings.logos_description }}</p>
    <div class="logo-grid">
      {% for block in section.blocks %}
        <div class="logo-item" {{ block.shopify_attributes }}>
          <div class="logo-box">
            {% if block.settings.logo_image != blank %}
              <img
                src="{{ block.settings.logo_image | img_url: '300x300' }}"
                alt="Brand Logo"
                width="300" 
                height="300"
              >
            {% endif %}
          </div>
          <div class="logo-downloads">
            {% if block.settings.logo_png_file != blank %}
              <a href="{{ block.settings.logo_png_file }}" class="download-link">PNG</a>
            {% endif %}
            {% if block.settings.logo_svg_file != blank %}
              <a href="{{ block.settings.logo_svg_file }}" class="download-link">SVG</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    // Handle download links
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('download-link')) {
        e.preventDefault();
        const url = e.target.getAttribute('href');

        // Extract filename from URL
        const urlParts = url.split('/');
        const filename = urlParts[urlParts.length - 1].split('?')[0];

        // Fetch the file and trigger download
        fetch(url)
          .then(response => response.blob())
          .then(blob => {
            const blobUrl = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.style.display = 'none';
            a.href = blobUrl;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(blobUrl);
            document.body.removeChild(a);
          })
          .catch(error => {
            console.error('Download failed:', error);
            // Fallback: open in new tab if fetch fails
            window.open(url, '_blank');
          });
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Brand Logos",
  "settings": [
    {
      "type": "header",
      "content": "Logos Section"
    },
    {
      "type": "text",
      "id": "logos_heading",
      "label": "Logos Heading",
      "default": "LOGOS"
    },
    {
      "type": "textarea",
      "id": "logos_description",
      "label": "Logos Description",
      "default": "We design the most advanced cut-resistant baselayer and neck guards in the game, built with proprietary technology and trusted by players at all levels of the game."
    },
    {
      "type": "header",
      "content": "Global Heading Settings"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "title-sm",
          "label": "t:sections.global.settings.heading_size.options__1.label"
        },
        {
          "value": "title-md",
          "label": "t:sections.global.settings.heading_size.options__2.label"
        },
        {
          "value": "title-lg tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__3.label"
        },
        {
          "value": "title-xl tracking-heading",
          "label": "t:sections.global.settings.heading_size.options__4.label"
        }
      ],
      "default": "title-md",
      "label": "t:sections.global.settings.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.global.settings.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.global.settings.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.global.settings.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.global.settings.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.global.settings.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.global.settings.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.global.settings.heading_tag.options__7.label"
        },
        {
          "value": "span",
          "label": "t:sections.global.settings.heading_tag.options__8.label"
        },
        {
          "value": "p",
          "label": "t:sections.global.settings.heading_tag.options__9.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.global.settings.heading_tag.label",
      "info": "t:sections.global.settings.heading_tag.info"
    },
    {
      "type": "header",
      "content": "t:sections.global.settings.header__section.content"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_top.label",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_bottom.label",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Preview Image"
        },
        {
          "type": "url",
          "id": "logo_png_file",
          "label": "PNG File URL"
        },
        {
          "type": "url",
          "id": "logo_svg_file",
          "label": "SVG File URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos",
      "blocks": [
      ]
    }
  ]
}
{% endschema %}
