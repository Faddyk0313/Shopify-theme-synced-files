    #authenticating-modal:not([active]) .drawer__inner {
      opacity: 1;
      pointer-events: none;
    }

    #authenticating-modal[active] {
      pointer-events: all;
      transform: translateY(0);
    }

    #authenticating-modal #authenticating-modal-overlay {
    transition: all 2s cubic-bezier(.7,0,.2,1);
      transform: translate(0px);
