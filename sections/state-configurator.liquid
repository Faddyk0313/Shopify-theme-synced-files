<div class="table-wrapper">
  <div id="state-config">
    <h1>{{ section.settings.heading }}</h1>
    <table id="config-table">
      <thead>
        <tr>
          <th>State</th>
          <th>ATC Label</th>
          <th>Policy</th>
          <th>Messaging</th>
          <th>Delete</th>
        </tr>
      </thead>
      <tbody style="padding: 0.1rem;">
        <!-- rows will be injected here -->
      </tbody>
    </table>

    <div class="controls">
      <button
        id="add-row-button"
        class="button button--primary icon-with-text col-span-full"
        type="submit"
        name="checkout"
        is="hover-button"
      >
        <span class="btn-fill" data-fill></span>
        <span class="btn-text">Add State</span>
      </button>
      <button
        id="run-sync-button"
        class="button button--primary icon-with-text col-span-full"
        type="submit"
        name="checkout"
        is="hover-button"
      >
        <span class="btn-fill" data-fill></span>
        <span class="btn-text">Run Sync</span>
      </button>
    </div>
  </div>
</div>

<script>
  let intervalId;

  document.addEventListener("DOMContentLoaded", function () {
    const modalHTML =`
      <x-modal
        id="authenticating-modal"
        class="profile-modal x-modal drawer z-30 fixed bottom-0 left-0 h-full w-full pointer-events-none"
        role="dialog"
        aria-modal="true"
        active
      >
        <overlay-element
          id="authenticating-modal-overlay"
          class="overlay fixed-modal fixed bottom-0 left-0 w-full h-screen transition-opacity duration-300"
          aria-expanded="false"
        ></overlay-element>
        <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
          <gesture-element class="drawer__header flex justify-between relative">
            <span class="drawer__title heading">
              This product is for your team only.<br>
              Enter Password to continue.
            </span>
          </gesture-element>
          <div class="drawer__content flex flex-col h-full grow shrink">
            <div class="drawer__scrollable relative flex flex-col gap-5 md:gap-4 grow shrink">
              <form id="auth-form" class="grid gap-4d5 md:gap-6">
                <div class="field">
                  <input
                    id="sync-password"
                    class="input is-floating"
                    type="password"
                    autocapitalize="off"
                    autocomplete="current-password"
                    required
                    placeholder="Password"
                    style="background-color: #e2e8f0;"
                  />
                  <label class="label is-floating" for="sync-password">
                    Enter Password
                  </label>
                </div>
                <div class="field">
                  <label for="customPopupSubmit" class="sr-only">Continue</label>
                  <button
                    id="customPopupSubmit"
                    type="submit"
                    class="button button--primary button--fixed"
                    is="hover-button"
                  >
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">Continue</span>
                  </button>
                </div>
                <p id="errorMsggg" style="color: red;" class="text-red-500 text-sm mt-2"></p>
                <div class="field rte text-sm">
                  {{- 'shopify.online_store.spam_detection.disclaimer_html' | t -}}
                </div>
              </form>
            </div>
          </div>
        </div>
      </x-modal>
    `;

    function ensureModal() {
      if (!document.getElementById("authenticating-modal")) {
        document.body.insertAdjacentHTML("beforeend", modalHTML);
      }
      const m = document.getElementById("authenticating-modal");
      m.style.display       = "flex";
      m.style.visibility    = "visible";
      m.style.opacity       = "1";
      m.style.pointerEvents = "auto";
      document.body.classList.add("modal-visible");
    }

    ensureModal();
    intervalId = setInterval(ensureModal, 1000);

    document
      .getElementById("auth-form")
      .addEventListener("submit", submitForm);
  });

  function submitForm(e) {
    e.preventDefault();
    clearInterval(intervalId);

    const existing = document.getElementById("authenticating-modal");
    if (existing) {
      existing.style.display = 'none';
      document.body.classList.remove("modal-visible");
    }
  }
</script>

<script>
  (function () {
    const SYNC_URL = 'https://state-configurator.onrender.com/api/updateproduct_state1';

    let rows = [{ key: '', label: '', policy: 'continue', message: '' }];

    const tbody = document.querySelector('#config-table tbody');
    const addBtn = document.getElementById('add-row-button');
    const runSyncBtn = document.getElementById('run-sync-button');

    // Render table body from rows
    function renderTable() {
      tbody.innerHTML = '';
      rows.forEach((row, idx) => {
        const headers = ['State', 'ATC Label', 'Policy', 'Messaging', 'Delete'];

        const tr = document.createElement('tr');

        // key
        const tdKey = document.createElement('td');
        tdKey.setAttribute('data-label', headers[0]);
        tdKey.classList.add('inputContainer');

        const inpKey = document.createElement('input');
        inpKey.type = 'text';
        inpKey.placeholder = 'Preorder, Exiting';
        inpKey.value = row.key;
        inpKey.addEventListener('input', (e) => updateCell(idx, 'key', e.target.value));
        tdKey.appendChild(inpKey);
        tr.appendChild(tdKey);

        // label
        const tdLabel = document.createElement('td');
        tdLabel.setAttribute('data-label', headers[1]);
        tdLabel.classList.add('inputContainer');

        const inpLbl = document.createElement('input');
        inpLbl.type = 'text';
        inpLbl.placeholder = 'Add to Cart Label';
        inpLbl.value = row.label;
        inpLbl.addEventListener('input', (e) => updateCell(idx, 'label', e.target.value));
        tdLabel.appendChild(inpLbl);
        tr.appendChild(tdLabel);

        // policy
        const tdPolicy = document.createElement('td');
        tdPolicy.setAttribute('data-label', headers[2]);
        tdPolicy.classList.add('group');

        const tdPolicyDropdownContainer = document.createElement('div');
        tdPolicyDropdownContainer.classList.add('custom-dropdown');

        const sel = document.createElement('select');
        sel.classList.add('my_dropdown');

        [
          ['continue', 'Allow oversell'],
          ['deny', 'Deny oversell'],
        ].forEach(([val, text]) => {
          const opt = document.createElement('option');
          opt.value = val;
          opt.textContent = text;
          if (row.policy === val) opt.selected = true;
          sel.appendChild(opt);
        });
        sel.addEventListener('change', (e) => updateCell(idx, 'policy', e.target.value));

        const arrow = document.createElement('span');
        arrow.classList.add('custom-arrow');

        tdPolicyDropdownContainer.appendChild(sel);
        tdPolicyDropdownContainer.appendChild(arrow);
        tdPolicy.appendChild(tdPolicyDropdownContainer);

        tr.appendChild(tdPolicy);

        // message
        const tdMsg = document.createElement('td');
        tdMsg.setAttribute('data-label', headers[3]);
        tdMsg.classList.add('inputContainer');

        const inpMsg = document.createElement('input');
        inpMsg.type = 'text';
        inpMsg.placeholder = 'Preorder/ Backorder Message';
        inpMsg.value = row.message;
        inpMsg.addEventListener('input', (e) => updateCell(idx, 'message', e.target.value));
        tdMsg.appendChild(inpMsg);
        tr.appendChild(tdMsg);

        // delete
        const tdDel = document.createElement('td');
        tdDel.classList.add('noPadding');
        const btnDel = document.createElement('button');
        btnDel.textContent = 'Delete';
        // tdDel.setAttribute('data-label', headers[4]);
        btnDel.className = 'delete-row-button';
        btnDel.addEventListener('click', () => {
          rows.splice(idx, 1);
          renderTable();
        });
        tdDel.appendChild(btnDel);
        tr.appendChild(tdDel);

        tbody.appendChild(tr);
      });
    }

    // Update one field
    function updateCell(i, field, value) {
      rows[i][field] = value;
    }

    // Add blank row
    addBtn.addEventListener('click', () => {
      rows.push({ key: '', label: '', policy: 'continue', message: '' });
      renderTable();
    });

    runSyncBtn.addEventListener('click', async () => {
      const password = document.getElementById('sync-password').value;
      // 2️⃣ start loader
      runSyncBtn.classList.add('animatingBtn');
      runSyncBtn.disabled = true;
      const btnTextEl = document.querySelector('#run-sync-button .btn-text');
      const originalText = btnTextEl.textContent;
      let dots = 0;
      const dotInterval = setInterval(() => {
        dots = (dots + 1) % 4; // cycles 0→3
        btnTextEl.textContent = 'Running' + '.'.repeat(dots);
      }, 500);

      try {
        // 3️⃣ your existing fetch logic
        const res = await fetch(SYNC_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ config: rows, password }),
        });
        const data = await res.json();

        if (res.ok) {
          alert('Inventory updated successfully, ' + (data.admin_url || ''));
          console.log(data);
        } else {
          // alert('❌ Inventory update failed');
          alert(data.message);
          console.error(data);
        }
      } catch (err) {
        console.error(err);
        alert('❌ Something went wrong.');
      } finally {
        // 4️⃣ stop loader & restore
        runSyncBtn.classList.remove('animatingBtn');
        clearInterval(dotInterval);
        btnTextEl.textContent = originalText;
        runSyncBtn.disabled = false;
      }
    });

    // kick off
    renderTable();
  })();
</script>

