    #shopify-section-{{ section.id }} .klaviyo-form-SaDUB8 {
      display: none;
      position: absolute ;
      height: 1px;
      opacity: 0 ;
      pointer-events: none ;
    }

    /* Custom form styles */
    #shopify-section-{{ section.id }} .custom-klaviyo-form {
      max-width: 600px;
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .custom-form-field {
