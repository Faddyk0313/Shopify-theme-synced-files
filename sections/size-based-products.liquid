      </div>
    </div>

    <!-- No Products Message -->
    <div id="no-products-{{ section.id }}" class="no-products-message text-center py-8" style="display: none;">
      <p class="text-gray-600">
        {{ section.settings.no_products_text | default: 'Sorry, no products are currently available in this size.' }}
      </p>
    </div>
  </div>
</div>

<section
  id="size-products-carousel"
  class="section--padding page-width{% if section.settings.full_width %} page-width--full{% endif %} relative"
  style="background-color: {{ section.settings.color_background_carousel | default: 'white' }}; padding-bottom: 0 !important;"
>
  <div id="size-products-{{ section.id }}" class="size-products-container" style="display: none;">
    {%- if section.settings.heading_2 != blank or section.settings.subheading_2 != blank -%}
      <div
        style="margin-bottom: 0;"
        class="title-wrapper with-nav{% if section.settings.heading_size_2 == 'title-xl' %} title-wrapper-lg{% endif %} leading-none gap-4 lg:gap-8 {{ section.settings.heading_alignment_2 }} md:justify-between relative z-1"
      >
        <div class="heading-content">
          {%- if section.settings.heading_2 != blank or section.settings.subheading_2 != blank -%}
            <div class="grid gap-4">
              {%- if section.settings.subheading_2 != blank -%}
                {%- liquid
                  if section.settings.heading_size_2 == 'title-sm'
                    assign subtext_size = 'subtext-md'
                  else
                    assign subtext_size = 'subtext-lg'
                  endif
                -%}
                <p class="heading normal-case font-medium {{ subtext_size }} leading-none tracking-none">
                  {{- section.settings.subheading_2 | escape -}}
                </p>
              {%- endif -%}

              {%- if section.settings.heading_2 != blank -%}
                <{{ section.settings.heading_tag_2 }} class="heading {{ section.settings.heading_size_2 }}">
                  <split-words class="split-words block" data-animate="fade-up-large">
                    <span id="carousel-heading-{{ section.id }}">{{- section.settings.heading_2 -}}</span>
                  </split-words>
                </{{ section.settings.heading_tag_2 }}>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if section.settings.button_label != blank -%}
            <p>
              {%- render 'button',
                style: 'secondary',
                label: section.settings.button_label,
                link: section.settings.button_link,
                external: section.settings.button_external,
                show_icon: section.settings.button_icon
              -%}
            </p>
          {%- endif -%}

          {%- liquid
            if section_button != blank
              echo section_button
            endif
          -%}
        </div>

        <!-- Carousel Navigation Buttons -->
        <div class="carousel-nav-buttons indicators hidden lg:flex gap-2d5">
          <button
            class="carousel-nav-btn button button--secondary"
            type="button"
            is="previous-button"
            id="carousel-prev-{{ section.id }}"
            aria-label="Previous"
          >
            <span class="btn-fill" data-fill></span>
            <span class="btn-text">
              {%- render 'icon', icon: 'chevron-left', class: 'transform' -%}
            </span>
          </button>
          <button
            class="carousel-nav-btn button button--secondary"
            type="button"
            is="next-button"
            id="carousel-next-{{ section.id }}"
            aria-label="Next"
          >
            <span class="btn-fill" data-fill></span>
            <span class="btn-text">
              {%- render 'icon', icon: 'chevron-right', class: 'transform' -%}
            </span>
          </button>
        </div>
      </div>
    {%- endif -%}

    <slider-element
      id="Slider-{{ section.id }}"
      class="grid slider{% if section.settings.carousel_on_desktop %} slider--desktop{% endif %}{% if section.settings.swipe_on_mobile %} slider--tablet{% endif %}"
      selector=".card-grid>.card"
    >
      <motion-list class="product-grid card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid">
        {%- assign size_options = 'YTH-XS,YTH-SM,YTH-MD,YTH-LG,YTH-XL,YTH-SM/MD,YTH-LG/XL,SR-XS,SR-SM,SR-MD,SR-LG,SR-XL,SR-2XL,SR-3XL,SR-SM/MD,SR-LG/XL,SR-2XL/3XL'
          | split: ','
        -%}

        {%- comment -%} Target collections from section settings {%- endcomment -%}
        {%- assign selected_collections = section.settings.source_collections -%}
        {%- assign fallback_collection_handles = 'cut-resistant-battlegear,battlegear-3-0' | split: ',' -%}
        {%- assign last_chance_collection_id = 343124541618 -%}

        {%- assign other_products_markup = '' -%}
        {%- assign last_chance_products_markup = '' -%}
        {%- assign neckguard_products_markup = '' -%}
        {%- assign rendered_product_ids = '' -%}

        {%- assign source_collection_handles = '' -%}
        {%- if selected_collections != blank -%}
          {%- for current_collection in selected_collections -%}
            {%- if current_collection != blank -%}
              {%- if source_collection_handles != blank -%}
                {%- assign source_collection_handles = source_collection_handles | append: ',' -%}
              {%- endif -%}
              {%- assign source_collection_handles = source_collection_handles | append: current_collection.handle -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign source_collection_handles = fallback_collection_handles | join: ',' -%}
        {%- endif -%}

        {% assign source_collection_handles_arr = source_collection_handles | split: ',' %}

        {%- for collection_handle in source_collection_handles_arr -%}
          {%- assign current_collection = collections[collection_handle] -%}
          {%- if current_collection != blank -%}
            {%- paginate current_collection.products by 250 -%}
              {%- for product in current_collection.products -%}
                {%- assign product_id_token = ',' | append: product.id | append: ',' -%}
                {%- if rendered_product_ids contains product_id_token -%}
                  {%- continue -%}
                {%- endif -%}
                {%- assign rendered_product_ids = rendered_product_ids | append: product_id_token -%}

              {%- assign found_sizes = '' -%}

              {%- for variant in product.variants -%}
                {%- if variant.inventory_policy == 'continue' or variant.inventory_quantity > 0 -%}
                  {%- for i in (1..3) -%}
                    {%- case i -%}
                      {%- when 1 -%}
                        {%- assign option_value = variant.option1 -%}
                      {%- when 2 -%}
                        {%- assign option_value = variant.option2 -%}
                      {%- when 3 -%}
                        {%- assign option_value = variant.option3 -%}
                    {%- endcase -%}

                    {%- if option_value != blank and size_options contains option_value -%}
                      {%- unless found_sizes contains option_value -%}
                        {%- if found_sizes == blank -%}
                          {%- assign found_sizes = option_value -%}
                        {%- else -%}
                          {%- assign found_sizes = found_sizes | append: ',' | append: option_value -%}
                        {%- endif -%}
                      {%- endunless -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}

                {%- if found_sizes != blank -%}
                {%- comment -%} Build size-to-variant mapping {%- endcomment -%}
                {%- assign size_variant_map = '' -%}
                {%- for variant in product.variants -%}
                  {%- if variant.inventory_policy == 'continue' or variant.inventory_quantity > 0 -%}
                    {%- for i in (1..3) -%}
                      {%- case i -%}
                        {%- when 1 -%}
                          {%- assign option_value = variant.option1 -%}
                        {%- when 2 -%}
                          {%- assign option_value = variant.option2 -%}
                        {%- when 3 -%}
                          {%- assign option_value = variant.option3 -%}
                      {%- endcase -%}
                      {%- if option_value != blank and size_options contains option_value -%}
                        {%- if size_variant_map == blank -%}
                          {%- assign size_variant_map = option_value | append: ':' | append: variant.id -%}
                        {%- else -%}
                          {%- assign size_variant_map = size_variant_map
                            | append: ','
                            | append: option_value
                            | append: ':'
                            | append: variant.id
                          -%}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- capture product_card_markup -%}
                  <div
                    class="product-card"
                    style="background-color: transparent !important;"
                    data-sizes="{{ found_sizes }}"
                    data-size-variants="{{ size_variant_map }}"
                  >
                    {%- render 'product-card',
                      product: product,
                      product_id: product.id,
                      section_id: section.id,
                      lazy_load: false,
                      image_ratio: settings.product_image_ratio,
                      image_fill: settings.product_image_fill,
                      show_secondary_image: settings.product_secondary_image,
                      show_vendor: settings.product_vendor,
                      show_rating: settings.product_rating,
                      show_color_swatches: settings.product_color_swatches,
                      show_countdown: settings.product_countdown,
                      show_quick_add: settings.product_quick_add,
                      show_quick_view: settings.product_quick_view,
                      show_save_amount: settings.product_save_amount,
                      save_type: settings.product_save_type,
                      show_icon_list: settings.product_icon_list
                    -%}
                  </div>
                {%- endcapture -%}

                  {%- assign is_neckguard = false -%}
                  {%- if product.type == 'Neck Guard' or product.type == 'Neck Guard 3.0' -%}
                    {%- assign is_neckguard = true -%}
                  {%- endif -%}
                {%- assign is_last_chance = false -%}
                {%- for product_collection in product.collections -%}
                  {%- if product_collection.id == last_chance_collection_id -%}
                    {%- assign is_last_chance = true -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- if is_neckguard -%}
                  {%- assign neckguard_products_markup = neckguard_products_markup | append: product_card_markup -%}
                {%- elsif is_last_chance -%}
                  {%- assign last_chance_products_markup = last_chance_products_markup | append: product_card_markup -%}
                {%- else -%}
                  {%- assign other_products_markup = other_products_markup | append: product_card_markup -%}
                {%- endif -%}
              {%- endif -%}
              {%- endfor -%}
            {%- endpaginate -%}
          {%- endif -%}
        {%- endfor -%}

        {{- other_products_markup -}}
        {{- last_chance_products_markup -}}
        {{- neckguard_products_markup -}}
      </motion-list>
    </slider-element>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const productsContainer = document.getElementById('size-products-{{ section.id }}');
    const noProductsElement = document.getElementById('no-products-{{ section.id }}');
    const trigger = document.getElementById('size-trigger-{{ section.id }}');
    const optionsContainer = document.getElementById('size-options-{{ section.id }}');
    const closeBtn = document.getElementById('close-btn-{{ section.id }}');
    const sizeOptions = document.querySelectorAll('.custom-size-selector-{{ section.id }} .option');

    // Variable to store the currently selected size
    let currentSelectedSize = null;
    // Flag to track if this is the initial page load
    let isInitialLoad = true;

    // Toggle dropdown open
    trigger.addEventListener('click', function() {
      optionsContainer.classList.add('show');
    });

    // Close dropdown
    closeBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      optionsContainer.classList.remove('show');
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', function (e) {
      const customSelector = document.querySelector('.custom-size-selector-{{ section.id }}');
      if (customSelector && !customSelector.contains(e.target)) {
        optionsContainer.classList.remove('show');
      }
    });

    // Function to add variant parameter to product links
    function updateProductLinks() {
      if (!currentSelectedSize) return;

      const allProductCards = productsContainer.querySelectorAll('.product-card[data-size-variants]');

      allProductCards.forEach(function(card) {
        const sizeVariantMap = card.getAttribute('data-size-variants');
        if (!sizeVariantMap) return;

        // Parse the size-variant mapping (format: "SR-SM:123,SR-MD:456")
        const variantPairs = sizeVariantMap.split(',');
        let variantId = null;

        // First try direct match
        for (let i = 0; i < variantPairs.length; i++) {
          const [size, vid] = variantPairs[i].split(':');
          if (size === currentSelectedSize) {
            variantId = vid;
            break;
          }
        }

        // If no direct match, try combined sizes
        if (!variantId && sizeMapping[currentSelectedSize]) {
          const combinedSizes = sizeMapping[currentSelectedSize];
          for (let j = 0; j < combinedSizes.length; j++) {
            for (let i = 0; i < variantPairs.length; i++) {
              const [size, vid] = variantPairs[i].split(':');
              if (size === combinedSizes[j]) {
                variantId = vid;
                break;
              }
            }
            if (variantId) break;
          }
        }

        if (variantId) {
          // Find all links within the product card
          const links = card.querySelectorAll('a[href*="/products/"]');
          links.forEach(function(link) {
            const url = new URL(link.href);
            // Only update if it's a product page link and doesn't already have a variant
            if (url.pathname.includes('/products/')) {
              url.searchParams.set('variant', variantId);
              url.searchParams.set('size_selected', 'true');
              link.href = url.toString();
            }
          });
        }
      });
    }

    // Map of single sizes to their combined size equivalents
    const sizeMapping = {
      'YTH-SM': ['YTH-SM/MD'],
      'YTH-MD': ['YTH-SM/MD'],
      'YTH-LG': ['YTH-LG/XL'],
      'YTH-XL': ['YTH-LG/XL'],
      'SR-SM': ['SR-SM/MD'],
      'SR-MD': ['SR-SM/MD'],
      'SR-LG': ['SR-LG/XL'],
      'SR-XL': ['SR-LG/XL'],
      'SR-2XL': ['SR-2XL/3XL'],
      'SR-3XL': ['SR-2XL/3XL']
    };

    // Function to check if a product matches the selected size
    function matchesSelectedSize(productSizes, selectedSize) {
      // Direct match
      if (productSizes.includes(selectedSize)) {
        return true;
      }

      // Check for combined size matches
      if (sizeMapping[selectedSize]) {
        const combinedSizes = sizeMapping[selectedSize];
        for (let i = 0; i < combinedSizes.length; i++) {
          if (productSizes.includes(combinedSizes[i])) {
            return true;
          }
        }
      }

      return false;
    }

    // Function to handle size selection
    function handleSizeSelection(selectedSize) {
      currentSelectedSize = selectedSize;

      // Save selected size to localStorage
      if (selectedSize) {
        localStorage.setItem('userSize', selectedSize);
      }

      // Update the display text and carousel heading
      if (selectedSize) {
        trigger.textContent = selectedSize;

        // Update carousel heading with selected size
        const carouselHeading = document.getElementById('carousel-heading-{{ section.id }}');
        {% if section.settings.heading_2_template != blank %}
          const headingTemplate = '{{ section.settings.heading_2_template }}';
          if (carouselHeading && headingTemplate.includes('{size}')) {
            carouselHeading.textContent = headingTemplate.replace('{size}', selectedSize);
          }
        {% elsif section.settings.show_size_in_heading %}
          // Fallback: append size to original heading
          if (carouselHeading) {
            carouselHeading.textContent = '{{ section.settings.heading_2 }} - ' + selectedSize;
          }
        {% endif %}
      } else {
        trigger.textContent = '{{ section.settings["button-text"] }}';

        // Reset carousel heading to original
        const carouselHeading = document.getElementById('carousel-heading-{{ section.id }}');
        if (carouselHeading) {
          carouselHeading.textContent = '{{ section.settings.heading_2 }}';
        }
      }

      // Close dropdown after selection
      optionsContainer.classList.remove('show');

      // Show the carousel section
      const sizeProductsCarousel = document.getElementById('size-products-carousel');
      sizeProductsCarousel.style.display = 'block';

      // Hide containers
      productsContainer.style.display = 'none';
      noProductsElement.style.display = 'none';

      if (!selectedSize) {
        return;
      }

      const allProductCards = productsContainer.querySelectorAll('.product-card[data-sizes]');
      let visibleCount = 0;

      allProductCards.forEach(function (card) {
        const productSizes = card.getAttribute('data-sizes').split(',');

        if (matchesSelectedSize(productSizes, selectedSize)) {
          card.classList.add('show');
          visibleCount++;
        } else {
          card.classList.remove('show');
        }
      });

      const countElement = document.querySelector('#cus_count_prods');
      if (countElement) {
        countElement.innerText = visibleCount + ' Products';
      }

      if (visibleCount > 0) {
        productsContainer.style.display = 'block';
        // Update product links with the selected variant
        updateProductLinks();

        // Smooth scroll to the carousel section (only if not initial load)
        if (!isInitialLoad) {
          const carouselSection = document.getElementById('size-products-carousel');
          if (carouselSection) {
            setTimeout(function() {
              carouselSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
          }
        }
      } else {
        noProductsElement.style.display = 'block';
      }

      // After first selection, set flag to false
      isInitialLoad = false;
    }

    // Add click handlers to size options
    sizeOptions.forEach(function(option) {
      option.addEventListener('click', function() {
        const selectedSize = this.getAttribute('data-size');

        // Remove selected class from all options
        sizeOptions.forEach(function(opt) {
          opt.classList.remove('selected');
        });

        // Add selected class to clicked option
        this.classList.add('selected');

        // Handle the selection
        handleSizeSelection(selectedSize);
      });
    });

    // Handle preselected size on page load
    const preselectedOption = document.querySelector('.custom-size-selector-{{ section.id }} .option[data-preselected="true"]');
    if (preselectedOption) {
      const preselectedSize = preselectedOption.getAttribute('data-size');
      preselectedOption.classList.add('selected');
      handleSizeSelection(preselectedSize);
    }

    // Carousel Navigation Functionality
    function initCarouselNavigation() {
      const carouselPrevBtn = document.getElementById('carousel-prev-{{ section.id }}');
      const carouselNextBtn = document.getElementById('carousel-next-{{ section.id }}');
      const slider = document.getElementById('Slider-{{ section.id }}');

      if (!carouselPrevBtn || !carouselNextBtn || !slider) {
        return;
      }

      const motionList = slider.querySelector('motion-list');

      if (!motionList) {
        return;
      }

      function updateCarouselButtons() {
        const scrollLeft = motionList.scrollLeft;
        const scrollWidth = motionList.scrollWidth;
        const clientWidth = motionList.clientWidth;

        // Disable prev button if at start
        if (scrollLeft <= 0) {
          carouselPrevBtn.disabled = true;
        } else {
          carouselPrevBtn.disabled = false;
        }

        // Disable next button if at end
        if (scrollLeft + clientWidth >= scrollWidth - 10) {
          carouselNextBtn.disabled = true;
        } else {
          carouselNextBtn.disabled = false;
        }
      }

      function scrollCarousel(direction) {
        const visibleCards = motionList.querySelectorAll('.product-card.show');

        if (visibleCards.length === 0) return;

        // Calculate how many cards are visible per screen
        const containerWidth = motionList.clientWidth;
        const cardWidth = visibleCards[0].offsetWidth || 300;
        const computedStyle = window.getComputedStyle(motionList);
        const gap = parseInt(computedStyle.gap) || 20;

        const cardsPerScreen = Math.floor(containerWidth / (cardWidth + gap));

        // Scroll logic: if 3 or 4 cards per screen -> scroll 3, if 5 cards -> scroll 4
        let cardsToScroll;
        if (cardsPerScreen === 2 || cardsPerScreen === 3) {
          cardsToScroll = 3;
        } else {
          cardsToScroll = 4;
        }

        const scrollAmount = cardsToScroll * (cardWidth + gap);

        if (direction === 'next') {
          motionList.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        } else {
          motionList.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        }

        // Update button states after scroll animation
        setTimeout(updateCarouselButtons, 300);
      }

      carouselPrevBtn.addEventListener('click', function(e) {
        e.preventDefault();
        scrollCarousel('prev');
      });

      carouselNextBtn.addEventListener('click', function(e) {
        e.preventDefault();
        scrollCarousel('next');
      });

      // Update buttons on scroll
      motionList.addEventListener('scroll', updateCarouselButtons);

      // Initial button state
      setTimeout(updateCarouselButtons, 500);

      // Update button states when products are loaded/filtered
      const observer = new MutationObserver(function() {
        setTimeout(updateCarouselButtons, 100);
      });

      observer.observe(motionList, { childList: true, subtree: true, attributes: true, attributeFilter: ['class'] });
    }

    // Initialize carousel navigation after products are displayed
    const originalHandleSizeSelection = handleSizeSelection;
    handleSizeSelection = function(selectedSize) {
      originalHandleSizeSelection(selectedSize);
      setTimeout(initCarouselNavigation, 200);
    };

    // Also init on page load if preselected
    if (document.querySelector('.custom-size-selector-{{ section.id }} .option[data-preselected="true"]')) {
      setTimeout(initCarouselNavigation, 500);
    }
  });
</script>

<script>
  // Track size selector clicks Posthog Metric
  document.addEventListener('click', function(e) {  
    if (e.target.closest('.template-collection .size-selection-container .options .option')) {  
      posthog.capture('Size Selector Option Clicked', {  
        page_type: 'collection'  
      });  
    }  
  });  
</script>

