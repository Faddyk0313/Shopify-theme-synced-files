<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }

  #shopify-section-{{ section.id }} .title-wrapper {
    margin-bottom: var(--sp-4) !important;
  }

  .size-products-container .product-card[data-sizes] {
    display: none;
  }

  @media (min-width: 786px) {
    .size-products-container .product-card.show {
      margin-top: 2rem !important;
    }
  }

  .size-products-container .product-card.show {
    display: block;
  }

  /* Custom Size Selector Styles */
  .custom-size-selector-{{ section.id }} .trigger {
    background-color: black;
    border-radius: 10px;
    color: white;
    padding: 1rem;
    cursor: pointer;
    min-width: 170px;
    text-align: center;
    user-select: none;
  }
  .custom-size-selector-{{ section.id }} .options {
    background-color: black;
    border-radius: 10px;
    color: white;
    max-height: 0;
    {% comment %} max-width: 0; {% endcomment %}
    position: absolute;
    top: 5px;
    left: 5px;
    overflow: hidden;
    transition: all 0.2s ease-in-out;
    z-index: 100;
  }
  .custom-size-selector-{{ section.id }} .options.show {
    padding: 1.5rem !important;
    padding-bottom: 0.7rem;
    max-height: 600px !important;
    {% comment %} max-width: 180px !important; {% endcomment %}
    top: 0px;
    left: 0px;
  }
  .custom-size-selector-{{ section.id }} .options .head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 5rem;
    padding-bottom: 1rem;
  }
  .custom-size-selector-{{ section.id }} .options .title {
    font-size: 15px;
    color: gray;
    font-weight: 600;
  }
  .custom-size-selector-{{ section.id }} .close-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: white;
    padding: 0.4rem;
    border-radius: 20px;
    color: black;
    cursor: pointer;
    border: none;
    transition: all 0.3s ease-in-out;
  }
  .custom-size-selector-{{ section.id }} .close-btn:hover {
    transform: scale(1.1);
  }
  .custom-size-selector-{{ section.id }} .options .option {
    transition: all 0.1s ease-in-out;
    cursor: pointer;
    margin-bottom: 0.8rem;
    font-size: 18px;
    font-weight: 500;
  }
  .custom-size-selector-{{ section.id }} .options .option:hover {
    text-decoration: underline;
  }
  .custom-size-selector-{{ section.id }} .options .option.selected {
    color: gray;
  }

  .sizeContainer .title-wrapper {
    justify-content: center;
  }
  #size-products-carousel {
    display: none;
  }

  /* Carousel Navigation Buttons */
  /*.carousel-nav-buttons {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .carousel-nav-btn {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 1px solid rgb(23,23,23);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .carousel-nav-btn:hover {
    background: rgb(23,23,23);
    border-color: rgb(23,23,23);
  }

  .carousel-nav-btn:hover svg {
    stroke: #fff;
  }

  .carousel-nav-btn:disabled {
    opacity: .3;
    pointer-events: none;
  }

  .carousel-nav-btn svg {
    width: 20px;
    height: 20px;
    stroke: rgb(23,23,23);
    stroke-width: 2;
    transition: stroke 0.3s ease;
  }*/

  .title-wrapper.with-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .carousel-nav-buttons {
      display: none;
    }
  }

  /* Force carousel to scroll */
  #Slider-{{ section.id }} motion-list {
    overflow-x: auto !important;
    overflow-y: hidden !important;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE and Edge */
  }

  #Slider-{{ section.id }} motion-list::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  #Slider-{{ section.id }} motion-list .product-card {
    scroll-snap-align: start;
    flex-shrink: 0;
  }
</style>

{% comment %} Size chart Css {% endcomment %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap');
  [id^="SizeChart"] .drawer__title {
    font-family: 'Armourxbd';
    margin: auto;
  }
  [id^="SizeChart"] .drawer__close {
    margin-inline-start: 0 !important;
  }
  [id^="SizeChart"] .drawer__scrollable {
    padding-block: 1rem;
  }
  .cusheader {
    margin-block: 1rem;
  }
  .sizechartContent .heading {
    font-size: 1rem;
    font-family: 'Armourxbd';
    margin: 0 !important;
    text-transform: uppercase;

  }
  .sizechartContent .sub_heading {
    font-size: 1rem;
    font-family: 'Armourmd';
    margin: 0 !important;
  }
  .sizechartContent .chartHeading {
    background-color: black;
    width:100%;
    font-size: 1rem;
    font-family: 'Armourxbd';
    color:white;
    padding:10px;
    text-align: center;

  }
  .boldText {
    font-weight: 700;
  }
  .sizechartContent .tableOuter {
    grid-template-columns: repeat(5, 1fr);
  }
  .sizechartContent .tableOuter.neckGuardVersion {
    grid-template-columns: repeat(6, 1fr);
  }
  .sizechartContent .tableOuter {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    background-color: #f2f2f2;
    padding: 10px;
    font-family: "Rajdhani", sans-serif;
    text-align: center;
    font-weight: 500;
  }
  .tableOuter > * {
    border-bottom: 1px solid gray;
    padding-inline: 10px;
    padding-block: 5px;
    font-size: 16px;
    white-space: nowrap;
  }
  .tableOuter.neckGuardVersion > * {
    font-size: 12px;
  }
  .noBorder {
    border-bottom: none !important;
  }
  .borderLeft {
    border-left: 1px solid gray;
  }
  .cus_disclaimer {
    background-color: #f2f2f2;
    padding: 10px;
    padding-top: 0;
    width: 100%;
    text-align: end;
    font-size: 12px;
    font-family: "Roboto", sans-serif;
    margin-bottom: 1rem;
  }
  .cus_disclaimer p {
    margin: 0 !important;
  }

  @media (min-width: 786px) {
    [id^="SizeChart"] .drawer__title {transform: translateX(24px);}
    .sizechartContent .heading {font-size: 1.5rem;}
    .sizechartContent .sub_heading {font-size: 1.5rem;}
    .sizechartContent .chartHeading {font-size: 1.5rem;}
    .tableOuter > *, .tableOuter.neckGuardVersion > * {font-size: 19px;}
    .cus_disclaimer {font-size: 14px;}
  }
</style>

<div class="sizeContainerOuter section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="sizeContainer page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
