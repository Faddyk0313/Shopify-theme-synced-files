                      <div class="boldText">NECK*</div>
                      <div class="boldText">HEAD</div>
                      <div class="boldText">CHEST</div>
                      <div class="boldText">ARM</div>
                      <div class="boldText">YTH-XS</div>
                      <div>10.5"</div>
                      <div>18"</div>
                      <div>22"</div>
                      <div>18"</div>
                      <div class="boldText">YTH-SM</div>
                      <div>11"</div>
                      <div>19"</div>
                      <div>26"</div>
                      <div>19"</div>
                      <div class="boldText">YTH-MD</div>
                      <div>11.5"</div>
                      <div>20"</div>
                      <div>30"</div>
                      <div>20"</div>
                      <div class="boldText">YTH-LG</div>
                      <div>12"</div>
                      <div>21"</div>
                      <div>34"</div>
                      <div>22"</div>
                      <div class="boldText noBorder">YTH-XL</div>
                      <div class="noBorder">12.5"</div>
                      <div class="noBorder">22"</div>
                      <div class="noBorder">38"</div>
                      <div class="noBorder">24"</div>
                    </div>

                    <div class="cus_disclaimer">
                      <p>Measure in inches</p>
                      <p>*Neck is the primary measurement for sizing</p>
                    </div>

                    <div class="chartHeading">SENIOR SIZE</div>

                    <div class="tableOuter">
                      <div class="boldText">SIZE</div>
                      <div class="boldText">NECK*</div>
                      <div class="boldText">HEAD</div>
                      <div class="boldText">CHEST</div>
                      <div class="boldText">ARM</div>
                      <div class="boldText">SR-XS</div>
                      <div>13"</div>
                      <div>22"</div>
                      <div>38"</div>
                      <div>27"</div>
                      <div class="boldText">SR-SM</div>
                      <div>13.5"</div>
                      <div>22.5"</div>
                      <div>40"</div>
                      <div>28"</div>
                      <div class="boldText">SR-MD</div>
                      <div>14"</div>
                      <div>23"</div>
                      <div>42"</div>
                      <div>29"</div>
                      <div class="boldText">SR-LG</div>
                      <div>15"</div>
                      <div>23.5"</div>
                      <div>44"</div>
                      <div>30"</div>
                      <div class="boldText">SR-XL</div>
                      <div>16"</div>
                      <div>24"</div>
                      <div>46"</div>
                      <div>31"</div>
                      <div class="boldText">SR-2XL</div>
                      <div>17"</div>
                      <div>24.5"</div>
                      <div>50"</div>
                      <div>32"</div>
                      <div class="boldText noBorder">SR-3XL</div>
                      <div class="noBorder">18"</div>
                      <div class="noBorder">25"</div>
                      <div class="noBorder">54"</div>
                      <div class="noBorder">33"</div>
                    </div>

                    <div class="cus_disclaimer">
                      <p>Measure in inches</p>
                      <p>*Neck is the primary measurement for sizing</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </x-modal>
        </div>
        <div class="flex-shrink-0 flex flex-row items-center gap-4 md:gap-8" style="justify-content: center;">
          <div class="custom-size-selector-{{ section.id }}" style="position: relative">
            <div class="trigger" id="size-trigger-{{ section.id }}">{{ section.settings['button-text'] }}</div>
            <div class="options" id="size-options-{{ section.id }}">
              <div class="head">
                <div class="title">Size</div>
                <button class="close-btn" id="close-btn-{{ section.id }}" type="button">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                  </svg>
                </button>
              </div>
              <div
                class="option"
                data-size="YTH-XS"
                {% if section.settings.preselected_size == 'YTH-XS' %}
                  data-preselected="true"
                {% endif %}
              >
                YTH-XS
              </div>
              <div
                class="option"
                data-size="YTH-SM"
                {% if section.settings.preselected_size == 'YTH-SM' %}
                  data-preselected="true"
                {% endif %}
              >
                YTH-SM
              </div>
              <div
                class="option"
                data-size="YTH-MD"
                {% if section.settings.preselected_size == 'YTH-MD' %}
                  data-preselected="true"
                {% endif %}
              >
                YTH-MD
              </div>
              <div
                class="option"
                data-size="YTH-LG"
                {% if section.settings.preselected_size == 'YTH-LG' %}
                  data-preselected="true"
                {% endif %}
              >
                YTH-LG
              </div>
              <div
                class="option"
                data-size="YTH-XL"
                {% if section.settings.preselected_size == 'YTH-XL' %}
                  data-preselected="true"
                {% endif %}
              >
                YTH-XL
              </div>
              <div
                class="option"
                data-size="SR-SM"
                {% if section.settings.preselected_size == 'SR-SM' %}
                  data-preselected="true"
                {% endif %}
              >
                SR-SM
              </div>
              <div
                class="option"
                data-size="SR-MD"
                {% if section.settings.preselected_size == 'SR-MD' %}
                  data-preselected="true"
                {% endif %}
              >
                SR-MD
              </div>
              <div
                class="option"
                data-size="SR-LG"
                {% if section.settings.preselected_size == 'SR-LG' %}
                  data-preselected="true"
                {% endif %}
              >
                SR-LG
              </div>
              <div
                class="option"
                data-size="SR-XL"
                {% if section.settings.preselected_size == 'SR-XL' %}
                  data-preselected="true"
                {% endif %}
              >
                SR-XL
              </div>
              <div
                class="option"
                data-size="SR-2XL"
                {% if section.settings.preselected_size == 'SR-2XL' %}
                  data-preselected="true"
                {% endif %}
              >
                SR-2XL
