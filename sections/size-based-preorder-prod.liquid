<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
  }

  /* Hide section initially */
  #shopify-section-{{ section.id }} {
    display: none;
  }

  /* Show section when it has the 'show' class */
  #shopify-section-{{ section.id }}.show {
    display: block;
  }

</style>

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- render 'section-heading', section: section -%}

    <!-- No Products Message -->
    <div id="no-preorder-products-{{ section.id }}" class="no-products-message text-center py-8" style="display: none;">
      <p class="text-gray-600">
        {{ section.settings.no_products_text | default: 'No preorder products are currently available.' }}
      </p>
    </div>

    <div id="preorder-products-{{ section.id }}" class="preorder-products-container" style="display: none;">
      <slider-element
        id="Slider-{{ section.id }}"
        class="grid slider{% if section.settings.carousel_on_desktop %} slider--desktop{% endif %}{% if section.settings.swipe_on_mobile %} slider--tablet{% endif %}"
        selector=".card-grid>.card"
      >
        <motion-list class="product-grid card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid">
          {%- comment -%} Target specific collection by ID {%- endcomment -%}
          {%- assign target_collection_id = 321970929842 -%}
          {%- assign target_collection = null -%}

          {%- comment -%} Find the collection by ID {%- endcomment -%}
          {%- for collection in collections -%}
            {%- if collection.id == target_collection_id -%}
              {%- assign target_collection = collection -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if target_collection -%}
            {%- assign preorder_count = 0 -%}
            {%- assign size_options = 'YTH-XS,YTH-SM,YTH-MD,YTH-LG,YTH-XL,SR-XS,SR-SM,SR-MD,SR-LG,SR-XL,SR-2XL,SR-3XL' | split: ',' -%}
            {%- paginate target_collection.products by 300 -%}
              {%- for product in target_collection.products -%}
                {%- comment -%} Check if product has preorder metafield {%- endcomment -%}
                {%- assign product_state1 = product.metafields.custom.product_state1 -%}

                {%- if product_state1 == 'preorder-august' -%}
                  {%- assign preorder_count = preorder_count | plus: 1 -%}

                  {%- comment -%} Build size-to-variant mapping for this product {%- endcomment -%}
                  {%- assign size_variant_map = '' -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.available -%}
                      {%- for i in (1..3) -%}
                        {%- case i -%}
                          {%- when 1 -%}
                            {%- assign option_value = variant.option1 -%}
                          {%- when 2 -%}
                            {%- assign option_value = variant.option2 -%}
                          {%- when 3 -%}
                            {%- assign option_value = variant.option3 -%}
                        {%- endcase -%}
                        {%- if option_value != blank and size_options contains option_value -%}
                          {%- if size_variant_map == blank -%}
                            {%- assign size_variant_map = option_value | append: ':' | append: variant.id -%}
                          {%- else -%}
                            {%- assign size_variant_map = size_variant_map | append: ',' | append: option_value | append: ':' | append: variant.id -%}
                          {%- endif -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endfor -%}

                  <div class="product-card" style="background-color: transparent !important;" data-size-variants="{{ size_variant_map }}">
                    {%- render 'product-card',
                      product: product,
                      product_id: product.id,
                      section_id: section.id,
                      lazy_load: false,
                      image_ratio: settings.product_image_ratio,
                      image_fill: settings.product_image_fill,
                      show_secondary_image: settings.product_secondary_image,
                      show_vendor: settings.product_vendor,
                      show_rating: settings.product_rating,
                      show_color_swatches: settings.product_color_swatches,
                      show_countdown: settings.product_countdown,
                      show_quick_add: settings.product_quick_add,
                      show_quick_view: settings.product_quick_view,
                      show_save_amount: settings.product_save_amount,
                      save_type: settings.product_save_type,
                      show_icon_list: settings.product_icon_list
                    -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- endpaginate -%}
          {%- else -%}
            <!-- Fallback message when collection is not found -->
            <div class="text-center py-8">
              <p class="text-gray-600">Collection not found (ID: {{ target_collection_id }})</p>
            </div>
          {%- endif -%}
        </motion-list>
      </slider-element>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sectionElement = document.getElementById('shopify-section-{{ section.id }}');
    const productsContainer = document.getElementById('preorder-products-{{ section.id }}');
    const noProductsElement = document.getElementById('no-preorder-products-{{ section.id }}');

    if (!sectionElement || !productsContainer || !noProductsElement) return;

    // Count product cards
    const productCards = productsContainer.querySelectorAll('.product-card');
    const productCount = productCards.length;

    // Initially show/hide based on product count
    if (productCount > 0) {
      productsContainer.style.display = 'block';
      noProductsElement.style.display = 'none';
    } else {
      productsContainer.style.display = 'none';
      noProductsElement.style.display = 'block';
    }

    // Function to get selected size from the size selector
    function getSelectedSize() {
      // Look for the unique .sort-selection element (from sizes-in-stock-section)
      const sizeSelectionElement = document.querySelector('.sort-selection');
      if (!sizeSelectionElement) return null;

      const sizeText = sizeSelectionElement.textContent.trim();

      console.log("hi", sizeText)
      // Check if a valid size is selected (not the default text)
      if (sizeText === 'Select your size' || sizeText === '' || !sizeText) {
        return null;
      }


      return sizeText;
    }

    // Function to update product links with variant ID
    function updateProductLinks(selectedSize) {
      if (!selectedSize) return;

      const allProductCards = productsContainer.querySelectorAll('.product-card[data-size-variants]');

      allProductCards.forEach(function(card) {
        const sizeVariantMap = card.getAttribute('data-size-variants');
        if (!sizeVariantMap) return;

        // Parse the size-variant mapping (format: "SR-SM:123,SR-MD:456")
        const variantPairs = sizeVariantMap.split(',');
        let variantId = null;

        for (let i = 0; i < variantPairs.length; i++) {
          const [size, vid] = variantPairs[i].split(':');
          if (size === selectedSize) {
            variantId = vid;
            break;
          }
        }

        if (variantId) {
          // Find all links within the product card
          const links = card.querySelectorAll('a[href*="/products/"]');
          links.forEach(function(link) {
            const url = new URL(link.href);
            // Only update if it's a product page link
            if (url.pathname.includes('/products/')) {
              url.searchParams.set('variant', variantId);
              url.searchParams.set('size_selected', 'true');
              link.href = url.toString();
            }
          });
        }
      });
    }

    // Function to check size selection and show/hide section
    function checkSizeSelection() {
      const selectedSize = getSelectedSize();

      if (selectedSize) {
        // Show the section
        sectionElement.classList.add('show');
        // Update product links
        updateProductLinks(selectedSize);
      } else {
        // Hide the section
        sectionElement.classList.remove('show');
      }
    }

    // Check on load
    checkSizeSelection();

    // Monitor for size selection changes
    // Use MutationObserver to watch for changes in the size selector
    const observer = new MutationObserver(function() {
      checkSizeSelection();
    });

    // Observe the document for changes to the size selection text
    const targetNode = document.querySelector('.sort-selection');
    if (targetNode) {
      observer.observe(targetNode, {
        childList: true,
        characterData: true,
        subtree: true
      });
    }

    // Also listen for custom events or changes in case the size selector dispatches them
    document.addEventListener('change', function(e) {
      if (e.target && e.target.name && e.target.name.includes('size_selector')) {
        checkSizeSelection();
      }
    });

    // Poll every 500ms as a fallback (in case MutationObserver doesn't catch everything)
    setInterval(checkSizeSelection, 500);
  });
</script>

