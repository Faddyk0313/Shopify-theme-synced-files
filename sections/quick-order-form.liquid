        align-items: center;
        flex-direction: column;
        gap: 1rem;
      }
      #qof-subtotal {
        text-align: center;
        padding-bottom: 1rem;
      }
      .button-grp-mobile {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      #qof-count {
        flex-direction: row;
        align-items: baseline;
      }
    }

      .disabled {
        color: gray;
        cursor: not-allowed;
      }
      /* hide the native arrows so only your code quantity buttons ever changes the value */
      .quantity__input::-webkit-inner-spin-button,
      .quantity__input::-webkit-outer-spin-button {
        -webkit-appearance: none !important;
        margin: 0 !important;
      }
      .quantity__input {
        -moz-appearance: textfield !important; /* Firefox */
      }
  </style>

  {% assign quick_collection_handles = 'battlegear-og,inline-core-colors,novelty,team-colors' | split: ',' %}
  {% assign active_collection = quick_collection_handles[0] %}

  
  
  <section class="page-width quick-order-page">
    <!-- Collections Bar -->
    <div class="qof-collections-bar name-grid">
      {% for handle in quick_collection_handles %}
        {% assign col = collections[handle] %}
        <button
          type="button"
          class="name-box qof-collection-btn{% if handle == active_collection %} selected_name{% endif %}"
          data-collection-handle="{{ handle }}"
          data-collection-title="{{ col.title }}"
        >
          {{ col.title }}
        </button>
      {% endfor %}
    </div>

    <h2 id="qof-current-collection">
      {{ collections[active_collection].title }}
    </h2>
    <!-- Global Search -->
    <div class="qof-search-container">
      <input
        type="search"
        id="qof-search-input"
        placeholder="Search products…"
      >
    </div>

    <!-- DESKTOP TABLE (hidden on mobile) -->
    <div class="qof-desktop">
      <form id="quick-order-form">
        <table id="tableView">
          <thead>
            <tr>
              <th class="align-left">Product</th>
              <th class="quantity_selector">Quantity</th>
              <th class="msg">Stock / Message</th>
              <th class="price">Price</th>
              <th class="align-right total last">Total</th>
            </tr>
          </thead>
          <tbody>
            {% for handle in quick_collection_handles %}
              {% for product in collections[handle].products %}
                <!-- Product Row -->
                <tr
                  class="product-row"
                  data-collection-handle="{{ handle }}"
                  data-product-id="{{ product.id }}"
                  {% unless handle == active_collection %}
                    style="display:none"
                  {% endunless %}
                >
                  <!-- Image + product Name ans show variants button -->
                  <td class="product-info">
                    <img
                      src="{{ product.featured_image | image_url: width:80, height:80 }}"
                      alt="{{ product.title }}"
                    >
                    <div class="product-info__meta">
                      <span class="product-info__title">{{ product.title }}</span>
                      <button
                        type="button"
                        class="toggle-variants"
                        data-product-id="{{ product.id }}"
                        aria-expanded="false"
                      >
                        Show Variants
                      </button>
                    </div>
                  </td>
                  <!-- Quantity (parent row) -->
                  <td class="quantity_selector">–</td>
                  <!-- Stock/Message -->
                  <td class="msg">–</td>
                  <!-- Price (first variant) -->
                  {% if wholesale_discount > 0 %}
                    {%- assign discount_amount = product.price_min | times: wholesale_discount -%}
                    {%- assign discounted_price = product.price_min | minus: discount_amount -%}
                    <td class="price">{{ discounted_price | money }}/ea</td>
                  {% endif %}
                  <!-- Total -->
                  <td class="product-total total align-right last">$0.00</td>
                </tr>

                <!-- Variant Rows -->
                {% for variant in product.variants %}
                  <tr
                    class="variant-row"
                    data-parent-id="{{ product.id }}"
                    data-collection-handle="{{ handle }}"
                    style="display:none"
                  >
                    <!-- ↳ Variant (image + title) -->
                    <td class="variant-info variant-indent">
                      <img
                        src="
                          {{ variant.image | default: product.featured_image
                          | image_url: width:60, height:60 }}
                        "
                        alt="{{ variant.title }}"
                      >

                      <div class="title_sku_container">
                        <span class="variant-info__title">{{ variant.title }}</span>
                        <span class="variant-info__sku">Variant SKU: {{ variant.sku }}</span>
                      </div>
                    </td>

                    <!-- Quantity -->
                    <td class="quantity_selector">
                    {% if variant.inventory_management and variant.inventory_quantity > 0 %}
                        <quantity-input class="quantity inline-flex relative" data-variant-id="{{ variant.id }}">
                          <button type="button" name="minus" class="active quantity__button">
                            {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                          </button>
                          <input
                            class="desktop variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                            type="number"
                            data-id="{{ variant.id }}"
                            inputmode="numeric"
                            autocomplete="off"
                            min="0"
                            max="{{ variant.inventory_quantity }}"
                            value="0"
                          >
                          <button
                            type="button"
                            name="plus"
                            class="active quantity__button"
                            aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                          >
                            {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                          </button>
                        </quantity-input>
                    {% elsif variant.inventory_management and variant.inventory_quantity <= 0 and variant.inventory_policy == 'continue' %}
                        <quantity-input class="quantity inline-flex relative" data-variant-id="{{ variant.id }}">
                          <button type="button" name="minus" class="active quantity__button">
                            {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                          </button>
                          <input
                            class="desktop variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                            type="number"
                            data-id="{{ variant.id }}"
                            inputmode="numeric"
                            autocomplete="off"
                            min="0"
                            value="0"
                          >
                          <button
                            type="button"
                            name="plus"
                            class="active quantity__button"
                            aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                          >
                            {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                          </button>
                        </quantity-input>
                      {% else %}
                        <quantity-input
                          class="quantity disabled  inline-flex relative"
                          data-variant-id="{{ variant.id }}"
                        >
                          <button type="button" name="minus" class="quantity__button">
                            {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                          </button>
                          <input
                            class="desktop variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                            type="number"
                            data-id="{{ variant.id }}"
                            inputmode="numeric"
                            autocomplete="off"
                            min="0"
                            max="{{ variant.inventory_quantity }}"
                            value="0"
                            disabled
                      
                          >
                          <button
                            type="button"
                            name="plus"
                            class="quantity__button"
                            aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                          >
                            {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                          </button>
                        </quantity-input>
                      {% endif %}
                    </td>

                    <!-- Stock / Message -->
                    <td class="msg">
                      {% assign msg = variant.metafields.custom.preproduction_note %}
                      {% if msg %}
                        <!-- <span class="variant-message">{{ msg }}</span> -->
                        <span class="variant-message">Preproduction</span>
                      {% elsif variant.inventory_management and variant.inventory_quantity > 0 %}
                        <span class="in-stock">{{ variant.inventory_quantity }} in stock</span>
                      {% elsif variant.metafields.custom.notify_me_button_label == '<strong>Coming Soon - Notify Me</strong>'  %}
                        <span class="variant-message">Future Drops</span>
                      {% else %}
                        <span class="out-of-stock">Sold Out</span>
                      {% endif %}
                    </td>

                    {% if wholesale_discount > 0 %}
                      {%- assign discount_amount = variant.price | times: wholesale_discount -%}
                      {%- assign discounted_price = variant.price | minus: discount_amount -%}
                  
                      <td class="wholesale-price price whitespace-nowrap ">
                        <span class="diagonal-strike price__regular whitespace-nowrap relative inline-block text-gray-500" style="color: gray; font-size: 13px;">
                          {{ variant.price | money }}
                        </span>
                        <span class="variant-price  price__regular new whitespace-nowrap text-red-600 font-semibold">
                          {{ discounted_price | money }}
                        </span>
                      </td>
                  
                    {%- else -%}
                        <!-- Price -->
                        <td class="variant-price price">{{ variant.price | money }}/ea </td>
                    {% endif %}

                    <!-- Variant Total -->
                    <td class="variant-total total align-right">$0.00</td>
                  </tr>
                {% endfor %}
              {% endfor %}
            {% endfor %}
            <!-- No Results Message -->
            <tr class="no-results" style="display:none">
              <td colspan="5" style="text-align:center; padding:2rem;">No products found for your search.</td>
            </tr>
          </tbody>
        </table>
      </form>
    </div>

    <!-- MOBILE CARDS (hidden on desktop) -->
    <div class="qof-mobile">
      {% for handle in quick_collection_handles %}
        {% for product in collections[handle].products %}
          <div
            class="qof-mobile-product product-row"
            data-collection-handle="{{handle}}"
            {% unless handle == active_collection %}
              style="display:none"
            {% endunless %}
          >
            <div class="qof-mobile-header">
              <div class="image-title">
                <img
                  src="{{ product.featured_image | image_url: width:60, height:60 }}"
                  alt="{{product.title}}"
                >
                <div class="qof-mobile-meta">
                  <h3>{{ product.title }}</h3>
                </div>
              </div>
              {% if wholesale_discount > 0 %}
                  {%- assign discount_amount = product.price_min | times: wholesale_discount -%}
                  {%- assign discounted_price = product.price_min | minus: discount_amount -%}
                  <span class="mobile-price">{{ discounted_price | money }}/ea</span>
              {% else %}
                <span class="mobile-price">{{ product.price_min | money }}/ea</span>
              {% endif %}
            </div>
            <button
              type="button"
              class="toggle-variants"
              data-product-id="{{product.id}}"
              aria-expanded="false"
            >
              Show Variants
            </button>
            <div
              id="mobile-variants-{{product.id}}"
              class="qof-mobile-variants"
            >
              {% for variant in product.variants %}
                <div class="variant-row" data-parent-id="{{product.id}}" style="display:none">
                  <div class="mobile-product-details">
                    <div class="variant-info">
                      <img
                        src="{{ product.featured_image | image_url: width:60, height:60 }}"
                        alt="{{product.title}}"
                      >
                      <div>
                        <strong>{{ variant.title }}</strong><br>
                        <small>SKU: {{ variant.sku }}</small>
                      </div>
                    </div>
                    {% if wholesale_discount > 0 %}
                      {%- assign discount_amount = variant.price | times: wholesale_discount -%}
                      {%- assign discounted_price = variant.price | minus: discount_amount -%}
                  
                      <p class="wholesale-price whitespace-nowrap flex items-center gap-2 hi {%- if is_center == false -%}hi justify-start {%- else -%}hi justify-center {%- endif -%}">
                        <span class="diagonal-strike price__regular whitespace-nowrap relative inline-block text-gray-500" style="color: gray; font-size: 13px;">
                          {{ variant.price | money }}
                        </span>
                        <span class="variant-price  price__regular new whitespace-nowrap text-red-600 font-semibold">
                          {{ discounted_price | money }}
                        </span>
                      </p>
                  
                    {%- else -%}
                        <!-- Price -->
                        <div class="variant-price price">{{ variant.price | money }}/ea </div>
                    {% endif %}
                  </div>

                  <div class="variant-stock">
                    {% assign msg = variant.metafields.custom.preproduction_note %}
                    {% if msg %}
                      <span class="variant-message">Preproduction</span>
                    {% elsif variant.inventory_management and variant.inventory_quantity > 0 %}
                      <span class="in-stock">{{ variant.inventory_quantity }} in stock</span>
                    {% elsif variant.metafields.custom.notify_me_button_label == '<strong>Coming Soon - Notify Me</strong>'  %}
                        <span class="variant-message">Future Drops</span>
                      {% else %}
                      <span class="out-of-stock">Sold Out</span>
                    {% endif %}
                  </div>

                  

                  <div class="mobile-quantity-total">
                    {% if variant.inventory_management and variant.inventory_quantity > 0 %}
                      <quantity-input class="quantity inline-flex relative" data-variant-id="{{ variant.id }}">
                        <button type="button" name="minus" class="active quantity__button">
                          {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                        <input
                          class="mobile variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                          type="number"
                          data-id="{{ variant.id }}"
                          inputmode="numeric"
                          autocomplete="off"
                          min="0"
                          max="{{ variant.inventory_quantity }}"
                          value="0"
                        >
                        <button
                          type="button"
                          name="plus"
                          class="active quantity__button"
                          aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                        >
                          {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                      </quantity-input>
                    {% elsif variant.inventory_management and variant.inventory_quantity <= 0 and variant.inventory_policy == 'continue' %}
                     <quantity-input class="quantity inline-flex relative" data-variant-id="{{ variant.id }}">
                        <button type="button" name="minus" class="active quantity__button">
                          {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                        <input
                          class="mobile variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                          type="number"
                          data-id="{{ variant.id }}"
                          inputmode="numeric"
                          autocomplete="off"
                          min="0"
                          max="{{ variant.inventory_quantity }}"
                          value="0"
                        >
                        <button
                          type="button"
                          name="plus"
                          class="active quantity__button"
                          aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                        >
                          {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                      </quantity-input>
                    {% else %}
                      <quantity-input
                        class="quantity disabled  inline-flex relative"
                        data-variant-id="{{ variant.id }}"
                      >
                        <button type="button" name="minus" class="quantity__button">
                          {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                        <input
                          class="mobile variant-quantity  quantity__input text-sm sm:text-base font-medium text-center"
                          type="number"
                          data-id="{{ variant.id }}"
                          inputmode="numeric"
                          autocomplete="off"
                          min="0"
                          max="{{ variant.inventory_quantity }}"
                          value="0"
                          disabled
                        >
                        <button
                          type="button"
                          name="plus"
                          class="quantity__button"
                          aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                        >
                          {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                      </quantity-input>
                    {% endif %}
                    <div class="variant-total">$0.00</div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>

    <div class="qof-footer desktop ">
      <!-- <button id="add-to-cart-btn" class="btn">Add Selected to Cart</button> -->
      <button
        id="add-to-cart-btn"
        class="button button--primary"
        is="hover-button"
      >
        <span class="btn-fill" data-fill></span>

        <span class="btn-text">
          {%- liquid
            echo 'products.product.add_to_cart' | t
          -%}
        </span>
      </button>
      <!-- <button id="qof-clear" class="btn-clear">Remove all</button> -->
      <a
        href="#"
        id="qof-clear"
        class="button button--secondary"
        is="hover-link"
        data-no-instant
      >
        <span class="btn-fill" data-fill style="transform: translateY(var(--motion-translateY));"></span>
        <span class="btn-text">Reset Form</span>
      </a>
      <div id="qof-count">
        <div id="qof-count-value">0</div>
        <div>Total Items</div>
      </div>
      <!-- now 2nd -->

      <div class="qof-taxmsg">
        <div id="qof-subtotal">
          <span id="qof-subtotal-value">$0.00</span><br>
          <small>Product subtotal</small>
        </div>
        Taxes, Discounts and <a href="/policies/shipping-policy">Shipping</a> calculated at checkout
      </div>
    </div>

    <div class="qof-footer mobile">
      <div id="qof-count">
        <small>Total Items: </small>
        <div id="qof-count-value">0</div>
      </div>
      <!-- now 2nd -->
      <div class="qof-taxmsg">
        <div id="qof-subtotal"><small>Product subtotal</small>: <span id="qof-subtotal-value">$0.00</span></div>
        <div>Taxes, Discounts and <a href="/policies/shipping-policy">Shipping</a> calculated at checkout</div>
      </div>
      <div class="button-grp-mobile">
        <!-- <button id="add-to-cart-btn" class="btn">Add Selected to Cart</button> -->
        <button
          id="add-to-cart-btn"
          class="button button--primary"
          is="hover-button"
        >
          <span class="btn-fill" data-fill></span>

          <span class="btn-text">
            {%- liquid
              echo 'products.product.add_to_cart' | t
            -%}
          </span>
        </button>
        <!-- <button id="qof-clear" class="btn-clear">Remove all</button> -->
        <a
          href="#"
          id="qof-clear"
          class="button button--secondary"
          is="hover-link"
          data-no-instant
        >
          <span class="btn-fill" data-fill style="transform: translateY(var(--motion-translateY));"></span>
          <span class="btn-text">Reset Form</span>
