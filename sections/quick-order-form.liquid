  <script>
  document.addEventListener("DOMContentLoaded", function() {
    // — Variant toggling —
    document.querySelectorAll(".toggle-variants").forEach(button => {
      button.addEventListener("click", () => {
        const pid  = button.dataset.productId;
        const rows = document.querySelectorAll(`.variant-row[data-parent-id="${pid}"]`);
        if (!rows.length) return;
    
        const willShow = rows[0].style.display === "none";
        // decide “display” mode based on viewport width
        const isMobile     = window.matchMedia("(max-width: 1150px)").matches;
        const showStyle    = isMobile ? "flex" : "table-row";
    
        rows.forEach(r => {
          r.style.display = willShow ? showStyle : "none";
        });
    
        button.textContent       = willShow ? "Hide Variants" : "Show Variants";
        button.setAttribute("aria-expanded", willShow);
      });
    });

function updateTotalFor(input) {
  // 1. clamp the raw input value to [min, max]:
  const min = parseInt(input.min,  10) || 0;
  const max = parseInt(input.max, 10) || Infinity;
  let qty  = parseInt(input.value, 10) || 0;

  if (qty < min) {
    qty = min;
    input.value = qty;
  } else if (qty > max) {
    qty = max;
    input.value = qty;
  }

  // 2. now use the clamped `qty` for your total logic:
  const row       = input.closest("tr.variant-row");
  const priceCell = row.querySelector(".variant-price");
  const totalCell = row.querySelector(".variant-total");
  const price     = parseFloat(priceCell.textContent.replace(/[^0-9.-]+/g,"")) || 0;

  if (qty > 0) {
    totalCell.textContent = "$" + (price * qty).toFixed(2);
  } else {
    totalCell.textContent = "$0.00";
  }

  // …and the rest of your subtotal/items recalculation…
  let items = 0, subtotal = 0;
  document.querySelectorAll(".variant-quantity").forEach(el => {
    const q = parseInt(el.value, 10) || 0;
    if (q > 0) {
      items += q;
      const r = el.closest("tr.variant-row");
      const p = parseFloat(
        r.querySelector(".variant-price")
         .textContent.replace(/[^0-9.-]+/g,"")
      ) || 0;
      subtotal += p * q;
    }
  });

  document.getElementById("qof-count").innerHTML =
    `<div id='qof-count-value'>${items}</div> <div>Total Items</div>`;
  document.getElementById("qof-subtotal").innerHTML =
    `<span id='qof-subtotal-value'>$${subtotal.toFixed(2)}</span><br><small>Product subtotal</small>`;
}

function updateTotalForMobile(input) {
  // clamp to [min, max] just like above
  const min = parseInt(input.min,  10) || 0;
  const max = parseInt(input.max, 10) || Infinity;
  let qty  = parseInt(input.value, 10) || 0;

  if (qty < min) {
    qty = min;
    input.value = qty;
  } else if (qty > max) {
    qty = max;
    input.value = qty;
  }

  // now your existing mobile total logic…
  const row       = input.closest("div.variant-row");
  const priceCell = row.querySelector(".variant-price");
  const totalCell = row.querySelector(".variant-total");
  const cleanText = priceCell.textContent.replace(/[^0-9.,]/g, "").replace(/,/g, "");
  const price = parseFloat(cleanText) || 0;

  if (qty > 0) {
    totalCell.textContent = "$" + (price * qty).toFixed(2);
  } else {
    totalCell.textContent = "$0.00";
  }

  let items = 0, subtotal = 0;
  document.querySelectorAll("div.qof-mobile input.mobile.variant-quantity")
    .forEach(el => {
      const q = parseInt(el.value, 10) || 0;
      if (q > 0) {
        items += q;
        const r = el.closest("div.variant-row");
        const p = parseFloat(
          r.querySelector(".variant-price")
           .textContent.replace(/[^0-9.-]+/g,"")
        ) || 0;
        subtotal += p * q;
      }
    });

  document.getElementById("qof-count-value").innerText    = items;
  document.getElementById("qof-subtotal-value").innerText = "$" + subtotal.toFixed(2);
}

// re-attach your listeners:
document.querySelectorAll("quantity-input input.desktop.variant-quantity")
  .forEach(input => {
    const handler = () => updateTotalFor(input);
    input.addEventListener("input",  handler);
    input.addEventListener("change", handler);
  });
document.querySelectorAll("quantity-input input.mobile.variant-quantity")
  .forEach(input => {
    const handler = () => updateTotalForMobile(input);
    input.addEventListener("input",  handler);
    input.addEventListener("change", handler);
  });

    // — Add Selected to Cart —
    document.getElementById("add-to-cart-btn").addEventListener("click", () => {
      const items = [];
      document.querySelectorAll(".variant-quantity").forEach(input => {
        const qty = parseInt(input.value, 10) || 0;
        if (qty > 0) {
          items.push({ id: input.dataset.id, quantity: qty });
        }
      });
      if (!items.length) {
        return alert("Please select at least one item.");
      }
      fetch("/cart/add.js", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ items })
      })
      .then(res => res.json())
      .then(() => { window.location.href = "/cart"; })
      .catch(err => {
        console.error("Cart error:", err);
        alert("Failed to add items. Please try again.");
      });
    });

    // — Collection switching —
    const collBtns = document.querySelectorAll(".qof-collection-btn");
    const prodRows = document.querySelectorAll(".product-row");
    const varRows  = document.querySelectorAll(".variant-row");
    let currentCollection = collBtns[0].dataset.collectionHandle;
    
    function showCollection(handle) {
      currentCollection = handle;
      // highlight
      collBtns.forEach(b => b.classList.toggle("selected_name", b.dataset.collectionHandle === handle));
      // show/hide products
      prodRows.forEach(r => {
        r.style.display = (r.dataset.collectionHandle === handle ? "" : "none");
      });
      // hide & reset all variants
      varRows.forEach(r => r.style.display = "none");
      document.querySelectorAll(".toggle-variants").forEach(btn => {
        btn.textContent       = "Show Variants";
        btn.setAttribute("aria-expanded", "false");
      });
      // 3) Update the <h2> text:
      const title = document
        .querySelector(`.qof-collection-btn[data-collection-handle="${handle}"]`)
        .dataset.collectionTitle;
      document.getElementById("qof-current-collection").textContent = title;

    }
    
    collBtns.forEach(btn => {
      btn.addEventListener("click", () => showCollection(btn.dataset.collectionHandle));
    });
    // init load
    if (collBtns.length) {
      showCollection(collBtns[0].dataset.collectionHandle);
    }

    // Global search Logic
    const searchInput = document.getElementById("qof-search-input");
    const noRow       = document.querySelector(".no-results");

    searchInput.addEventListener("input", () => {
      const term = searchInput.value.trim().toLowerCase();

      // if search is empty, revert to collection filter
      if (!term) {
        noRow.style.display = "none";
        return showCollection(currentCollection);
      }

      // non-empty search → un-highlight all collections
      collBtns.forEach(btn => btn.classList.remove("selected_name"));

      // otherwise, bypass collection filter & do a substring match on product title
      let matches = 0;
      // hide all variants & reset toggles
      varRows.forEach(r => r.style.display = "none");
      document.querySelectorAll(".toggle-variants").forEach(btn => {
        btn.textContent = "Show Variants";
        btn.setAttribute("aria-expanded", "false");
      });

      prodRows.forEach(row => {
        const titleEl = row.querySelector(".product-info__title");
        const title   = titleEl ? titleEl.textContent.trim().toLowerCase() : "";

        if (title.includes(term)) {
          row.style.display = "";
          matches++;
        } else {
          row.style.display = "none";
        }
      });

      // show or hide the “no results” message
      noRow.style.display = matches ? "none" : "table-row";
    });

    // --- FOOTER LOGIC ---
    const clearBtn = document.getElementById("qof-clear");
    
    clearBtn.addEventListener("click", (e) => {
      e.preventDefault();    // stop the “#” from jumping
      // 1) Reset every variant row:
      document.querySelectorAll("tr.variant-row").forEach(row => {
        const input   = row.querySelector("input.variant-quantity");
        const totalTd = row.querySelector(".variant-total");
        if (input)   input.value = 0;
        if (totalTd) totalTd.textContent = "$0.00";
      });
      document.querySelectorAll("div.variant-row").forEach(row => {
        const input   = row.querySelector("input.variant-quantity");
        const totalTd = row.querySelector(".variant-total");
        if (input)   input.value = 0;
        if (totalTd) totalTd.textContent = "$0.00";
      });
    
      // 2) Reset the sticky footer values:
      document.getElementById("qof-count-value").innerText    = "0";
      document.getElementById("qof-subtotal-value").innerText = "$0.00";
    });

  });
  </script>
{% else %}
  <div style="text-align: center; padding: 50px;">
    <h2>This page is only available for wholesale customers.</h2>
  </div>
{% endif %}
