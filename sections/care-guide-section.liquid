<style>
  .cus_wrapper {
    padding-block: {{ section.settings.section_gap }}px;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.section_gap }}px;
  }

  .cus_care-section {
    background: {{ section.settings.section_bg_color }};
    color: {{ section.settings.section_text_color }};
  }

  .cus_care-section.blackBG {
    background: {{ section.settings.dark_section_bg_color }};
    color: {{ section.settings.dark_section_text_color }};
  }

  .cus_care-section .care-header {
    background: {{ section.settings.header_bg_color }};
    color: {{ section.settings.header_text_color }};
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 25px;
  }

  .cus_care-section .care-header h2 {
    margin: 0;
    color: {{ section.settings.header_text_color }};
    font-size: 32px;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .cus_care-section .care-content {
    padding: 35px 25px;
  }

  .cus_care-section .care-item {
    margin-bottom: 20px;
  }

  .cus_care-section .care-item .icon-heading-grp {
    display: flex;
    gap: 5px;
    align-items: center;
  }

  .cus_care-section .care-item:last-child {
    margin-bottom: 0;
  }

  .cus_care-section .care-item h3 {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
  }

  .cus_care-section.blackBG .care-item h3 {
    color: {{ section.settings.dark_section_text_color }};
  }

  .cus_care-section .care-item p {
    margin: 0 0 0 18px;
    font-size: 14px;
    line-height: 1.45;
    color: {{ section.settings.section_paragraph_color }};
  }

  .cus_care-section.blackBG .care-item p {
    color: {{ section.settings.dark_section_text_color }};
  }

  @media (max-width: 749px) {
    .cus_care-section .care-content {
      padding: 25px 15px;
    }
    .cus_care-section .care-header {
      padding: 12px 15px;
    }
    .cus_care-section .care-header h2 {
      font-size: 24px;
    }

    .cus_care-section .care-item h3 {
      font-size: 12px;
    }

    .cus_care-section .care-item p {
      font-size: 12px;
    }

    .cus_care-section .care-header img {
      transform: scale(0.9);
      transform-origin: left center;
    }

    .cus_care-section .care-item .icon-heading-grp img {
      transform: scale(0.8);
      transform-origin: left center;
    }
  }
</style>

<div class="cus_wrapper page-width page-width--narrow ">
  {% for block in section.blocks %}
    <div
      class="cus_care-section{% if block.settings.use_dark_theme %} blackBG{% endif %}"
      {{ block.shopify_attributes }}
    >
      {% if block.settings.show_header %}
        <div class="care-header">
          {% if block.settings.header_icon_url != blank %}
            <div>
              <img
                src="{{ block.settings.header_icon_url | escape }}"
                width="{{ block.settings.header_icon_width }}"
                height="auto"
                loading="lazy"
              >
            </div>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h2>{{ block.settings.heading }}</h2>
          {% endif %}
        </div>
      {% endif %}

      <div class="care-content">
        {% for i in (1..6) %}
          {% assign title_key = 'item_' | append: i | append: '_title' %}
          {% assign text_key = 'item_' | append: i | append: '_text' %}
          {% assign item_title = block.settings[title_key] %}
          {% assign item_text = block.settings[text_key] %}

          {% if item_title != blank or item_text != blank %}
            <div class="care-item">
              {% if item_title != blank %}
                <div class="icon-heading-grp">
                  {% if block.settings.item_icon_url != blank %}
                    <img
                      src="{{ block.settings.item_icon_url | escape }}"
                      width="{{ block.settings.item_icon_width }}"
                      height="auto"
                      loading="lazy"
                    >
                  {% endif %}
                  <h3>{{ item_title }}</h3>
                </div>
              {% endif %}

              {% if item_text != blank %}
                <p style="margin-left: {{ block.settings.item_text_margin_left }}px;">{{ item_text }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endfor %}
</div>

