{% assign section_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collage-gallery-{{ section_id }} {
    padding: {{ section.settings.section_padding }}px 0;
    background-color: {{ section.settings.background_color }};
  }

  .ai-collage-gallery__container-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collage-gallery__header-{{ section_id }} {
    text-align: {{ section.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-collage-gallery__title-{{ section_id }} {
    margin: 0 0 12px;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
  }

  .ai-collage-gallery__description-{{ section_id }} {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.description_size }}px;
  }

  .ai-collage-gallery__grid-{{ section_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: {{ section.settings.row_height }}px;
    gap: {{ section.settings.grid_gap }}px;
  }

  .ai-collage-gallery__item-{{ section_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-collage-gallery__item-{{ section_id }}--1 {
    grid-column: span {{ section.settings.image_1_width }};
    grid-row: span {{ section.settings.image_1_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--2 {
    grid-column: span {{ section.settings.image_2_width }};
    grid-row: span {{ section.settings.image_2_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--3 {
    grid-column: span {{ section.settings.image_3_width }};
    grid-row: span {{ section.settings.image_3_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--4 {
    grid-column: span {{ section.settings.image_4_width }};
    grid-row: span {{ section.settings.image_4_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--5 {
    grid-column: span {{ section.settings.image_5_width }};
    grid-row: span {{ section.settings.image_5_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--6 {
    grid-column: span {{ section.settings.image_6_width }};
    grid-row: span {{ section.settings.image_6_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--7 {
    grid-column: span {{ section.settings.image_7_width }};
    grid-row: span {{ section.settings.image_7_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--8 {
    grid-column: span {{ section.settings.image_8_width }};
    grid-row: span {{ section.settings.image_8_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--9 {
    grid-column: span {{ section.settings.image_9_width }};
    grid-row: span {{ section.settings.image_9_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--10 {
    grid-column: span {{ section.settings.image_10_width }};
    grid-row: span {{ section.settings.image_10_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--11 {
    grid-column: span {{ section.settings.image_11_width }};
    grid-row: span {{ section.settings.image_11_height }};
  }

  .ai-collage-gallery__item-{{ section_id }}--12 {
    grid-column: span {{ section.settings.image_12_width }};
    grid-row: span {{ section.settings.image_12_height }};
  }

  .ai-collage-gallery__image-{{ section_id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-collage-gallery__item-{{ section_id }}:hover .ai-collage-gallery__image-{{ section_id }} {
    transform: scale(1.05);
  }

  @media screen and (max-width: 749px) {
    .ai-collage-gallery__grid-{{ section_id }} {
      grid-template-columns: 1fr;
      grid-auto-rows: {{ section.settings.mobile_row_height }}px;
    }

    .ai-collage-gallery__item-{{ section_id }}--1,
    .ai-collage-gallery__item-{{ section_id }}--2,
    .ai-collage-gallery__item-{{ section_id }}--3,
    .ai-collage-gallery__item-{{ section_id }}--4,
    .ai-collage-gallery__item-{{ section_id }}--5,
    .ai-collage-gallery__item-{{ section_id }}--6,
    .ai-collage-gallery__item-{{ section_id }}--7,
    .ai-collage-gallery__item-{{ section_id }}--8,
    .ai-collage-gallery__item-{{ section_id }}--9,
    .ai-collage-gallery__item-{{ section_id }}--10,
    .ai-collage-gallery__item-{{ section_id }}--11,
    .ai-collage-gallery__item-{{ section_id }}--12 {
      grid-column: span 1;
      grid-row: span 1;
    }

    .ai-collage-gallery__title-{{ section_id }} {
      font-size: {{ section.settings.heading_size | times: 0.7 }}px;
    }

    .ai-collage-gallery__description-{{ section_id }} {
      font-size: {{ section.settings.description_size | times: 0.9 }}px;
    }

    .ai-collage-gallery__header-{{ section_id }} {
      margin-bottom: 24px;
    }
  }
{% endstyle %}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.narrow %} page-width--narrow{% endif %} relative">
    <div class="ai-collage-gallery-{{ section_id }}">
      <div class="ai-collage-gallery__container-{{ section_id }}">
        {% if section.settings.heading != blank or section.settings.description != blank %}
          <div class="ai-collage-gallery__header-{{ section_id }}">
            {% if section.settings.heading != blank %}
              <h2 class="ai-collage-gallery__title-{{ section_id }}">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.description != blank %}
              <div class="ai-collage-gallery__description-{{ section_id }}">{{ section.settings.description }}</div>
            {% endif %}
          </div>
        {% endif %}

        <div class="ai-collage-gallery__grid-{{ section_id }}">
          {% for i in (1..12) %}
            {% assign image_key = 'image_' | append: i %}
            {% assign image = section.settings[image_key] %}

            {% if image %}
              <div class="ai-collage-gallery__item-{{ section_id }} ai-collage-gallery__item-{{ section_id }}--{{ i }}">
                <img
                  src="{{ image | image_url: width: 1200 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-collage-gallery__image-{{ section_id }}"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

