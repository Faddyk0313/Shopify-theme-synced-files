<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  {% comment %} Tbg custom code {% endcomment %}
  .diagonal-strike {
    color: gray;
    position: relative;
  }
  .diagonal-strike::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    background: red;
    transform: rotate(-15deg); /* changed from -15deg to 15deg */
    transform-origin: center;

  }
  h1.cartheading {
    font-size: 42px;
    margin: 0;
  }
  .cartheading {
    font-size: 36px;
    margin-top: 7px;
  }
  .savingsLine {
    font-size: 17px;
  }
  .titleWrapperCont {
    gap: var(--sp-8)
  }
  @media (min-width: 1250px) {
    .titleWrapperCont {
      min-width: 760px;
    }
  }
  #mobileiconssvg {
    display: none
  }
  .desktopiconssvg {
    display: block
  }
  .desktopVer.cart__sidebar {
    border-radius: var(--rounded-button);
    padding: 1.3rem !important;
    background-color: #f2f2f2 !important;
  }
  .cart__sidebar .totals {
    padding-block: var(--sp-6) !important;
    border-block-start: 1px solid rgb(var(--color-border-dark)) !important;
    border-block-end: 1px solid rgb(var(--color-border-dark)) !important;
  }
  .cart-item-card {
    position: relative;
    background: #f2f2f2;
    border-radius: var(--rounded-button);
    {% comment %} padding: 1rem; {% endcomment %}
    {% comment %} border: 1px solid rgb(var(--color-border-light));
    box-shadow: 0 16px 35px rgba(15, 15, 15, 0.08); {% endcomment %}
  }
  .cart-item-card__remove {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    z-index: 2;
  }
  .cart-item-card__loader {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-item-card__loader[hidden] {
    display: none !important;
  }
  .cart-item-card__remove-link {
    width: 18px;
    height: 18px;
    display: grid;
    place-items: center;
  }
  .cart-item-card__remove-icon {
    width: 100%;
    height: 100%;
  }
  .cart-item-card__media {
    flex-shrink: 0;
    width: 90px;
  }
  .cart-item-card__media .media {
    width: 100%;
    height: 100%;
  }
  .cart-item-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-item-card__details {
    min-width: 0;
    padding-right: 0.25rem;
  }
  .cart-item-card__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .cart-item-card__media-details {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .desktop.cart-item-card__price-info {
    display: none;
  }
  .mobile.cart-item-card__price-info {
    display: flex;
    align-self: baseline;
  }
  .desktop.cart-item-card__quantity-column {
    display: none;
  }
  .mobile.cart-item-card__quantity-column {
    display: flex;
  }
  .cart-item-card__price-info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .cart-item-card__line-total {
    font-weight: 600;
    display: flex;
    justify-content: flex-end;
    min-width: 130px;
  }
  .cart-item-card__quantity-column {
    display: flex;
    justify-content: flex-end;
  }
  .flexContainer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
  }
  .cart-item-card__price-info .discounts__discount {
    background-color: #00adee;
    border-radius: 4px;
    padding-right: 0.6rem;
  }
  .cart-item-card__price-info .discounts__discount .badge.badge--highlight {
    border-radius: 4px !important;
  }
  .cart-item-card__price-info .discounts .badge--highlight {
    background-color: #baeaf7;
    color: #4aa3e7;
    font-weight: 600;
    font-size: clamp(0.4rem,0.5rem, 0.5rem);
  }
  .cart-item-card__price-info .discounts .badge--onsale {
    background-color: transparent !important;
    padding: 0 !important;
    font-size: clamp(0.4rem,0.5rem, 0.5rem);
  }

  #cus_upsell_banner.mobile,
  .cus_free-shipping.mobile {
    display: grid;
  }
  #cus_upsell_banner.desktop,
  .cus_free-shipping.desktop {
    display: none;
  }
  .cart__item-title {
    font-size:14px;
    line-height: 0.5;
    font-family: 'Armourxbd';
    text-transform: uppercase;
  }
  .cart-item-card__quantity-input {
    display: flex;
    align-items: center;
    padding: 0.25rem;
    background: #fff;
    border-radius: var(--rounded-button);
    border: 1px solid transparent;
    width: fit-content !important;
    height: fit-content !important;
    max-width: 90px;
  }
  .cart-item-card__quantity-input:focus-within {
    border-color: rgba(0, 0, 0, 0.2);
  }
  .cart-item-card__quantity-input--disabled {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: #f4f4f4;
    border-radius: 999px;
    border: 1px solid transparent;
  }
  .cart-item-card__qty-input {
    background: transparent;
    border: none;
    min-width: 20px;
    max-width: 30px;
    font-weight: 600;
    text-align: center;
    padding-inline: 0 !important;
  }
  .cart-item-card__qty-input:focus-visible {
    outline: none;
  }
  .cart-item-card__qty-btn {
    border: none;
    background: transparent;
    padding: 0.2rem 0.45rem;
    font-size: 1.25rem;
    line-height: 1;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .summary_heading {
    font-size: 20px;
  }
  .cus_free-shipping .free-shipping-bar {
    padding: 0 !important;
  }
  .desktop .complementary-products__header {
    padding-bottom: 2rem;
  }
  @media (min-width: 1024px) {
    .titleCont.mobile {
      display: none;
    }
    .cart-item-card__price-info {
      align-items: center !important;
    }
    .cart-item-card__price-info .discounts__discount {
      border-radius: 7px;
    }
    .cart-item-card__price-info .discounts__discount .badge.badge--highlight {
      border-radius: 7px !important;
    }
    .cart-item-card__price-info .discounts .badge--highlight {
      background-color: #e5f7fd;
      color: #00adee;
      font-size: clamp(0.5rem,0.6rem, 0.6rem);
    }
    .cart-item-card__price-info .discounts .badge--onsale {
      background-color: transparent !important;
      padding: 0 !important;
      font-size: clamp(0.5rem,0.6rem, 0.6rem);
    }
    .cart__item-title {
      font-size:18px;
    }
    #cus_upsell_banner.mobile,
    .cus_free-shipping.mobile {
      display: none;
    }
    #cus_upsell_banner.desktop,
    .cus_free-shipping.desktop {
      display: flex;
      width: clamp(340px, 30vw, 480px);
    }
    .mobile.cart-item-card__price-info {
      display: none;
    }
    .desktop.cart-item-card__price-info {
      display: flex;
    }
    .mobile.cart-item-card__quantity-column {
      display: none;
    }
    .desktop.cart-item-card__quantity-column {
      display: flex;
    }
    .cart-item-card__content {
      align-items: center;
      gap: 1rem;
      padding-inline: 1rem;
      display: grid;
      grid-template-columns: auto 170px 90px 25px;
    }
    .cart-quantity__info,
    .cart-item-card__remove-link {
      margin:auto
    }
    .cart-item-card__media-details {
      align-items: center;
      min-width: 47%;
    }
    .cart-item-card__price-info {
      align-items: flex-start;
    }
    .cart-item-card__quantity-column {
      justify-content: flex-start;
    }
    .cart-item-card__remove {
      position: static;
      grid-column: 4 / 5;
      justify-self: center;
    }
    .cart-item-card__remove-link {
      width: 20px;
      height: 20px;
    }
    .desktop.cart-item-card__price-info .price * {
      font-size: 1.2rem;
    }
  }
  @media (min-width: 1200px) {
    .cart-item-card__content {
      gap: 2rem;
      padding-inline: 2rem;
    }
  }
  @media (max-width: 768px) {

    .cart-item-card__price-info .discounts__discount {
      padding-right: 0.3rem;
    }
    .cart-item-card__qty-btn[name='minus'] {
      padding-block: 0.2rem !important;
      padding-left: 0.45rem !important;
      padding-right: 0 !important;
    }
    .cart-item-card__qty-btn[name='plus'] {
      padding-block: 0.2rem !important;
      padding-right: 0.45rem !important;
      padding-left: 0 !important;
    }
    .cart-quantity.cart-item-card__quantity-input {
      padding: 0 !important;
    }
    .cart-item-card__quantity-input {
      font-size: 12px;
    }

    .cart-item-card__remove {
      top: 0.75rem;
      right: 0.75rem;
    }
    .cart-item-card__line-total {
      min-width: 0;
    }
  }
  @media (max-width:1024px){
    .cart-item-card {
      padding: 0.6rem;
    }
    .titleCont.desktop {
      display: none;
    }
    #cart-heading-with-total{
      {% comment %} flex-direction: column; {% endcomment %}
      align-items: center;
      justify-content: center;
    }
    #cart-heading-with-total *{
      width: fit-content;
    }
    .savingsLine {
      width: fit-content;
      margin: auto;
    }
    h1.cartheading {
      font-size: 22px;
    }
    .cartheading {
      font-size: 18px;
      margin-top: 5px;

    }
    .buttonStack .btn-text {
      font-size: 10px
    }
    .title-wrapper {
      margin-bottom: 32px
    }
    .titleWrapperCont {
      gap: var(--sp-4)
    }
    .cart__content {
      gap: var(--sp-3) !important;
    }
    .horizontal-product__title,
    .product-card__title {
      font-size: 12px;
    }
    #mobileiconssvg {
      display: block
    }
    {% comment %} #desktopiconssvg {
      display: none;
    } {% endcomment %}

    .cart-item td:not(.cart-item__quantity) {
      padding-inline: 0 !important;
    }
    .govx-id-full-wrapper {
      display: none;
    }
    .cart-item__media, .horizontal-product__media {
      width: 65px !important;
    }
    .cart__sidebar .totals {
      padding-block: var(--sp-3) !important;
      border-block-start: 1px solid rgb(var(--color-border-dark)) !important;
      border-block-end: 1px solid rgb(var(--color-border-dark)) !important;
    }
    .stickyCheckout {
      position: sticky;
      bottom: 0;
      left: 0;
      z-index: 20;
      border-radius: 0;
      margin-bottom: 0.5rem;
    }
    .cart-item-card__loader {
      top: 0.9rem;
      right: 3rem;
    }
  }
</style>

{{ 'cart.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart.js' | asset_url }}" defer></script>
{%- if settings.gift_wrap_product != blank and settings.gift_wrap_product.available -%}
  <script src="{{ 'gift-wrapping.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<div class="cart{% if cart == empty %} is-empty{% endif %} section{% if cart != empty %} section--padding{% endif %}{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    <div class="empty-state grid items-center justify-center text-center gap-7d5 md:gap-14">
      <div class="flex flex-col items-center gap-5 md:gap-10">
        {%- render 'icon', icon: 'empty', size: 'xxxl' -%}
        <div class="grid gap-5">
          <p class="heading leading-none tracking-tight">{{ 'cart.general.empty' | t }}</p>
        </div>
      </div>
      <a
        class="empty-state__link button button--primary button--fixed"
        href="{{ routes.all_products_collection_url }}"
        is="hover-link"
      >
        <span class="btn-fill" data-fill></span>
        <span class="btn-text">{{ 'cart.general.continue_shopping' | t }}</span>
      </a>
    </div>

    {%- if cart != empty -%}
      {%- liquid
        if settings.gift_wrap_product != blank and settings.gift_wrap_product.available
          assign enable_gift_wrapping = true

          assign gift_wrap_product = settings.gift_wrap_product
          assign gift_wrap_variant = gift_wrap_product.first_available_variant
          assign gift_wrap_per_product = settings.gift_wrap_per_product
          assign gift_items = cart.items | where: 'variant_id', gift_wrap_variant.id

          unless gift_wrap_per_product
            assign gift_wraps_in_cart = 0
            for item in gift_items
              assign gift_wraps_in_cart = gift_wraps_in_cart | plus: item.quantity
            endfor
          endunless
        endif

        assign cart_gift_wrap_items = null
      -%}
      <div
        style="margin-bottom: 2rem;"
        class="{% if section.settings.heading_size == 'title-xl' %} title-wrapper-lg{% endif %} titleCont desktop leading-none grid gap-4 md:flex {{ section.settings.heading_alignment }} relative md:justify-center"
      >
        <a
          style="display: flex; align-items: center; gap: 0.5rem; position: absolute; left: 0;top: 50%;transform: translateY(-50%);"
          href="https://www.titanbattlegear.com/"
        >
          <svg
            fill="#000000"
            height="20px"
            width="20px"
            version="1.1"
            id="Layer_1"
            xmlns="http://www.w3.org/2000/svg"
            xmlns:xlink="http://www.w3.org/1999/xlink"
            viewBox="0 0 330 330"
            xml:space="preserve"
          >
            <path id="XMLID_92_" d="M111.213,165.004L250.607,25.607c5.858-5.858,5.858-15.355,0-21.213c-5.858-5.858-15.355-5.858-21.213,0.001
              l-150,150.004C76.58,157.211,75,161.026,75,165.004c0,3.979,1.581,7.794,4.394,10.607l150,149.996
              C232.322,328.536,236.161,330,240,330s7.678-1.464,10.607-4.394c5.858-5.858,5.858-15.355,0-21.213L111.213,165.004z"/>
          </svg>
          <span>Back to the store</span>
        </a>
        <div class="flex flex-col gap-3">
          <div id="cart-heading-with-total" class="flex gap-3">
            <{{ section.settings.heading_tag }} class="heading cartheading" style="white-space:nowrap;">
              {%- assign heading_content = 'cart.general.title' | t -%}
              <split-words class="split-words js-invisible block" data-animate="fade-up-large"> CART </split-words>
            </{{ section.settings.heading_tag }}>
          </div>
        </div>
      </div>

      <main-cart
        id="MainCart-{{ section.id }}"
        class="cart__content flex flex-col lg:flex-row"
        data-section-id="{{ section.id }}"
      >
        <div class="titleWrapperCont grow flex flex-col gap-8">
          <div class="{% if section.settings.heading_size == 'title-xl' %} title-wrapper-lg{% endif %} titleCont mobile leading-none grid gap-4 md:flex {{ section.settings.heading_alignment }} relative md:justify-center">
            <a
              style="position: absolute; left: 0;top: 50%;transform: translateY(-50%);"
              href="https://www.titanbattlegear.com/"
            >
              <svg
                fill="#000000"
                height="20px"
                width="20px"
                version="1.1"
                id="Layer_1"
                xmlns="http://www.w3.org/2000/svg"
                xmlns:xlink="http://www.w3.org/1999/xlink"
                viewBox="0 0 330 330"
                xml:space="preserve"
              >
                <path id="XMLID_92_" d="M111.213,165.004L250.607,25.607c5.858-5.858,5.858-15.355,0-21.213c-5.858-5.858-15.355-5.858-21.213,0.001
                  l-150,150.004C76.58,157.211,75,161.026,75,165.004c0,3.979,1.581,7.794,4.394,10.607l150,149.996
                  C232.322,328.536,236.161,330,240,330s7.678-1.464,10.607-4.394c5.858-5.858,5.858-15.355,0-21.213L111.213,165.004z"/>
              </svg>
            </a>
            <div class="flex flex-col gap-3">
              <div id="cart-heading-with-total" class="flex gap-3">
                <{{ section.settings.heading_tag }} class="heading cartheading" style="white-space:nowrap;">
                  {%- assign heading_content = 'cart.general.title' | t -%}
                  <split-words class="split-words js-invisible block" data-animate="fade-up-large"> CART </split-words>
                </{{ section.settings.heading_tag }}>
              </div>
            </div>
          </div>
          <div class="cus_free-shipping mobile">
            {%- liquid
              assign minimum_amounts = 100
              assign show_free_shipping_bar = false

              if minimum_amounts contains ':'
                assign minimum_amounts = minimum_amounts | split: ','
                for amount in minimum_amounts
                  assign amount_parts = amount | split: ':'
                  assign currency_code = amount_parts | first | upcase
                  if currency_code == cart.currency.iso_code
                    assign minimum_amount = amount_parts | last
                    assign show_free_shipping_bar = true
                    break
                  endif
                endfor
              else
                assign minimum_amount = minimum_amounts
                assign show_free_shipping_bar = true
              endif

              if show_free_shipping_bar
                render 'free-shipping-bar', minimum_amount: minimum_amount
              endif
            -%}
          </div>

          <style>
                      /* TBG Custom Code */
            #cus_upsell_banner {
              display: flex;
              flex-direction: column;
              border-radius: var(--rounded-button);
              overflow: clip;
              background: linear-gradient(to right, #A1DA74, #D6EB76, #E9FB4B);
              padding: 0.875rem 0.75rem;
              gap: 0.875rem;
            }

            .cus_message {
              text-align: center;
            }

            .upsellMsgHeading {
              font-size: clamp(13px, 3.8vw, 18px);
              line-height: 1.18;
              text-align: center;
              margin: 0;
              text-wrap: balance;
            }

            #cus_button {
              display: flex;
              justify-content: center;
              align-items: center;
            }
            /* End TBG Custom Code */
          </style>

          <div id="cus_upsell_banner" class="mobile">
            <div class="cus_message">
              <h2 class="upsellMsgHeading heading leading-none title-sm">
                ADD A SECOND SHIRT AND SAVE 10%<br>
                OR ADD A THIRD SHIRT TO SAVE 20%
              </h2>
            </div>
            <div id="cus_button">
              {%- render 'button',
                label: 'SHOP BATTLEGEAR',
                link: '/collections/cut-resistant-battlegear',
                style: 'primary',
                size: 'xs',
                textSize: '12px'
              -%}
            </div>
          </div>
          <form class="cart__form" action="{{ routes.cart_url }}" method="POST" id="cart">
            <cart-items class="cart__items block" data-section-id="{{ section.id }}">
              <div class="cart-item-list grid gap-5 md:gap-6">
                {%- for item in cart.items -%}
                  {%- liquid
                    assign is_gift_wrap_item = false
                    if gift_wrap_variant != null and item.id == gift_wrap_variant.id
                      assign is_gift_wrap_item = true
                    endif
                  -%}
                  {%- capture cart_item -%}
                    <article class="cart-item-card" id="CartItem-{{ item.key }}">
                      <div class="cart-item-card__content">
                        <div class="cart-item-card__media-details flex items-start md:items-center gap-4d5 md:gap-10">
                          <div class="cart-item-card__media">
                            {%- if item.image -%}
                              {%- unless is_gift_wrap_item -%}
                                <a class="cart-item__media media relative overflow-hidden shrink-0" href="{{ item.url }}">
                                  {{- item.image | image_url: width: item.image.width | image_tag: loading: 'lazy', widths: '180,360,540', is: 'lazy-image' -}}
                                </a>
                              {%- else -%}
                                <figure class="cart-item__media media relative overflow-hidden shrink-0">
                                  {{- item.image | image_url: width: item.image.width | image_tag: loading: 'lazy', widths: '180,360,540', is: 'lazy-image' -}}
                                </figure>
                              {%- endunless -%}
                            {%- endif -%}
                          </div>
                          <div class="cart-item-card__details grow flex flex-col justify-start gap-1d5">
                            <div class="grid gap-1">
                              <div class="block leading-tight">
                                {%- unless is_gift_wrap_item -%}
                                  {%- if section.settings.show_vendor -%}
                                    <p class="text-xs text-opacity">{{ item.product.vendor }}</p>
                                  {%- endif -%}
                                  <a href="{{ item.url }}" class="cart__item-title reversed-link font-medium text-base ">
                                    {% assign title_parts = item.product.title | split: ' - ' %}
                                    {{ title_parts[0] | escape }}<br>
                                    {{ title_parts[1] | escape }}
                                  </a>
                                  {% comment %} <h1 class="heading leading-none {{ block.settings.title_size }} mobile:{{ block.settings.title_size_mobile }} col-span-full">
                                    {%- if settings.enable_heading_reveal -%}
                                      <split-words class="split-words js-invisible block" data-animate="fade-up">
                                        {{- product.title -}}
                                      </split-words>
                                    {%- else -%}
                                      {{- product.title -}}
                                    {%- endif -%}
                                  </h1> {% endcomment %}
                                {%- else -%}
                                  <p class="font-medium text-base leading-tight">{{ item.product.title | escape }}</p>
                                {%- endunless -%}
                              </div>
                              {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != null -%}
                                <dl class="grid gap-1d5">
                                  {%- unless item.product.has_only_default_variant -%}
                                    {%- for option in item.options_with_values -%}
                                      <div class="text-xs text-opacity leading-tight">
                                        <dt class="sr-only">{{ option.name }}:</dt>
                                        <dd class="inline">{{ option.value }}</dd>
                                      </div>
                                    {%- endfor -%}
                                  {%- endunless -%}
                                  {%- for property in item.properties -%}
                                    {%- assign property_first_char = property.first | slice: 0 -%}
                                    {%- if property.last != blank and property_first_char != '_' -%}
                                      <div class="text-xs text-opacity leading-tight">
                                        <dt class="inline">{{ property.first }}:&nbsp;</dt>
                                        <dd class="inline">
                                          {%- if property.last contains '/uploads/' -%}
