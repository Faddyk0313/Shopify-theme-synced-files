<script>
  // TBG Custom Code
  document.addEventListener('DOMContentLoaded', function () {
    var lastChanceProductIds = [];
    var collectionsLoaded = false;

    function loadAllCollectionProductIds(handle) {
      var limit = 250;
      var page = 1;
      var all = [];

      function fetchPage() {
        var url = '/collections/' + handle + '/products.json?limit=' + limit + '&page=' + page;

        return fetch(url)
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var products = (data && data.products) ? data.products : [];

            for (var i = 0; i < products.length; i++) {
              all.push(products[i].id);
            }

            if (products.length === limit) {
              page += 1;
              return fetchPage();
            }

            return all;
          });
      }

      return fetchPage();
    }

    loadAllCollectionProductIds('last-chance')
      .then(function (ids) {
        lastChanceProductIds = ids;
        collectionsLoaded = true;
        updatePromoText();
      })
      .catch(function () {
        collectionsLoaded = true;
        updatePromoText();
      });

    function isGiftCardItem(item) {
      if (item && item.gift_card === true) return true;

      var pt = (item && item.product_type) ? String(item.product_type).toLowerCase() : '';
      if (pt === 'gift card') return true;

      var title = (item && item.product_title) ? String(item.product_title) : '';
      if (/gift\s*card/i.test(title)) return true;

      return false;
    }

    function isLastChanceItem(item) {
      var pid = item && item.product_id;
      if (!pid) return false;
      return lastChanceProductIds.indexOf(pid) > -1;
    }

    function updatePromoText() {
      if (!collectionsLoaded) return;

      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          // Get all elements with class 'cus_message'
          var upsellMsgContainers = document.querySelectorAll('.cus_message');

          if (upsellMsgContainers.length === 0) return;

          if (cart.item_count === 0) {
            upsellMsgContainers.forEach(function(container) {
              container.style.display = 'none';
            });
            return;
          }

          var nonGiftItems = (cart.items || []).filter(function (item) {
            return !isGiftCardItem(item);
          });

          if (nonGiftItems.length === 0) {
            upsellMsgContainers.forEach(function(container) {
              container.style.display = 'none';
            });
            return;
          }

          // Exclude ONLY last-chance items (gift cards already excluded above)
          var nonLastChanceItems = nonGiftItems.filter(function (item) {
            return !isLastChanceItem(item);
          });

          if (nonLastChanceItems.length === 0) {
            upsellMsgContainers.forEach(function(container) {
              container.style.display = 'none';
            });
            return;
          }

          var nonLastChanceCount = nonLastChanceItems.reduce(function (total, item) {
            return total + (item.quantity || 0);
          }, 0);

          var firstItem = nonLastChanceItems[0];
          var origCents = (firstItem.original_line_price || firstItem.line_price) || 0;
          var qty = firstItem.quantity || 1;
          var price = qty ? (origCents / 100) / qty : 0;

          var msg = '';
          var currencySymbol = {{ cart.currency.symbol | json }};

          if (nonLastChanceCount === 1) {
            var d1 = price * 2 * 0.10;
            var d2 = price * 3 * 0.20;
            msg =
              '<h2 class="upsellMsgHeading heading leading-none title-sm">ADD A SECOND SHIRT AND SAVE 10% (' +
              currencySymbol + ' ' + d1.toFixed(2) + ')<br>' +
              'OR ADD A THIRD AND SAVE 20% (' + currencySymbol + ' ' + d2.toFixed(2) + ')</h2>';
          } else if (nonLastChanceCount === 2) {
            msg = '<h2 class="upsellMsgHeading heading leading-none title-sm">ADD A THIRD SHIRT TO SAVE 20%</h2>';
          } else {
            msg = '<h2 class="upsellMsgHeading heading leading-none title-sm">ADD A SECOND SHIRT AND SAVE 10%<br>OR ADD A THIRD SHIRT TO SAVE 20%</h2>';
          }

          // Update all containers
          upsellMsgContainers.forEach(function(container) {
            container.style.display = 'block';
            container.innerHTML = msg;
          });
        })
        .catch(function () {});
    }

    document.addEventListener('cart:updated', updatePromoText);
  });
  // End TBG Custom Code
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function showLoaderByKey(itemKey) {
      if (!itemKey) return;
      var loader = document.getElementById('Loader-{{ section.id }}-' + itemKey);
      if (loader) loader.removeAttribute('hidden');
    }

    function showLoaderFromTarget(target) {
      if (!target) return;
      var card = target.closest('.cart-item-card');
      if (!card) return;
      var input = card.querySelector('.cart-item-card__qty-input[data-index]');
      var itemKey = input ? input.getAttribute('data-index') : null;
      showLoaderByKey(itemKey);
    }

    document.addEventListener('click', function (e) {
      var removeLink = e.target.closest('a[is="cart-remove-button"], a[is="remove-gift-wrap"]');
      if (removeLink) {
        showLoaderByKey(removeLink.getAttribute('data-index'));
        return;
      }

      var qtyBtn = e.target.closest('.cart-item-card__qty-btn');
      if (qtyBtn) {
        showLoaderFromTarget(qtyBtn);
      }
    });

    document.addEventListener('change', function (e) {
      if (e.target && e.target.classList.contains('cart-item-card__qty-input')) {
        showLoaderFromTarget(e.target);
      }
    });

    function hideAllLoaders() {
      document.querySelectorAll('.cart-item-card__loader').forEach(function (loader) {
        loader.setAttribute('hidden', '');
      });
    }

    document.addEventListener('cart:updated', hideAllLoaders);
    document.addEventListener('shopify:cart:change', hideAllLoaders);
    document.addEventListener('shopify:section:load', hideAllLoaders);
  });
</script>

