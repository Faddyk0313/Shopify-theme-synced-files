{%- doc -%}
  Renders a feature-rich product card with media, pricing, and interactive elements for collection grids and product listings.

  Supports quick add functionality, variant swatches, ratings, badges, countdown timers, and responsive layouts with hover effects.

  @param {object} product - Shopify product object to display
  @param {string} product_id - Unique product identifier for component targeting
  @param {string} section_id - Section identifier for component namespacing
  @param {string} [block_id] - Optional block identifier for additional uniqueness
  @param {string} [image_ratio] - Image aspect ratio ('square', 'landscape', 'portrait')
  @param {boolean} [image_fill] - Crop images to fill container
  @param {boolean} [lazy_load] - Enable lazy loading (reserved for future use)
  @param {boolean} [show_secondary_image] - Show image on hover
  @param {boolean} [show_multiple_images] - Show multiple images on hover
  @param {boolean} [show_vendor] - Display product vendor name
  @param {boolean} [title_truncation] - Enable product title truncation
  @param {number} [title_line_limit] - Maximum lines to display
  @param {boolean} [show_rating] - Show product ratings from metafields
  @param {boolean} [show_quick_add] - Display quick add button
  @param {boolean} [show_quick_view] - Enable quick view modal
  @param {boolean} [show_color_swatches] - Show color variant swatches
  @param {boolean} [show_countdown] - Display countdown timer
  @param {boolean} [vertical_badges] - Show badges vertically
  @param {boolean} [show_sold_out] - Display sold out badge
  @param {boolean} [show_save_amount] - Show savings badge
  @param {boolean} [show_icon_list] - Display feature icons from metafields
  @param {string} [save_type] - Savings calculation method for badges
  @param {boolean} [mobile_quick_add] - Add mobile-specific quick add button
  @param {string} [display_mode] - Rating display mode ('count' or value)
  @param {boolean} [show_on_model] - Show on model image
  @param {string} [sizes] - Responsive sizes hint for image srcset (e.g. '(max-width: 639px) 50vw, 33vw')

  @example
  {% render 'product-card',
     product: product,
     product_id: product.id,
     section_id: section.id,
     image_ratio: 'square'
  %}
{%- enddoc -%}



{% comment %} TBG custom code {% endcomment %}

<style>
  .cus_collectionName {
    text-align: start !important;
    font-size: 9px !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
    color:rgb(32, 31, 31) !important;
    font-weight: 500 !important;
  }
  .size-font {
    font-size: 12px; /* Default size */
  }
  .size {
    border: 1px solid;
    border-radius: 5px;
    padding: 3px;
    position: relative;
    color: rgb(var(--color-price) / .6);
  }

  @media (max-width: 768px) {
    .size-font {
      font-size: 10px; /* Smaller font for tablets */
    }
  }

  @media (max-width: 480px) {
    .size-font {
      font-size: 8px; /* Smaller font for mobile devices */
    }
  }
</style>

<style>
  .badges.custom {
    position: absolute !important;
    top: 0 !important;
    left: auto !important;
    right: 0 !important;
    z-index: 10 !important;
  }

  .badge.custom {
    border-radius: 0 !important;
    border-bottom-left-radius: 12px !important;
    color: #fff !important;
    background-color: rgb(135 135 135) !important;
  }
</style>
{% comment %} TBG custom code {% endcomment %}

{%- if product != blank -%}
  {%- liquid
    assign featured_media = product.featured_media
    assign product_media = product.media
    assign media_count = product_media.size

    assign product_url = product.url | within: collection
    if settings.product_disable_collection_portion
      assign product_url = product.url
    endif

    unless lazy_load == false
      assign loading = 'lazy'
      assign lazyimage = 'lazy-image'
    else
      assign loading = 'eager'
      assign lazyimage = null
    endunless

    unless sizes
      assign sizes = '(max-width: 639px) 50vw, 33vw'
    endunless
  -%}
  <div class="card product-card product-card--{{ settings.card_style }}{% if settings.card_border_thickness > 0 %} product-card--thickness{% endif %}{% unless featured_media %} no-media{% endunless %}{% if product.available and show_quick_add and mobile_quick_add %} mobile:with-quick-add{% endif %} flex flex-col leading-none relative">
    {%- if featured_media -%}
      <div class="product-card__media relative h-auto">
        {%- if show_quick_view -%}
          {%- capture quick_view_id -%}Quickview-{{ section_id }}{% if block_id != blank %}-{{ block_id }}{% endif %}-{{ product_id }}{%- endcapture -%}
          <button type="button" class="quick-view__button button button--secondary z-2 absolute top-0 right-0 opacity-0" is="hover-button" aria-controls="{{ quick_view_id }}" aria-expanded="false">
            <span class="btn-fill" data-fill></span>
            <span class="btn-text">
              {%- render 'icon', icon: 'eye', size: 'sm' -%}
              <span class="sr-only">
                {{- 'products.product.quick_view' | t -}}
              </span>
            </span>
          </button>
          <quick-view id="{{ quick_view_id }}" class="quick-view x-modal drawer z-40 fixed bottom-0 left-0 h-full w-full pointer-events-none" data-product-url="{{ product_url }}" role="dialog" aria-label="{{ 'products.product.choose_product_options' | t: title: product.title | escape }}" aria-modal="true" hidden>
            <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="{{ quick_view_id }}" aria-expanded="false"></overlay-element>
            <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
              <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative" tabindex="0">
                <button class="button button--secondary button--close drawer__close z-1 absolute top-0 right-0 flex items-center justify-center opacity-0" type="button" is="hover-button" aria-controls="{{ quick_view_id }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">
                    {%- render 'icon', icon: 'close', size: 'sm' -%}
                  </span>
                </button>
              </gesture-element>
              <div class="quick-view__content drawer__content opacity-0 invisible flex flex-col h-full grow shrink"></div>
            </div>
          </quick-view>
        {%- endif -%}

        {%- if show_rating -%}
          {%- liquid
            assign rating_max = 5
          
            if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count.value > 0
              assign rating_value = product.metafields.reviews.rating.value.rating | round: 1
              assign rating_count = product.metafields.reviews.rating_count.value
              assign rating_max = product.metafields.reviews.rating.value.scale_max
            else
              assign hide_rating = true
            endif
          -%}
          
          {%- unless hide_rating -%}
            <div class="rating product-card__rating z-2 absolute rounded-full flex items-center gap-2 md:gap-1d5 pointer-events-none" title="{{ 'general.accessibility.star_reviews_count' | t: count: rating_count | escape }}">
              <span role="img" aria-label="{{ 'general.accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: rating_max }}">
                {%- render 'icon', icon: 'star', size: 'xs' -%}
              </span>
              {%- liquid
                if display_mode == 'count'
                  echo 'general.accessibility.star_reviews_count' | t: count: rating_count
                else
                  echo rating_value
                endif
              -%}
            </div>
          {%- endunless -%}
        {%- endif -%}

        {%- render 'product-badges', product: product, vertical_badges: vertical_badges, show_sold_out: show_sold_out, show_save_amount: show_save_amount, save_type: save_type, class: 'z-2 absolute grid gap-3 pointer-events-none' -%}

        {% comment %} TBG CUSTOM CODE {% endcomment %}
        <a class="pdpPageLink block relative media media--{{ image_ratio }}{% unless image_fill %} media--contain{% endunless %}{% unless show_secondary_image and media_count > 1 and show_multiple_images %} overflow-hidden{% endunless %}" href="{{ product_url }}" data-tbg-product-link aria-label="{{ product.title | escape }}" tabindex="-1">
          {%- unless featured_media.media_type == 'video' or featured_media.media_type == 'external_video' -%}
            {%- if show_secondary_image and media_count > 1 and show_multiple_images -%}
              <template>
                {%- capture media_class -%}media media--height{% unless image_fill %} media--contain{% endunless %} w-full h-full overflow-hidden{%- endcapture -%}
                {%- for media in product_media limit: 4 -%}
                  {%- unless media.media_type == 'video' or media.media_type == 'external_video' -%}
                    {%- assign max_width = media.width | default: media.preview_image.width -%}
                    <div class="{{ media_class }}">
                      {{- media | image_url: width: max_width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', sizes: sizes, is: 'lazy-image' -}}
                    </div>
                  {%- else -%}
                    {%- render 'product-video',
                      video: media,
                      muted: true,
                      autoplay: false,
                      loop: true,
                      cover_image: media,
                      show_play_button: false,
                      class: media_class
                    -%}
                  {%- endunless -%}
                {%- endfor -%}
              </template>
              <secondary-media class="product-card__carousel block absolute top-0 left-0 w-full h-full hidden md:block" selected-index="0"></secondary-media>
            {%- endif -%}

            {%- assign max_width = featured_media.width | default: featured_media.preview_image.width -%}
            {{- featured_media | image_url: width: max_width | image_tag: loading: loading, widths: '180,360,540,720,900,1080', sizes: sizes, is: lazyimage -}}

            {%- if show_secondary_image and media_count > 1 and show_multiple_images == false -%}
              {%- liquid
                assign secondary_media = blank
                for media in product_media limit: 4
                  if media != featured_media
                    assign secondary_media = media
                    break
                  endif
                endfor
              -%}
              {%- if secondary_media != blank -%}
                {%- assign max_width = secondary_media.width | default: secondary_media.preview_image.width -%}
                <div class="product-card__secondary media media--height{% unless image_fill %} media--contain{% endunless %} absolute top-0 left-0 w-full h-full hidden md:block opacity-0 invisible pointer-events-none overflow-hidden">
                  {{- secondary_media | image_url: width: max_width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', sizes: sizes, is: 'lazy-image' -}}
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- else -%}
            {%- capture featured_media_class -%}media{% unless image_fill %} media--contain{% endunless %} relative w-full overflow-hidden{%- endcapture -%}
            {%- render 'product-video',
              video: featured_media,
              muted: false,
              autoplay: false,
              loop: false,
              cover_image: featured_media,
              show_play_button: true,
              class: featured_media_class
            -%}
          {%- endunless -%}

          {%- if show_on_model and product.metafields.theme.model_media.value != blank -%}
            {%- assign model_media = product.metafields.theme.model_media.value -%}
            {%- capture model_media_class -%}product-card__model media media--height{% unless image_fill %} media--contain{% endunless %} absolute top-0 left-0 w-full h-full opacity-0 invisible pointer-events-none overflow-hidden{%- endcapture -%}
            {%- if model_media.media_type != 'video' -%}
              {%- assign max_width = model_media.width | default: model_media.preview_image.width -%}
              <div class="{{ model_media_class }}">
                {{- model_media | image_url: width: max_width | image_tag: loading: loading, widths: '180,360,540,720,900,1080', sizes: sizes, is: lazyimage -}}
              </div>
            {%- else -%}
              {%- render 'product-video',
                video: model_media,
                muted: false,
                autoplay: false,
                loop: false,
                cover_image: model_media,
                show_play_button: true,
                class: model_media_class
              -%}
            {%- endif -%}
          {%- endif -%}
        </a>

        {%- if product.available -%}
          {%- liquid
            assign should_show_size_variants = false
            if settings.product_quick_add_by_size and product.options.size == 1
              assign size_trigger = 'products.general.size_trigger' | t | downcase | strip

              for option in product.options_with_values
                assign downcased_option = option.name | downcase | strip

                if downcased_option == size_trigger
                  assign should_show_size_variants = true
                  break
                endif
              endfor
            endif
          -%}
          {%- if should_show_size_variants -%}
            <div class="quick-add flex justify-end md:justify-center absolute w-full z-1 pointer-events-none">
              <div class="buttons hidden pointer-events-auto md:flex md:justify-center md:opacity-0">
                {%- for option in product.options_with_values -%}
                  <fieldset class="js product-form__input variant-input-wrapper relative">
                    <legend class="sr-only">{{ option.name }}</legend>
                    <div class="swatches swatches--round flex justify-center flex-wrap gap-2">
                      {%- for variant in product.variants -%}
                        {%- if variant.available -%}
                          {%- capture product_form_id -%}QuickAddProductForm-{{ section_id }}-{{ product_id }}-{{ variant.id }}{%- endcapture -%}
                          {%- form 'product', product, is: 'product-form', id: product_form_id -%}
                            <input type="hidden" name="id" value="{{ variant.id }}" />
                            <button type="submit" class="button button--primary" is="hover-button" data-variant-id="{{ variant.id }}" aria-label="{{ variant.title | escape }}">
                              <span class="btn-fill" data-fill></span>
                              <span class="btn-text">{{ variant.title }}</span>
                            </button>
                          {%- endform -%}
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </fieldset>
                {%- endfor -%}
              </div>
              {%- if show_quick_view -%}
                <button type="button" class="button button--primary pointer-events-auto md:hidden" is="hover-button" aria-controls="{{ quick_view_id }}" aria-expanded="false" aria-label="{{ 'products.product.choose_product_options' | t: title: product.title | escape }}">
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">
                    {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                    <span class="hidden md:block">
                      {{- 'products.product.choose_options' | t -}}
                    </span>
                  </span>
                </button>
              {%- else -%}
                <a href="{{ product_url }}" class="button button--primary pointer-events-auto md:hidden" is="hover-link" aria-label="{{ 'products.product.view_product_label' | t: title: product.title | escape }}">
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">
                    {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                    <span class="hidden md:block">
                      {{- 'products.product.view_product' | t -}}
                    </span>
                  </span>
                </a>
              {%- endif -%}
            </div>
          {%- elsif show_quick_add -%}
            <div class="quick-add flex justify-end md:justify-center absolute w-full z-1 pointer-events-none">
              {%- if product.variants.size == 1 -%}
                {%- capture product_form_id -%}QuickAddProductForm-{{ section_id }}-{{ product_id }}{%- endcapture -%}
                {%- form 'product', product, is: 'product-form', id: product_form_id -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
                  <input type="hidden" name="quantity" value="{{ product.selected_or_first_available_variant.quantity_rule.min }}" />
                  {%- liquid
                    if product.template_suffix != 'pre-order'
                      assign add_to_cart_label = 'products.product.add_to_cart' | t
                      assign add_to_cart_aria = 'products.product.add_to_cart_label' | t: title: product.title
                    else
                      assign add_to_cart_label = 'products.product.pre_order' | t
                      assign add_to_cart_aria = 'products.product.pre_order_label' | t: title: product.title
                    endif
                  -%}
                  <button type="submit" class="button button--primary pointer-events-auto md:opacity-0" is="hover-button" data-variant-id="{{ product.selected_or_first_available_variant.id }}" aria-label="{{ add_to_cart_aria | escape }}">
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">
                      {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                      <span class="hidden md:block" data-sold-out="{{ 'products.product.sold_out' | t | escape }}">
                        {{- add_to_cart_label -}}
                      </span>
                    </span>
                  </button>
                {%- endform -%}
              {%- else -%}
                {%- if show_quick_view -%}
                  <button type="button" class="button button--primary pointer-events-auto md:opacity-0" is="hover-button" aria-controls="{{ quick_view_id }}" aria-expanded="false" aria-label="{{ 'products.product.choose_product_options' | t: title: product.title | escape }}">
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">
                      {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                      <span class="hidden md:block">
                        {{- 'products.product.choose_options' | t -}}
                      </span>
                    </span>
                  </button>
                {%- else -%}
                  <a href="{{ product_url }}" class="button button--primary pointer-events-auto md:opacity-0" is="hover-link" aria-label="{{ 'products.product.view_product_label' | t: title: product.title | escape }}">
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">
                      {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                      <span class="hidden md:block">
                        {{- 'products.product.view_product' | t -}}
                      </span>
                    </span>
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- else -%}
          {%- unless show_sold_out -%}
            <div class="quick-add flex justify-center absolute w-full z-1 pointer-events-none">
              <button type="button" class="button button--secondary button--blur" disabled="disabled">
                {{- 'products.product.sold_out' | t -}}
              </button>
            </div>
          {%- endunless -%}
        {%- endif -%}

        {%- if show_countdown and product.metafields.theme.countdown.value != blank -%}
          {%- liquid
            assign now_time = 'now' | date: '%s' | times: 1
            assign countdown_time = product.metafields.theme.countdown.value | date: '%s' | times: 1
          -%}
          {%- if countdown_time > now_time -%}
            <div class="product-card__countdown hidden sm:flex justify-center absolute w-full z-0 pointer-events-none no-js-hidden">
              <div class="button icon-with-text">
                <div class="btn-text">
                  {%- render 'icon', icon: 'countdown-compact', size: 'sm', class: 'shrink-0 hidden md:block' -%}
                  <countdown-timer
                    class="flex gap-3"
                    data-expires="{{ product.metafields.theme.countdown.value | date: '%FT%T%:z' | escape }}"
                    data-compact="true"
                  >
                    <div class="countdown__item">
                      <p>--{{ 'general.date.d' | t }}</p>
                    </div>
                    <div class="countdown__item">
                      <p>--{{ 'general.date.h' | t }}</p>
                    </div>
                    <div class="countdown__item">
                      <p>--{{ 'general.date.m' | t }}</p>
                    </div>
                    <div class="countdown__item">
                      <p>--{{ 'general.date.s' | t }}</p>
                    </div>
                  </countdown-timer>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="product-card__media h-auto overflow-hidden">
        <span class="block aspect-{{ image_ratio }}"></span>
      </div>
    {%- endif -%}
    <div class="product-card__content grow flex flex-col{% if featured_media %} justify-start text-{{ settings.card_text_alignment }} w-full{% else %} justify-center items-center absolute top-0 left-0 w-full h-full{% endif %}">
      {% comment %} TBG CUUSTOM CODE {% endcomment %}
      {% if show_collection_name %}
        {% assign allowed_collection_handles = 'cut-resistant-baselayer,battlegear-2-0-neck-guard,graphic-yth-tee,graphic-yth-hoodie,shorts,hats' | split: ',' %}
        
        {% assign product_collection_label = blank %}

        {% for collection in product.collections %}
          {% if allowed_collection_handles contains collection.handle %}
            {% assign product_collection_label = collection.title %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if product_collection_label != blank %}
          <div class="cus_collectionName">
            {{ product_collection_label }}
          </div>
        {% endif %}
      {% endif %}
      {%- if show_vendor -%}
        <div class="product-card__top w-full">
          <a href="{{ product.vendor | url_for_vendor }}" title="{{ product.vendor | escape }}" class="caption reversed-link uppercase leading-none tracking-widest">
            <span class="sr-only">{{ 'general.accessibility.vendor' | t }}</span>
            {{- product.vendor -}}
          </a>
        </div>
      {%- endif -%}

      <div class="product-card__details flex flex-col lg:flex-row items-baseline gap-2 w-full">
        {% comment %} TBG CUSTOM CODE {% endcomment %}
        {% if showShortTitle %}
          {% assign title_parts = product.title | split: " - " %}
          {% if title_parts.size > 1 %}
            {% assign display_title = title_parts.last | strip %}
          {% else %}
            {% assign display_title = product.title %}
          {% endif %}
          <p class="grow{% if title_truncation %} line-clamp-{{ title_line_limit }}{% endif %}">
            <a class="pdpPageLink product-card__title reversed-link text-base-xl font-medium leading-tight" href="{{ product_url }}" data-tbg-product-link>
               {{ display_title }}
            </a>
          </p>
        {% else %}
          <p class="grow{% if title_truncation %} line-clamp-{{ title_line_limit }}{% endif %}">
            <a class="pdpPageLink product-card__title reversed-link text-base-xl font-medium leading-tight" href="{{ product_url }}" data-tbg-product-link>
              {{- product.title | escape -}}
            </a>
          </p>
        {% endif %}
        <div class="flex flex-col gap-2">
          {%- render 'product-price', product: product, class: 'flex flex-wrap lg:flex-col lg:items-end gap-2 md:gap-1d5' -%}
          {%- if product.quantity_price_breaks_configured? -%}
            <div class="text-sm font-medium leading-tight">{{ 'products.volume_pricing.note' | t }}</div>
          {%- endif -%}
        </div>
      </div>

      {%- if show_color_swatches -%}
        {%- assign swatch_trigger_list = 'products.general.color_swatch_trigger' | t | downcase | split: ',' -%}
        {%- for option in product.options_with_values -%}
          {%- liquid
            assign is_color = false
            assign downcased_option = option.name | downcase | strip
            for trigger in swatch_trigger_list
              assign swatch_trigger = trigger | strip
              if downcased_option == swatch_trigger
                assign is_color = true
              elsif swatch_trigger == 'color' and downcased_option contains 'colour'
                assign is_color = true
              endif

              if is_color == true
                break
              endif
            endfor
          -%}
          {%- if is_color -%}
            {%- liquid
              assign option_index_0 = forloop.index0
              assign color_count = option.values.size
              assign max_color_count = settings.product_max_color_swatches
            -%}
            <div class="product-card__bottom flex items-center gap-2">
              {% comment %} TBG CUSTOM CODE whole ul {% endcomment %}
              <ul class="swatches swatches--{{ settings.rounded_swatch }}{% if settings.product_color_swatch_type == 'variant' %} swatches--variant{% endif %} swatches--{{ product.id }} inline-flex items-start gap-2">
                {%- for value in option.values limit: max_color_count -%}
                  {%- liquid
                    assign downcased_value = value | downcase | strip
                    assign value_variant = value.variant
                    for variant in product.variants
                      assign variant_value = variant.options[option_index_0] | downcase | strip
                      if variant_value == downcased_value
                        assign value_variant = variant
                        break
                      endif
                    endfor

                    assign swatch = value.swatch
                    if settings.product_color_swatch_type == 'variant' and value_variant.image
                      assign swatch = value_variant
                    endif

                    assign color_title = product.title | append: ' - ' | append: value
                    assign color_url = value_variant.url | within: collection
                    if settings.product_disable_collection_portion
                      assign color_url = value_variant.url
                    endif
                    assign color_url = value.product_url | default: color_url
                  -%}
                  {%- if color_count <= max_color_count -%}
                    <li>
                      {%- render 'swatch', href: color_url, title: color_title, value: value, value_label: value, swatch: swatch -%}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
              {%- if color_count > max_color_count -%}
                <a href="{{ product_url }}" class="reversed-link font-medium text-xs text-opacity leading-none tracking-widest" is="hover-link"{% if show_quick_view %} aria-controls="{{ quick_view_id }}" aria-expanded="false"{% endif %}>+{{ color_count | minus: max_color_count }}</a>
              {%- endif -%}
            </div>
            {%- if color_count < 1 -%}
              <style>
                .swatches--{{ product.id }} { display: none; }
              </style>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if show_icon_list -%}
      {%- if settings.product_icon_list_metafield != blank -%}
        {%- liquid
          assign metafield_parts = settings.product_icon_list_metafield | split: '.'
          assign metafield_namespace = metafield_parts | first
          assign metafield_key = metafield_parts | last
          assign product_icon_list_metafield = product.metafields[metafield_namespace][metafield_key]
        -%}
        {%- if product_icon_list_metafield.value != blank and product_icon_list_metafield.list? -%}
          <scroll-shadow class="product-card__spec block overflow-hidden">
            <div class="product-card__icons{% unless settings.product_icon_list_carousel %} product-card__icons--grid md:grid md:grid-cols-2{% endunless %} flex flex-nowrap" is="icons-carousel" tabindex="0">
              {%- for item in product_icon_list_metafield.value limit: settings.product_icon_list_max -%}
                <div class="product-card__icon shrink-0">
                  <div class="flex flex-col items-center md:flex-row md:items-start gap-2">
                    {%- if item.icon.value != blank -%}
                      {%- assign icon_alt = item.icon.value.alt | default: item.title | escape -%}
                      {%- assign max_width = item.icon.value.width -%}
                      <figure class="shrink-0 media media--transparent relative inline-block">
                        {%- capture sizes -%}24px{%- endcapture -%}
                        {%- capture widths -%}{{ 24 | times: 1.5 | at_most: max_width | round }}, {{ 24 | times: 2 | at_most: max_width }}, {{ 24 | times: 3 | at_most: max_width }}{%- endcapture -%}
                        {{- item.icon.value | image_url: width: max_width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: icon_alt, class: 'w-full h-full', is: 'lazy-image' -}}
                      </figure>
                    {%- endif -%}
                    <div class="flex flex-col items-center md:items-start gap-1 text-center md:text-left text-xs font-medium leading-none">
                      {{- item.title -}}
                      {%- if item.description != blank -%}
                        <p class="text-opacity font-normal text-3xs leading-tight">{{ item.description }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <template>
              <slot></slot>
              <s dir="{% render 'direction' %}" style="--t: 0;--b: 0;--l: 0;--r: 0;" class="{{ settings.card_style }}">
                <span class="l"></span>
                <span class="r"></span>
              </s>
              <style>
                :host{display:inline-block;position:relative}:host([hidden]){display:none}
                s{position:absolute;inset:0;pointer-events:none;border-radius:var(--card-shadow-radius);overflow:hidden;}
                s.card{border-start-start-radius:0;border-start-end-radius:0}
                s span{position:absolute;inset-block:0;width:clamp(var(--sp-12),4.73vw,var(--sp-23));opacity:0;transition:opacity var(--animation-short);}
                s .l{inset-inline-start:0;opacity:var(--l);background:linear-gradient(90deg,rgb(var(--color-background)) 0%,transparent 100%);}
                s .r{inset-inline-end:0;opacity:var(--r);background:linear-gradient(270deg,rgb(var(--color-background)) 0%,transparent 100%);}
                s[dir=rtl] :is(.icon-chevron-left,.icon-chevron-right){transform:scaleX(-1);}
              </style>
            </template>
          </scroll-shadow>
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}

    {%- if show_quick_add and mobile_quick_add -%}
      <div class="lg:hidden">
        {%- if product.available -%}
          {%- if product.variants.size == 1 -%}
            {%- capture product_form_id -%}MobileQuickAddProductForm-{{ section_id }}-{{ product_id }}{%- endcapture -%}
            {%- form 'product', product, is: 'product-form', id: product_form_id -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
              <input type="hidden" name="quantity" value="{{ product.selected_or_first_available_variant.quantity_rule.min }}" />
              <button type="submit" class="button button--primary button--small icon-with-text" is="hover-button" data-variant-id="{{ product.selected_or_first_available_variant.id }}" aria-label="{{ 'products.product.quick_add_label' | t: title: product.title | escape }}">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- liquid
                    render 'icon', icon: 'plus', size: '2xs'
                    echo 'products.product.quick_add' | t
                  -%}
                </span>
              </button>
            {%- endform -%}
          {%- else -%}
            {%- if show_quick_view -%}
              <button type="button" class="button button--primary button--small icon-with-text" is="hover-button" aria-label="{{ 'products.product.quick_view_label' | t: title: product.title | escape }}" aria-controls="{{ quick_view_id }}" aria-expanded="false">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- liquid
                    render 'icon', icon: 'plus', size: '2xs'
                    echo 'products.product.quick_view' | t
                  -%}
                </span>
              </button>
            {%- else -%}
              <a href="{{ product.url }}" class="button button--primary button--small icon-with-text" is="hover-link" aria-label="{{ 'products.product.quick_view_label' | t: title: product.title | escape }}">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- liquid
                    render 'icon', icon: 'plus', size: '2xs'
                    echo 'products.product.quick_view' | t
                  -%}
                </span>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- else -%}
          <span class="button button--primary button--small" disabled="disabled">
            {{- 'products.product.sold_out' | t -}}
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}
    <!-- TBG custom code -->
    <script type="application/json" data-tbg-product-variants>
      {{ product.variants | json }}
    </script>
    <!-- End TBG custom code -->
  </div>
{%- else -%}
  {%- render 'product-card-placeholder', placeholder: 'product-1', image_ratio: image_ratio, show_vendor: show_vendor -%}
{%- endif -%}


<!-- TBG custom code -->
<script>
  (() => {
    if (window.__tbgProductCardVariantLinksInitialized) return;
    window.__tbgProductCardVariantLinksInitialized = true;

    const CARD_SELECTOR = '[data-tbg-product-card]';
    const LINK_SELECTOR = '[data-tbg-product-link]';

    function toSafeString(value) {
      if (typeof value === 'string') return value;
      if (value == null) return '';
      return String(value);
    }

    function findVariantForUserSize(variants, userSize) {
      if (!userSize || !Array.isArray(variants)) return null;

      return variants.find((variant) => {
        const variantTitle = toSafeString(variant && variant.title);

        if (variantTitle === userSize) return true;

        if (userSize.includes('/')) {
          const userParts = userSize.split('/');
          return userParts.includes(variantTitle);
        }

        if (variantTitle.includes('/')) {
          const parts = variantTitle.split('/');
          const prefix = parts[0].substring(0, parts[0].lastIndexOf('-') + 1);
          const fullSizes = parts.map((part, index) => (index === 0 ? part : prefix + part));
          return fullSizes.includes(userSize);
        }

        return false;
      }) || null;
    }

    function updateCardLinks(card) {
      if (!card) return;

      const productUrl = toSafeString(card.getAttribute('data-tbg-product-url'));
      const variantsNode = card.querySelector('[data-tbg-product-variants]');
      const userSize = toSafeString(localStorage.getItem('userSize'));
      if (!productUrl || !variantsNode || !userSize) {
        return;
      }

      let variants = [];
      try {
        variants = JSON.parse(variantsNode.textContent.trim());
      } catch (error) {
        return;
      }

      const matchedVariant = findVariantForUserSize(variants, userSize);
      if (!matchedVariant || !matchedVariant.id) {
        return;
      }

      const matchedVariantId = toSafeString(matchedVariant.id);
      if (card.dataset.tbgMatchedVariantId === matchedVariantId) return;

      card.querySelectorAll(LINK_SELECTOR).forEach((link) => {
        const href = toSafeString(link.getAttribute('href'));
        if (!href) return;

        const url = new URL(href, window.location.origin);
        if (url.pathname !== new URL(productUrl, window.location.origin).pathname) return;

        url.searchParams.set('variant', matchedVariant.id);
        link.setAttribute('href', `${url.pathname}${url.search}${url.hash}`);
      });

      card.dataset.tbgMatchedVariantId = matchedVariantId;
    }

    function enhanceProductCardLinks(scope = document) {
      scope.querySelectorAll(CARD_SELECTOR).forEach(updateCardLinks);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => enhanceProductCardLinks(document));
    } else {
      enhanceProductCardLinks(document);
    }

    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        mutation.addedNodes.forEach((node) => {
          if (node.nodeType !== 1) return;
          if (node.matches?.(CARD_SELECTOR)) {
            updateCardLinks(node);
            return;
          }
          if (node.querySelector?.(CARD_SELECTOR)) {
            enhanceProductCardLinks(node);
          }
        });
      });
    });

    observer.observe(document.documentElement, { childList: true, subtree: true });
  })();
</script>
<!-- End TBG custom code -->
