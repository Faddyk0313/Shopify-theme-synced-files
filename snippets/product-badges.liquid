{%- doc -%}

  TBG CUSTOM CODE IN THEME UPDATE COPY PASTE WHOLE FILE.

  Renders product badges including custom labels and sale indicators with flexible display options.

  Displays promotional badges, custom labels, and calculated savings on product cards and pages.

  @param {object} product - Shopify product object with price and metafield data
  @param {object} [variant] - Specific variant for single badge display
  @param {boolean} [use_variant] - Show variant sale badge
  @param {boolean} [vertical_badges] - Show badges vertically
  @param {boolean} [show_sold_out] - Enable sold out badge display
  @param {boolean} [show_save_amount] - Enable savings badge display
  @param {string} [save_type] - Savings calculation format
  @param {string} [class] - Additional CSS classes

  @example
  {% render 'product-badges',
     product: product,
     show_save_amount: true,
     save_type: 'dollar'
  %}
{%- enddoc -%}

{% comment %} TBG custom code {% endcomment %}
<style>

  .badges {
    top: 0;
    left: 0;
    min-width: 30%;
  }

  .badges .badge {
    border-radius: 0;
    {% comment %} border-bottom-right-radius: 12px; {% endcomment %}
    width: 100%;
    text-align: center;
    display: flex;
    justify-content: center;
    white-space: nowrap;
    font-size: 0.4rem ;
    text-transform: uppercase;
  }

  @media screen and (min-width: 768px) {
    .badges .badge {
        padding: var(--sp-1d5) var(--sp-2d5) !important;
    }
  }
   /* 2️⃣  Optional viewport fallbacks (only if you want     */
  /*     extra granularity on browsers without cqi units)   */
  @media (min-width: 480px){ .badges .badge{ font-size: 0.50rem ; } } /* small tablets */
  @media (min-width: 768px){ .badges .badge{ font-size: 0.6rem; } } /* landscape tab */
  @media (min-width:1024px){ .badges .badge{ font-size: 0.7rem; } } /* laptops / up  */
</style>
{% comment %} TBG custom code {% endcomment %}

{%- liquid
  assign hide_sale_badge = false
  assign show_save_label_badge = false
  assign show_save_value_badge = false
  for product_collection in product.collections
    if product_collection.handle == 'last-chance' or product_collection.id == 358732595378
      assign hide_sale_badge = true
      break
    endif
  endfor

  if show_save_amount
    if use_variant
      assign target = variant | default: product.selected_or_first_available_variant
    else
      assign target = product
    endif
    if target.compare_at_price > target.price
    comment
    TBG CUSTOM CODE
    endcomment
      if save_type == 'label'
        assign saved_amount = save_type
      elsif save_type == 'labelAndDollar'
        assign saved_amount = target.compare_at_price | minus: target.price | money
        assign show_save_label_badge = true
        assign show_save_value_badge = true
      elsif save_type == 'labelAndPercent'
        assign saved_amount = target.compare_at_price | minus: target.price | times: 100.0 | divided_by: target.compare_at_price | round
        assign saved_amount = saved_amount | append: '%'
        assign show_save_label_badge = true
        assign show_save_value_badge = true
      elsif save_type == 'dollar'
        assign saved_amount = target.compare_at_price | minus: target.price | money
      else
        assign saved_amount = target.compare_at_price | minus: target.price | times: 100.0 | divided_by: target.compare_at_price | round
        assign saved_amount = saved_amount | append: '%'
      endif
    endif
  endif
-%}
{%- capture badge_styles -%}
  {%- if product.metafields.theme.label_color.value != blank -%}
    --badge-background: {{ product.metafields.theme.label_color.value }};
    --badge-foreground: #ffffff;
    color: #ffffff;
  {%- endif -%}
  {%- if product.metafields.custom.product_label_text_color.value != blank -%}
    --badge-foreground: {{ product.metafields.custom.product_label_text_color.value }};
    color: {{ product.metafields.custom.product_label_text_color.value }};
  {%- endif -%}
{%- endcapture -%}
{%- assign badge_styles = badge_styles | strip -%}
<div class=" badges{% if class != blank %} {{ class }}{% endif %}">
  {% unless show_sold_out and product.available == false %}
    {%- if product.metafields.theme.label.value != blank -%}
      {%- for label in product.metafields.theme.label.value -%}
        <span
          class="badge{% if vertical_badges %} badge--vertical{% endif %} flex items-center gap-1d5 leading-none rounded-full font-bold"
          {% if badge_styles != blank %}
            style="{{ badge_styles }}"
          {% endif %}
        >
          {{- label | escape -}}
        </span>
      {%- endfor -%}
    {%- endif -%}
  {%- endunless -%}


  {%- if saved_amount != blank and hide_sale_badge == false -%}
    {% if product.available %}
      {% comment %} TBG custom code {% endcomment %}
      {%- if show_save_label_badge -%}
        <span class="badge{% if vertical_badges %} badge--vertical{% endif %} badge--onsale flex items-center gap-1d5 leading-none rounded-full font-bold"
          {% if badge_styles != blank %}
              style="{{ badge_styles }}"
            {% endif %}
        >
          {{- 'products.general.sale' | t -}}
        </span>
      {%- endif -%}

      <span class="badge{% if vertical_badges %} badge--vertical{% endif %} badge--onsale flex items-center gap-1d5 leading-none rounded-full font-bold"
        {% if badge_styles != blank %}
            style="{{ badge_styles }}"
          {% endif %}
      >
        {%- liquid
          if save_type == 'label'
            echo 'products.general.sale' | t
          else
            echo 'products.general.save_html' | t: saved_amount: saved_amount
          endif
        -%}
      </span>
    {%- endif -%}
  {%- endif -%}

  {% comment %} {%- if show_sold_out -%}
    {%- unless product.available -%}
      <span class="badge{% if vertical_badges %} badge--vertical{% endif %} badge--soldout flex items-center gap-1d5 font-medium leading-none rounded-full"
        {% if styles != blank %}
          style="{{ styles }}"
        {% endif %}
      >
        {{- 'products.product.sold_out' | t -}}
      </span>
    {%- endunless -%}
  {%- endif -%} {% endcomment %}

  {%- if show_sold_out -%}
    {%- assign product_type_downcase = product.type | downcase -%}
    {%- unless product.available or product_type_downcase == 'neck guard 3.0' or product_type_downcase == 'baselayer 3.0' -%}
      <span class="badge{% if vertical_badges %} badge--vertical{% endif %} badge--soldout flex items-center gap-1d5 font-bold leading-none rounded-full"
        {% if badge_styles != blank %}
          style="{{ badge_styles }}"
        {% endif %}
      >
        {{- 'products.product.sold_out' | t -}}
      </span>
    {%- endunless -%}
  {%- endif -%}

</div>
