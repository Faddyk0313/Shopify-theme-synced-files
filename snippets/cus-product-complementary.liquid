        }
        .recommend__title {
            color: white;
        }
      }
    {% endif %}
    .horizontal-product__title {
        font-family: 'Armourxbd';
    }
    .recommend__title {
        font-family: 'Armourxbd';
        text-transform: uppercase;
        font-size: 1.4rem;
