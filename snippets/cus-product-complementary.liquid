{%- liquid
  if recommendations.performed
    if recommendations_products != blank
      assign products_count = recommendations_products.count
    elsif recommendations.products_count > 0
      assign recommendations_products = recommendations.products
      assign products_count = recommendations.products_count
    endif
  endif
-%}
<product-recommendations
  {% comment %} TBG CUSTOM CODE {% endcomment %}
  class="{% if cartDrawer %} cartDrawerEL {% endif %} {% if govxPage %} govxPage {% endif %} {% if onlyDesktop %}desktop hidden lg:block {% else %}mobile page-width block {% endif %} complementary-products flex flex-col relative"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section_id }}&product_id={{ product_id }}&limit={{ limit }}&intent=complementary"
  data-complementary-carousel
>
  <div class="complementary-products__header  flex justify-between gap-4 items-start">
    {% unless govxPage %} <p class="custom recommend__title heading cartheading grow">{{ heading | escape }}</p> {% endunless %}
    {%- if products_count > 1 -%}
      <div class="complementary-products__controls gap-2">
        <button
          type="button"
          aria-label="{{ 'general.pagination.previous' | t | escape }}"
          data-prev-button
          disabled
        >
          <svg fill="#000000" height="30px" width="30px" version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" 
              viewBox="0 0 330 330" xml:space="preserve">
            <path id="XMLID_92_" d="M111.213,165.004L250.607,25.607c5.858-5.858,5.858-15.355,0-21.213c-5.858-5.858-15.355-5.858-21.213,0.001
              l-150,150.004C76.58,157.211,75,161.026,75,165.004c0,3.979,1.581,7.794,4.394,10.607l150,149.996
              C232.322,328.536,236.161,330,240,330s7.678-1.464,10.607-4.394c5.858-5.858,5.858-15.355,0-21.213L111.213,165.004z"/>
          </svg>
        </button>
        <button
          type="button"
          aria-label="{{ 'general.pagination.next' | t | escape }}"
          data-next-button
        >
          <svg fill="#000000" height="30px" width="30px" style="transform: rotate(180deg);" version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" 
              viewBox="0 0 330 330" xml:space="preserve">
            <path id="XMLID_92_" d="M111.213,165.004L250.607,25.607c5.858-5.858,5.858-15.355,0-21.213c-5.858-5.858-15.355-5.858-21.213,0.001
              l-150,150.004C76.58,157.211,75,161.026,75,165.004c0,3.979,1.581,7.794,4.394,10.607l150,149.996
              C232.322,328.536,236.161,330,240,330s7.678-1.464,10.607-4.394c5.858-5.858,5.858-15.355,0-21.213L111.213,165.004z"/>
          </svg>
        </button>
      </div>
    {%- endif -%}
  </div>
  {%- if recommendations.performed -%}
    <div class="complementary-carousel">
      <div class="horizontal-products" data-complementary-track>
        {% for recommendation in recommendations_products %}
          {% assign accessibility = true %}
          {% if products_count > 1 and forloop.index > 1 %}
            {% assign accessibility = false %}
          {% endif %}
          <div class="complementary-carousel__slide">
            {%- render 'cus-product-card-horizontal',
              product: recommendation,
              product_id: recommendation.id,
              section_id: section_id,
              image_ratio: image_ratio,
              image_fill: image_fill,
              show_vendor: show_vendor,
              show_price: show_price,
              show_quick_add: settings.show_quick_add,
              show_quick_view: settings.product_quick_view,
              accessibility: accessibility
            -%}
          </div>
        {% endfor %}
      </div>
    </div>
  {%- else -%}
    <div class="horizontal-products relative"></div>
  {%- endif -%}
</product-recommendations>

{%- liquid
  if onlyDesktop
    assign carousel_class = 'desktop'
  else
    assign carousel_class = 'mobile'
  endif
-%}

<script>
  (function () {
    if (window.__complementaryCarouselBound) return;
    window.__complementaryCarouselBound = true;

    function getSlideWidth(track) {
      const firstSlide = track.querySelector('.complementary-carousel__slide');
      return firstSlide ? firstSlide.offsetWidth : track.clientWidth;
    }

    function updateButtonStates(track, prevButton, nextButton) {
      const atStart = track.scrollLeft <= 5;
      const atEnd = track.scrollLeft >= (track.scrollWidth - track.clientWidth - 5);
      if (prevButton) prevButton.disabled = atStart;
      if (nextButton) nextButton.disabled = atEnd;
    }

    document.addEventListener('click', function (e) {
      const btn = e.target.closest('[data-prev-button],[data-next-button]');
      if (!btn) return;

      const carousel = btn.closest('[data-complementary-carousel]');
      if (!carousel) return;

      const track = carousel.querySelector('[data-complementary-track]');
      if (!track) return;

      const direction = btn.hasAttribute('data-prev-button') ? -1 : 1;
      const offset = getSlideWidth(track) * direction;
      track.scrollBy({ left: offset, behavior: 'smooth' });

      const prevButton = carousel.querySelector('[data-prev-button]');
      const nextButton = carousel.querySelector('[data-next-button]');
      setTimeout(function () {
        updateButtonStates(track, prevButton, nextButton);
      }, 300);
    });

    document.addEventListener('scroll', function (e) {
      const track = e.target.closest ? e.target.closest('[data-complementary-track]') : null;
      if (!track) return;
      const carousel = track.closest('[data-complementary-carousel]');
      if (!carousel) return;
      const prevButton = carousel.querySelector('[data-prev-button]');
      const nextButton = carousel.querySelector('[data-next-button]');
      updateButtonStates(track, prevButton, nextButton);
    }, true);
  })();
</script>
