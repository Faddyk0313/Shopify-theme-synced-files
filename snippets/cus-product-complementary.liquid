        justify-content: center;
        font-size: 32px;
        font-weight: 600;
        padding: 0;
        cursor: pointer;
    }
    .complementary-products__controls button:disabled {
        opacity: 0.35;
        cursor: default;
    }
    .complementary-products .horizontal-products {
        display: flex;
        flex-wrap: nowrap;
        gap: 1.5rem;
        justify-content: flex-start;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-behavior: smooth;
        scroll-snap-type: x mandatory;
        -ms-overflow-style: none;
        scrollbar-width: none;
        touch-action: pan-x;
    }
    .complementary-products .horizontal-products::-webkit-scrollbar {
        display: none;
    }
    .complementary-products .horizontal-product {
        color: #fff;
        border-radius: var(--rounded-button);
        padding: 1rem !important;
        min-width: 100%;
        height: 100%;
        border: 1px solid rgba(255, 255, 255, 0.1);
        flex: 0 0 100%;
        max-width: 100%;
        box-sizing: border-box;
        display: flex;
        align-items: center;
    }
    .desktop.complementary-products .horizontal-product {
        background: #000;
    }
    .mobile.complementary-products .horizontal-product {
        background: transparent;
    }
    .complementary-products .horizontal-product__media {
      border-radius: var(--rounded-button);
      min-width: 150px;
      max-width: 150px;
      flex-grow: 1;
    }
    .govxPage.complementary-products .horizontal-product__media {
      min-width: 140px !important;
      max-width: 140px !important;
    }
    @media (min-width: 1024px) {
      .govxPage.complementary-products .horizontal-product__media {
        min-width: 250px !important;
        max-width: 250px !important;
      }
    
    }

    .complementary-products .horizontal-product__media img,
    .complementary-products .horizontal-product__media picture {
        width: 100%;
        height: auto;
    }
    .complementary-products .horizontal-product__header {
        color: #fff;
    }
    .complementary-products .horizontal-product__details {
        padding: 0 0 0 6px;
    }
    .complementary-products .horizontal-product__title {
      text-transform: uppercase;
      font-size: 14px;
      letter-spacing: 0.05em;
      color: #fff;
    }
    @media (min-width: 1325px) {
      .govxPage.complementary-products .horizontal-product__title {
        font-size: 25px;
      }
    }
    
    .complementary-products .horizontal-product__price-group {
        margin-bottom: 6px
    }

    .complementary-products .horizontal-product__price-group .customPriceEl,
    .complementary-products .horizontal-product__price-group .cusPrice,
    .complementary-products .horizontal-product__price-group .price__regular {
        color: #fff !important;
        font-family: 'Armourxbd';
        font-size: 18px;

    }
    .complementary-products .horizontal-product__quick-add-row {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        width: 100%;
        flex-wrap: wrap;
    }
    .complementary-products .horizontal-product__size-stack {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }
    .complementary-products .horizontal-product__size-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: white
    }
    @media (min-width: 1325px) {
      .govxPage.complementary-products .horizontal-product__size-label {
        font-size: 18px;
      }
    }
    .complementary-products .horizontal-product__size-field {
        position: relative;
        min-width: fit-content;
    }
    .complementary-products .horizontal-product__size-field .select {
        width: 100%;
        height: 30px;
        background: white;
        color: #000;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 400;
        {% comment %} font-family: 'Armourxbd'; {% endcomment %}
        padding: 0.1rem 0.5rem;
        padding-right: 1.5rem;
        border: none;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
    }
    @media (min-width: 1325px) {
      .govxPage.complementary-products .horizontal-product__size-field .select {
          height: 40px !important;
          font-size: 18px;
      }
    }
    .complementary-products .horizontal-product__size-field .select:focus {
        outline: 2px solid #fff;
        outline-offset: 2px;
    }
    .complementary-products .horizontal-product__dropdown-icon {
        position: absolute;
        top: 50%;
        right: 0.4rem;
        transform: translateY(-50%);
        pointer-events: none;
    }
    .complementary-products .horizontal-product__dropdown-icon svg {
        stroke: #000;
        width: 16px;
        height: 16px;
    }
    .complementary-products .horizontal-product__quick-add .cusaddToCart {
        width: 48px;
        height: 48px;
    }
    .complementary-products .horizontal-product__quick-add .btn-fill {
        display: none;
    }
    .complementary-products .horizontal-product__quick-add .btn-text {
        font-size: 1.25rem;
        color: inherit;
    }
    .complementary-products .horizontal-product__quick-add .btn-text svg {
        stroke: currentColor;
    }
    .complementary-carousel__slide {
        flex: 0 0 100%;
        width: 100%;
        scroll-snap-align: start;
    }
    </style>
    {% if onlyDesktop %} 
        <style>
          @media (min-width: 1024px) {
            .recommend__title {
              font-size: 1.9rem !important;
            }
            .complementary-products .horizontal-product__media {
              border-radius: var(--rounded-button) !important;
              min-width: 44% !important;
              max-width: 120px !important;
              flex-grow: 1 !important;
            }
            .complementary-products .horizontal-product {
              flex: 0 0 calc((100% - 1.5rem) / 2) !important;
              max-width: calc((100% - 1.5rem) / 2) !important;
            }
            .complementary-carousel__slide {
              flex: 0 0 calc((100% - 1.5rem) / 2) !important;
              width: calc((100% - 1.5rem) / 2) !important;
            }
          }
        </style>
    {% endif %}
