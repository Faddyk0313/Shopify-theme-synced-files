{% comment %}
  ─── Wholesale gating & discount ───
{% endcomment %}
{% assign wholesale_discount = 0 %}
{% assign tags = customer.tags | downcase %}

{% if customer %}
  {% assign tags = customer.tags | downcase %}
  {% if tags contains 'wholesale-gold' %}
    {% assign wholesale_discount = 0.44 %}
  {% elsif tags contains 'wholesale-silver' %}
    {% assign wholesale_discount = 0.37 %}
  {% elsif tags contains 'wholesale-bronze' %}
    {% assign wholesale_discount = 0.30 %}
  {% elsif tags contains 'gold-dealer' %}
    {% assign wholesale_discount = 0.30 %}
  {% elsif tags contains 'silver-dealer' %}
    {% assign wholesale_discount = 0.25 %}
  {% elsif tags contains 'bronze-dealer' %}
    {% assign wholesale_discount = 0.20 %}
  {% endif %}
{% endif %}

{% assign chosen_products = products %}

<style>
  /* --- Collections Bar --- */
  .quick-order-page1 .name-grid {
    padding-top: 20px;
    display: flex;
    gap: 10px;
  }

  /* Name Buttons */
  .quick-order-page1 .name-box {
    background: white;
    border: 2px solid rgb(210, 209, 209);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease-in-out;
    cursor: pointer;
  }

  .quick-order-page1 .name-box:active {
    transform: scale(0.9);
  }

  .quick-order-page1 .name-box:hover,
  .quick-order-page1 .selected_name {
    border-color: black;
    font-weight: bold;
  }

  .quick-order-page1 #qof-current-collection {
    padding-block: 20px;
  }

  .quick-order-page1 .quick-order-page1 {
    /* width: 100%; */
    padding-block: 2rem;
  }

  .quick-order-page1 .quick-order-title {
    font-size: var(--title-md);
    margin-bottom: 20px;
  }

  .quick-order-page1 .qof-search-container {
    border-radius: 15px;
    overflow: clip;
  }

  .quick-order-page1 .qof-search-container input {
    border-radius: 15px;
    padding-block: 0.7rem;
    padding-inline: 1rem;
    transition: all 0.3s ease-in-out;
    border: 2px solid rgb(210, 209, 209);
    cursor: text;
    outline: none;
    max-width: 20rem;
    width: 20rem;
  }
  .qof-search-container input:focus {
    border-color: black;
    outline: none;
  }

  *:focus {
    outline: none;
  }

  .quick-order-page1 *:focus:not(:focus-visible) {
    outline: none;
  }

  /* --- Quick Order Table (scoped) --- */

  /* wrap the form so it can scroll horizontally */
  .quick-order-page1 #quick-order-form {
    width: 100%;
    overflow-x: auto; /* allow horizontal scroll */
    -webkit-overflow-scrolling: touch; /* smooth scrolling on iOS */
  }

  /* ensure the table inside is as wide as needed */
  .quick-order-page1 #quick-order-form table {
    width: max-content; /* let the table size to its content */
    min-width: 100%; /* but never smaller than the viewport/form width */
    border-collapse: collapse;
    box-shadow: none;
  }

  /* optional: hide vertical scrollbar and only show horizontal */
  .quick-order-page1 #quick-order-form {
    overflow-y: hidden;
  }

  /* Header row: single bottom border */
  .quick-order-page1 #quick-order-form thead th {
    padding-block: 1rem;
    padding-right: 3.5rem;
    padding-left: 0rem;
    font-size: 0.68rem;
    font-weight: 400;
    text-transform: uppercase;
    border-bottom: 1px solid #e5e5e5;
    text-align: center;
    background-color: transparent;
  }

  /* Body rows: only horizontal dividers */
  .quick-order-page1 #quick-order-form tbody tr {
    border: none;
  }

  .quick-order-page1 #quick-order-form tbody * {
    font-size: 0.9rem;
  }

  /* Cells: comfy padding */
  .quick-order-page1 #quick-order-form td:not(.variant-indent) {
    padding-top: 1.4rem;
    padding-bottom: 0rem;
    padding-right: 3.5rem;
    padding-left: 0rem;
    vertical-align: middle;
    text-align: center;
    box-sizing: content-box;
  }

  /* Merge Image + Product into one cell */
  .quick-order-page1 #quick-order-form .product-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .quick-order-page1 #quick-order-form .product-info img {
    width: 60px;
    height: auto;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .quick-order-page1 #quick-order-form .product-info__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .quick-order-page1 #quick-order-form .product-info__title {
    font-weight: 500;
  }

  /* Toggle‐variants button stays inline with product title */
  .quick-order-page1 #quick-order-form .toggle-variants {
    margin-left: 0.5rem;
  }

  /* Variant rows: merge image+title, splice into first column */
  .quick-order-page1 #quick-order-form .variant-row .variant-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* .quick-order-page1 .quantity_selector {
        max-width: 14rem;
        min-width: 14rem;
        width: 14rem;
      } */
  .quick-order-page1 .total {
    max-width: 6rem;
    min-width: 6rem;
    width: 6em;
  }

  .quick-order-page1 .price {
    max-width: 7rem;
    min-width: 7rem;
    width: 7rem;
  }
  /* .quick-order-page1 .msg {
        max-width: 18rem;
        min-width: 18rem;
        width: 18rem;
      } */

  .quick-order-page1 #quick-order-form .variant-info img {
    width: 60px;
    height: auto;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .quick-order-page1 #quick-order-form .variant-info__title {
    font-weight: 500;
  }
  .quick-order-page1 #quick-order-form .variant-info__sku {
    font-weight: 400;
    font-size: 0.7rem;
  }

  .quick-order-page1 .title_sku_container {
    display: flex;
    flex-direction: column;
  }

  /* You can remove the old gray bg on .variant-row if you like */
  .quick-order-page1 #quick-order-form .variant-row {
    background: transparent;
  }

  .quick-order-page1 .toggle-variants {
    padding: 5px;
    font-size: 12px !important;
    cursor: pointer;
    border: 1px solid #333;
    border-radius: 10px;
    background: #fff;
  }

  .quick-order-page1 .variant-indent {
    padding-block: 0.5rem;
    padding-right: 2rem;
    padding-left: 1.5rem;
    vertical-align: middle;
  }

  @media (min-width: 678px) {
    .quick-order-page1 .variant-indent {
      padding-left: 2.5rem;
    }
  }

  .quick-order-page1 .btn {
    display: inline-block;
    padding: 10px 20px;
    background: #000;
    color: #fff;
    text-transform: uppercase;
    cursor: pointer;
    border: none;
  }

  /* --- Sticky footer --- */
  .quick-order-page1 .qof-footer.desktop {
    display: grid;
    grid-template-columns:
      auto /* Add to Cart  */
      auto /* Remove all   */
      1fr /* Total Items  */
      auto /* Subtotal     */;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid #ddd;
    position: sticky;
    bottom: 0;
    z-index: 10;
    width: max-content;
    min-width: 100%;
    margin-top: 1.4rem;
    background-color: #fff;
  }

  /* “View cart” button style */
  .quick-order-page1 .btn-outline {
    padding: 10px 20px;
    border: 1px solid #000;
    background: transparent;
    cursor: pointer;
    text-transform: uppercase;
  }

  /* “Remove all” link style */
  .quick-order-page1 .btn-clear {
    cursor: pointer;
    font-size: 0.9rem;
  }

  .quick-order-page1 #add-to-cart-btn,
  .quick-order-page1 #qof-clear {
    width: 12rem;
    font-size: 14px;
  }

  .quick-order-page1 #qof-clear > .btn-fill {
    --motion-translateY: -76%;
  }
  .quick-order-page1 #qof-clear:hover > .btn-fill {
    --motion-translateY: 0;
  }
  .quick-order-page1 #add-to-cart-btn-mobile,
  .quick-order-page1 #qof-clear-mobile {
    width: 9rem;
    font-size: 12px;
  }

  .quick-order-page1 #qof-clear-mobile > .btn-fill {
    --motion-translateY: -76%;
  }

  /* Tax message style */
  .quick-order-page1 #qof-count {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 5px;
  }
  .quick-order-page1 .qof-taxmsg {
    font-size: 0.8rem;
    color: #666;
    text-align: right;
  }
  .quick-order-page1 #qof-subtotal {
    font-size: 1rem;
    color: #000;
  }

  .quick-order-page1 .align-left {
    text-align: left !important;
    padding-left: 2rem;
  }
  .quick-order-page1 .align-right {
    text-align: right !important;
    padding-right: 0rem !important;
  }

  .quick-order-page1 .taxMsg {
    position: relative;
  }

  .quick-order-page1 .taxMsg .underline {
    position: absolute;
    bottom: -2px;
    left: 0px;
    width: 0px;
    max-width: 0px;
    height: 1px;
    transition: all 0.8s ease-in-out;
    background-color: black;
  }

  .quick-order-page1 .taxMsg:hover .underline {
    width: 100%;
    max-width: 100%;
  }

  .quick-order-page1 .qof-footer.mobile {
    display: none;
  }
  /* by default, mobile cards hidden, desktop table shown */
  .quick-order-page1 .qof-mobile {
    display: none;
  }
  .quick-order-page1 .qof-desktop {
    display: block;
  }

  /* at small viewports, swap them */
  @media (max-width: 1150px) {
    .quick-order-page1 .qof-desktop {
      display: none;
    }
    .quick-order-page1 .qof-mobile {
      display: block;
    }


    .qof-mobile-product {
      border-bottom: 1px solid #eee;
      padding: 1rem 0;
    }

    .quick-order-page1 .qof-mobile-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .quick-order-page1 .qof-mobile-header > div.image-title {
      display: flex;
      align-items: center;
      gap: 0.7rem;
    }

    .quick-order-page1 #quick-order-form img {
      border-radius: 0.7rem;
      flex-shrink: 0;
    }

    .quick-order-page1 .variant-info img {
      width: 50px;
      height: 50px;
      border-radius: 0.3rem;
      flex-shrink: 0;
    }
    .quick-order-page1 .qof-mobile-meta h3 {
      margin: 0;
      font-size: 1rem;
    }
    .quick-order-page1 .qof-mobile-meta .mobile-price {
      font-size: 0.9rem;
      color: #333;
    }

    .quick-order-page1 .toggle-variants {
      margin-top: 0.5rem;
      padding: 0.4rem 0.6rem;
      font-size: 0.85rem;
    }

    .quick-order-page1 .qof-mobile-variants {
      margin-top: 0.75rem;
    }

    .quick-order-page1 .mobile-product-details {
      display: flex;
      gap: 5px;
      justify-content: space-between;
      align: start;
      col-span: 2;
    }

    .quick-order-page1 .variant-row {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.7rem 0;
      border-top: 1px solid #eee;
    }
    .quick-order-page1 .variant-info {
      display: flex;
      align-items: start;
      gap: 0.7rem;
    }
    .quick-order-page1 .variant-stock {
      font-size: 0.85rem;
      color: #666;
      margin-left: auto;
    }
    .quick-order-page1 .variant-price {
      font-size: 0.9rem;
    }
    .quick-order-page1 .variant-total {
      font-weight: bold;
    }

    .quick-order-page1 .mobile-quantity-total {
      display: flex;
      gap: 5px;
      justify-content: space-between;
      align-items: center;
    }
    .quick-order-page1 .qof-footer.desktop {
      display: none;
    }
    .quick-order-page1 .qof-footer.mobile {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      gap: 1rem;
    }
    .quick-order-page1 #qof-subtotal {
      text-align: center;
      padding-bottom: 1rem;
    }
    .quick-order-page1 .button-grp-mobile {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .quick-order-page1 #qof-count {
      flex-direction: row;
      align-items: baseline;
    }
  }

  .quick-order-page1 .disabled {
    color: gray;
    cursor: not-allowed;
  }
  /* hide the native arrows so only your code quantity buttons ever changes the value */
  .quick-order-page1 .quantity__input::-webkit-inner-spin-button,
  .quick-order-page1 .quantity__input::-webkit-outer-spin-button {
    -webkit-appearance: none !important;
    margin: 0 !important;
  }
  .quick-order-page1 .quantity__input {
    -moz-appearance: textfield !important; /* Firefox */
  }

  .quick-order-page1 .qof-footer {
    padding-block: 1rem;
  }

  .quick-order-page1 .variantsBtn-and-price {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  @media (max-width: 786px) {
    .quick-order-page1 .variant-message, .in-stock {
      text-align: right;
    }
  }

  .quick-order-page1 input.variant-quantity.quantity__input {
      min-width: 40px !important;
      width: 40px !important;
      max-width: 41px !important;
    }
</style>

<section id="qo-{{ uniq }}" class="quick-order-page1">
  <!-- —————— DESKTOP TABLE —————— -->
  <div class="qof-desktop">
    <form id="quick-order-form">
      <table>
        <thead>
          <tr>
            <th class="align-left">Product</th>
            <th class="quantity_selector">Quantity</th>
            <th class="msg">Production Status</th>
            <th class="msg">Launch Date</th>
            <th class="msg">Stock / Message</th>
            <th class="price">Price (MSRP)</th>
            <th class="price real">Price (wholesale)</th>
            <th class="align-right total last">Total</th>
          </tr>
        </thead>
        <tbody>
          {% for product in chosen_products %}
            {% if product %}
              {%- comment -%}
                ——— Product Row ———
              {%- endcomment -%}
              <tr class="product-row" data-product-id="{{ product.id }}">
                <td class="product-info">
                  <img
                    width="80"
                    height="80"
                    src="{{ product.featured_image | image_url: width:80, height:80 }}"
                    alt="{{ product.title }}"
                  >
                  <div class="product-info__meta">
                    <span class="product-info__title">{{ product.title }}</span>
                    <button
                      type="button"
                      class="toggle-variants"
                      data-product-id="{{ product.id }}"
                      aria-expanded="false"
                    >
                      Show Variants
                    </button>
                  </div>
                </td>
                <td class="quantity_selector">–</td>
                <td class="msg">–</td>
                <td class="msg">–</td>
                <td class="msg">–</td>
                <td class="variant-price price">{{ product.price_min | money }}/ea</td>
                {% if wholesale_discount > 0 %}
                  {% assign discount_amount = product.price_min | times: wholesale_discount %}
                  {% assign discounted_price = product.price_min | minus: discount_amount %}
                  <td class="wholesale-price1 price">
                    <span class="price__regular diagonal-strike" style="position: relative;">
                      {{- product.price_min | money -}}
                    </span>
                    <span class="variant-price real">{{ discounted_price | money }}</span>
                  </td>
                {% else %}
                  <td class="variant-price price">{{ product.price_min | money }}/ea</td>
                {% endif %}
                <td class="product-total total align-right last">$0.00</td>
              </tr>

              {%- comment -%} ——— Variant Rows ——— {%- endcomment -%}
              {% for variant in product.variants %}
                <tr
                  class="variant-row"
                  data-parent-id="{{ product.id }}"
                  style="display: none"
                >
                  <td class="variant-info variant-indent">
                    <img
                      width="60"
                      height="60"
                      src="{{ variant.image | default: product.featured_image | image_url: width:60, height:60 }}"
                      alt="{{ variant.title }}"
                    >
                    <div class="title_sku_container">
                      <span class="variant-info__title">{{ variant.title }}</span>
                      <span class="variant-info__sku">SKU: {{ variant.sku }}</span>
                    </div>
                  </td>
                  <td class="quantity_selector">
                    {% if variant.inventory_management and variant.inventory_quantity > 0 %}
                      <quantity-input
                        class="quantity inline-flex relative"
                        data-variant-id="{{ variant.id }}"
                      >
                        <button
                          type="button"
                          name="minus"
                          class="active quantity__button"
                        >
                          {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                        <input
                          class="desktop variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                          type="number"
                          data-id="{{ variant.id }}"
                          inputmode="numeric"
                          autocomplete="off"
                          min="0"
                          max="{{ variant.inventory_quantity }}"
                          value="0"
                        >
                        <button
                          type="button"
                          name="plus"
                          class="active quantity__button"
                          aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                        >
                          {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                      </quantity-input>
                    {% elsif variant.inventory_management
                      and variant.inventory_quantity <= 0
                      and variant.inventory_policy == 'continue'
                    %}
                      <quantity-input
                        class="quantity inline-flex relative"
                        data-variant-id="{{ variant.id }}"
                      >
                        <button
                          type="button"
                          name="minus"
                          class="active quantity__button"
                        >
                          {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                        <input
                          class="desktop variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                          type="number"
                          data-id="{{ variant.id }}"
                          inputmode="numeric"
                          autocomplete="off"
                          min="0"
                          value="0"
                        >
                        <button
                          type="button"
                          name="plus"
                          class="active quantity__button"
                          aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                        >
                          {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                      </quantity-input>
                    {% else %}
                      <quantity-input
                        class="quantity disabled inline-flex relative"
                        data-variant-id="{{ variant.id }}"
                      >
                        <button type="button" name="minus" class="quantity__button">
                          {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                        <input
                          class="desktop variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                          type="number"
                          data-id="{{ variant.id }}"
                          inputmode="numeric"
                          autocomplete="off"
                          min="0"
                          max="{{ variant.inventory_quantity }}"
                          value="0"
                          disabled
                        >
                        <button
                          type="button"
                          name="plus"
                          class="quantity__button"
                          aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                        >
                          {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                        </button>
                      </quantity-input>
                    {% endif %}
                  </td>
                  <td class="msg">
                    {% assign msg1 = variant.metafields.Style.Status %}
                    {% if msg %}
                      <span class="variant-message">{{ msg1 }}</span>
                    {% else %}
                      <span class="out-of-stock">-</span>
                    {% endif %}
                  </td>
                  <td class="msg">
                    {% assign msg2 = variant.metafields.Launch.date %}
                    {% if msg %}
                      <span class="variant-message">{{ msg2 }}</span>
                    {% else %}
                      <span class="out-of-stock">-</span>
                    {% endif %}
                  </td>
                  <td class="msg">
                    {% assign msg = variant.metafields.Stock.Message %}
                    {% if variant.inventory_management and variant.inventory_quantity > 0 %}
                    <p class="in-stock">{{ variant.inventory_quantity }} in stock</p>
                    {% elsif variant.inventory_management and variant.inventory_quantity < 0 and variant.inventory_policy == "deny" %}
                      <p class="out-of-stock">Sold Out</p>
                    {% elsif msg %}
                      <p class="variant-message">{{ msg }}</p>
                    {% else %}
                      <p class="variant-message">-</p>
                    {% endif %}
                  </td>
                  <td class="variant-price price">{{ variant.price | money }}</td>
                  {% if wholesale_discount > 0 %}
                    {% assign discount_amount = variant.price | times: wholesale_discount %}
                    {% assign discounted_price = variant.price | minus: discount_amount %}
                    <td class="wholesale-price1 price">
                      <span class="price__regular diagonal-strike" style="position: relative;">
                        {{- variant.price | money -}}
                      </span>
                      <span class="variant-price real">{{ discounted_price | money }}</span>
                    </td>
                  {% else %}
                    <td class="variant-price price">{{ variant.price | money }}/ea</td>
                  {% endif %}
                  <td class="variant-total total align-right">$0.00</td>
                </tr>
              {% endfor %}
            {% endif %}
          {% endfor %}
          {%- comment -%}
            ——— No-results
            row (hidden unless you add a search back) ———
          {%- endcomment -%}
          <tr class="no-results" style="display: none">
            <td colspan="5" class="align-center" style="padding: 2rem">No products found.</td>
          </tr>
        </tbody>
      </table>
    </form>
  </div>

  <!-- —————— MOBILE CARDS —————— -->
  <div class="qof-mobile">
    {% for product in chosen_products %}
      {% if product %}
        <div
          class="qof-mobile-product product-row"
          data-product-id="{{ product.id }}"
        >
          <div class="qof-mobile-header">
            <div class="image-title">
              <img
                width="60"
                height="60"
                src="{{ product.featured_image | image_url: width:60, height:60 }}"
                alt="{{ product.title }}"
              >
              <div class="qof-mobile-meta">
                <h3>{{ product.title }}</h3>
              </div>
            </div>
          </div>
          <div class="variantsBtn-and-price">
            <button
              type="button"
              class="toggle-variants"
              data-product-id="{{ product.id }}"
              aria-expanded="false"
            >
              Show Variants
            </button>
            {% if wholesale_discount > 0 %}
              {% assign da = product.price_min | times: wholesale_discount %}
              {% assign dp = product.price_min | minus: da %}
              <span class="mobile-price">{{ dp | money }}/ea</span>
            {% else %}
              <span class="mobile-price">{{ product.price_min | money }}/ea</span>
            {% endif %}
          </div>

          <div class="qof-mobile-variants">
            {% for variant in product.variants %}
              <div
                class="variant-row"
                data-parent-id="{{product.id}}"
                style="display: none"
              >
                <div class="mobile-product-details">
                  <div class="variant-info">
                    <img
                      width="60"
                      height="60"
                      src="{{ product.featured_image | image_url: width:60, height:60 }}"
                      alt="{{product.title}}"
                    >
                    <div>
                      <strong>{{ variant.title }}</strong><br>
                      <small>SKU: {{ variant.sku }}</small>
                    </div>
                  </div>
                  {% if wholesale_discount > 0 %}
                    {%- assign discount_amount = variant.price | times: wholesale_discount -%}
                    {%- assign discounted_price = variant.price | minus: discount_amount -%}

                    <p
                      class="wholesale-price1 whitespace-nowrap flex items-center gap-2 hi {%- if is_center == false -%}hi justify-start {%- else -%}hi justify-center {%- endif -%}"
                    >
                      <span
                        class="diagonal-strike price__regular whitespace-nowrap relative inline-block text-gray-500"
                        style="color: gray; font-size: 13px"
                      >
                        {{ variant.price | money }}
                      </span>
                      <span
                        class="variant-price real price__regular new whitespace-nowrap text-red-600 font-semibold"
                      >
                        {{ discounted_price | money }}
                      </span>
                    </p>

                  {%- else -%}
                    <!-- Price -->
                    <div class="variant-price real price">{{ variant.price | money }}/ea</div>
                  {% endif %}
                </div>

                <div class="variant-stock">
                  {% assign msg1 = variant.metafields.Style.Status %}
                  {% assign msg2 = variant.metafields.Launch.date %}
                  {% assign msg = variant.metafields.Stock.Message %}
                  {% if variant.inventory_management and variant.inventory_quantity > 0 %}
                    <p class="in-stock">{{ variant.inventory_quantity }} in stock</p>
                  {% elsif variant.inventory_management and variant.inventory_quantity < 0 and variant.inventory_policy == "deny" %}
                    <p class="out-of-stock">Sold Out</p>
                  {% elsif msg %}
                    <p class="variant-message">{{ msg }}</p>
                  {% else %}
                    <p class="variant-message">-</p>
                  {% endif %}
              
                  {% if msg1 %}
                  <p class="variant-message">Style Status: {{ msg1 }}</p>
                  {% else %}
                  <p class="variant-message">Style Status: -</p>
                  {% endif %}
              
                  {% if msg2 %}
                  <p class="variant-message">Launch Date: {{ msg2 }}</p>
                  {% else %}
                    <p class="variant-message">Launch Date: -</p>
                  {% endif %}
                </div>

                <div class="mobile-quantity-total">
                  {% if variant.inventory_management and variant.inventory_quantity > 0 %}
                    <quantity-input
                      class="quantity inline-flex relative"
                      data-variant-id="{{ variant.id }}"
                    >
                      <button
                        type="button"
                        name="minus"
                        class="active quantity__button"
                      >
                        {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                      </button>
                      <input
                        class="mobile variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                        type="number"
                        data-id="{{ variant.id }}"
                        inputmode="numeric"
                        autocomplete="off"
                        min="0"
                        max="{{ variant.inventory_quantity }}"
                        value="0"
                      >
                      <button
                        type="button"
                        name="plus"
                        class="active quantity__button"
                        aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                      >
                        {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                      </button>
                    </quantity-input>
                  {% elsif variant.inventory_management
                    and variant.inventory_quantity <= 0
                    and variant.inventory_policy == 'continue'
                  %}
                    <quantity-input
                      class="quantity inline-flex relative"
                      data-variant-id="{{ variant.id }}"
                    >
                      <button
                        type="button"
                        name="minus"
                        class="active quantity__button"
                      >
                        {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                      </button>
                      <input
                        class="mobile variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                        type="number"
                        data-id="{{ variant.id }}"
                        inputmode="numeric"
                        autocomplete="off"
                        min="0"
                        max="99"
                        value="0"
                      >
                      <button
                        type="button"
                        name="plus"
                        class="active quantity__button"
                        aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                      >
                        {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                      </button>
                    </quantity-input>
                  {% else %}
                    <quantity-input
                      class="quantity disabled inline-flex relative"
                      data-variant-id="{{ variant.id }}"
                    >
                      <button type="button" name="minus" class="quantity__button">
                        {%- render 'icon', icon: 'chevron-left', size: 'sm', class: 'stroke-2 transform' -%}
                      </button>
                      <input
                        class="mobile variant-quantity quantity__input text-sm sm:text-base font-medium text-center"
                        type="number"
                        data-id="{{ variant.id }}"
                        inputmode="numeric"
                        autocomplete="off"
                        min="0"
                        max="{{ variant.inventory_quantity }}"
                        value="0"
                        disabled
                      >
                      <button
                        type="button"
                        name="plus"
                        class="quantity__button"
                        aria-label="{{ 'products.quantity.increase' | t: product: product.title | escape }}"
                      >
                        {%- render 'icon', icon: 'chevron-right', size: 'sm', class: 'stroke-2 transform' -%}
                      </button>
                    </quantity-input>
                  {% endif %}
                  <div class="variant-total">$0.00</div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="qof-footer desktop">
    <!-- <button id="add-to-cart-btn" class="btn">Add Selected to Cart</button> -->
    <button
      id="add-to-cart-btn"
      class="button button--primary"
      is="hover-button"
    >
      <span class="btn-fill" data-fill></span>

      <span class="btn-text">
        {%- liquid
          echo 'products.product.add_to_cart' | t
        -%}
      </span>
    </button>
    <!-- <button id="qof-clear" class="btn-clear">Remove all</button> -->
    <a
      href="#"
      id="qof-clear"
      class="qof-clear button button--secondary"
      is="hover-link"
      data-no-instant
    >
      <span
        class="btn-fill"
        data-fill
        style="transform: translateY(var(--motion-translateY))"
      ></span>
      <span class="btn-text">Reset Form</span>
    </a>
    <div id="qof-count">
      <div id="qof-count-value">0</div>
      <div>Total Items</div>
    </div>
    <!-- now 2nd -->

    <div class="qof-taxmsg">
      <div id="qof-subtotal">
        <span id="qof-subtotal-value">$0.00</span><br>
        <small>Product subtotal</small>
      </div>
      Taxes, Discounts and
      <a href="/policies/shipping-policy">Shipping</a> calculated at checkout
    </div>
  </div>

  <div class="qof-footer mobile">
    <div id="qof-count">
      <small>Total Items: </small>
      <div id="qof-count-value-mobile">0</div>
    </div>
    <!-- now 2nd -->
    <div class="qof-taxmsg">
      <div id="qof-subtotal">
        <small>Product subtotal</small>:
        <span id="qof-subtotal-value-mobile">$0.00</span>
      </div>
      <div>
        Taxes, Discounts and
        <a href="/policies/shipping-policy">Shipping</a> calculated at checkout
      </div>
    </div>
    <div class="button-grp-mobile">
      <!-- <button id="add-to-cart-btn" class="btn">Add Selected to Cart</button> -->
      <button
        id="add-to-cart-btn-mobile"
        class="add-to-cart-btn mobile button button--primary"
        is="hover-button"
      >
        <span class="btn-fill" data-fill></span>

        <span class="btn-text">
          {%- liquid
            echo 'products.product.add_to_cart' | t
          -%}
        </span>
      </button>
      <!-- <button id="qof-clear" class="btn-clear">Remove all</button> -->
      <a
        href="#"
        id="qof-clear-mobile"
        class="qof-clear button button--secondary"
        is="hover-link"
        data-no-instant
      >
        <span
          class="btn-fill"
          data-fill
          style="transform: translateY(var(--motion-translateY))"
        ></span>
        <span class="btn-text">Reset Form</span>
      </a>
    </div>
  </div>
</section>

<script>
  (function(){
    const container = document.getElementById('qo-{{ uniq }}');
    if (!container) return;
    document.addEventListener("DOMContentLoaded", function () {
      // — Variant toggling —
      container.querySelectorAll(".toggle-variants").forEach((button) => {
        button.addEventListener("click", () => {
          const pid = button.dataset.productId;
          const rows = container.querySelectorAll(
            `.variant-row[data-parent-id="${pid}"]`
          );
          if (!rows.length) return;
  
          const willShow = rows[0].style.display === "none";
          // decide “display” mode based on viewport width
          const isMobile = window.matchMedia("(max-width: 1150px)").matches;
          const showStyle = isMobile ? "flex" : "table-row";
  
          rows.forEach((r) => {
            r.style.display = willShow ? showStyle : "none";
          });
  
          button.textContent = willShow ? "Hide Variants" : "Show Variants";
          button.setAttribute("aria-expanded", willShow);
        });
      });
  
      function updateTotalFor(input) {
        // 1. clamp the raw input value to [min, max]:
        const min = parseInt(input.min, 10) || 0;
        const max = parseInt(input.max, 10) || Infinity;
        let qty = parseInt(input.value, 10) || 0;
  
        if (qty < min) {
          qty = min;
          input.value = qty;
        } else if (qty > max) {
          qty = max;
          input.value = qty;
        }
  
        // 2. now use the clamped `qty` for your total logic:
        const row = input.closest("tr.variant-row");
        const priceCell = row.querySelector(".variant-price.real");
        const totalCell = row.querySelector(".variant-total");
        const price =
          parseFloat(priceCell.textContent.replace(/[^0-9.-]+/g, "")) || 0;
  
        if (qty > 0) {
          totalCell.textContent = "$" + (price * qty).toFixed(2);
        } else {
          totalCell.textContent = "$0.00";
        }
  
        // …and the rest of your subtotal/items recalculation…
        let items = 0,
          subtotal = 0;
        container.querySelectorAll(".variant-quantity").forEach((el) => {
          const q = parseInt(el.value, 10) || 0;
          if (q > 0) {
            items += q;
            const r = el.closest("tr.variant-row");
            const p =
              parseFloat(
                r
                  .querySelector(".variant-price.real")
                  .textContent.replace(/[^0-9.-]+/g, "")
              ) || 0;
            subtotal += p * q;
          }
        });
  
        container.querySelector("#qof-count-value").innerText = items;
        container.querySelector("#qof-subtotal-value").innerText =
          "$" + subtotal.toFixed(2);
      }
  
      function updateTotalForMobile(input) {
        // clamp to [min, max] just like above
        const min = parseInt(input.min, 10) || 0;
        const max = parseInt(input.max, 10) || Infinity;
        let qty = parseInt(input.value, 10) || 0;
  
        if (qty < min) {
          qty = min;
          input.value = qty;
        } else if (qty > max) {
          qty = max;
          input.value = qty;
        }
  
        // now your existing mobile total logic…
        const row = input.closest("div.variant-row");
        const priceCell = row.querySelector(".variant-price.real");
        const totalCell = row.querySelector(".variant-total");
        const cleanText = priceCell.textContent
          .replace(/[^0-9.,]/g, "")
          .replace(/,/g, "");
        const price = parseFloat(cleanText) || 0;
  
        if (qty > 0) {
          totalCell.textContent = "$" + (price * qty).toFixed(2);
        } else {
          totalCell.textContent = "$0.00";
        }
  
        let items = 0,
          subtotal = 0;
        container
          .querySelectorAll("div.qof-mobile input.mobile.variant-quantity")
          .forEach((el) => {
            const q = parseInt(el.value, 10) || 0;
            if (q > 0) {
              items += q;
              const r = el.closest("div.variant-row");
              const p =
                parseFloat(
                  r
                    .querySelector(".variant-price.real")
                    .textContent.replace(/[^0-9.-]+/g, "")
                ) || 0;
              subtotal += p * q;
            }
          });
  
        container.querySelector("#qof-count-value-mobile").innerText = items;
        container.querySelector("#qof-subtotal-value-mobile").innerText =
          "$" + subtotal.toFixed(2);
      }
  
      // re-attach your listeners:
      container
        .querySelectorAll("quantity-input input.desktop.variant-quantity")
        .forEach((input) => {
          const handler = () => updateTotalFor(input);
          input.addEventListener("input", handler);
          input.addEventListener("change", handler);
        });
      
      container
        .querySelectorAll("quantity-input input.mobile.variant-quantity")
        .forEach((input) => {
          const handler = () => updateTotalForMobile(input);
          input.addEventListener("input", handler);
          input.addEventListener("change", handler);
        });
  
      // — Add Selected to Cart —
      container.querySelector("#add-to-cart-btn").addEventListener("click", () => {
        const items = [];
        container.querySelectorAll(".variant-quantity.desktop").forEach((input) => {
          const qty = parseInt(input.value, 10) || 0;
          if (qty > 0) {
            items.push({ id: input.dataset.id, quantity: qty });
          }
        });
        if (!items.length) {
          return alert("Please select at least one item.");
        }
        fetch("/cart/add.js", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items }),
        })
          .then((res) => res.json())
          .then(() => {
            window.location.href = "/cart";
          })
          .catch((err) => {
            console.error("Cart error:", err);
            alert("Failed to add items. Please try again.");
          });
      });
      container.querySelector(".add-to-cart-btn.mobile").addEventListener("click", () => {
        const items = [];
        container.querySelectorAll(".variant-quantity.mobile").forEach((input) => {
          const qty = parseInt(input.value, 10) || 0;
          if (qty > 0) {
            items.push({ id: input.dataset.id, quantity: qty });
          }
        });
        if (!items.length) {
          return alert("Please select at least one item.");
        }
        fetch("/cart/add.js", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items }),
        })
          .then((res) => res.json())
          .then(() => {
            window.location.href = "/cart";
          })
          .catch((err) => {
            console.error("Cart error:", err);
            alert("Failed to add items. Please try again.");
          });
      });
  
      // --- FOOTER LOGIC ---
      const clearBtn = container.querySelector("#qof-clear");
      const clearBtnMobile = container.querySelector("#qof-clear-mobile");
  
      clearBtn.addEventListener("click", (e) => {
        e.preventDefault(); // stop the “#” from jumping
        // 1) Reset every variant row:
        container.querySelectorAll("tr.variant-row").forEach((row) => {
          const input = row.querySelector("input.variant-quantity");
          const totalTd = row.querySelector(".variant-total");
          if (input) input.value = 0;
          if (totalTd) totalTd.textContent = "$0.00";
        });
  
        // 2) Reset the sticky footer values:
        container.querySelector("#qof-count-value").innerText = "0";
        container.querySelector("#qof-subtotal-value").innerText = "$0.00";
      });
      
      clearBtnMobile.addEventListener("click", (e) => {
        e.preventDefault(); // stop the “#” from jumping
        // 1) Reset every variant row:
        container.querySelectorAll("div.variant-row").forEach((row) => {
          const input = row.querySelector("input.variant-quantity");
          const totalTd = row.querySelector(".variant-total");
          if (input) input.value = 0;
          if (totalTd) totalTd.textContent = "$0.00";
        });
  
        // 2) Reset the sticky footer values:
        container.querySelector("#qof-count-value-mobile").innerText = "0";
        container.querySelector("#qof-subtotal-value-mobile").innerText = "$0.00";
      });
      
    });
  })(); // end container-scoped script
</script>
