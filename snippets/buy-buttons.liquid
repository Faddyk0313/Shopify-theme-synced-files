{% if product.metafields.custom.product_state1 == 'preorder-august' %}
  <script>
    // Store all custom button texts and availability
    window.variantButtonTexts = {
      {% for variant in product.variants %}
        "{{ variant.id }}": "{{ variant.metafields.custom.button_text | escape }}"{% unless forloop.last %},{% endunless %}
      {% endfor %}
    };

    // expose true/false based on real stock
    window.variantAvailabilityId = {
      {% for variant in product.variants %}
        "{{ variant.id }}": {% if variant.inventory_quantity > 0 %}true{% else %}false{% endif %}{% unless forloop.last %},{% endunless %}
      {% endfor %}
    };

    function getVariantId() {
      const input = document.querySelector('form[action^="/cart/add"] [name="id"]');
      return input ? input.value : null;
    }

    // Initialize watcher
    document.addEventListener('DOMContentLoaded', function() {
      const btnTextEl = document.querySelector('.buy-buttons .product-form__submit .btn-text');
      const atcBackorderSaleEl = document.querySelector('.buy-buttons .product-form__submit .cus-atc-sale-msg');
      const shipMsgEl = document.getElementById('estimatedShippingMsg');
      if (!btnTextEl) return;

      const root = btnTextEl.closest('.buy-buttons');
      const metafieldState = "{{ product.metafields.custom.product_state1 | escape }}";

      let lastVariantId = 0;
      let expectedLabel = '';
      let expectedSaleLabel = '';
      let expectedShipMsg = '';

      function updateButtonText(variantId) {
        const available = window.variantAvailabilityId[variantId];
        const hasDiscountLabel = "{{ product.metafields.custom.atc_discount_label }}" === "true";
        const trimmedState = window.product_state1.trim();
        let label, saleLabel, shipMsg;

        // 1) PREORDER state
        if (trimmedState.startsWith('preorder')) {
          if (!available) {
            label   = "{{ product.metafields.custom.add_to_cart_button_label }}" || "PREORDER";
            saleLabel = hasDiscountLabel ? "SAVE 25%" : "";
            shipMsg = "{{ product.metafields.custom.estimated_shipping2 }}";
          } else {
            label   = "ADD TO CART";
            saleLabel = "";
            shipMsg = "";
          }
        }
        // 2) CURRENT state
        else if (trimmedState === 'current') {
          if (!available) {
            label   = "BACKORDER";
            saleLabel = hasDiscountLabel ? "SAVE 15%" : "";
            shipMsg = "Save 15% when you backorder today and reserve your unit from the next restock.<br>Shipping priority is based on order date and restocks often sell out before production completes.";
          } else {
            label   = "ADD TO CART";
            saleLabel = "";
            shipMsg = "";
          }
        }
        // 3) DISCONTINUED state
        else if (trimmedState === 'discontinued') {
          if (available) {
            label   = "{{ product.metafields.custom.add_to_cart_button_label }}" || "ADD TO CART";
            saleLabel = "";
            shipMsg = "{{ product.metafields.custom.estimated_shipping2 }}";
          } else {
            label   = "SOLD OUT";
            saleLabel = "";
            shipMsg = "Discontinued Color - stock will not be replenished";
          }
        }
        // fallback
        else {
          label   = "{{ product.metafields.custom.add_to_cart_button_label }}" || "ADD TO CART";
          saleLabel = "";
          shipMsg = "";
        }

        // Store expected values
        expectedLabel = label;
        expectedSaleLabel = saleLabel;
        expectedShipMsg = shipMsg;

        if (shipMsgEl) shipMsgEl.innerHTML = shipMsg;
        btnTextEl.textContent = label;
        atcBackorderSaleEl.textContent = saleLabel;
      }

      // Watch for external changes and immediately override them
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'characterData' || mutation.type === 'childList') {
            const currentText = btnTextEl.textContent;
            // If text doesn't match what we expect, force it back
            if (expectedLabel && currentText !== expectedLabel) {
              btnTextEl.textContent = expectedLabel;
              atcBackorderSaleEl.textContent = expectedSaleLabel;
              if (shipMsgEl) shipMsgEl.innerHTML = expectedShipMsg;
            }
          }
        });
      });
      observer.observe(btnTextEl, { childList: true, characterData: true, subtree: true });

      // Initialize button text for the currently selected variant on page load
      const initialVariantId = getVariantId();
      if (initialVariantId) {
        lastVariantId = initialVariantId;
        updateButtonText(initialVariantId);
      }

      // Check for changes every 200ms
      setInterval(() => {
        const currentVariantId = getVariantId();
        if (currentVariantId && currentVariantId !== lastVariantId) {
          lastVariantId = currentVariantId;
          updateButtonText(currentVariantId);
        }
      }, 200);
    });
  </script>
{% endif %}
