<script>
  (function () {
    const observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        mutation.addedNodes.forEach(function (node) {
          if (node.nodeType === 1 && node.matches && node.matches('back-in-stock-drawer')) {
            initSync();
          }
        });
      });
    });

    observer.observe(document.body, { childList: true, subtree: true });

    document.addEventListener('DOMContentLoaded', function () {
      const drawer = document.querySelector('back-in-stock-drawer');
      if (drawer && !drawer.hasAttribute('hidden')) {
        initSync();
      }

      const drawerButtons = document.querySelectorAll('[aria-controls^="BackInStockDrawer"]');
      drawerButtons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          setTimeout(initSync, 500);
        });
      });
    });

    function initSync() {
      const customInput = document.querySelector('#ContactFormEmail-{{ section_id }}');
      const customSubmit = document.querySelector('#ContactSubmit-{{ section_id }}');
      {% comment %} const descDiv = document.querySelector('.desc'); {% endcomment %}

      function getKlaviyoElements() {
        const formRows = document.querySelectorAll('[data-testid="form-row"]');
        const emailInput = formRows[0]?.querySelector('input[type="email"]');
        {% comment %} const infoText = formRows[2]?.querySelector('p'); {% endcomment %}
        const submitBtn = formRows[6]?.querySelector('button[type="button"]');
        return { emailInput, submitBtn };
      }

      function fillHiddenFields() {
        // Product URL
        const productUrlInput = document.querySelector('input[id*="product_url"]');
        if (productUrlInput) {
          productUrlInput.value = window.location.href;
          productUrlInput.dispatchEvent(new Event('input', { bubbles: true }));
          productUrlInput.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // Product Image URL
        const imageUrlInput = document.querySelector('input[id*="image_url"]');
        if (imageUrlInput) {
          const productImg = document.querySelector('.product__media-container img');
          if (productImg) {
            imageUrlInput.value = productImg.src;
            imageUrlInput.dispatchEvent(new Event('input', { bubbles: true }));
            imageUrlInput.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }

        // Preferred Size - get from drawer header display
        const sizeInput = document.querySelector('input[id*="preferred_size"]');
        if (sizeInput) {
          const drawerHeader = document.querySelector('.drawer__title dl');
          if (drawerHeader) {
            const sizeOption = Array.from(drawerHeader.querySelectorAll('div')).find(function(div) {
              return div.textContent.includes('Size:');
            });
            if (sizeOption) {
              const sizeValue = sizeOption.querySelector('.font-medium');
              if (sizeValue) {
                sizeInput.value = sizeValue.textContent.trim();
                sizeInput.dispatchEvent(new Event('input', { bubbles: true }));
                sizeInput.dispatchEvent(new Event('change', { bubbles: true }));
              }
            }
          }
        }

        // Product Name
        const productNameInput = document.querySelector('input[id*="Product_Name"]');
        if (productNameInput) {
          productNameInput.value = '{{ product.title | escape }}';
          productNameInput.dispatchEvent(new Event('input', { bubbles: true }));
          productNameInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
        // Product SKU
        const productSkuInput = document.querySelector('input[id*="Variant_SKU"]');
        if (productSkuInput) {
          productSkuInput.value = '{{ product.selected_or_first_available_variant.sku | escape }}';
          productSkuInput.dispatchEvent(new Event('input', { bubbles: true }));
          productSkuInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }

      // Auto-fill when Klaviyo form loads
      const checkInterval = setInterval(function() {
        const klaviyoDiv = document.querySelector('.klaviyo-form-Uc74fE');
        if (klaviyoDiv && klaviyoDiv.innerHTML.trim() !== '') {
          fillHiddenFields();
          clearInterval(checkInterval);
        }
      }, 100);

      if (customInput && !customInput.dataset.syncAttached) {
        customInput.dataset.syncAttached = 'true';
        customInput.addEventListener('input', function (e) {
          const { emailInput } = getKlaviyoElements();
          if (emailInput) {
            emailInput.value = e.target.value;
            emailInput.dispatchEvent(new Event('input', { bubbles: true }));
            emailInput.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });
      }

      if (customSubmit && !customSubmit.dataset.syncAttached) {
        customSubmit.dataset.syncAttached = 'true';
        customSubmit.addEventListener('click', function (e) {
          e.preventDefault();

          // Check if Klaviyo div is empty, reload if needed
          const klaviyoDiv = document.querySelector('.klaviyo-form-Uc74fE');
          if (!klaviyoDiv || klaviyoDiv.innerHTML.trim() === '') {
            const currentUrl = new URL(window.location.href);
            currentUrl.searchParams.set('size_selected', 'true');
            window.location.href = currentUrl.toString();
            return;
          }

          fillHiddenFields();

          // Add success message to DOM immediately
          setTimeout(function() {
            const formContent = document.querySelector('.form-content');
            if (formContent && !document.querySelector('.success-message')) {
              const successDiv = document.createElement('div');
              successDiv.className = 'success-message';
              successDiv.innerHTML = `
                <div class="alert alert--success flex items-start gap-3 text-sm md:text-base leading-tight" style="margin-bottom:10px;" role="alert"> 
                  <svg class="icon icon-icon icon-sm shrink-0" viewBox="0 0 24 24" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12L11 14L16 9M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z"></path>
                  </svg>
                  Your email has been received.
                </div>
              `;
              {% comment %} formContent.appendChild(successDiv); {% endcomment %}
              formContent.insertBefore(successDiv, formContent.firstChild);


              // Empty the custom input field
              if (customInput) {
                customInput.value = '';
              }
            }
          }, 100);

          // Click Klaviyo submit button
          setTimeout(function() {
            const { submitBtn } = getKlaviyoElements();
            if (submitBtn) {
              submitBtn.click();
            }
          }, 150);
        });
      }

      // Wait 5 seconds before starting checks
      setTimeout(function() {
        let wasFilledBefore = false;
        let hasReloaded = false;

        // Check if Klaviyo form is empty and reload page once
        setInterval(function() {
          const klaviyoDiv = document.querySelector('.klaviyo-form-Uc74fE');
          const customSuccessMsg = document.querySelector('.success-message');

          if (klaviyoDiv && klaviyoDiv.innerHTML.trim() !== '') {
            wasFilledBefore = true;
          }

          // Only reload if form becomes empty AND no custom success message exists
          if (klaviyoDiv && klaviyoDiv.innerHTML.trim() === '' && wasFilledBefore && !hasReloaded && !customSuccessMsg) {
            hasReloaded = true;
            const currentUrl = new URL(window.location.href);
            currentUrl.searchParams.set('size_selected', 'true');
            window.location.href = currentUrl.toString();
          }
        }, 500);
      }, 5000);
    }
  })();
</script>

<script>
  (function () {
    if (window.__klaviyoBisConsentDefaultChecked) return;
    window.__klaviyoBisConsentDefaultChecked = true;

    const consentSelectors = ['#opt_in_promotional_email__31__32', '[class*="klaviyo-form"] input[type="checkbox"]'];

    function defaultCheckKlaviyoConsent(root) {
      const scope = root && root.querySelectorAll ? root : document;
      const checkboxes = [];
      const selector = consentSelectors.join(',');

      if (scope.matches && scope.matches(selector)) {
        checkboxes.push(scope);
      }

      scope.querySelectorAll(selector).forEach(function (checkbox) {
        checkboxes.push(checkbox);
      });

      checkboxes.forEach(function (checkbox) {
        if (checkbox.dataset.klaviyoDefaultChecked === 'true') return;

        checkbox.dataset.klaviyoDefaultChecked = 'true';

        if (!checkbox.checked) {
          checkbox.checked = true;
          checkbox.dispatchEvent(new Event('input', { bubbles: true }));
          checkbox.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    }

    const observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        mutation.addedNodes.forEach(function (node) {
          if (node.nodeType !== 1) return;
          defaultCheckKlaviyoConsent(node);
        });
      });
    });

    defaultCheckKlaviyoConsent(document);
    document.addEventListener('DOMContentLoaded', function () {
      defaultCheckKlaviyoConsent(document);
    });
    observer.observe(document.documentElement, { childList: true, subtree: true });
  })();
</script>

